        """
        from ipfs_datasets_py.logic.flogic import FLogicFrame

        ergo = self._get_ergo()
        violations: List[OntologyViolation] = []

        # Group triples by subject to build frames
        subject_map: Dict[str, Dict[str, str]] = {}
        for triple in kg_triples:
