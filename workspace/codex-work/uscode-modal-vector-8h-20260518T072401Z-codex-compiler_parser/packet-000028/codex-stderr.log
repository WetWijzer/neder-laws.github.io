   476	                terms=("agency", "notice"),
   477	            ),
   478	        )
   479	    )
   480	    compiler = DeterministicModalCompiler(
   481	        ModalCompilerConfig(parser_backend="regex", frame_score_margin=1.0),
   482	        frame_selector=frame_selector,
   483	    )
   484	
   485	    compiled = compiler.compile(
   486	        "The agency must provide notice.",
   487	        document_id="compiler-doc",
