+def _frame_candidate_terms_from_dict(candidate: Mapping[str, Any]) -> List[str]:
+    terms: List[str] = []
+    frame_id = candidate.get("frame_id")
+    terms.extend(_tokenize_ontology_value(frame_id))
+    for key in ("matched_terms", "ontology_terms"):
+        values = candidate.get(key)
+        if not isinstance(values, (list, tuple, set)):
+            continue
+        for value in values:
+            terms.extend(_tokenize_ontology_value(value))
+    return _unique_preserve_order(terms)
+
+
+def _modal_ir_frame_terms(
+    modal_ir: ModalIRDocument,
+    *,
+    selected_frame: Optional[str],
+) -> List[str]:
+    terms: List[str] = []
+    terms.extend(_tokenize_ontology_value(selected_frame))
+    for frame in modal_ir.frame_candidates:
+        terms.extend(_tokenize_ontology_value(frame.frame_id))
+        for value in frame.matched_terms:
+            terms.extend(_tokenize_ontology_value(value))
+    return _unique_preserve_order(terms)
+
+
