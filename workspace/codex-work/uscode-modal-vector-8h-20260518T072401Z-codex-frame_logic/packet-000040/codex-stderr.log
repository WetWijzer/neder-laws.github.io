   720	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   721	    """Return observed modal-family frequencies for multi-family legal clauses."""
   722	    families = [formula.operator.family for formula in modal_ir.formulas]
   723	    if not families:
   724	        return {ModalLogicFamily.HYBRID.value: 1.0}
   725	    counts: Dict[str, int] = {}
   726	    for family in families:
   727	        counts[family] = counts.get(family, 0) + 1
   728	    total = float(sum(counts.values()))
   729	    return {
   730	        family: count / total
   731	        for family, count in sorted(counts.items())
   732	    }
