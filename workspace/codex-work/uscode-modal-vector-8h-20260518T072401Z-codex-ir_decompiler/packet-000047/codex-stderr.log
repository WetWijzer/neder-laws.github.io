        formula_id="f-1",
        operator=ModalIROperator(
            family="deontic",
            system="kd",
            symbol="O",
            label="obligatory",
        ),
        predicate=ModalIRPredicate(name="maintain_drug_approval"),
        provenance=ModalIRProvenance(
