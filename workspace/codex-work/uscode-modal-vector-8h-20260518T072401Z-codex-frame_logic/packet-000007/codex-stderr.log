   664	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
   665	    if not logits:
   666	        return {}
   667	    max_logit = max(float(value) for value in logits.values())
   668	    exponentials = {
   669	        name: math.exp(float(value) - max_logit)
   670	        for name, value in logits.items()
   671	    }
   672	    total = sum(exponentials.values())
   673	    if total == 0.0:
   674	        uniform = 1.0 / len(exponentials)
   675	        return {name: uniform for name in sorted(exponentials)}
   676	    return {name: exponentials[name] / total for name in sorted(exponentials)}
