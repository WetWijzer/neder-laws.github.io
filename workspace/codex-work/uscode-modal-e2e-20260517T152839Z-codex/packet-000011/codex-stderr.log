   182	    def _classify_segment_role(self, text: str) -> str:
   183	        lowered = text.lower()
   184	        if lowered.startswith(("if ", "unless ", "except ", "provided that ", "subject to ")):
   185	            return "condition"
   186	        if " means " in lowered or lowered.startswith("the term "):
   187	            return "definition"
   188	        if any(term in lowered for term in ("penalty", "fine", "sanction", "remedy")):
   189	            return "remedy"
   190	        return "clause"
   191	
   192	    def _segment_for_cue(self, segments: Iterable[LegalSegment], cue: ModalCueSpan) -> LegalSegment:
   193	        for segment in segments:
   194	            if segment.start_char <= cue.start_char < segment.end_char:
   195	                return segment
   196	        return LegalSegment(text="", start_char=cue.start_char, end_char=cue.end_char)
   197	
   198	    def _predicate_from_segment(self, segment_text: str, cue: str) -> str:
   199	        after_cue = segment_text.lower().split(cue.lower(), 1)[-1]
   200	        tokens = _TOKEN_RE.findall(after_cue)
   201	        if not tokens:
   202	            tokens = _TOKEN_RE.findall(segment_text.lower())
   203	        return "_".join(tokens[:6]) or "unnamed_predicate"
   204	
   205	    def _conditions_and_exceptions_from_segment(
   206	        self,
   207	        segment_text: str,
   208	    ) -> tuple[List[str], List[str]]:
   209	        return (
   210	            self._prefixed_clause_phrases(segment_text, _CONDITION_PREFIXES),
   211	            self._prefixed_clause_phrases(segment_text, _EXCEPTION_PREFIXES),
   212	        )
   213	
   214	    def _prefixed_clause_phrases(
   215	        self,
   216	        segment_text: str,
   217	        prefixes: Iterable[str],
   218	    ) -> List[str]:
   219	        normalized = self.normalize_text(segment_text)
   220	        phrases: List[str] = []
   221	        for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
   222	            pattern = re.compile(rf"(?<!\w){re.escape(prefix)}(?!\w)", re.IGNORECASE)
   223	            for match in pattern.finditer(normalized):
   224	                fragment = normalized[match.start() :]
   225	                fragment = _CLAUSE_DELIMITER_RE.split(fragment, maxsplit=1)[0]
   226	                phrase = self._normalized_clause_phrase(fragment)
   227	                if phrase and phrase not in phrases:
   228	                    phrases.append(phrase)
   229	        return phrases
   230	
   231	    def _normalized_clause_phrase(self, text: str) -> str:
   232	        tokens = _TOKEN_RE.findall(text.lower())
   233	        return " ".join(tokens[:18]).strip()
   234	
   235	    def _document_id(self, normalized_text: str) -> str:
   236	        digest = hashlib.sha256(normalized_text.encode("utf-8")).hexdigest()[:16]
   237	        return f"legal-text-{digest}"
   238	
   239	    def _uscode_codification_fallback_formula(
   240	        self,
   241	        *,
   242	        resolved_document_id: str,
   243	        normalized_text: str,
   244	        citation: Optional[str],
   245	        segments: Sequence[LegalSegment],
   246	        start_index: int,
   247	    ) -> Optional[ModalIRFormula]:
   248	        if not normalized_text.strip():
