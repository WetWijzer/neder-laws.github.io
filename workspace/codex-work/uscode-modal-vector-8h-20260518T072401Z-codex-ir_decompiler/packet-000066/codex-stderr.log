  1433	def _support_span(formulas: Sequence[ModalIRFormula]) -> List[int]:
  1434	    if not formulas:
  1435	        return [0, 0]
  1436	    starts = [formula.provenance.start_char for formula in formulas]
  1437	    ends = [formula.provenance.end_char for formula in formulas]
  1438	    return [min(starts), max(ends)]
