   369	                            candidate_ids=[primary_family, best_other_family],
   370	                            metadata={
   371	                                "best_other_family": best_other_family,
   372	                                "best_other_share": round(best_other_share, 6),
   373	                                "family_margin": round(family_margin, 6),
   374	                                "family_ranking": ranking,
   375	                                "primary_family": primary_family,
   376	                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
   377	                                "primary_share": round(primary_share, 6),
   378	                            },
   379	                        )
   380	                    )
   381	        ambiguities.extend(
   382	            self._temporal_target_family_ambiguities(
   383	                encoding,
   384	                ranking=ranking,
   385	                family_shares=family_shares,
   386	            )
   387	        )
   388	        ambiguities.extend(
   389	            self._temporal_scope_target_family_ambiguities(
   390	                encoding,
   391	                ranking=ranking,
   392	                family_shares=family_shares,
   393	            )
   394	        )
   395	        ambiguities.extend(
   396	            self._frame_scope_target_family_ambiguities(
   397	                encoding,
   398	                ranking=ranking,
   399	                family_shares=family_shares,
   400	            )
   401	        )
   402	        ambiguities.extend(
   403	            self._conditional_scope_target_family_ambiguities(
   404	                encoding,
   405	                ranking=ranking,
   406	                family_shares=family_shares,
   407	            )
   408	        )
   409	        ambiguities.extend(
   410	            self._deontic_scope_target_family_ambiguities(
   411	                encoding,
   412	                ranking=ranking,
   413	                family_shares=family_shares,
   414	            )
   415	        )
   416	        ambiguities.extend(
   417	            self._temporal_deontic_scope_family_ambiguities(
   418	                encoding,
   419	                ranking=ranking,
   420	                family_shares=family_shares,
   421	            )
   422	        )
   423	        ambiguities.extend(
   424	            self._dynamic_scope_target_family_ambiguities(
   425	                encoding,
   426	                ranking=ranking,
   427	                family_shares=family_shares,
   428	            )
   429	        )
   430	        ambiguities.extend(
   431	            self._alethic_scope_target_family_ambiguities(
   432	                encoding,
   433	                ranking=ranking,
   434	                family_shares=family_shares,
   435	            )
   436	        )
   437	        ambiguities.extend(
   438	            self._adaptive_family_margin_ambiguities(
   439	                encoding,
   440	                modal_ir=modal_ir,
   441	                ranking=ranking,
   442	                family_shares=family_shares,
   443	                frame_selections=frame_selections,
   444	                predicted_family_source="ranked_modal_families",
   445	            )
   446	        )
   447	        adaptive_ranking = self._adaptive_family_ranking_from_logits(encoding)
   448	        if adaptive_ranking:
   449	            adaptive_family_shares = {
   450	                str(candidate["family"]): self._ranking_share(candidate)
   451	                for candidate in adaptive_ranking
   452	            }
   453	            ambiguities.extend(
   454	                self._adaptive_family_margin_ambiguities(
   455	                    encoding,
   456	                    modal_ir=modal_ir,
   457	                    ranking=adaptive_ranking,
   458	                    family_shares=adaptive_family_shares,
   459	                    frame_selections=frame_selections,
   460	                    predicted_family_source="adaptive_logits",
   461	                )
   462	            )
   463	        if len(ranking) < 2:
   464	            return self._ensure_explicit_adaptive_ambiguities(ambiguities)
   465	
   466	        top, runner_up = ranking[0], ranking[1]
   467	        share_margin = self._ranking_share(top) - self._ranking_share(runner_up)
   468	        if share_margin <= self.config.modal_family_share_margin:
   469	            ambiguities.append(
   470	                ModalCompilationAmbiguity(
   471	                    ambiguity_type="close_modal_family_shares",
   472	                    message="Top modal families are close enough that legal family selection is ambiguous.",
   473	                    candidate_ids=[str(top["family"]), str(runner_up["family"])],
   474	                    metadata={
   475	                        "family_margin": round(share_margin, 6),
   476	                        "family_ranking": ranking,
   477	                        "share_margin": round(share_margin, 6),
   478	                        "top_family": str(top["family"]),
   479	                        "runner_up_family": str(runner_up["family"]),
   480	                    },
   481	                )
   482	            )
   483	
   484	        has_frame_formula = any(
   485	            str(formula.operator.family) == ModalLogicFamily.FRAME.value
   486	            for formula in modal_ir.formulas
   487	        )
   488	        if has_frame_formula:
   489	            frame_share = family_shares.get(ModalLogicFamily.FRAME.value, 0.0)
   490	            best_non_frame = max(
   491	                (
   492	                    candidate
   493	                    for candidate in ranking
   494	                    if str(candidate["family"]) != ModalLogicFamily.FRAME.value
   495	                ),
   496	                key=lambda candidate: (
   497	                    self._ranking_share(candidate),
   498	                    str(candidate["family"]),
   499	                ),
   500	                default=None,
   501	            )
   502	            if best_non_frame is not None:
   503	                competing_family = str(best_non_frame["family"])
   504	                competing_share = self._ranking_share(best_non_frame)
   505	                frame_margin = frame_share - competing_share
   506	                if frame_margin < self.config.modal_primary_family_outvote_margin:
   507	                    ambiguities.append(
   508	                        ModalCompilationAmbiguity(
   509	                            ambiguity_type="frame_modal_family_outvoted",
   510	                            message=(
   511	                                "Cue evidence favors a non-frame modal family over the compiled "
   512	                                "frame interpretation."
   513	                            ),
   514	                            candidate_ids=[ModalLogicFamily.FRAME.value, competing_family],
   515	                            severity="requires_rule",
   516	                            metadata={
   517	                                "competing_family": competing_family,
   518	                                "competing_share": round(competing_share, 6),
   519	                                "family_margin": round(frame_margin, 6),
   520	                                "family_ranking": ranking,
   521	                                "frame_share": round(frame_share, 6),
   522	                                "outvote_margin_threshold": self.config.modal_primary_family_outvote_margin,
   523	                            },
   524	                        )
   525	                    )
   526	                if frame_margin <= self.config.modal_primary_family_margin:
   527	                    ambiguities.append(
   528	                        ModalCompilationAmbiguity(
   529	                            ambiguity_type="low_frame_modal_family_margin",
   530	                            message=(
   531	                                "Frame-family evidence is weak relative to competing modal cues; "
   532	                                "family interpretation requires review."
   533	                            ),
   534	                            candidate_ids=[ModalLogicFamily.FRAME.value, competing_family],
   535	                            metadata={
   536	                                "competing_family": competing_family,
   537	                                "competing_share": round(competing_share, 6),
   538	                                "family_margin": round(frame_margin, 6),
   539	                                "family_ranking": ranking,
   540	                                "frame_share": round(frame_share, 6),
   541	                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
   542	                            },
   543	                        )
   544	                    )
   545	
   546	        strong_contenders = [
   547	            candidate
   548	            for candidate in ranking
   549	            if self._ranking_share(candidate)
   550	            >= self.config.modal_family_secondary_share_floor
   551	        ]
   552	        contender_families = {
   553	            str(candidate["family"]) for candidate in strong_contenders
   554	        }
   555	        has_temporal = ModalLogicFamily.TEMPORAL.value in contender_families
   556	        has_normative = any(
   557	            is_normative_modal_family(str(candidate["family"]))
   558	            for candidate in strong_contenders
   559	        )
   560	        runner_share = self._ranking_share(runner_up)
   561	        if (
   562	            has_temporal
   563	            and has_normative
   564	            and len(contender_families) > 1
   565	        ):
   566	            ambiguities.append(
   567	                ModalCompilationAmbiguity(
   568	                    ambiguity_type="temporal_normative_overlap",
   569	                    message=(
   570	                        "Temporal scope and normative force both have strong cue evidence; "
   571	                        "family interpretation requires review."
   572	                    ),
   573	                    candidate_ids=sorted(contender_families),
   574	                    metadata={
   575	                        "family_ranking": ranking,
   576	                        "runner_up_share": round(runner_share, 6),
   577	                        "secondary_share_floor": self.config.modal_family_secondary_share_floor,
   578	                    },
   579	                )
   580	            )
   581	        return self._ensure_explicit_adaptive_ambiguities(ambiguities)
