    17	def cosine_similarity(left: Sequence[float], right: Sequence[float]) -> float:
    18	    """Return cosine similarity for two vectors."""
    19	    _check_same_length(left, right)
    20	    left_norm = math.sqrt(sum(value * value for value in left))
    21	    right_norm = math.sqrt(sum(value * value for value in right))
    22	    if left_norm == 0.0 or right_norm == 0.0:
    23	        return 0.0
    24	    return sum(a * b for a, b in zip(left, right)) / (left_norm * right_norm)
    25	
    26	
    27	def cosine_loss(left: Sequence[float], right: Sequence[float]) -> float:
    28	    """Return ``1 - cosine_similarity``."""
    29	    return 1.0 - cosine_similarity(left, right)
    30	
    31	
    32	def mse_loss(left: Sequence[float], right: Sequence[float]) -> float:
    33	    """Return mean squared reconstruction error."""
    34	    _check_same_length(left, right)
    35	    if not left:
    36	        return 0.0
    37	    return sum((a - b) ** 2 for a, b in zip(left, right)) / len(left)
    38	
