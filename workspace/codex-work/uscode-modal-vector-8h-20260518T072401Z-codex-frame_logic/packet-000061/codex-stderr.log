   420	def _cosine_similarity(a: List[float], b: List[float]) -> float:
   421	    """Compute cosine similarity between two vectors."""
   422	    if len(a) != len(b):
   423	        raise ValueError(
   424	            f"Embedding dimension mismatch: {len(a)} vs {len(b)}"
   425	        )
   426	    dot = sum(x * y for x, y in zip(a, b))
   427	    norm_a = math.sqrt(sum(x * x for x in a))
   428	    norm_b = math.sqrt(sum(y * y for y in b))
   429	    if norm_a == 0.0 or norm_b == 0.0:
   430	        return 0.0
   431	    return dot / (norm_a * norm_b)
