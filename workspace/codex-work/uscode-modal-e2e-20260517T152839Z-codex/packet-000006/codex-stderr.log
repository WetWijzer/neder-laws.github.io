   222	    def _formula_ambiguities(
   223	        self,
   224	        modal_ir: ModalIRDocument,
   225	    ) -> List[ModalCompilationAmbiguity]:
   226	        by_span: Dict[tuple[int, int], List[str]] = {}
   227	        for formula in modal_ir.formulas:
   228	            span = (formula.provenance.start_char, formula.provenance.end_char)
   229	            candidate = (
   230	                f"{formula.formula_id}:{formula.operator.family}:"
   231	                f"{formula.operator.system}:{formula.operator.symbol}"
   232	            )
   233	            by_span.setdefault(span, []).append(candidate)
   234	
   235	        ambiguities: List[ModalCompilationAmbiguity] = []
   236	        for span, candidates in sorted(by_span.items()):
   237	            families = {candidate.split(":")[1] for candidate in candidates}
   238	            if len(candidates) > 1 and len(families) > 1:
   239	                ambiguities.append(
   240	                    ModalCompilationAmbiguity(
   241	                        ambiguity_type="multi_family_same_span",
   242	                        message="Multiple modal families were compiled from the same text span.",
   243	                        candidate_ids=sorted(candidates),
   244	                        metadata={"span": list(span)},
   245	                    )
   246	                )
   247	        return ambiguities
