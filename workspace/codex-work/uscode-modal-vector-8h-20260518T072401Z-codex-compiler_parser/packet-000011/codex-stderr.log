                                "competing_share": round(competing_share, 6),
                                "family_margin": round(frame_margin, 6),
                                "family_ranking": ranking,
                                "frame_share": round(frame_share, 6),
                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
                            },
