   401	def test_spacy_codec_debiases_generic_frame_cues_when_deontic_force_is_present() -> None:
   402	    codec = SpaCyModalCodec(
   403	        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
