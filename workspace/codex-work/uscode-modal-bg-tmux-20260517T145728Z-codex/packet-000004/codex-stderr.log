   222	class ModalRegistry:
   223	    """Lookup table for modal parse profiles."""
   224	
   225	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   226	        self._profiles: Dict[str, ModalParseProfile] = {
   227	            profile.profile_id: profile for profile in profiles
   228	        }
   229	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   230	            profile.family: profile for profile in profiles
   231	        }
   232	
   233	    def get_profile(
   234	        self,
   235	        family: ModalLogicFamily | str,
   236	        system: Optional[ModalSystem | str] = None,
   237	    ) -> ModalParseProfile:
   238	        """Get a profile by family, optionally constrained by system."""
   239	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   240	        if system is None:
   241	            return self._by_family[resolved_family]
   242	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   243	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   244	
   245	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   246	        """Return all profiles in deterministic order."""
   247	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   248	
   249	    def to_dict(self) -> Mapping[str, object]:
   250	        """Return a stable JSON-ready registry mapping."""
   251	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   252	
   253	
   254	DEFAULT_MODAL_REGISTRY = ModalRegistry()
