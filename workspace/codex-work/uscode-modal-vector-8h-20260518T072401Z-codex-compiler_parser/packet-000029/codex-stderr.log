texts={
 'us-code-46-55318.-a7002ab697067d67':(\"46 U.S.C. 55318.\",\"§55318. Effect on other law This subchapter does not affect chapter 5 of title 5. (Pub. L. 109–304, §8(c), Oct. 6, 2006, 120 Stat. 1648.) Historical and Revision Notes Revised Section Source (U.S. Code) Source (Statutes at Large) 55318 46 App.:1208f(a), (c). Pub. L. 99–509, title V, §5004(a), (c), Oct. 21, 1986, 100 Stat. 1910, 1911.\"),
 'us-code-8-606-f7dcbbfb006072f7':(\"8 U.S.C. 606\",\"U.S.C. Title 8 - ALIENS AND NATIONALITY 8 U.S.C. United States Code, 2024 Edition Title 8 - ALIENS AND NATIONALITY CHAPTER 11 - NATIONALITY SUBCHAPTER II - NATIONALITY AT BIRTH Sec. 606 - Transferred From the U.S. Government Publishing Office, www.gpo.gov §606. Transferred Editorial Notes Codification Section transferred to section 1421l of Title 48, Territories and Insular Possessions. That section was later repealed. See section 1407 of this title.\"),
 'us-code-46-115.-286a747a33fe04bb':(\"46 U.S.C. 115.\",\"§115. Vessel In this title, the term \\\"vessel\\\" has the meaning given that term in section 3 of title 1. (Pub. L. 109–304, §4, Oct. 6, 2006, 120 Stat. 1487.) Historical and Revision Notes Revised Section Source (U.S. Code) Source (Statutes at Large) 115 46:2101(45).\"),
}
parser=LegalModalParser()
for sid,(citation,text) in texts.items():
    doc=parser.parse(text,document_id=sid,source='us_code',citation=citation)
    print('\\nPARSER',sid,'formulas',len(doc.formulas))
    if doc.formulas:
        f=doc.formulas[-1]
        print('  family',f.operator.family,'cue',f.metadata.get('cue'),'rule',f.metadata.get('fallback_rule'))

for backend in ('regex','spacy'):
    comp=DeterministicModalCompiler(ModalCompilerConfig(parser_backend=backend,spacy_model_name='definitely_missing_legal_model'))
    print('\\nBACKEND',backend)
    for sid,(citation,text) in texts.items():
        result=comp.compile(text,document_id=sid,citation=citation,source='us_code')
        print(' ',sid,'formulas',len(result.modal_ir.formulas),'missing?',any(a.ambiguity_type=='missing_modal_formula' for a in result.ambiguities))
        if result.modal_ir.formulas:
            f=result.modal_ir.formulas[-1]
            print('    last',f.operator.family,f.metadata.get('cue'),f.metadata.get('fallback_rule'))
