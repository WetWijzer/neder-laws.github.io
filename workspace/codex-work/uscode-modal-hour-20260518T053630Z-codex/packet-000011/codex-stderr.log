   530	class SpaCyModalDecoder:
   531	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   532	
   533	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   534	        if dimensions < 1:
   535	            raise ValueError("dimensions must be >= 1")
   536	        vector = [0.0 for _ in range(dimensions)]
   537	        for feature in self._feature_stream(encoding):
   538	            slot, value = _feature_hash(feature, dimensions)
   539	            vector[slot] += value
   540	        norm = math.sqrt(sum(value * value for value in vector))
   541	        if norm == 0.0:
   542	            return vector
   543	        return [round(value / norm, 6) for value in vector]
   544	
   545	    def family_logits(
   546	        self,
   547	        encoding: SpaCyLegalEncoding,
   548	        *,
   549	        modal_families: Sequence[str],
   550	    ) -> Dict[str, float]:
   551	        logits = {family: -0.25 for family in modal_families}
   552	        counts = encoding.modal_family_counts()
   553	        for family, count in counts.items():
   554	            if family in logits:
   555	                logits[family] = 2.0 + float(count)
   556	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   557	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   558	        return logits
   559	
   560	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   561	        yield f"doclen:{len(encoding.tokens)}"
   562	        for token in encoding.tokens:
   563	            if token.is_alpha and not token.is_stop:
   564	                yield f"lemma:{token.normalized()}"
   565	            if token.pos:
   566	                yield f"pos:{token.pos}"
   567	            if token.dep:
   568	                yield f"dep:{token.dep}"
   569	        for cue in encoding.cues:
   570	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   571	        for family, count in encoding.modal_family_counts().items():
   572	            yield f"family:{family}:{count}"
