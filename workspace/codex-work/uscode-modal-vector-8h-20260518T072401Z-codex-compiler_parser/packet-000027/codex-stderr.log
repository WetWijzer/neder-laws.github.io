+            candidate_text = self.normalize_text(candidate_text[:cutoff])
+        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(candidate_text):
+            return None
+
+        return LegalSegment(
+            text=candidate_text,
+            start_char=start,
+            end_char=start + len(candidate_text),
+            role="clause",
+        )
