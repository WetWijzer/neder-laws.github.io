   306	    def _prefixed_clause_phrases(
   307	        self,
   308	        segment_text: str,
   309	        prefixes: Iterable[str],
   310	    ) -> List[str]:
   311	        normalized = self.normalize_text(segment_text)
   312	        phrases: List[str] = []
   313	        for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
   314	            pattern = re.compile(rf"(?<!\w){re.escape(prefix)}(?!\w)", re.IGNORECASE)
   315	            for match in pattern.finditer(normalized):
