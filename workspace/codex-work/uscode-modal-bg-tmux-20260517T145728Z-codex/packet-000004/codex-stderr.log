    91	class DeterministicModalCompiler:
    92	    """Compile legal text into modal IR with explainable frame selection."""
    93	
    94	    def __init__(
    95	        self,
    96	        config: Optional[ModalCompilerConfig] = None,
    97	        *,
    98	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
    99	        frame_selector: Optional[BM25FrameSelector] = None,
   100	    ) -> None:
   101	        self.config = config or ModalCompilerConfig()
   102	        self.registry = registry
   103	        self.parser = LegalModalParser(registry=registry)
   104	        self.encoder = SpaCyLegalEncoder(
   105	            model_name=self.config.spacy_model_name,
   106	            registry=registry,
   107	        )
   108	        self.ir_compiler = SpaCyModalIRCompiler()
   109	        self.family_decoder = SpaCyModalDecoder()
   110	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   111	
   112	    def compile(
   113	        self,
   114	        text: str,
   115	        *,
   116	        document_id: Optional[str] = None,
   117	        citation: Optional[str] = None,
   118	        source: str = "legal_text",
   119	    ) -> ModalCompilationResult:
   120	        """Compile text into modal IR using deterministic rules only."""
   121	        normalized_text = self.parser.normalize_text(text)
   122	        backend = self.config.parser_backend.lower().strip()
   123	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   124	            text,
   125	            document_id=document_id,
   126	            citation=citation,
   127	            source=source,
   128	        )
   129	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   130	            modal_ir = self.parser.parse(
   131	                text,
   132	                document_id=document_id or encoding.document_id,
   133	                citation=citation,
   134	                source=source,
   135	            )
   136	            parser_name = "legal_modal_parser_v1"
   137	        else:
   138	            modal_ir = self.ir_compiler.compile(encoding)
   139	            parser_name = "spacy_modal_codec_v1"
   140	
   141	        frame_selections = self.frame_selector.rank(
   142	            normalized_text,
   143	            top_k=self.config.top_k_frames,
   144	            domain=self.config.frame_domain,
   145	        )
   146	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   147	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   148	        ambiguities = [
   149	            *self._formula_ambiguities(modal_ir),
   150	            *self._family_ambiguities(modal_ir, encoding),
   151	            *self._frame_ambiguities(frame_selections),
   152	        ]
   153	        if normalized_text and not modal_ir.formulas:
   154	            ambiguities.append(
   155	                ModalCompilationAmbiguity(
   156	                    ambiguity_type="missing_modal_formula",
   157	                    message="No deterministic modal formula was produced for non-empty text.",
   158	                    severity="requires_rule",
   159	                )
   160	            )
   161	
   162	        modal_ir = self._attach_metadata(
   163	            modal_ir,
   164	            frame_selections,
   165	            parser_name=parser_name,
   166	            selected_frame=selected_frame,
   167	            ambiguity_count=len(ambiguities),
   168	            encoding=encoding,
   169	        )
   170	        return ModalCompilationResult(
   171	            modal_ir=modal_ir,
   172	            parser_name=parser_name,
   173	            normalized_text=normalized_text,
   174	            frame_candidates=frame_candidates,
   175	            selected_frame=selected_frame,
   176	            ambiguities=ambiguities,
   177	            encoding=encoding,
   178	            metadata={
   179	                "ambiguity_count": len(ambiguities),
   180	                "deterministic_compiler": "modal_compiler_v1",
   181	                "frame_selector": "bm25_v1",
   182	                "llm_call_count": 0,
   183	                "parser_backend": self.config.parser_backend,
   184	            },
   185	        )
   186	
   187	    def _attach_metadata(
   188	        self,
   189	        modal_ir: ModalIRDocument,
   190	        frame_selections: Sequence[FrameSelection],
   191	        *,
   192	        parser_name: str,
   193	        selected_frame: Optional[str],
   194	        ambiguity_count: int,
   195	        encoding: SpaCyLegalEncoding,
   196	    ) -> ModalIRDocument:
   197	        frame_candidates = [
   198	            ModalIRFrame(
   199	                frame_id=selection.frame.frame_id,
   200	                score=selection.score,
   201	                matched_terms=list(selection.matched_terms),
   202	                explanation=selection.explanation,
   203	            )
   204	            for selection in frame_selections
   205	        ]
   206	        metadata = {
   207	            **modal_ir.metadata,
   208	            "ambiguity_count": ambiguity_count,
   209	            "deterministic_compiler": "modal_compiler_v1",
   210	            "deterministic_parser": parser_name,
   211	            "frame_selector": "bm25_v1",
   212	            "llm_call_count": 0,
   213	            "modal_family_counts": encoding.modal_family_counts(),
   214	            "selected_frame": selected_frame,
   215	        }
   216	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
   217	
   218	    def _formula_ambiguities(
   219	        self,
   220	        modal_ir: ModalIRDocument,
   221	    ) -> List[ModalCompilationAmbiguity]:
   222	        by_span: Dict[tuple[int, int], List[str]] = {}
   223	        for formula in modal_ir.formulas:
   224	            span = (formula.provenance.start_char, formula.provenance.end_char)
   225	            candidate = (
   226	                f"{formula.formula_id}:{formula.operator.family}:"
   227	                f"{formula.operator.system}:{formula.operator.symbol}"
   228	            )
   229	            by_span.setdefault(span, []).append(candidate)
   230	
   231	        ambiguities: List[ModalCompilationAmbiguity] = []
   232	        for span, candidates in sorted(by_span.items()):
   233	            families = {candidate.split(":")[1] for candidate in candidates}
   234	            if len(candidates) > 1 and len(families) > 1:
   235	                ambiguities.append(
   236	                    ModalCompilationAmbiguity(
   237	                        ambiguity_type="multi_family_same_span",
   238	                        message="Multiple modal families were compiled from the same text span.",
   239	                        candidate_ids=sorted(candidates),
   240	                        metadata={"span": list(span)},
   241	                    )
   242	                )
   243	        return ambiguities
   244	
   245	    def _frame_ambiguities(
   246	        self,
   247	        frame_selections: Sequence[FrameSelection],
   248	    ) -> List[ModalCompilationAmbiguity]:
   249	        if len(frame_selections) < 2:
   250	            return []
   251	        first, second = frame_selections[0], frame_selections[1]
   252	        margin = float(first.score) - float(second.score)
   253	        if margin > self.config.frame_score_margin:
   254	            return []
   255	        return [
   256	            ModalCompilationAmbiguity(
   257	                ambiguity_type="close_bm25_frame_scores",
   258	                message="Top ontology frame choices are close enough to require review.",
   259	                candidate_ids=[first.frame.frame_id, second.frame.frame_id],
   260	                metadata={
   261	                    "margin": round(margin, 6),
   262	                    "top_score": first.score,
   263	                    "runner_up_score": second.score,
   264	                },
   265	            )
   266	        ]
   267	
   268	    def _family_ambiguities(
   269	        self,
   270	        modal_ir: ModalIRDocument,
   271	        encoding: SpaCyLegalEncoding,
   272	    ) -> List[ModalCompilationAmbiguity]:
   273	        if not encoding.normalized_text:
   274	            return []
   275	        modal_families = [family.value for family in ModalLogicFamily]
   276	        logits = self.family_decoder.family_logits(
   277	            encoding,
   278	            modal_families=modal_families,
   279	        )
   280	        probabilities = _softmax(logits)
   281	        if not probabilities:
   282	            return []
   283	        target_family = (
   284	            modal_ir.formulas[0].operator.family
   285	            if modal_ir.formulas
   286	            else ModalLogicFamily.HYBRID.value
   287	        )
   288	        target_probability = float(probabilities.get(target_family, 0.0))
   289	        best_other_family = ""
   290	        best_other_probability = 0.0
