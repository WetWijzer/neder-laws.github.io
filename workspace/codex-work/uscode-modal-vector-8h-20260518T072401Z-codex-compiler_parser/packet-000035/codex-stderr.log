        body_text = self.normalize_text(normalized_text[marker.start() :])
        body_token_count = len(_TOKEN_RE.findall(body_text.lower()))
        if body_token_count < _USCODE_SUBSECTION_HEADING_BODY_MIN_TOKENS:
            return None

        return LegalSegment(
            text=heading_prefix,
            start_char=0,
            end_char=marker.start(),
            role="clause",
        )

