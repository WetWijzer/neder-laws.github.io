   697	    @staticmethod
   698	    def _canonical_modal_family_name(value: Any) -> str:
   699	        """Normalize modal family tokens for stable explicit ambiguity typing."""
   700	        resolved = str(value or "").strip()
   701	        if not resolved:
   702	            return ""
   703	        leaf = resolved.rsplit(".", maxsplit=1)[-1].strip()
   704	        for candidate in (
   705	            resolved,
   706	            resolved.lower(),
   707	            leaf,
   708	            leaf.lower(),
   709	        ):
   710	            if not candidate:
   711	                continue
   712	            try:
   713	                return ModalLogicFamily(candidate).value
   714	            except ValueError:
   715	                continue
   716	        return leaf.lower()
