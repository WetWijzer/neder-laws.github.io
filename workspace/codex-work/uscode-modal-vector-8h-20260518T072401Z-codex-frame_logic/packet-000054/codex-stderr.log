            "predicate": "condition",
            "object": "unless written notice is provided",
        }
    )

    terms = frame_ontology_terms_from_triples(dense_triples)

    assert "unless_written_notice_provided" in terms
    assert "term_fj" in terms
    assert len(terms) > 64


