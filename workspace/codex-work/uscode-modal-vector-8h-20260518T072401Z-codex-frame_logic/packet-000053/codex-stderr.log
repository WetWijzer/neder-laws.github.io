   285	@dataclass(frozen=True)
   286	class FrameCandidate:
   287	    """Candidate ontology frame for legal interpretation."""
   288	
   289	    frame_id: str
   290	    label: str
   291	    description: str = ""
   292	    terms: Sequence[str] = field(default_factory=tuple)
   293	    domain: str = "general"
   294	    metadata: Mapping[str, object] = field(default_factory=dict)
   295	
   296	    def document_text(self) -> str:
   297	        """Return lexical text indexed by BM25."""
   298	        return " ".join([self.label, self.description, *self.terms, self.domain])
   299	
   300	
   301	@dataclass(frozen=True)
   302	class FrameSelection:
   303	    """BM25 selection result with deterministic explanation fields."""
   304	
