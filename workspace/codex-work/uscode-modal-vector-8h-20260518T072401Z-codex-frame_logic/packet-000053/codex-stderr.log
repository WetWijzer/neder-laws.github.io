   611	class SpaCyModalCodec:
   612	    """Convenience facade for encoder -> IR -> vector workflows."""
   613	
   614	    def __init__(
   615	        self,
   616	        *,
   617	        encoder: Optional[SpaCyLegalEncoder] = None,
   618	        compiler: Optional[SpaCyModalIRCompiler] = None,
   619	        decoder: Optional[SpaCyModalDecoder] = None,
   620	    ) -> None:
   621	        self.encoder = encoder or SpaCyLegalEncoder()
   622	        self.compiler = compiler or SpaCyModalIRCompiler()
   623	        self.decoder = decoder or SpaCyModalDecoder()
   624	
   625	    def encode_sample(self, sample: LegalSample) -> SpaCyLegalEncoding:
   626	        return self.encoder.encode(
   627	            sample.text,
   628	            document_id=sample.sample_id,
   629	            citation=sample.citation,
   630	            source=sample.source,
   631	        )
   632	
   633	    def compile_sample_ir(self, sample: LegalSample) -> ModalIRDocument:
   634	        return self.compiler.compile(self.encode_sample(sample))
   635	
   636	    def decode_sample_embedding(self, sample: LegalSample, *, dimensions: int) -> List[float]:
   637	        return self.decoder.decode_embedding(self.encode_sample(sample), dimensions=dimensions)
   638	
   639	    def family_logits_for_sample(
   640	        self,
   641	        sample: LegalSample,
   642	        *,
   643	        modal_families: Sequence[str],
   644	    ) -> Dict[str, float]:
   645	        return self.decoder.family_logits(
   646	            self.encode_sample(sample),
   647	            modal_families=modal_families,
   648	        )
   649	
   650	    def feature_keys_for_sample(self, sample: LegalSample) -> List[str]:
   651	        """Return text-derived features that can receive generalizable SGD updates."""
   652	        encoding = self.encode_sample(sample)
   653	        return _unique_preserve_order(self.decoder._feature_stream(encoding))
