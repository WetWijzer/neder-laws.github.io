   161	class LegalModalAutoencoderLoop:
   162	    """Run the deterministic legal modal codec plus a sparse Codex repair loop."""
   163	
   164	    def __init__(
   165	        self,
   166	        config: Optional[ModalAutoencoderLoopConfig] = None,
   167	        *,
   168	        codec: Optional[DeterministicModalLogicCodec] = None,
   169	        autoencoder: Optional[AdaptiveModalAutoencoder] = None,
   170	        cache: Optional[CodexCallCache] = None,
   171	        llm_generate: Optional[LLMGenerateFn] = None,
   172	    ) -> None:
   173	        self.config = config or ModalAutoencoderLoopConfig()
   174	        self.cache_path = (
   175	            Path(self.config.codex_cache_path).expanduser()
   176	            if self.config.codex_cache_path
   177	            else None
   178	        )
   179	        self.codec = codec or DeterministicModalLogicCodec(self.config.codec_config)
   180	        self.autoencoder = autoencoder or AdaptiveModalAutoencoder(feature_codec=self.codec)
   181	        self.cache = cache if cache is not None else self._load_cache()
   182	        self.llm_generate = llm_generate
   183	
   184	    def run(
   185	        self,
   186	        text: str,
   187	        *,
   188	        document_id: Optional[str] = None,
   189	        citation: Optional[str] = None,
   190	        source: str = "us_code",
   191	        title: str = "modal",
   192	        section: Optional[str] = None,
   193	        source_embedding: Optional[Sequence[float]] = None,
   194	        allow_llm_repair: Optional[bool] = None,
   195	    ) -> ModalAutoencoderLoopResult:
   196	        """Run one cheap-first legal text -> modal IR -> validation pass."""
   197	
   198	        codec_result = self.codec.encode(
   199	            text,
   200	            document_id=document_id,
   201	            citation=citation,
   202	            source=source,
   203	            source_embedding=source_embedding,
   204	        )
   205	        sample = _sample_from_codec_result(
   206	            codec_result,
   207	            title=title,
   208	            section=section or document_id or codec_result.modal_ir.document_id,
   209	            embedding_vector=source_embedding,
   210	        )
   211	        graph_report = self._import_graph(sample.modal_ir)
   212	        prover_signal = self._evaluate_provers(sample)
   213	        available_external_provers = self._external_prover_inventory()
   214	        decision = self.autoencoder.codex_call_decision(
   215	            sample,
   216	            config=self.config.gate_config,
   217	            cache=self.cache,
   218	            prover_signal=prover_signal,
   219	        )
   220	
   221	        llm_called = False
   222	        llm_response = ""
   223	        llm_patch: Optional[Dict[str, Any]] = None
   224	        llm_patch_validation: Optional[FrameLogicPatchValidation] = None
   225	        repaired_modal_ir: Optional[ModalIRDocument] = None
   226	        should_call_llm = (
   227	            self.config.allow_llm_repair
   228	            if allow_llm_repair is None
   229	            else bool(allow_llm_repair)
   230	        )
   231	
   232	        if decision.should_call_codex and should_call_llm:
   233	            llm_called = True
   234	            self.cache.record_codex_call(decision)
   235	            llm_response = self._call_llm_repair(codec_result, sample, decision, prover_signal)
   236	            llm_patch = _parse_json_object(llm_response)
   237	            if llm_patch:
   238	                llm_patch_validation = validate_frame_logic_patch(sample.modal_ir, llm_patch)
   239	            if self.config.apply_llm_frame_logic_patches and llm_patch:
   240	                repaired_modal_ir = _apply_frame_logic_patch(
   241	                    sample.modal_ir,
   242	                    llm_patch,
   243	                    validation=llm_patch_validation,
   244	                )
   245	            self.save_cache()
   246	        elif not decision.reasons:
   247	            self.cache.record_local_success(decision)
   248	            self.save_cache()
   249	
   250	        accepted = _accepted(
   251	            decision,
   252	            graph_report=graph_report,
   253	            prover_signal=prover_signal,
   254	            require_provers=self.config.evaluate_provers,
   255	        )
   256	        return ModalAutoencoderLoopResult(
   257	            source_text=text,
   258	            codec_result=codec_result,
   259	            sample=sample,
   260	            codex_decision=decision,
   261	            accepted=accepted,
   262	            graph_import_report=graph_report,
   263	            prover_signal=prover_signal,
   264	            available_external_provers=tuple(available_external_provers),
   265	            llm_called=llm_called,
   266	            llm_response=llm_response,
   267	            llm_patch=llm_patch,
   268	            llm_patch_validation=llm_patch_validation,
   269	            repaired_modal_ir=repaired_modal_ir,
   270	            metadata={
   271	                "llm_model": self.config.llm_model if llm_called else "",
   272	                "llm_provider": self.config.llm_provider if llm_called else "",
   273	                "loop": "legal_modal_autoencoder_loop_v1",
   274	                "codex_cache_path": str(self.cache_path) if self.cache_path else "",
   275	            },
   276	        )
   277	
   278	    def run_many(
   279	        self,
   280	        records: Iterable[Mapping[str, Any] | str],
   281	        *,
   282	        allow_llm_repair: Optional[bool] = None,
   283	        default_source: str = "us_code",
   284	        default_title: str = "modal",
   285	    ) -> Sequence[ModalAutoencoderLoopResult]:
   286	        """Run multiple legal text records through one shared gate/cache."""
   287	
   288	        results = []
   289	        for index, record in enumerate(records):
   290	            if isinstance(record, str):
   291	                text = record
   292	                kwargs: Dict[str, Any] = {
   293	                    "source": default_source,
   294	                    "title": default_title,
   295	                }
   296	            elif isinstance(record, Mapping):
   297	                text = str(record.get("text") or "")
   298	                kwargs = {
   299	                    "citation": _optional_str(record.get("citation")),
   300	                    "document_id": _optional_str(
   301	                        record.get("document_id") or record.get("sample_id") or record.get("id")
   302	                    ),
   303	                    "section": _optional_str(record.get("section")),
   304	                    "source": _optional_str(record.get("source")) or default_source,
   305	                    "source_embedding": record.get("source_embedding")
   306	                    or record.get("embedding_vector"),
   307	                    "title": _optional_str(record.get("title")) or default_title,
   308	                }
   309	            else:
   310	                raise TypeError(f"Unsupported record type at index {index}: {type(record)!r}")
   311	            if not text.strip():
   312	                raise ValueError(f"Loop record at index {index} has empty text")
   313	            results.append(
   314	                self.run(
   315	                    text,
   316	                    allow_llm_repair=allow_llm_repair,
   317	                    **kwargs,
   318	                )
   319	            )
   320	        return tuple(results)
   321	
   322	    def save_cache(self) -> None:
   323	        """Persist the Codex call gate cache when ``codex_cache_path`` is set."""
   324	
   325	        if self.cache_path is None:
   326	            return
   327	        self.cache_path.parent.mkdir(parents=True, exist_ok=True)
   328	        self.cache_path.write_text(
   329	            json.dumps(
   330	                self.cache.to_dict(),
   331	                ensure_ascii=True,
   332	                sort_keys=True,
   333	                separators=(",", ":"),
   334	            )
   335	            + "\n",
   336	            encoding="utf-8",
   337	        )
   338	
   339	    def _load_cache(self) -> CodexCallCache:
   340	        if self.cache_path is None or not self.cache_path.exists():
   341	            return CodexCallCache()
   342	        try:
   343	            data = json.loads(self.cache_path.read_text(encoding="utf-8"))
   344	            if isinstance(data, Mapping):
   345	                return _codex_cache_from_mapping(data)
   346	        except (OSError, json.JSONDecodeError, TypeError, ValueError):
   347	            pass
   348	        return CodexCallCache()
   349	
   350	    def _import_graph(self, modal_ir: ModalIRDocument) -> Dict[str, int]:
   351	        if not self.config.import_frame_logic_graph:
   352	            return {}
   353	        _, report = import_modal_ir_to_graph_engine(modal_ir)
   354	        return report
   355	
   356	    def _evaluate_provers(self, sample: LegalSample) -> Optional[ProverCompilationSignal]:
   357	        if not self.config.evaluate_provers:
   358	            return None
   359	        return evaluate_modal_prover_compilation(sample)
