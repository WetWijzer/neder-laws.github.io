   585	@dataclass(frozen=True)
   586	class ModalParseProfile:
   587	    """Registry entry for one modal parsing profile."""
   588	
   589	    family: ModalLogicFamily
   590	    system: ModalSystem
   591	    operators: Tuple[ModalOperatorSpec, ...]
   592	    semantics: ModalSemanticsSpec = field(default_factory=ModalSemanticsSpec)
   593	    description: str = ""
   594	
   595	    @property
   596	    def profile_id(self) -> str:
   597	        """Stable profile identifier."""
   598	        return f"{self.family.value}:{self.system.value}"
   599	
   600	    def to_dict(self) -> Dict[str, object]:
   601	        """Return a stable JSON-ready mapping."""
   602	        return {
   603	            "description": self.description,
   604	            "family": self.family.value,
   605	            "operators": [
   606	                {
   607	                    "aliases": list(operator.aliases),
   608	                    "allowed_systems": [system.value for system in operator.allowed_systems],
   609	                    "arity": operator.arity,
   610	                    "cue_terms": list(operator.cue_terms),
   611	                    "symbol": operator.symbol,
   612	                }
   613	                for operator in self.operators
   614	            ],
   615	            "profile_id": self.profile_id,
   616	            "semantics": self.semantics.to_dict(),
   617	            "system": self.system.value,
   618	        }
