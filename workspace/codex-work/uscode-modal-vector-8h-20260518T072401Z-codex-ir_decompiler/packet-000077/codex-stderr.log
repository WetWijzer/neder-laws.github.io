    source_id: str
    start_char: int
    end_char: int
    citation: Optional[str] = None

    def to_dict(self) -> Dict[str, Any]:
        return {
            "citation": self.citation,
            "end_char": self.end_char,
            "source_id": self.source_id,
            "start_char": self.start_char,
        }


