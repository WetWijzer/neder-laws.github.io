   215	def test_spacy_encoder_compiles_modal_ir_without_downloaded_model() -> None:
   216	    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
   217	    encoding = encoder.encode(
   218	        "The agency must make records promptly available to any person.",
   219	        document_id="sample-5-552",
   220	        citation="5 U.S.C. 552",
   221	        source="us_code",
   222	    )
   223	
   224	    modal_ir = SpaCyModalIRCompiler().compile(encoding)
   225	
   226	    assert encoding.used_fallback_model is True
   227	    assert encoding.tokens
   228	    assert encoding.cues[0].family == "deontic"
   229	    assert modal_ir.metadata["llm_call_count"] == 0
   230	    assert modal_ir.formulas[0].operator.family == "deontic"
   231	    assert "records" in modal_ir.formulas[0].predicate.name
   232	
