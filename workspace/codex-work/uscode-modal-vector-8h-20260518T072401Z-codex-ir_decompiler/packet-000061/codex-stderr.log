from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.logic.modal import decode_modal_ir_document, decoded_modal_phrase_slot_text_map, modal_ir_to_flogic_triples

samples=[('48','2146.'),('42','15113.'),('25','3742'),('46','30908.'),('42','3796ii'),('12','1831cc'),('33','3203'),('34','20991'),('42','665.'),('46','55318.'),('14','1155'),('42','15251.')]
for title,sec in samples:
    sample=build_us_code_sample(title=title,section=sec,citation=f\"{title} U.S.C. {sec}\",text=f\"Sec. {sec} - Administrative provisions.\")
    decoded=decode_modal_ir_document(sample.modal_ir)
    slot_map=decoded_modal_phrase_slot_text_map(decoded)
    triples=modal_ir_to_flogic_triples(sample.modal_ir)
    pred={}
    for t in triples:
        p=t['predicate'];o=t['object']
        pred.setdefault(p,[])
        if o not in pred[p]: pred[p].append(o)
    missing_in_triples=[]
    mismatch=[]
    for k,v in slot_map.items():
        if k not in pred:
            missing_in_triples.append(k)
        elif pred[k]"'!=v:
            mismatch.append((k,v,pred[k]))
    extra=[k for k in pred if k not in slot_map]
    if missing_in_triples or mismatch:
        print('"'SAMPLE',title,sec,'MISSING',len(missing_in_triples),'MISMATCH',len(mismatch),'EXTRA',len(extra))
        if missing_in_triples[:10]: print(' missing',missing_in_triples[:10])
        if mismatch[:10]:
            for m in mismatch[:3]: print(' mismatch',m)
    else:
        print('SAMPLE',title,sec,'OK','extra',len(extra))
        if extra:
            print(' extra first',extra[:8])
