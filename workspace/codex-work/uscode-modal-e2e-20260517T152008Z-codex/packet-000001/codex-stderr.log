   262	def _token_overlap_ratio(left: str, right: str) -> float:
   263	    left_tokens = {
   264	        token.lower()
   265	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
   266	    }
   267	    right_tokens = {
   268	        token.lower()
   269	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
   270	    }
   271	    if not left_tokens:
   272	        return 1.0 if not right_tokens else 0.0
   273	    return len(left_tokens & right_tokens) / len(left_tokens)

