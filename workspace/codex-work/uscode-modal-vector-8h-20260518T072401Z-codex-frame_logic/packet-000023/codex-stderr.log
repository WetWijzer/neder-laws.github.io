   455	    ).strip("_")
   456	    if not normalized:
   457	        return ""
   458	    canonical = _FRAME_ONTOLOGY_PREDICATE_ALIASES.get(normalized, normalized)
   459	    if canonical in _FRAME_ONTOLOGY_AUDIT_PREDICATES:
   460	        return canonical
   461	    return ""
   462	
   463	
   464	def _is_contextual_frame_ontology_predicate(predicate: str) -> bool:
   465	    normalized = _FRAME_ONTOLOGY_PREDICATE_TOKEN_RE.sub(
   466	        "_",
   467	        str(predicate or "").strip().lower(),
   468	    ).strip("_")
   469	    return (
