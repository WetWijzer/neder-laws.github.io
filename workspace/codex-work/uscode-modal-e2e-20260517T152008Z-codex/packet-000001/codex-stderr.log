   168	                lower=token.lower_,
   169	                pos=token.pos_,
   170	                dep=token.dep_,
   171	                start_char=token.idx,
   172	                end_char=token.idx + len(token.text),
   173	                is_stop=bool(token.is_stop),
   174	                is_alpha=bool(token.is_alpha),
   175	            )
   176	            for token in doc
   177	        ]
