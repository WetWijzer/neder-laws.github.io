   130	def load_laws_table():
   131	    fs = HfFileSystem()
   132	    path = f"datasets/{HF_USCODE_DATASET_ID}/{USCODE_LAWS_PARQUET}"
   133	    with fs.open(path, "rb") as laws_file:
   134	        return pq.ParquetFile(laws_file).read(columns=LAW_COLUMNS)
   135	
   136	
   137	@contextmanager
   138	def queue_file_lock(queue_path: Path) -> Iterator[None]:
   139	    """Serialize async autoencoder/Codex writes to the shared JSONL queue."""
   140	    import fcntl
   141	
   142	    lock_path = queue_path.with_suffix(queue_path.suffix + ".lock")
   143	    lock_path.parent.mkdir(parents=True, exist_ok=True)
   144	    with lock_path.open("w", encoding="utf-8") as handle:
   145	        fcntl.flock(handle, fcntl.LOCK_EX)
   146	        try:
   147	            yield
   148	        finally:
   149	            fcntl.flock(handle, fcntl.LOCK_UN)
   150	
   151	
   152	def row_to_sample(row: Mapping[str, Any]):
   153	    return USCodeParquetRecord.from_row(row).to_sample()
   154	
   155	
   156	def sample_train_validation_rows(
   157	    laws_table,
   158	    rng: random.Random,
   159	    *,
   160	    train_count: int,
   161	    validation_count: int,
   162	    blocked_validation_sample_ids: set[str],
   163	):
   164	    train_indices = rng.sample(range(laws_table.num_rows), train_count)
   165	    train_rows = laws_table.take(train_indices).to_pylist()
   166	    train_samples = [row_to_sample(row) for row in train_rows]
   167	    selected_indices = set(train_indices)
   168	    validation_indices = []
   169	    validation_samples = []
   170	    attempts = 0
   171	    max_attempts = max(1000, validation_count * 100)
   172	    while len(validation_samples) < validation_count and attempts < max_attempts:
   173	        attempts += 1
   174	        index = rng.randrange(laws_table.num_rows)
   175	        if index in selected_indices:
   176	            continue
   177	        sample = row_to_sample(laws_table.take([index]).to_pylist()[0])
   178	        if sample.sample_id in blocked_validation_sample_ids:
   179	            continue
   180	        selected_indices.add(index)
   181	        validation_indices.append(index)
   182	        validation_samples.append(sample)
   183	    if len(validation_samples) < validation_count:
   184	        raise RuntimeError(
   185	            "Unable to sample enough validation rows without prior sample-memory exposure"
   186	        )
   187	    return train_indices, train_samples, validation_indices, validation_samples, attempts
   188	
   189	
   190	def metric_block(evaluation) -> Dict[str, Any]:
   191	    return {
   192	        "cosine_loss": round(evaluation.cosine_loss, 9),
   193	        "cosine_similarity": round(evaluation.embedding_cosine_similarity, 9),
   194	        "cross_entropy_loss": round(evaluation.cross_entropy_loss, 9),
   195	        "reconstruction_loss": round(evaluation.reconstruction_loss, 9),
   196	        "sample_count": evaluation.sample_count,
   197	        "symbolic_validity_penalty": round(evaluation.symbolic_validity_penalty, 9),
   198	    }
   199	
   200	
   201	def compiler_ir_metric_block(
   202	    samples: Sequence[Any],
   203	    codec: DeterministicModalLogicCodec,
   204	) -> Dict[str, Any]:
   205	    """Aggregate deterministic compiler/IR/decompiler round-trip metrics."""
   206	    sample_list = list(samples)
   207	    if not sample_list:
   208	        return {
   209	            "evaluated_count": 0,
   210	            "metric_failures": 0,
   211	            "sample_count": 0,
   212	        }
   213	
   214	    losses: Dict[str, List[float]] = {
   215	        "cosine_loss": [],
   216	        "cosine_similarity": [],
   217	        "cross_entropy_loss": [],
   218	        "flogic_similarity_loss": [],
   219	        "flogic_similarity_score": [],
   220	        "frame_ranking_loss": [],

