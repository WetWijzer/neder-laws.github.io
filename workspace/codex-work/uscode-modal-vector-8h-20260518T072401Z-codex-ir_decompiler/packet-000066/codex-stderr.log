   290	def decoded_modal_phrase_slot_text_map(
   291	    decoded: DecodedModalText,
   292	    *,
   293	    include_fixed: bool = False,
   294	    include_provenance_only: bool = True,
   295	) -> Dict[str, List[str]]:
   296	    """Return decoded phrase texts grouped by source slot."""
   297	    slot_texts: Dict[str, List[str]] = {}
   298	    for phrase in decoded.phrases:
   299	        if phrase.fixed and not include_fixed:
   300	            continue
   301	        if phrase.provenance_only and not include_provenance_only:
   302	            continue
   303	        slot = str(phrase.slot or "").strip()
   304	        text = _clean_text(phrase.text)
   305	        if not slot or not text:
   306	            continue
   307	        values = slot_texts.setdefault(slot, [])
   308	        if text not in values:
   309	            values.append(text)
   310	    return slot_texts
