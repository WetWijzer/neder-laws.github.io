   332	def _cosine_similarity(a: List[float], b: List[float]) -> float:
   333	    """Compute cosine similarity between two vectors."""
   334	    if len(a) != len(b):
   335	        raise ValueError(
   336	            f"Embedding dimension mismatch: {len(a)} vs {len(b)}"
   337	        )
   338	    dot = sum(x * y for x, y in zip(a, b))
   339	    norm_a = math.sqrt(sum(x * x for x in a))
   340	    norm_b = math.sqrt(sum(y * y for y in b))
   341	    if norm_a == 0.0 or norm_b == 0.0:
   342	        return 0.0
   343	    return dot / (norm_a * norm_b)
   344	
