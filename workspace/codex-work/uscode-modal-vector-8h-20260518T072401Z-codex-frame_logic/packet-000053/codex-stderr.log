   656	def _normalize(text: str) -> str:
   657	    return _WHITESPACE_RE.sub(" ", text).strip()
   658	
   659	
   660	def _document_id(normalized: str) -> str:
   661	    digest = hashlib.sha256(normalized.encode("utf-8")).hexdigest()[:16]
   662	    return f"spacy-legal-text-{digest}"
   663	
   664	
   665	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
   666	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
   667	    slot = int.from_bytes(digest[:4], "big") % dimensions
   668	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
   669	    magnitude = 0.5 + (digest[5] / 255.0)
   670	    return slot, sign * magnitude
   671	
   672	
   673	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
   674	    """Rank modal families by deterministic cue count and normalized share."""
   675	    counts = encoding.modal_family_counts()
   676	    total = sum(counts.values())
   677	    if total <= 0:
   678	        return []
   679	    ranking: List[Dict[str, float]] = []
   680	    for family, count in sorted(counts.items(), key=lambda item: (-item[1], item[0])):
   681	        ranking.append(
   682	            {
   683	                "family": family,
   684	                "count": int(count),
   685	                "share": round(float(count) / float(total), 6),
   686	            }
   687	        )
   688	    return ranking
