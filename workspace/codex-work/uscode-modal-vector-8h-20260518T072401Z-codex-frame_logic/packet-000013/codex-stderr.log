    40	def cross_entropy_loss(probabilities: Mapping[str, float], target: str) -> float:
    41	    """Return categorical cross entropy for a target label."""
    42	    probability = max(float(probabilities.get(target, 0.0)), 1e-12)
    43	    return -math.log(probability)
