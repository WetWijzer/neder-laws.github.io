   215	def frame_ontology_terms(
   216	    frame: FrameCandidate,
   217	    *,
   218	    matched_terms: Sequence[str] = (),
   219	    max_terms: int = 24,
   220	) -> List[str]:
   221	    """Return deterministic ontology terms for one frame candidate.
   222	
   223	    The term list is intentionally stable and explainable: we keep canonical
   224	    phrase forms plus tokenized atoms for frame id/label/domain/terms and the
   225	    lexical matches that affected BM25 scoring.
   226	    """
   227	
   228	    raw_values = [
   229	        (frame.frame_id, False),
   230	        *((value, True) for value in matched_terms),
   231	        (frame.label, True),
   232	        (frame.domain, True),
   233	        *((value, True) for value in frame.terms),
   234	    ]
   235	    terms: List[str] = []
   236	    for raw, include_tokens in raw_values:
   237	        text = str(raw or "").strip()
   238	        if not text:
   239	            continue
   240	        canonical = normalize_frame_ontology_term(text)
   241	        if canonical and canonical not in terms:
   242	            terms.append(canonical)
   243	            if len(terms) >= max_terms:
   244	                break
   245	        if include_tokens:
   246	            for token in _informative_ontology_tokens(text):
   247	                if token not in terms:
   248	                    terms.append(token)
   249	                    if len(terms) >= max_terms:
   250	                        break
   251	        if len(terms) >= max_terms:
   252	            break
   253	    return terms
