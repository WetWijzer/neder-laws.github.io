from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_modal_parser import LegalModalParser
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.spacy_modal_codec import SpaCyLegalEncoder, SpaCyModalIRCompiler
from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler, ModalCompilerConfig

cases = [
    (\"us-code-15-8563-3b998304c368f8a4\", \"15 U.S.C. 8563\", \"\\u00a78563. Renumbered.\", \"renumbered\"),
    (\"us-code-2-74b-55df9e8ab40ae3a5\", \"2 U.S.C. 74b\", \"\\u00a774b. Terminated.\", \"terminated\"),
    (\"us-code-42-11924.-096a2b2493c6c5cf\", \"42 U.S.C. 11924.\", \"\\u00a711924. Vacant.\", \"vacant\"),
]

# parser fallback
parser = LegalModalParser()
for document_id, citation, text, expected_status in cases:
    document = parser.parse(text, document_id=document_id, source=\"us_code\", citation=citation)
    assert document.formulas, (document_id, \"no formulas\")
    fallback = document.formulas[-1]
    assert fallback.metadata[\"fallback_rule\"] == \"uscode_editorial_status_heading_v1\"
    assert fallback.metadata[\"status_keyword\"] == expected_status

# spacy fallback
encoder = SpaCyLegalEncoder(model_name=\"definitely_missing_legal_model\")
spacy_compiler = SpaCyModalIRCompiler()
for document_id, citation, text, expected_status in cases:
    encoding = encoder.encode(text, document_id=document_id, citation=citation, source=\"us_code\")
    modal_ir = spacy_compiler.compile(encoding)
    assert modal_ir.formulas, (document_id, \"no formulas via spacy\")
    fallback = modal_ir.formulas[-1]
    assert fallback.metadata[\"fallback_rule\"] == \"uscode_editorial_status_heading_v1\"
    assert fallback.metadata[\"status_keyword\"] == expected_status

# modal compiler regex path
compiler = DeterministicModalCompiler(ModalCompilerConfig(parser_backend=\"regex\"))
for document_id, citation, text, expected_status in cases:
    compiled = compiler.compile(text, document_id=document_id, citation=citation, source=\"us_code\")
    assert compiled.modal_ir.formulas, (document_id, \"no formulas via compiler\")
    assert all(a.ambiguity_type "'!= "missing_modal_formula" for a in compiled.ambiguities)
    fallback = compiled.modal_ir.formulas[-1]
    assert fallback.metadata["fallback_rule"] == "uscode_editorial_status_heading_v1"
    assert fallback.metadata["status_keyword"] == expected_status

print("verified_new_editorial_status_cases=ok")
