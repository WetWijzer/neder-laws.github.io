                "predicate": "candidate_ontology_frame",
                "object": frame.frame_id,
            }
        )
        candidate_terms = frame_terms_by_frame.get(frame.frame_id, [])
        for term in candidate_terms:
            triples.append(
                {
                    "subject": modal_ir.document_id,
                    "predicate": "candidate_ontology_term",
                    "object": term,
