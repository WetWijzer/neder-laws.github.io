+    compiler = SpaCyModalIRCompiler()
+    cases = [
+        (
+            "us-code-26-6503-4c2f54aaf561a1a1",
+            "26 U.S.C. 6503",
+            _USCODE_26_6503_SYMBOLIC_VALIDITY_TODO_TEXT,
