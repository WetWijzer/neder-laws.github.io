   215	def normalize_frame_ontology_term(value: str, *, max_tokens: int = 8) -> str:
   216	    tokens = _informative_ontology_tokens(value)
   217	    if not tokens:
   218	        return ""
   219	    return "_".join(tokens[:max_tokens])
