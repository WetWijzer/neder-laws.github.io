+def test_spacy_codec_strengthens_epistemic_share_for_statutory_generic_frame_competition() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="7",
+        section="6011",
+        text=(
+            "Authority and jurisdiction and authority and jurisdiction under this section "
+            "rest upon a formal finding that the applicant concealed facts."
+        ),
+    )
+    encoding = codec.encode_sample(sample)
+    ranking = ranked_modal_families(encoding)
+
+    assert not any(cue.family == "epistemic" for cue in encoding.cues)
+    epistemic_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "epistemic"
+    )
+    frame_share = next(
+        float(item["share"])
+        for item in ranking
+        if item["family"] == "frame"
+    )
+    assert epistemic_share > 0.25
+    assert frame_share > epistemic_share
+
+
+def test_spacy_codec_strengthens_conditional_share_for_dense_generic_frame_condition_clauses() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    baseline = build_us_code_sample(
+        title="7",
+        section="6012",
+        text=(
+            "Authority and jurisdiction and authority and jurisdiction under this section apply."
+        ),
+    )
+    competing = build_us_code_sample(
+        title="7",
+        section="6013",
+        text=(
+            "When designated by the Secretary, authority and jurisdiction and authority "
+            "and jurisdiction under this section apply."
+        ),
+    )
+    baseline_encoding = codec.encode_sample(baseline)
+    competing_encoding = codec.encode_sample(competing)
+    baseline_ranking = ranked_modal_families(baseline_encoding)
+    competing_ranking = ranked_modal_families(competing_encoding)
+
+    assert not any(cue.family == "conditional_normative" for cue in competing_encoding.cues)
+    baseline_conditional_share = next(
+        float(item["share"])
+        for item in baseline_ranking
+        if item["family"] == "conditional_normative"
+    )
+    competing_conditional_share = next(
+        float(item["share"])
+        for item in competing_ranking
+        if item["family"] == "conditional_normative"
+    )
+    assert competing_conditional_share > baseline_conditional_share
+    assert competing_conditional_share > 0.2
+
+
