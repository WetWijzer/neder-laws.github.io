                ),
            ),
        ],
    )
    ambiguities = compiler._adaptive_family_margin_ambiguities(
        encoding,
        modal_ir=modal_ir,
        ranking=[
            {"family": "temporal", "count": 1, "share": 0.5750000000000001},
