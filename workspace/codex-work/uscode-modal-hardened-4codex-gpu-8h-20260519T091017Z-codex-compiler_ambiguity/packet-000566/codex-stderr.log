   395	def _ordered_unique_adaptive_ambiguity_family_pairs(
   396	    pairs: Iterable[Tuple[str, str]],
   397	) -> Tuple[Tuple[str, str], ...]:
   398	    """Return a stable pair table with duplicates removed and order preserved."""
   399	    unique_pairs: list[Tuple[str, str]] = []
   400	    seen_pairs: set[Tuple[str, str]] = set()
   401	    for pair in pairs:
   402	        if pair in seen_pairs:
   403	            continue
   404	        seen_pairs.add(pair)
   405	        unique_pairs.append(pair)
   406	    return tuple(unique_pairs)
