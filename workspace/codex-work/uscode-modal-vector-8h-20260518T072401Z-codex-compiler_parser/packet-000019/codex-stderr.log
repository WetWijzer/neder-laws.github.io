import pyarrow.parquet as pq
import pyarrow.compute as pc
from pathlib import Path
path = Path('/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet')
table = pq.read_table(path, columns=['ipfs_cid','citation_text','normalized_citation','section_number','law_name','text'])
need = {'16 u.s.c. 6410','16 u.s.c. 47a','7 u.s.c. 614'}
mask = None
for citation in need:
    cond = pc.equal(pc.utf8_lower(table['citation_text']), citation)
    mask = cond if mask is None else pc.or_(mask, cond)
rows = table.filter(mask)
print('matched rows', rows.num_rows)
for i in range(rows.num_rows):
    ct = rows['citation_text'][i].as_py()
    ln = rows['law_name'][i].as_py()
    sn = rows['section_number'][i].as_py()
    cid = rows['ipfs_cid'][i].as_py()
    text = rows['text'][i].as_py() or ''
    print('\\n===', ct, 'cid', cid)
    print('section', sn, 'law_name', ln)
    print('text:', text[:900].replace('\\n',' '))
