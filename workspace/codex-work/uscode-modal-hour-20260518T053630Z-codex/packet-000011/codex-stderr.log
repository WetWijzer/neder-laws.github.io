   131	def synthesis_hints_from_autoencoder_introspections(
   132	    introspections: Iterable[Mapping[str, Any]],
   133	) -> List[ModalProgramSynthesisHint]:
   134	    """Convert multiple introspection records into deterministic hints."""
   135	    hints: Dict[str, ModalProgramSynthesisHint] = {}
   136	    for introspection in introspections:
   137	        for hint in synthesis_hints_from_autoencoder_introspection(introspection):
   138	            hints[hint.hint_id] = hint
   139	    return sorted(hints.values(), key=lambda hint: (-hint.priority, hint.hint_id))
   140	
   141	
   142	def _hint(
   143	    sample_id: str,
   144	    *,
   145	    action: str,
   146	    target_component: str,
   147	    rationale: str,
   148	    priority: float,
   149	    evidence: Mapping[str, Any],
   150	) -> ModalProgramSynthesisHint:
   151	    evidence_dict = dict(evidence)
   152	    evidence_dict.setdefault("sample_id", sample_id)
   153	    payload = {
   154	        "action": action,
   155	        "evidence": evidence_dict,
   156	        "sample_id": sample_id,
   157	        "target_component": target_component,
   158	    }
   159	    digest = hashlib.sha256(
   160	        json.dumps(payload, ensure_ascii=True, sort_keys=True).encode("utf-8")
   161	    ).hexdigest()[:16]
   162	    return ModalProgramSynthesisHint(
   163	        hint_id=f"modal-synthesis-{digest}",
   164	        action=action,
   165	        target_component=target_component,
   166	        rationale=rationale,
   167	        priority=round(max(0.0, float(priority)), 12),
   168	        evidence=evidence_dict,
   169	    )
   170	
   171	
   172	def _feature_names(contributions: Any) -> List[str]:
   173	    if not isinstance(contributions, Sequence) or isinstance(contributions, (str, bytes)):
   174	        return []
   175	    names: List[str] = []
   176	    for contribution in contributions:
   177	        if not isinstance(contribution, Mapping):
   178	            continue
   179	        feature = str(contribution.get("feature") or "").strip()
   180	        if feature and feature not in names:
   181	            names.append(feature)
   182	    return names
   183	
   184	
   185	def _frame_features(introspection: Mapping[str, Any]) -> List[str]:
   186	    features: List[str] = []
   187	    for key in ("top_family_contributions", "top_embedding_contributions"):
   188	        for feature in _feature_names(introspection.get(key, [])):
   189	            if (
   190	                feature.startswith("frame:")
   191	                or feature.startswith("frame-candidate:")
   192	                or feature.startswith("flogic:")
   193	            ) and feature not in features:
   194	                features.append(feature)
   195	    return features
   196	
   197	
   198	def _priority_from_probability_gap(introspection: Mapping[str, Any]) -> float:
   199	    target_probability = float(introspection.get("target_probability") or 0.0)
   200	    predicted_probability = float(introspection.get("predicted_probability") or 0.0)
   201	    return max(0.0, predicted_probability - target_probability, 1.0 - target_probability)
   202	
   203	
   204	def _family_margin(introspection: Mapping[str, Any]) -> float:
   205	    try:
   206	        return float(introspection.get("family_margin") or 0.0)
   207	    except (TypeError, ValueError):
   208	        return 0.0
   209	
