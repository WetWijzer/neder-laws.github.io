+    def _extend_sparse_uscode_heading_segment(
+        self,
+        *,
+        candidate_segment: LegalSegment,
+        segments: Sequence[LegalSegment],
+        citation_section: str,
+    ) -> LegalSegment:
+        """Extend bare ``§1234.`` heading segments with adjacent heading text."""
+        if not citation_section:
+            return candidate_segment
+
+        normalized_candidate = self.normalize_text(candidate_segment.text)
+        candidate_tokens = _TOKEN_RE.findall(normalized_candidate.lower())
+        if len(candidate_tokens) >= 2:
+            return candidate_segment
+        if not (
+            self._starts_with_citation_section_reference(
+                normalized_candidate,
+                citation_section,
+            )
+            or self._contains_citation_section_reference(
+                normalized_candidate,
+                citation_section,
+            )
+        ):
+            return candidate_segment
+
+        candidate_index = -1
+        for index, segment in enumerate(segments):
+            if (
+                segment.start_char == candidate_segment.start_char
+                and segment.end_char == candidate_segment.end_char
+                and segment.text == candidate_segment.text
+            ):
+                candidate_index = index
+                break
+        if candidate_index < 0 or candidate_index + 1 >= len(segments):
+            return candidate_segment
+
+        next_segment = segments[candidate_index + 1]
+        next_text = self.normalize_text(next_segment.text)
+        if not next_text:
+            return candidate_segment
+        if self._starts_with_citation_section_reference(next_text, citation_section):
+            return candidate_segment
+
+        next_tokens = _TOKEN_RE.findall(next_text.lower())
+        if (
+            len(next_tokens) < 2
+            or len(next_tokens) > _USCODE_SECTION_HEADING_SHORT_MAX_TOKENS
+        ):
+            return candidate_segment
+        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(next_text):
+            return candidate_segment
+        if not self._looks_like_heading_without_section_reference(next_text):
+            return candidate_segment
+
+        combined_text = self.normalize_text(f"{normalized_candidate} {next_text}")
+        combined_tokens = _TOKEN_RE.findall(combined_text.lower())
+        if len(combined_tokens) > _USCODE_SECTION_HEADING_EXTENDED_MAX_TOKENS:
+            return candidate_segment
+
+        return LegalSegment(
+            text=combined_text,
+            start_char=candidate_segment.start_char,
+            end_char=next_segment.end_char,
+            role=candidate_segment.role,
+        )
