    87	class DeterministicModalCompiler:
    88	    """Compile legal text into modal IR with explainable frame selection."""
    89	
    90	    def __init__(
    91	        self,
    92	        config: Optional[ModalCompilerConfig] = None,
    93	        *,
    94	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
    95	        frame_selector: Optional[BM25FrameSelector] = None,
    96	    ) -> None:
    97	        self.config = config or ModalCompilerConfig()
    98	        self.registry = registry
    99	        self.parser = LegalModalParser(registry=registry)
   100	        self.encoder = SpaCyLegalEncoder(
   101	            model_name=self.config.spacy_model_name,
   102	            registry=registry,
   103	        )
   104	        self.ir_compiler = SpaCyModalIRCompiler()
   105	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   106	
   107	    def compile(
   108	        self,
   109	        text: str,
   110	        *,
   111	        document_id: Optional[str] = None,
   112	        citation: Optional[str] = None,
   113	        source: str = "legal_text",
   114	    ) -> ModalCompilationResult:
   115	        """Compile text into modal IR using deterministic rules only."""
   116	        normalized_text = self.parser.normalize_text(text)
   117	        backend = self.config.parser_backend.lower().strip()
   118	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   119	            text,
   120	            document_id=document_id,
   121	            citation=citation,
   122	            source=source,
   123	        )
   124	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   125	            modal_ir = self.parser.parse(
   126	                text,
   127	                document_id=document_id or encoding.document_id,
   128	                citation=citation,
   129	                source=source,
   130	            )
   131	            parser_name = "legal_modal_parser_v1"
   132	        else:
   133	            modal_ir = self.ir_compiler.compile(encoding)
   134	            parser_name = "spacy_modal_codec_v1"
   135	
   136	        frame_selections = self.frame_selector.rank(
   137	            normalized_text,
   138	            top_k=self.config.top_k_frames,
   139	            domain=self.config.frame_domain,
   140	        )
   141	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   142	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   143	        ambiguities = [
   144	            *self._formula_ambiguities(modal_ir),
   145	            *self._frame_ambiguities(frame_selections),
   146	        ]
   147	        if normalized_text and not modal_ir.formulas:
   148	            ambiguities.append(
   149	                ModalCompilationAmbiguity(
   150	                    ambiguity_type="missing_modal_formula",
   151	                    message="No deterministic modal formula was produced for non-empty text.",
   152	                    severity="requires_rule",
   153	                )
   154	            )
   155	
   156	        modal_ir = self._attach_metadata(
   157	            modal_ir,
   158	            frame_selections,
   159	            parser_name=parser_name,
   160	            selected_frame=selected_frame,
   161	            ambiguity_count=len(ambiguities),
   162	            encoding=encoding,
   163	        )
   164	        return ModalCompilationResult(
   165	            modal_ir=modal_ir,
   166	            parser_name=parser_name,
   167	            normalized_text=normalized_text,
   168	            frame_candidates=frame_candidates,
   169	            selected_frame=selected_frame,
   170	            ambiguities=ambiguities,
   171	            encoding=encoding,
   172	            metadata={
   173	                "ambiguity_count": len(ambiguities),
   174	                "deterministic_compiler": "modal_compiler_v1",
   175	                "frame_selector": "bm25_v1",
   176	                "llm_call_count": 0,
   177	                "parser_backend": self.config.parser_backend,
   178	            },
   179	        )
   180	
   181	    def _attach_metadata(
   182	        self,
   183	        modal_ir: ModalIRDocument,
   184	        frame_selections: Sequence[FrameSelection],
   185	        *,
   186	        parser_name: str,
   187	        selected_frame: Optional[str],
   188	        ambiguity_count: int,
   189	        encoding: SpaCyLegalEncoding,
   190	    ) -> ModalIRDocument:
   191	        frame_candidates = [
   192	            ModalIRFrame(
   193	                frame_id=selection.frame.frame_id,
   194	                score=selection.score,
   195	                matched_terms=list(selection.matched_terms),
   196	                explanation=selection.explanation,
   197	            )
   198	            for selection in frame_selections
   199	        ]
   200	        metadata = {
   201	            **modal_ir.metadata,
   202	            "ambiguity_count": ambiguity_count,
   203	            "deterministic_compiler": "modal_compiler_v1",
   204	            "deterministic_parser": parser_name,
   205	            "frame_selector": "bm25_v1",
   206	            "llm_call_count": 0,
   207	            "modal_family_counts": encoding.modal_family_counts(),
   208	            "selected_frame": selected_frame,
   209	        }
   210	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
   211	
   212	    def _formula_ambiguities(
   213	        self,
   214	        modal_ir: ModalIRDocument,
   215	    ) -> List[ModalCompilationAmbiguity]:
   216	        by_span: Dict[tuple[int, int], List[str]] = {}
   217	        for formula in modal_ir.formulas:
   218	            span = (formula.provenance.start_char, formula.provenance.end_char)
   219	            candidate = (
   220	                f"{formula.formula_id}:{formula.operator.family}:"
   221	                f"{formula.operator.system}:{formula.operator.symbol}"
   222	            )
   223	            by_span.setdefault(span, []).append(candidate)
   224	
   225	        ambiguities: List[ModalCompilationAmbiguity] = []
   226	        for span, candidates in sorted(by_span.items()):
   227	            families = {candidate.split(":")[1] for candidate in candidates}
   228	            if len(candidates) > 1 and len(families) > 1:
   229	                ambiguities.append(
   230	                    ModalCompilationAmbiguity(
   231	                        ambiguity_type="multi_family_same_span",
   232	                        message="Multiple modal families were compiled from the same text span.",
   233	                        candidate_ids=sorted(candidates),
   234	                        metadata={"span": list(span)},
   235	                    )
   236	                )
   237	        return ambiguities
   238	
   239	    def _frame_ambiguities(
   240	        self,
   241	        frame_selections: Sequence[FrameSelection],
   242	    ) -> List[ModalCompilationAmbiguity]:
   243	        if len(frame_selections) < 2:
   244	            return []
   245	        first, second = frame_selections[0], frame_selections[1]
   246	        margin = float(first.score) - float(second.score)
   247	        if margin > self.config.frame_score_margin:
   248	            return []
   249	        return [
   250	            ModalCompilationAmbiguity(
   251	                ambiguity_type="close_bm25_frame_scores",
   252	                message="Top ontology frame choices are close enough to require review.",
   253	                candidate_ids=[first.frame.frame_id, second.frame.frame_id],
   254	                metadata={
   255	                    "margin": round(margin, 6),
   256	                    "top_score": first.score,
   257	                    "runner_up_score": second.score,
   258	                },
   259	            )
   260	        ]
   261	
   262	
   263	__all__ = [
   264	    "DeterministicModalCompiler",
   265	    "ModalCompilationAmbiguity",
   266	    "ModalCompilationResult",
   267	    "ModalCompilerConfig",
   268	]

