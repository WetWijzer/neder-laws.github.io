            SpaCyTokenFeature(
                text=token.text,
                lemma=(token.lemma_ or token.lower_).lower(),
                lower=token.lower_,
                pos=token.pos_,
                dep=token.dep_,
                start_char=token.idx,
                end_char=token.idx + len(token.text),
                is_stop=bool(token.is_stop),
                is_alpha=bool(token.is_alpha),
