+            continue
+        emitted.add(marker)
+        triples.append(
+            {
+                "subject": subject,
+                "predicate": predicate,
+                "object": value,
+            }
+        )
+
+
+def _statutory_scope_entries(text: str) -> List[tuple[str, str]]:
+    normalized = _clean_non_empty_string(text).replace("_", " ").lower()
