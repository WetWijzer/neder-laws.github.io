def _utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


AUTOENCODER_SGD_ROLE = "autoencoder_sgd"
PROGRAM_SYNTHESIS_ROLE = "program_synthesis"
