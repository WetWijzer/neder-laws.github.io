   275	
   276	class SpaCyModalIRCompiler:
   277	    """Compile spaCy legal encodings into canonical modal IR documents."""
   278	
   279	    def compile(self, encoding: SpaCyLegalEncoding) -> ModalIRDocument:
   280	        formulas: List[ModalIRFormula] = []
   281	        for index, cue in enumerate(encoding.cues, start=1):
   282	            sentence = _sentence_for_cue(encoding.sentences, cue)
   283	            tokens = _tokens_for_span(encoding.tokens, sentence.start_char, sentence.end_char)
   284	            predicate = _predicate_from_tokens(tokens, cue)
   285	            conditions, exceptions = _conditions_and_exceptions_from_sentence(
   286	                sentence.text
   287	            )
   288	            formulas.append(
   289	                ModalIRFormula(
   290	                    formula_id=f"{encoding.document_id}:spacy:f{index:04d}",
   291	                    operator=ModalIROperator(
   292	                        family=cue.family,
   293	                        system=cue.system,
   294	                        symbol=cue.symbol,
   295	                        label=cue.label,
   296	                    ),
   297	                    predicate=predicate,
   298	                    provenance=ModalIRProvenance(
   299	                        source_id=encoding.document_id,
   300	                        start_char=sentence.start_char,
   301	                        end_char=sentence.end_char,
   302	                        citation=encoding.citation,
   303	                    ),
   304	                    conditions=conditions,
   305	                    exceptions=exceptions,
   306	                    metadata={
   307	                        "cue": cue.cue,
   308	                        "cue_start_char": cue.start_char,
   309	                        "cue_end_char": cue.end_char,
   310	                        "encoder": "spacy_modal_codec_v1",
   311	                    },
   312	                )
   313	            )
   314	        return ModalIRDocument(
   315	            document_id=encoding.document_id,
   316	            source=encoding.source,
   317	            normalized_text=encoding.normalized_text,
   318	            formulas=formulas,
   319	            metadata={
   320	                "citation": encoding.citation,
   321	                "deterministic_parser": "spacy_modal_codec_v1",
   322	                "llm_call_count": 0,
   323	                "model_name": encoding.model_name,
   324	                "sentence_count": len(encoding.sentences),
   325	                "token_count": len(encoding.tokens),
   326	                "used_fallback_model": encoding.used_fallback_model,
   327	            },
   328	        )
   329	
   330	
   331	class SpaCyModalDecoder:
   332	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   333	
   334	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   335	        if dimensions < 1:
   336	            raise ValueError("dimensions must be >= 1")
   337	        vector = [0.0 for _ in range(dimensions)]
   338	        for feature in self._feature_stream(encoding):
   339	            slot, value = _feature_hash(feature, dimensions)
   340	            vector[slot] += value
   341	        norm = math.sqrt(sum(value * value for value in vector))
   342	        if norm == 0.0:
   343	            return vector
   344	        return [round(value / norm, 6) for value in vector]
   345	
   346	    def family_logits(
   347	        self,
   348	        encoding: SpaCyLegalEncoding,
   349	        *,
   350	        modal_families: Sequence[str],
   351	    ) -> Dict[str, float]:
   352	        logits = {family: -0.25 for family in modal_families}
   353	        counts = encoding.modal_family_counts()
   354	        for family, count in counts.items():
   355	            if family in logits:
   356	                logits[family] = 2.0 + float(count)
   357	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   358	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   359	        return logits
   360	

