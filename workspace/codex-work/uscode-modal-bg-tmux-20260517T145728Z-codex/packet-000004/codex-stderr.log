    42	    is_alpha: bool = False
    43	
    44	    def normalized(self) -> str:
    45	        return self.lemma or self.lower or self.text.lower()
    46	
    47	    def to_dict(self) -> Dict[str, Any]:
    48	        return {
    49	            "dep": self.dep,
    50	            "end_char": self.end_char,
    51	            "is_alpha": self.is_alpha,
    52	            "is_stop": self.is_stop,
    53	            "lemma": self.lemma,
    54	            "lower": self.lower,
    55	            "pos": self.pos,
    56	            "start_char": self.start_char,
    57	            "text": self.text,
    58	        }
