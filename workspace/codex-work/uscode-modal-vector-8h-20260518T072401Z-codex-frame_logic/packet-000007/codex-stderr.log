+def _selection_ontology_terms(
+    frame: FrameCandidate,
+    matched_terms: Sequence[str],
+) -> List[str]:
+    matched = [
+        token
+        for value in matched_terms
+        for token in _tokenize_ontology_text(value)
+    ]
+    terms = _unique_preserve_order([*matched, *frame.ontology_terms()])
+    return terms[:_MAX_SELECTION_ONTOLOGY_TERMS]
+
+
+def _tokenize_text(text: str) -> List[str]:
+    return [token.lower() for token in _TOKEN_RE.findall(str(text or ""))]
+
+
+def _tokenize_ontology_text(text: str) -> List[str]:
+    return [
+        token
+        for token in _tokenize_text(text)
+        if len(token) > 1 and token not in _ONTOLOGY_TERM_STOPWORDS
+    ]
+
+
+def _unique_preserve_order(values: Iterable[str]) -> List[str]:
+    seen: set[str] = set()
+    result: List[str] = []
+    for value in values:
+        cleaned = str(value or "").strip().lower()
+        if not cleaned or cleaned in seen:
+            continue
+        seen.add(cleaned)
+        result.append(cleaned)
+    return result
+
