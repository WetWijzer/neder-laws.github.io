   777	        if not _USCODE_EDITORIAL_STATUS_HINT_RE.search(normalized):
   778	            return False
   779	        if self._contains_citation_section_reference(normalized, citation_section):
   780	            return True
   781	        if self._starts_with_citation_section_reference(normalized, citation_section):
   782	            return True
   783	        if normalized.startswith("repealed") or normalized.startswith("omitted") or normalized.startswith("reserved"):
   784	            previous = self.normalize_text(previous_segment_text).lower()
   785	            if self._contains_citation_section_reference(previous, citation_section):
