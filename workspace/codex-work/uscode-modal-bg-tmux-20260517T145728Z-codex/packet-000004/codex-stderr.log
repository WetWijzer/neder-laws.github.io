   268	class SpaCyModalIRCompiler:
   269	    """Compile spaCy legal encodings into canonical modal IR documents."""
   270	
   271	    def compile(self, encoding: SpaCyLegalEncoding) -> ModalIRDocument:
   272	        formulas: List[ModalIRFormula] = []
   273	        for index, cue in enumerate(encoding.cues, start=1):
   274	            sentence = _sentence_for_cue(encoding.sentences, cue)
   275	            tokens = _tokens_for_span(encoding.tokens, sentence.start_char, sentence.end_char)
   276	            predicate = _predicate_from_tokens(tokens, cue)
   277	            formulas.append(
   278	                ModalIRFormula(
   279	                    formula_id=f"{encoding.document_id}:spacy:f{index:04d}",
   280	                    operator=ModalIROperator(
   281	                        family=cue.family,
   282	                        system=cue.system,
   283	                        symbol=cue.symbol,
   284	                        label=cue.label,
   285	                    ),
   286	                    predicate=predicate,
   287	                    provenance=ModalIRProvenance(
   288	                        source_id=encoding.document_id,
   289	                        start_char=sentence.start_char,
   290	                        end_char=sentence.end_char,
   291	                        citation=encoding.citation,
   292	                    ),
   293	                    metadata={
   294	                        "cue": cue.cue,
   295	                        "cue_start_char": cue.start_char,
   296	                        "cue_end_char": cue.end_char,
   297	                        "encoder": "spacy_modal_codec_v1",
   298	                    },
   299	                )
   300	            )
   301	        return ModalIRDocument(
   302	            document_id=encoding.document_id,
   303	            source=encoding.source,
   304	            normalized_text=encoding.normalized_text,
   305	            formulas=formulas,
   306	            metadata={
   307	                "citation": encoding.citation,
   308	                "deterministic_parser": "spacy_modal_codec_v1",
   309	                "llm_call_count": 0,
   310	                "model_name": encoding.model_name,
   311	                "sentence_count": len(encoding.sentences),
   312	                "token_count": len(encoding.tokens),
   313	                "used_fallback_model": encoding.used_fallback_model,
   314	            },
   315	        )
