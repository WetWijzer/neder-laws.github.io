   103	@dataclass(frozen=True)
   104	class SpaCyLegalEncoding:
   105	    """Serializable spaCy-derived intermediate encoding for one legal text."""
   106	
   107	    document_id: str
   108	    text: str
   109	    normalized_text: str
   110	    tokens: List[SpaCyTokenFeature]
   111	    sentences: List[SpaCySentenceFeature]
   112	    cues: List[SpaCyModalCueFeature]
   113	    citation: Optional[str] = None
   114	    source: str = "legal_text"
   115	    model_name: str = ""
   116	    used_fallback_model: bool = False
   117	
   118	    def modal_family_counts(self) -> Dict[str, int]:
   119	        counts: Dict[str, int] = {}
   120	        for cue in self.cues:
   121	            counts[cue.family] = counts.get(cue.family, 0) + 1
   122	        return dict(sorted(counts.items()))
   123	
   124	    def to_dict(self) -> Dict[str, Any]:
   125	        return {
   126	            "citation": self.citation,
   127	            "cues": [cue.to_dict() for cue in self.cues],
   128	            "document_id": self.document_id,
   129	            "modal_family_counts": self.modal_family_counts(),
   130	            "model_name": self.model_name,
   131	            "normalized_text": self.normalized_text,
   132	            "sentences": [sentence.to_dict() for sentence in self.sentences],
   133	            "source": self.source,
   134	            "text": self.text,
   135	            "tokens": [token.to_dict() for token in self.tokens],
   136	            "used_fallback_model": self.used_fallback_model,
   137	        }
