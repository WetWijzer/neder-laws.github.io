  1070	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
  1071	    if not logits:
  1072	        return {}
  1073	    max_logit = max(float(value) for value in logits.values())
  1074	    exponentials = {
  1075	        name: math.exp(float(value) - max_logit)
  1076	        for name, value in logits.items()
  1077	    }
  1078	    total = sum(exponentials.values())
  1079	    if total == 0.0:
  1080	        uniform = 1.0 / len(exponentials)
  1081	        return {name: uniform for name in sorted(exponentials)}
  1082	    return {name: exponentials[name] / total for name in sorted(exponentials)}
