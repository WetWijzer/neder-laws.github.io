   575	def _prefixed_clause_phrases(segment_text: str, prefixes: Sequence[str]) -> List[str]:
   576	    normalized = _normalize(segment_text)
   577	    phrases: List[str] = []
   578	    for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
   579	        pattern = re.compile(rf"(?<!\w){re.escape(prefix)}(?!\w)", re.IGNORECASE)
   580	        for match in pattern.finditer(normalized):
   581	            fragment = normalized[match.start() :]
   582	            fragment = _CLAUSE_DELIMITER_RE.split(fragment, maxsplit=1)[0]
   583	            phrase = _normalized_clause_phrase(fragment)
   584	            if phrase and phrase not in phrases:
   585	                phrases.append(phrase)
   586	    return phrases
   587	
   588	
   589	def _normalized_clause_phrase(text: str) -> str:
   590	    tokens = _CLAUSE_TOKEN_RE.findall(text.lower())
   591	    return " ".join(tokens[:18]).strip()
