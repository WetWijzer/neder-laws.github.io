_FRAME_ONTOLOGY_POSITIONED_VALUE_RE = re.compile(
    r"^\s*\d+\s*:\s*(?P<value>.+?)\s*$"
)
_FRAME_ONTOLOGY_POSITIONED_VALUE_LEGACY_SLOT_RE = re.compile(
    r"^\s*\d+\s*_\s*(?P<value>.+?)\s*$"
)
