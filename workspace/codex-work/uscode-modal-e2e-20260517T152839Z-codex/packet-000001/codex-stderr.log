+            fragment = _CLAUSE_DELIMITER_RE.split(fragment, maxsplit=1)[0]
+            phrase = _normalized_clause_phrase(fragment)
+            if phrase and phrase not in phrases:
+                phrases.append(phrase)
+    return phrases
