+def test_modal_compiler_replays_sparse_heading_segments_for_42_1395w_5_3110_and_16_2204() -> None:
+    cases = [
+        (
+            "us-code-42-1395w-heading-segment",
+            "42 U.S.C. 1395w",
+            _USCODE_42_1395W_SPARSE_HEADING_TEXT,
