from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec, ModalLogicCodecConfig
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample

sections = [
    (\"22\", \"10006\"),
    (\"12\", \"5517\"),
    (\"31\", \"1106\"),
    (\"42\", \"1789.\"),
    (\"22\", \"5827\"),
    (\"30\", \"1304\"),
    (\"2\", \"2170\"),
    (\"2\", \"2026\"),
    (\"48\", \"2146.\"),
    (\"42\", \"15113.\"),
    (\"25\", \"3742\"),
    (\"46\", \"30908.\"),
]

codec = DeterministicModalLogicCodec(ModalLogicCodecConfig(parser_backend='spacy', embedding_dimensions=8))
for title, section in sections:
    sample = build_us_code_sample(title=title, section=section, text=f\"Sec. {section} The Secretary may transfer authority under section {section}.\")
    result = codec.encode(sample.text, document_id=sample.sample_id, citation=sample.citation, source=sample.source, source_embedding=sample.embedding_vector)
    terms = []
    if result.flogic_result:
        terms = result.flogic_result.metadata.get('frame_ontology_terms', [])
    matches = [t for t in terms if t.startswith(f\"{title}_\")]
    print(sample.sample_id, sample.citation, 'title_match_terms=', matches[:6], 'contains_target=', f\"{title}_{section.rstrip('.').lower()}\" in terms)
