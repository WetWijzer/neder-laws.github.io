   164	def load_hf_uscode_samples(
   165	    *,
   166	    repo_id: str = HF_USCODE_DATASET_ID,
   167	    laws_path: str = USCODE_LAWS_PARQUET,
   168	    embeddings_path: Optional[str] = None,
