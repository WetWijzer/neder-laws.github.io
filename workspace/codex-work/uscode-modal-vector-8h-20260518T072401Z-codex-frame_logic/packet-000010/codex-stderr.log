   280	
   281	def _informative_ontology_tokens(value: str) -> List[str]:
   282	    tokens = _ONTOLOGY_TERM_TOKEN_RE.findall(str(value or "").lower())
   283	    return [
   284	        token
   285	        for token in tokens
   286	        if _is_informative_ontology_token(token)
   287	    ]
   288	
   289	
   290	def _is_informative_ontology_token(token: str) -> bool:
   291	    if len(token) < 2:
   292	        return False
   293	    if token in _FRAME_ONTOLOGY_STOPWORDS:
   294	        return False
   295	    if token.isdigit():
   296	        return False
   297	    return any(character.isalpha() for character in token)
