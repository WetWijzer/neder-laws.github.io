   633	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   634	    """Return observed modal-family frequencies for multi-family legal clauses."""
   635	    families = [formula.operator.family for formula in modal_ir.formulas]
   636	    if not families:
   637	        return {ModalLogicFamily.HYBRID.value: 1.0}
   638	    counts: Dict[str, int] = {}
   639	    for family in families:
   640	        counts[family] = counts.get(family, 0) + 1

