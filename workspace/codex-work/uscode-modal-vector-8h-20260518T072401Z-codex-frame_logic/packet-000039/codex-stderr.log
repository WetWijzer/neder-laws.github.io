from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec, ModalLogicCodecConfig
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.frame_bm25_selector import is_frame_ontology_feature_key

samples = [
    (\"46\",\"60101.\",\"Sec. 60101. Transfers of authority under this chapter.\"),
    (\"2\",\"117j\",\"Sec. 117j. Agency may issue final order under this section.\"),
    (\"12\",\"548\",\"Sec. 548. Notice requirements and hearing rights.\"),
    (\"10\",\"2672\",\"Sec. 2672. Administrative hearing and appeal rights.\"),
    (\"42\",\"3231.\",\"Sec. 3231. Reserved and transferred authorities.\"),
    (\"49\",\"5902.\",\"Sec. 5902. Annual reports under subsection (a).\"),
    (\"26\",\"9038\",\"Sec. 9038. Commission shall administer benefits.\"),
    (\"38\",\"3674A\",\"Sec. 3674A. Secretary may provide payment assistance.\"),
    (\"42\",\"15022.\",\"Sec. 15022. Program shall remain in effect.\"),
    (\"10\",\"2409\",\"Sec. 2409. Contractor may file complaint.\"),
    (\"15\",\"78u\",\"Sec. 78u. Commission may bring action in court.\"),
    (\"22\",\"2877a\",\"Sec. 2877a. The Director may transfer authority.\"),
]
codec = DeterministicModalLogicCodec(ModalLogicCodecConfig(parser_backend=\"spacy\", embedding_dimensions=8))

for t,s,text in samples:
    sample = build_us_code_sample(title=t, section=s, text=text)
    result = codec.encode(sample.text, document_id=sample.sample_id, citation=sample.citation, source=sample.source)
    all_features = codec.feature_keys_for_sample(sample)
    frame_filtered = [f for f in all_features if is_frame_ontology_feature_key(f)]
    missed = [f for f in all_features if ('frame' in f.lower() or 'citation' in f.lower() or 'source_id' in f.lower()) and f not in frame_filtered]
    print('\\n', sample.sample_id)
    print('selected', result.selected_frame, 'terms', result.flogic_result.metadata.get('frame_ontology_terms')[:20])
    print('frame_filtered_count', len(frame_filtered), 'total', len(all_features), 'missed-like', len(missed))
    for m in missed[:20]:
        print('  MISS', m)
