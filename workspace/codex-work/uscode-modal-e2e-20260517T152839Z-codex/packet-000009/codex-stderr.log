)
compiled = compiler.compile(\"Before issuing a permit, the agency shall and must provide written notice.\")
a = find(compiled.ambiguities, 'conditional_scope_family_outvoted')
assert a.candidate_ids == ['deontic', 'conditional_normative']
assert a.metadata['predicted_family'] == 'deontic'
