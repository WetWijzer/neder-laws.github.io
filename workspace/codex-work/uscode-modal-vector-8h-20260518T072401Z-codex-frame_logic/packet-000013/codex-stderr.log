   141	
   142	def _hint(
   143	    sample_id: str,
   144	    *,
   145	    action: str,
   146	    target_component: str,
   147	    rationale: str,
   148	    priority: float,
   149	    evidence: Mapping[str, Any],
   150	) -> ModalProgramSynthesisHint:
   151	    evidence_dict = dict(evidence)
   152	    evidence_dict.setdefault("sample_id", sample_id)
   153	    payload = {
   154	        "action": action,
   155	        "evidence": evidence_dict,
   156	        "sample_id": sample_id,
   157	        "target_component": target_component,
   158	    }
   159	    digest = hashlib.sha256(
   160	        json.dumps(payload, ensure_ascii=True, sort_keys=True).encode("utf-8")
   161	    ).hexdigest()[:16]
   162	    return ModalProgramSynthesisHint(
   163	        hint_id=f"modal-synthesis-{digest}",
   164	        action=action,
   165	        target_component=target_component,
   166	        rationale=rationale,
   167	        priority=round(max(0.0, float(priority)), 12),
   168	        evidence=evidence_dict,
   169	    )
   170	
