  1018	    def _family_contributions_for(
  1019	        self,
  1020	        sample: LegalSample,
  1021	        feature_keys: Sequence[str],
  1022	        *,
  1023	        use_sample_memory: bool,
  1024	    ) -> List[AutoencoderFeatureContribution]:
  1025	        target = _target_family(sample)
  1026	        contributions: List[AutoencoderFeatureContribution] = []
  1027	        for feature in feature_keys:
  1028	            logits = self.state.feature_family_logits.get(feature, {})
  1029	            for family, value in logits.items():
  1030	                if family not in self.modal_families:
  1031	                    continue
  1032	                family_value = float(value) * self.feature_family_logit_scale
  1033	                contributions.append(
  1034	                    AutoencoderFeatureContribution(
  1035	                        feature=feature,
  1036	                        contribution_type="feature_family_logit",
  1037	                        family=family,
  1038	                        value=round(family_value, 12),
  1039	                        magnitude=round(abs(family_value), 12),
  1040	                        metadata={
  1041	                            "feature_family_logit_scale": self.feature_family_logit_scale,
  1042	                            "raw_value": round(float(value), 12),
  1043	                            "supports_target": family == target,
  1044	                        },
  1045	                    )
  1046	                )
  1047	        if use_sample_memory:
  1048	            for family, value in self.state.family_logits.get(sample.sample_id, {}).items():
  1049	                family_value = float(value)
  1050	                contributions.append(
  1051	                    AutoencoderFeatureContribution(
  1052	                        feature=f"sample-memory:{sample.sample_id}",
  1053	                        contribution_type="sample_family_logit",
  1054	                        family=family,
  1055	                        value=round(family_value, 12),
  1056	                        magnitude=round(abs(family_value), 12),
  1057	                        metadata={
  1058	                            "supports_target": family == target,
  1059	                        },
  1060	                    )
  1061	                )
  1062	        return sorted(
  1063	            contributions,
  1064	            key=lambda contribution: (
  1065	                -contribution.magnitude,
  1066	                contribution.feature,
  1067	                contribution.family or "",
  1068	            ),
  1069	        )
