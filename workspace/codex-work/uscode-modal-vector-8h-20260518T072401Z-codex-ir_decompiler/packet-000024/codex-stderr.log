        with pytest.raises(ValueError, match="convergence_threshold must be in"):
            config.validate()
        
        config = LogicSessionConfig(convergence_threshold=1.1)
        with pytest.raises(ValueError, match="convergence_threshold must be in"):
            config.validate()
    
