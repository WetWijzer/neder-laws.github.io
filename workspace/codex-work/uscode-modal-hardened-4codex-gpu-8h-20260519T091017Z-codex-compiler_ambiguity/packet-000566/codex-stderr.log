   666	    def _derive_explicit_adaptive_ambiguity_type(
   667	        self,
   668	        ambiguity: ModalCompilationAmbiguity,
   669	    ) -> Optional[str]:
   670	        """Resolve explicit adaptive ambiguity type from base metadata."""
   671	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   672	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   673	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   674	            return explicit_type
   675	
   676	        predicted_family, target_family, is_self_pair = (
   677	            self._adaptive_policy_families(ambiguity)
   678	        )
   679	        if is_self_pair and predicted_family and not target_family:
   680	            target_family = predicted_family
   681	        if not predicted_family or not target_family:
   682	            return None
   683	
   684	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   685	        if margin_direction not in {"contested", "outvoted"}:
   686	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   687	            try:
   688	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   689	            except (TypeError, ValueError):
   690	                margin_direction = "outvoted"
   691	        return self._adaptive_margin_explicit_type(
   692	            predicted_family,
   693	            target_family,
   694	            margin_direction,
   695	        )
