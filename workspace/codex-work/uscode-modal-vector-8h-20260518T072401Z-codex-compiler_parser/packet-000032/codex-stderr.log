        formula
        for formula in document.formulas
        if formula.operator.family == "deontic"
        and str(formula.metadata.get("cue", "")).lower() == "may"
    ]
    # `May 13, 2002` should not be parsed as permission cues.
    assert len(deontic_may_formulas) == 2
