   112	    def _explain(self, frame: FrameCandidate, matched_terms: Sequence[str], score: float) -> str:
   113	        if matched_terms:
   114	            return f"Frame {frame.frame_id} matched {', '.join(matched_terms)} with BM25 score {score:.3f}."
   115	        return f"Frame {frame.frame_id} had no lexical query matches; BM25 score {score:.3f}."
   116	
   117	    def _tokenize(self, text: str) -> List[str]:
   118	        return [token.lower() for token in _TOKEN_RE.findall(text)]
   119	
   120	    def _build_doc_freq(self, documents: Sequence[Sequence[str]]) -> Dict[str, int]:
   121	        frequencies: Dict[str, int] = {}
   122	        for document in documents:
   123	            for term in set(document):
   124	                frequencies[term] = frequencies.get(term, 0) + 1
   125	        return frequencies
