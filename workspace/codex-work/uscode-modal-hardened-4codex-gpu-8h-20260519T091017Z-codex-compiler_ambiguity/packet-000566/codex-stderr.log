   718	    def _adaptive_policy_families(
   719	        self,
   720	        ambiguity: ModalCompilationAmbiguity,
   721	    ) -> tuple[str, str, bool]:
   722	        """Resolve canonical predicted/target family names from ambiguity metadata."""
   723	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   724	        predicted_family = self._canonical_modal_family_name(
   725	            metadata.get("predicted_family")
   726	        )
   727	        target_family = self._canonical_modal_family_name(
   728	            metadata.get("target_family")
   729	        )
   730	        if not predicted_family and ambiguity.candidate_ids:
   731	            predicted_family = self._canonical_modal_family_name(
   732	                ambiguity.candidate_ids[0]
   733	            )
   734	        if not target_family and len(ambiguity.candidate_ids) > 1:
   735	            target_family = self._canonical_modal_family_name(
   736	                ambiguity.candidate_ids[1]
   737	            )
   738	
   739	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   740	        if "->" in policy_pair:
   741	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   742	            if not predicted_family:
   743	                predicted_family = self._canonical_modal_family_name(policy_predicted)
   744	            if not target_family:
   745	                target_family = self._canonical_modal_family_name(policy_target)
   746	
   747	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   748	            len(ambiguity.candidate_ids) == 1
   749	        )
   750	        return predicted_family, target_family, is_self_pair
