   199	def _iter_parquet_rows(
   200	    parquet_source: str | Path | BinaryIO,
   201	    *,
   202	    columns: Sequence[str],
   203	    batch_size: int,
   204	) -> Iterator[Mapping[str, Any]]:
   205	    try:
   206	        import pyarrow.parquet as pq
   207	    except ImportError as exc:  # pragma: no cover - exercised only without optional dependency
   208	        raise RuntimeError("pyarrow is required to read U.S. Code parquet samples") from exc
   209	
   210	    parquet_file = pq.ParquetFile(parquet_source)
   211	    available = set(parquet_file.schema_arrow.names)
   212	    selected = [column for column in columns if column in available]
   213	    for batch in parquet_file.iter_batches(batch_size=batch_size, columns=selected):
   214	        for row in batch.to_pylist():
   215	            yield row
