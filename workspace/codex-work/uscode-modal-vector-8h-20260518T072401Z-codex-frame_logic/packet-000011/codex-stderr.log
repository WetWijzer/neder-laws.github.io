+def _raw_frame_ontology_value_from_feature(feature: str) -> str:
+    for prefix in _FRAME_LINKED_FEATURE_PREFIXES:
+        if feature.startswith(prefix):
+            return feature[len(prefix) :].strip()
+    if not feature.startswith("flogic:"):
