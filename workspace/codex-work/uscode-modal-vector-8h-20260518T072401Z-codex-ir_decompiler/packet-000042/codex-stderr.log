     return "other"
 
 
+def _is_canonical_roman_numeral(value: str) -> bool:
+    cleaned = _clean_non_empty_string(value)
+    if not cleaned:
+        return False
+    return _STRICT_ROMAN_NUMERAL_RE.fullmatch(cleaned) is not None
