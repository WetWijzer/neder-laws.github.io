            "frame_ontology_terms": {
                selected_frame: {
                    "citations": [
                        "43 U.S.C. 641.",
                        "42 U.S.C. 295.",
                    ],
                    "sample_ids": [
                        "us-code-21-619-6c53879113090cdf",
