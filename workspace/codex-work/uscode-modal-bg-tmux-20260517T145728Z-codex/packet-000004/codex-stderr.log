   481	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   482	    """Return observed modal-family frequencies for multi-family legal clauses."""
   483	    families = [formula.operator.family for formula in modal_ir.formulas]
   484	    if not families:
   485	        return {ModalLogicFamily.HYBRID.value: 1.0}
   486	    counts: Dict[str, int] = {}
   487	    for family in families:
   488	        counts[family] = counts.get(family, 0) + 1
   489	    total = float(sum(counts.values()))
   490	    return {
   491	        family: count / total
   492	        for family, count in sorted(counts.items())
   493	    }
