  1388	def _overlap_aware_modal_family_counts(
  1389	    encoding: SpaCyLegalEncoding,
  1390	) -> Dict[str, float]:
  1391	    """Count family cues while collapsing nested same-family cue spans."""
  1392	    spans_by_family: Dict[str, List[tuple[int, int]]] = {}
  1393	    for cue in encoding.cues:
  1394	        start = int(cue.start_char)
  1395	        end = int(cue.end_char)
  1396	        if start < 0 or end <= start:
  1397	            continue
  1398	        spans_by_family.setdefault(cue.family, []).append((start, end))
  1399	
  1400	    counts: Dict[str, float] = {}
  1401	    for family, spans in spans_by_family.items():
  1402	        if not spans:
  1403	            continue
  1404	        unique_spans = sorted(set(spans))
  1405	        effective_spans: List[tuple[int, int]] = []
  1406	        for start, end in unique_spans:
  1407	            span_len = end - start
  1408	            covered_by_larger_span = False
  1409	            for other_start, other_end in unique_spans:
  1410	                if other_start == start and other_end == end:
  1411	                    continue
  1412	                other_len = other_end - other_start
  1413	                if (
  1414	                    other_start <= start
  1415	                    and other_end >= end
  1416	                    and other_len > span_len
  1417	                ):
  1418	                    covered_by_larger_span = True
  1419	                    break
  1420	            if not covered_by_larger_span:
  1421	                effective_spans.append((start, end))
  1422	        counts[family] = float(len(effective_spans))
  1423	    return counts
