   752	    def _adaptive_family_ranking_from_logits(
   753	        self,
   754	        encoding: SpaCyLegalEncoding,
   755	    ) -> List[Dict[str, float]]:
   756	        """Build fallback family ranking from deterministic decoder logits."""
   757	        modal_families = [family.value for family in ModalLogicFamily]
   758	        logits = self.decoder.family_logits(
   759	            encoding,
   760	            modal_families=modal_families,
   761	        )
   762	        if not logits:
   763	            return []
   764	        max_logit = max(float(value) for value in logits.values())
   765	        exp_by_family = {
   766	            family: math.exp(float(logit) - max_logit)
   767	            for family, logit in logits.items()
   768	        }
   769	        total = sum(exp_by_family.values())
   770	        if total <= 0.0:
   771	            return []
   772	        ranking: List[Dict[str, float]] = []
   773	        for family in sorted(
   774	            exp_by_family,
   775	            key=lambda key: (-exp_by_family[key], key),
   776	        ):
   777	            share_raw = exp_by_family[family] / total
   778	            ranking.append(
   779	                {
   780	                    "family": family,
   781	                    "count": 0,
   782	                    "logit": round(float(logits[family]), 6),
   783	                    "share_raw": share_raw,
   784	                    "share": round(share_raw, 6),
   785	                    "source": "logit_softmax_fallback",
   786	                }
   787	            )
   788	        return ranking
