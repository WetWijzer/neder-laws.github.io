   435	
   436	def _normalize(text: str) -> str:
   437	    return _WHITESPACE_RE.sub(" ", text).strip()
   438	
   439	
   440	def _document_id(normalized: str) -> str:
   441	    digest = hashlib.sha256(normalized.encode("utf-8")).hexdigest()[:16]
   442	    return f"spacy-legal-text-{digest}"
   443	
   444	
   445	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
   446	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
   447	    slot = int.from_bytes(digest[:4], "big") % dimensions
   448	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
   449	    magnitude = 0.5 + (digest[5] / 255.0)
   450	    return slot, sign * magnitude
   451	
   452	
   453	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
   454	    """Rank modal families by deterministic cue count and normalized share."""
   455	    counts = encoding.modal_family_counts()
   456	    total = sum(counts.values())
   457	    if total <= 0:
   458	        return []
   459	    ranking: List[Dict[str, float]] = []
   460	    for family, count in sorted(counts.items(), key=lambda item: (-item[1], item[0])):
   461	        ranking.append(
   462	            {
   463	                "family": family,
   464	                "count": int(count),
   465	                "share": round(float(count) / float(total), 6),
   466	            }
   467	        )
   468	    return ranking
   469	
   470	
   471	def modal_ambiguity_signals(encoding: SpaCyLegalEncoding) -> Dict[str, bool]:
   472	    """Return deterministic lexical/contextual flags used by ambiguity policy."""
   473	    condition_clauses = False
   474	    exception_clauses = False
   475	    for sentence in encoding.sentences:
   476	        if _prefixed_clause_phrases(sentence.text, _CONDITION_PREFIXES):
   477	            condition_clauses = True
   478	        if _prefixed_clause_phrases(sentence.text, _EXCEPTION_PREFIXES):
   479	            exception_clauses = True
   480	        if condition_clauses and exception_clauses:
   481	            break
   482	    token_terms = {
   483	        token.normalized()
   484	        for token in encoding.tokens
   485	        if token.is_alpha
   486	    }
   487	    cue_families = {cue.family for cue in encoding.cues}
   488	    frame_context = bool(token_terms & _FRAME_CONTEXT_TOKENS)
   489	    return {
   490	        "has_condition_clause": condition_clauses,
   491	        "has_exception_clause": exception_clauses,
   492	        "has_condition_or_exception_scope": condition_clauses or exception_clauses,
   493	        "has_frame_context": frame_context,
   494	        "has_frame_cue": ModalLogicFamily.FRAME.value in cue_families,
   495	    }
   496	
   497	
   498	def _unique_preserve_order(features: Iterable[str]) -> List[str]:
   499	    seen: set[str] = set()
   500	    result: List[str] = []
   501	    for feature in features:
   502	        if feature in seen:
   503	            continue
   504	        seen.add(feature)
   505	        result.append(feature)
   506	    return result
   507	
   508	
   509	def _sentence_for_cue(
   510	    sentences: Sequence[SpaCySentenceFeature],
   511	    cue: SpaCyModalCueFeature,
   512	) -> SpaCySentenceFeature:
   513	    for sentence in sentences:
   514	        if sentence.start_char <= cue.start_char < sentence.end_char:
   515	            return sentence
   516	    return SpaCySentenceFeature(text="", start_char=cue.start_char, end_char=cue.end_char)
   517	
   518	
   519	def _tokens_for_span(
   520	    tokens: Sequence[SpaCyTokenFeature],
   521	    start_char: int,
   522	    end_char: int,
   523	) -> List[SpaCyTokenFeature]:
   524	    return [
   525	        token
   526	        for token in tokens
   527	        if token.start_char < end_char and token.end_char > start_char
   528	    ]
   529	
   530	
   531	def _predicate_from_tokens(
   532	    tokens: Sequence[SpaCyTokenFeature],
   533	    cue: SpaCyModalCueFeature,
   534	) -> ModalIRPredicate:
   535	    after_cue = [
   536	        token.normalized()
   537	        for token in tokens
   538	        if token.start_char >= cue.end_char and token.is_alpha and not token.is_stop
   539	    ]
   540	    before_cue = [
   541	        token.normalized()
   542	        for token in tokens
   543	        if token.end_char <= cue.start_char and token.is_alpha and not token.is_stop
   544	    ]
   545	    predicate_terms = after_cue[:6] or before_cue[-6:] or [cue.label]
   546	    arguments = []
   547	    if before_cue:
   548	        arguments.append(f"actor:{'_'.join(before_cue[-4:])}")
   549	    if after_cue:
   550	        arguments.append(f"scope:{'_'.join(after_cue[:4])}")
   551	    return ModalIRPredicate(
   552	        name="_".join(predicate_terms),
   553	        arguments=arguments,
   554	        role=_role_for_cue(cue),
   555	    )
   556	
   557	
   558	def _role_for_cue(cue: SpaCyModalCueFeature) -> str:
   559	    if cue.family == ModalLogicFamily.CONDITIONAL_NORMATIVE.value:
   560	        return "condition"
   561	    if cue.family == ModalLogicFamily.TEMPORAL.value:
   562	        return "temporal_scope"
   563	    if cue.family == ModalLogicFamily.FRAME.value:
   564	        return "frame"
   565	    return "clause"
   566	
   567	
   568	def _conditions_and_exceptions_from_sentence(sentence_text: str) -> tuple[List[str], List[str]]:
   569	    return (
   570	        _prefixed_clause_phrases(sentence_text, _CONDITION_PREFIXES),
   571	        _prefixed_clause_phrases(sentence_text, _EXCEPTION_PREFIXES),
   572	    )
   573	
   574	
   575	def _prefixed_clause_phrases(segment_text: str, prefixes: Sequence[str]) -> List[str]:
   576	    normalized = _normalize(segment_text)
   577	    phrases: List[str] = []
   578	    for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
   579	        pattern = re.compile(rf"(?<!\w){re.escape(prefix)}(?!\w)", re.IGNORECASE)
   580	        for match in pattern.finditer(normalized):
   581	            fragment = normalized[match.start() :]
   582	            fragment = _CLAUSE_DELIMITER_RE.split(fragment, maxsplit=1)[0]
   583	            phrase = _normalized_clause_phrase(fragment)
   584	            if phrase and phrase not in phrases:
   585	                phrases.append(phrase)
   586	    return phrases
   587	
   588	
   589	def _normalized_clause_phrase(text: str) -> str:
   590	    tokens = _CLAUSE_TOKEN_RE.findall(text.lower())
   591	    return " ".join(tokens[:18]).strip()
