   647	
   648	def _deduplicated_ontology_entries(
   649	    entries: Iterable[tuple[str, int]]
   650	) -> List[tuple[str, int]]:
   651	    result: List[tuple[str, int]] = []
   652	    index_by_value: Dict[str, int] = {}
   653	    for value, priority in entries:
   654	        normalized_value = str(value or "").strip()
   655	        if not normalized_value:
   656	            continue
   657	        resolved_priority = int(priority)
   658	        existing_index = index_by_value.get(normalized_value)
   659	        if existing_index is None:
   660	            index_by_value[normalized_value] = len(result)
   661	            result.append((normalized_value, resolved_priority))
   662	            continue
   663	        existing_priority = result[existing_index][1]
   664	        if resolved_priority > existing_priority:
   665	            result[existing_index] = (normalized_value, resolved_priority)
   666	    return result
