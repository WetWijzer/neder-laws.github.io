   698	def decode_modal_ir_text(modal_ir: ModalIRDocument) -> str:
   699	    """Render a compact deterministic modal formula string for diagnostics."""
   700	    rendered = [modal_formula_to_text(formula) for formula in modal_ir.formulas]
   701	    return "; ".join(rendered)
   702	
   703	
   704	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   705	    """Render one modal IR formula into a stable formula-like string."""
   706	    arguments = ", ".join(formula.predicate.arguments)
   707	    predicate = formula.predicate.name
   708	    if arguments:
   709	        predicate = f"{predicate}({arguments})"
   710	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
   711	
   712	
   713	def target_family_for_modal_ir(modal_ir: ModalIRDocument) -> str:
   714	    """Return the training target family used for cross-entropy diagnostics."""
   715	    if not modal_ir.formulas:
   716	        return ModalLogicFamily.HYBRID.value
   717	    return modal_ir.formulas[0].operator.family
