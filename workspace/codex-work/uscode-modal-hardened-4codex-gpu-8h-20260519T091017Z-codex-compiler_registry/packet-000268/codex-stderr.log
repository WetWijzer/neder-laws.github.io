  2688	def _frame_logit_bonus(signals: Mapping[str, bool]) -> float:
  2689	    """Return deterministic frame-family logit bonus from structural signals."""
  2690	    explicit_conditional_scope = _has_explicit_conditional_scope(signals)
  2691	    has_editorial_or_direct_frame_signal = bool(
  2692	        signals.get("has_frame_scope_phrase")
  2693	        or signals.get("has_frame_editorial_scope_phrase")
  2694	        or signals.get("has_frame_cue")
  2695	    )
  2696	    has_non_frame_scope_competition = bool(
  2697	        signals.get("has_deontic_scope")
  2698	        or signals.get("has_deontic_cue")
  2699	        or signals.get("has_temporal_scope")
  2700	        or signals.get("has_temporal_scope_phrase")
  2701	        or signals.get("has_temporal_within_scope")
  2702	        or explicit_conditional_scope
  2703	    )
  2704	    bonus = 0.0
  2705	    if bool(signals.get("has_frame_context")):
  2706	        frame_context_bonus = 0.6
  2707	        if (
  2708	            not has_editorial_or_direct_frame_signal
  2709	            and has_non_frame_scope_competition
  2710	        ):
  2711	            frame_context_bonus = 0.35
  2712	        bonus += frame_context_bonus
  2713	    if bool(signals.get("has_statutory_scope_reference")):
  2714	        statutory_bonus = 0.8
  2715	        if (
  2716	            not has_editorial_or_direct_frame_signal
  2717	            and (
  2718	                explicit_conditional_scope
  2719	                or bool(signals.get("has_deontic_scope"))
  2720	                or bool(signals.get("has_temporal_scope"))
  2721	            )
