+def _alnum_segments(token: str) -> List[str]:
+    cleaned = _clean_text(token).lower()
+    if not cleaned:
+        return []
+    return [segment for segment in re.findall(r"[a-z]+|\d+", cleaned) if segment]
+
+
+def _alnum_segment_kind(value: str) -> str:
+    cleaned = _clean_text(value)
+    if not cleaned:
+        return "other"
+    if cleaned.isdigit():
+        return "numeric"
+    if cleaned.isalpha():
+        return "alpha"
+    return "other"
+
