    39	def test_parser_compiles_cues_to_modal_ir_with_provenance() -> None:
    40	    parser = LegalModalParser()
    41	
    42	    document = parser.parse(
    43	        "The agency must provide notice before termination.",
    44	        document_id="sample-doc",
    45	        source="us_code",
    46	        citation="5 U.S.C. 552",
    47	    )
    48	
    49	    assert document.document_id == "sample-doc"
    50	    assert document.metadata["deterministic_parser"] == "legal_modal_parser_v1"
    51	    assert document.formulas
    52	    assert document.formulas[0].operator.family == "deontic"
    53	    assert document.formulas[0].provenance.citation == "5 U.S.C. 552"
    54	    assert document.formulas[0].predicate.name.startswith("provide_notice")
    55	    assert document.canonical_hash() == document.canonical_hash()
    56	
