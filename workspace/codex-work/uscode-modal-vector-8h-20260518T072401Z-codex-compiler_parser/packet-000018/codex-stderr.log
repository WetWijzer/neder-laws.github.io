   826	    def _uscode_statement_hint(self, normalized_segment_text: str) -> str:
   827	        lowered = normalized_segment_text.lower()
   828	        if "sense of the congress" in lowered:
   829	            return "sense_of_congress"
   830	        if "purpose of this" in lowered:
   831	            return "purpose_clause"
   832	        if "there is established" in lowered or "there are established" in lowered:
   833	            return "establishment_clause"
   834	        return "declarative_clause"
