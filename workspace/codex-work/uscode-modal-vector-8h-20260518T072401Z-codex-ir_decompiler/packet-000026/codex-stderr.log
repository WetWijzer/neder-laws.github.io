+                ("citation_section_range_start", range_start),
+                ("citation_section_range_end", range_end),
+                ("citation_section_range_connector", range_connector),
+            ]
+        )
     component_shapes: List[str] = []
     numeric_component_count = 0
     suffix_component_count = 0

