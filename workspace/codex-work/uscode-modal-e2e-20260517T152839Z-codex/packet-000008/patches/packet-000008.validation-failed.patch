+def test_parser_emits_uscode_fallback_formula_when_no_modal_cues_match() -> None:
+    parser = LegalModalParser()
+
+    document = parser.parse(
+        "Criminal justice assistance and coordination.",
+        citation="42 U.S.C. 3731.",
+        source="us_code",
+    )
+
+    assert document.formulas
+    fallback = document.formulas[0]
+    assert fallback.operator.family == "frame"
+    assert fallback.metadata["cue"] == "__uscode_heading_fallback__"
+    assert fallback.predicate.name.startswith("criminal_justice_assistance")
+
