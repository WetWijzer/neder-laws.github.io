from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_autoencoder import AdaptiveModalAutoencoder
from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec

sample = build_us_code_sample(title='5', section='552', text='The agency must provide notice and a hearing before a final order.')
codec = DeterministicModalLogicCodec()
auto = AdaptiveModalAutoencoder(feature_codec=codec)
# apply todos to create contributions
Todo = type('Todo', (), {})
t1 = Todo(); t1.action='improve_modal_family_classifier'; t1.loss_name='cross_entropy_loss'; t1.sample_ids=[sample.sample_id]; t1.todo_id='x1'
t2 = Todo(); t2.action='improve_encoder_decoder_reconstruction'; t2.loss_name='cosine_loss'; t2.sample_ids=[sample.sample_id]; t2.todo_id='x2'
auto.apply_todos([t1,t2], {sample.sample_id: sample}, learning_rate=0.5)
ins = auto.introspect_sample(sample)
print('focus', ins.synthesis_focus)
print('top_family_features:')
for c in ins.top_family_contributions[:15]:
    print(c.feature, c.family, c.value)
print('top_embed_features:')
for c in ins.top_embedding_contributions[:20]:
    print(c.feature, c.metadata.get('alignment_with_residual'))
