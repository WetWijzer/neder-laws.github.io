)
_SECTION_HEADING_TAIL_SPLIT_RE = re.compile(r"[.;:\n]")
_STATUTORY_SCOPE_UNITS: tuple[str, ...] = (
    "subparagraph",
    "subsection",
    "subclause",
    "subchapter",
    "subdivision",
    "subpart",
    "subtitle",
    "subitem",
