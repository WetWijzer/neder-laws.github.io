   313	def modal_text_token_similarity(left: str, right: str) -> float:
   314	    """Return deterministic token-set F1 similarity for reconstruction checks."""
   315	    left_tokens = set(_tokenize_for_similarity(left))
   316	    right_tokens = set(_tokenize_for_similarity(right))
   317	    if not left_tokens and not right_tokens:
   318	        return 1.0
   319	    if not left_tokens or not right_tokens:
   320	        return 0.0
   321	    overlap = len(left_tokens & right_tokens)
   322	    if overlap == 0:
   323	        return 0.0
   324	    precision = overlap / len(right_tokens)
   325	    recall = overlap / len(left_tokens)
   326	    return round((2.0 * precision * recall) / (precision + recall), 6)
