   502	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   503	    """Return observed modal-family frequencies for multi-family legal clauses."""
   504	    families = [formula.operator.family for formula in modal_ir.formulas]
   505	    if not families:
   506	        return {ModalLogicFamily.HYBRID.value: 1.0}
   507	    counts: Dict[str, int] = {}
   508	    for family in families:
   509	        counts[family] = counts.get(family, 0) + 1
   510	    total = float(sum(counts.values()))
   511	    return {
   512	        family: count / total
   513	        for family, count in sorted(counts.items())
   514	    }
