;\n}\nh1, h2, h3 {\nfont-weight : bold;\n}\nh5, h6 {\nmargin-top: 2em;\n}\nh1.title-no, h1.title-name {\ncolor: #800000;\n}\nh2.chap-no, h2.chap-name {\n/* nothing special */\n}\nh3.part-name {\nmargin-top: 0.5em;\n}\nh3.part-no {\nmargin-top: 2em;\n}\nh4.chap_toc_hd {\nfont-weight: bold;\nmargin: 1.5em 0em 1em 0em;\ntext-align: left;\n}\nh4.subpart-name {\nfont-weight: bold;\nmargin-top: 0.5em;\n}\nh4.subpart-no {\nfont-weight: bold;\nmargin-top: 2em;\n}\n/* HORIZONTAL RULES */\nhr.titles_pg_bar {\nbackground-color: #a0a0a0;\nborder-width: 0;\ncolor: #a0a0a0;\nheight: .5em;\nmargin: 1em 0em;\nwidth: 100%;\n}\nhr.chaps_pg_bar {\nbackground-color: #8b0000;\nborder-width: 0;\ncolor: #8b0000;\nheight: .8em;\nmargin: .5em 0em;\nwidth: 100%;\n}\nhr.titles_toc_spcr {\nbackground-color: #ffcc00;\nborder-width: 0;\ncolor: #ffcc00;\nheight: 1em;\nmargin: 0.1em .5em;\ntext-align: left;\nvertical-align: top;\nwidth: 150px;\n}\n/* IMAGES */\nimg.center {\ndisplay: block;\nmargin-left: auto;\nmargin-right: auto;\n}\n/* PARAGRAPHS */\np {\nfont-size : 1em;\nfont-style : normal;\nfont-variant : normal;\nfont-weight : normal;\nline-height : 1.2;\nmargin : 1em 0em 0em 0em;\ntext-align : justify;\ntext-justify:distribute;\ntext-decoration : none;\ntext-indent: 1em;\n}\np.annotation, p.annotation-first {\ncolor: #ff3333;\n}\np.cross-ref, p.cross-ref-first {\ncolor: #009900;\n}\np.front-note, p.front-note-first {\ncolor : #ff6600;\n}\np.history, p.history-first {\ncolor : #9900FF;\n}\np.source, p.source-first {\ncolor : #996600;\n}\np.Form-center, p.Text-center, p.Form-head, p.lesser-head {\ntext-align : center;\ntext-indent: 0em;\n}\np.Form-head, p.lesser-head {\nmargin-top: 2em;\n}\np.Form-left, p.Text-left {\ntext-align : justify;\ntext-indent: 0em;\n}\np.Text-left1 {\ntext-align : justify;\ntext-indent: 0em;\nmargin-top: 0em;\n}\np.Form-right {\ntext-align : right;\ntext-indent: 0em;\n}\np.tb, p.tb-left, p.tb-left1, p.tb-left2, p.tb-center, p.tb-right {\ntext-align : justify;\ntext