   302	def _cosine_similarity(a: List[float], b: List[float]) -> float:
   303	    """Compute cosine similarity between two vectors."""
   304	    if len(a) != len(b):
   305	        raise ValueError(
   306	            f"Embedding dimension mismatch: {len(a)} vs {len(b)}"
   307	        )
   308	    dot = sum(x * y for x, y in zip(a, b))
   309	    norm_a = math.sqrt(sum(x * x for x in a))
   310	    norm_b = math.sqrt(sum(y * y for y in b))
   311	    if norm_a == 0.0 or norm_b == 0.0:
   312	        return 0.0
   313	    return dot / (norm_a * norm_b)
