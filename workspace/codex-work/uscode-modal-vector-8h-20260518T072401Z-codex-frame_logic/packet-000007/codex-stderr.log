   704	def _is_grounded_value(
   705	    value: str,
   706	    *,
   707	    exact_values: set[str],
   708	    source_text: str,
   709	    modal_text: str,
   710	) -> bool:
   711	    if value in exact_values:
   712	        return True
   713	    normalized_value = _normalize_grounding_text(value)
   714	    if not normalized_value:
   715	        return False
   716	    exact_normalized = {_normalize_grounding_text(item) for item in exact_values}
   717	    if normalized_value in exact_normalized:
   718	        return True
   719	    return _contains_grounded_phrase(normalized_value, source_text) or _contains_grounded_phrase(
   720	        normalized_value,
   721	        modal_text,
   722	    )
