         assert fallback.provenance.citation == citation
 
 
+def test_spacy_compiler_replays_short_editorial_status_zero_formula_cases() -> None:
+    encoder = SpaCyLegalEncoder(model_name="definitely_missing_legal_model")
+    compiler = SpaCyModalIRCompiler()
+    cases = [
+        (
+            "us-code-15-8563-3b998304c368f8a4",
+            "15 U.S.C. 8563",
+            "\u00a78563. Renumbered.",
+            "renumbered",
+        ),
+        (
