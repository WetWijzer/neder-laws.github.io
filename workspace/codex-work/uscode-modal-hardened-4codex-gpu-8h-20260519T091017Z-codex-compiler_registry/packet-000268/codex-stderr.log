  2742	        structural_bonus += 1.2
  2743	    if bool(signals.get("has_frame_editorial_scope_phrase")):
  2744	        structural_bonus += 2.2
  2745	    if structural_bonus <= 0.0:
  2746	        return 0.0
  2747	    return structural_bonus * _GENERIC_FRAME_STRUCTURAL_BONUS_DEBIAS_FACTOR
