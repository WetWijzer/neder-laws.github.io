   102	class DeterministicModalCompiler:
   103	    """Compile legal text into modal IR with explainable frame selection."""
   104	
   105	    def __init__(
   106	        self,
   107	        config: Optional[ModalCompilerConfig] = None,
   108	        *,
   109	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   110	        frame_selector: Optional[BM25FrameSelector] = None,
   111	    ) -> None:
   112	        self.config = config or ModalCompilerConfig()
   113	        self.registry = registry
   114	        self.parser = LegalModalParser(registry=registry)
   115	        self.encoder = SpaCyLegalEncoder(
   116	            model_name=self.config.spacy_model_name,
   117	            registry=registry,
   118	        )
   119	        self.ir_compiler = SpaCyModalIRCompiler()
   120	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   121	
   122	    def compile(
   123	        self,
   124	        text: str,
   125	        *,
   126	        document_id: Optional[str] = None,
   127	        citation: Optional[str] = None,
   128	        source: str = "legal_text",
   129	    ) -> ModalCompilationResult:
   130	        """Compile text into modal IR using deterministic rules only."""
   131	        normalized_text = self.parser.normalize_text(text)
   132	        backend = self.config.parser_backend.lower().strip()
   133	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   134	            text,
   135	            document_id=document_id,
   136	            citation=citation,
   137	            source=source,
   138	        )
   139	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   140	            modal_ir = self.parser.parse(
   141	                text,
   142	                document_id=document_id or encoding.document_id,
   143	                citation=citation,
   144	                source=source,
   145	            )
   146	            parser_name = "legal_modal_parser_v1"
   147	        else:
   148	            modal_ir = self.ir_compiler.compile(encoding)
   149	            parser_name = "spacy_modal_codec_v1"
   150	
   151	        frame_selections = self.frame_selector.rank(
   152	            normalized_text,
   153	            top_k=self.config.top_k_frames,
   154	            domain=self.config.frame_domain,
   155	        )
   156	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   157	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   158	        ambiguities = [
   159	            *self._formula_ambiguities(modal_ir),
   160	            *self._family_ambiguities(
   161	                encoding,
   162	                modal_ir=modal_ir,
   163	                frame_selections=frame_selections,
   164	            ),
   165	            *self._frame_ambiguities(frame_selections),
   166	        ]
   167	        if normalized_text and not modal_ir.formulas:
   168	            ambiguities.append(
   169	                ModalCompilationAmbiguity(
   170	                    ambiguity_type="missing_modal_formula",
   171	                    message="No deterministic modal formula was produced for non-empty text.",
   172	                    severity="requires_rule",
   173	                )
   174	            )
   175	
   176	        modal_ir = self._attach_metadata(
   177	            modal_ir,
   178	            frame_selections,
   179	            parser_name=parser_name,
   180	            selected_frame=selected_frame,
   181	            ambiguity_count=len(ambiguities),
   182	            encoding=encoding,
   183	        )
   184	        return ModalCompilationResult(
   185	            modal_ir=modal_ir,
   186	            parser_name=parser_name,
   187	            normalized_text=normalized_text,
   188	            frame_candidates=frame_candidates,
   189	            selected_frame=selected_frame,
   190	            ambiguities=ambiguities,
   191	            encoding=encoding,
   192	            metadata={
   193	                "ambiguity_count": len(ambiguities),
   194	                "deterministic_compiler": "modal_compiler_v1",
   195	                "frame_selector": "bm25_v1",
   196	                "llm_call_count": 0,
   197	                "parser_backend": self.config.parser_backend,
   198	            },
   199	        )
