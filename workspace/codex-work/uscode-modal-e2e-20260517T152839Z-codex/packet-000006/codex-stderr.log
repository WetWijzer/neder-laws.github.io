   391	class SpaCyModalCodec:
   392	    """Convenience facade for encoder -> IR -> vector workflows."""
   393	
   394	    def __init__(
   395	        self,
   396	        *,
   397	        encoder: Optional[SpaCyLegalEncoder] = None,
   398	        compiler: Optional[SpaCyModalIRCompiler] = None,
   399	        decoder: Optional[SpaCyModalDecoder] = None,
   400	    ) -> None:
   401	        self.encoder = encoder or SpaCyLegalEncoder()
   402	        self.compiler = compiler or SpaCyModalIRCompiler()
   403	        self.decoder = decoder or SpaCyModalDecoder()
   404	
   405	    def encode_sample(self, sample: LegalSample) -> SpaCyLegalEncoding:
   406	        return self.encoder.encode(
   407	            sample.text,
   408	            document_id=sample.sample_id,
   409	            citation=sample.citation,
   410	            source=sample.source,
   411	        )
   412	
   413	    def compile_sample_ir(self, sample: LegalSample) -> ModalIRDocument:
   414	        return self.compiler.compile(self.encode_sample(sample))
   415	
   416	    def decode_sample_embedding(self, sample: LegalSample, *, dimensions: int) -> List[float]:
   417	        return self.decoder.decode_embedding(self.encode_sample(sample), dimensions=dimensions)
   418	
   419	    def family_logits_for_sample(
   420	        self,
   421	        sample: LegalSample,
   422	        *,
   423	        modal_families: Sequence[str],
   424	    ) -> Dict[str, float]:
   425	        return self.decoder.family_logits(
   426	            self.encode_sample(sample),
   427	            modal_families=modal_families,
   428	        )
   429	
   430	    def feature_keys_for_sample(self, sample: LegalSample) -> List[str]:
   431	        """Return text-derived features that can receive generalizable SGD updates."""
   432	        encoding = self.encode_sample(sample)
   433	        return _unique_preserve_order(self.decoder._feature_stream(encoding))
