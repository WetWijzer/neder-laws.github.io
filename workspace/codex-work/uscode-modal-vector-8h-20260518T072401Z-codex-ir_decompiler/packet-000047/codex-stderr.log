                )
                if index == 1:
                    components.append(("citation_section_primary_suffix_case", suffix_case))
                if index == total_parts:
                    components.append(("citation_section_terminal_suffix_case", suffix_case))
            suffix_kind = _suffix_kind(suffix)
            if suffix_kind:
