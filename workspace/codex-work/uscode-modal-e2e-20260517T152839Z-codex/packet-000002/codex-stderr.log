   188	    def _attach_metadata(
   189	        self,
   190	        modal_ir: ModalIRDocument,
   191	        frame_selections: Sequence[FrameSelection],
   192	        *,
   193	        parser_name: str,
   194	        selected_frame: Optional[str],
   195	        ambiguity_count: int,
   196	        encoding: SpaCyLegalEncoding,
   197	    ) -> ModalIRDocument:
   198	        frame_candidates = [
   199	            ModalIRFrame(
   200	                frame_id=selection.frame.frame_id,
   201	                score=selection.score,
   202	                matched_terms=list(selection.matched_terms),
   203	                explanation=selection.explanation,
   204	            )
   205	            for selection in frame_selections
   206	        ]
   207	        metadata = {
   208	            **modal_ir.metadata,
   209	            "ambiguity_count": ambiguity_count,
   210	            "deterministic_compiler": "modal_compiler_v1",
   211	            "deterministic_parser": parser_name,
   212	            "frame_selector": "bm25_v1",
   213	            "llm_call_count": 0,
   214	            "modal_family_counts": encoding.modal_family_counts(),
   215	            "selected_frame": selected_frame,
   216	        }
   217	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
