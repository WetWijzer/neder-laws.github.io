   519	    def feature_keys_for_sample(self, sample: LegalSample) -> List[str]:
   520	        """Return generalizable modal, frame, and F-logic features for SGD."""
   521	        codec_result = self.encode(
   522	            sample.text,
   523	            document_id=sample.sample_id,
   524	            citation=sample.citation,
   525	            source=sample.source,
   526	            source_embedding=sample.embedding_vector,
   527	        )
   528	        features: List[str] = list(self.decoder._feature_stream(codec_result.encoding))
   529	        features.extend(_slot_features(codec_result.decoded_modal_text))
   530	        if codec_result.selected_frame:
   531	            features.append(f"frame:{codec_result.selected_frame}")
   532	        frame_terms = _frame_ontology_terms_by_frame(codec_result.modal_ir)
   533	        for frame_id in sorted(frame_terms):
   534	            terms = frame_terms[frame_id]
   535	            for term in terms:
   536	                features.append(f"frame-term:{term}")
   537	                if frame_id == codec_result.selected_frame:
   538	                    features.append(f"selected-frame-term:{term}")
   539	        for candidate in codec_result.frame_candidates:
   540	            frame_id = candidate.get("frame_id")
   541	            if frame_id:
   542	                features.append(f"frame-candidate:{frame_id}")
   543	        for triple in codec_result.kg_triples:
