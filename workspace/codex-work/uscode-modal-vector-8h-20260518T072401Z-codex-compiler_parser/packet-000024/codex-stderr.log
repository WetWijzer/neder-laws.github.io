pf=pq.ParquetFile(path)
for batch in pf.iter_batches(columns=['title_number','section_number','text'], batch_size=20000):
    for r in batch.to_pylist():
        key=(str(r.get('title_number')).strip(),str(r.get('section_number')).strip())
        if key in need:
            rows[key]=str(r.get('text') or '')
for key in sorted(rows):
    t,s=key
    text=rows[key]
    print('---',t,s,'len',len(text))
    # produce python string literal wrapped to 88 chars tokens by sentence segments roughly
    import textwrap
    escaped=text.replace('\\\\','\\\\\\\\').replace('\"','\\\\\"')
    # Split by spaces into lines max 96
    words=escaped.split(' ')
    line=''; lines=[]
    for w in words:
        candidate=(line+' '+w).strip()
        if len(candidate)>96 and line:
            lines.append(line)
            line=w
        else:
            line=candidate
    if line:
        lines.append(line)
    print('(')
    for ln in lines:
        print(f'    \"{ln} \"')
    print(')')
