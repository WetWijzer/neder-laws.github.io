   860	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   861	    """Return whether a modal family encodes normative legal force."""
   862	    if isinstance(family, ModalLogicFamily):
   863	        resolved = family
   864	    else:
   865	        try:
   866	            resolved = ModalLogicFamily(str(family))
   867	        except ValueError:
   868	            return False
   869	    return resolved in NORMATIVE_MODAL_FAMILIES
   870	
