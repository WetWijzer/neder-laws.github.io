        if re.search(
            rf"\bsection\s+{section_pattern}(?={_USCODE_SECTION_REF_SUFFIX_RE})",
            normalized,
        ):
            return True
        if re.search(
            rf"\bsec\.?\s*{section_pattern}(?={_USCODE_SECTION_REF_SUFFIX_RE})",
            normalized,
        ):
