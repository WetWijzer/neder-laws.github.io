    33	def synthesis_hints_from_autoencoder_introspection(
    34	    introspection: Mapping[str, Any],
    35	) -> List[ModalProgramSynthesisHint]:
    36	    """Convert one introspection record into typed synthesis hints."""
    37	    sample_id = str(introspection.get("sample_id") or "")
    38	    focus = [str(value) for value in introspection.get("synthesis_focus", [])]
    39	    hints: List[ModalProgramSynthesisHint] = []
    40	
    41	    if "add_deterministic_parser_rule" in focus:
    42	        hints.append(
    43	            _hint(
    44	                sample_id,
    45	                action="add_deterministic_parser_rule",
    46	                target_component="modal.compiler",
    47	                rationale="The deterministic compiler produced no modal formulas for this sample.",
    48	                priority=1.0,
    49	                evidence={
    50	                    "target_family": introspection.get("target_family"),
    51	                    "predicted_family": introspection.get("predicted_family"),
    52	                },
    53	            )
    54	        )
    55	
    56	    if "refine_modal_family_cue_rules" in focus:
    57	        hints.append(
    58	            _hint(
    59	                sample_id,
    60	                action="refine_modal_family_cue_rules",
    61	                target_component="modal.compiler.registry",
    62	                rationale="Adaptive family evidence disagrees with, or is weak for, the typed modal family.",
    63	                priority=_priority_from_probability_gap(introspection),
    64	                evidence={
    65	                    "family_margin": introspection.get("family_margin"),
    66	                    "predicted_family": introspection.get("predicted_family"),
    67	                    "target_family": introspection.get("target_family"),
    68	                    "target_probability": introspection.get("target_probability"),
    69	                    "top_family_features": _feature_names(
    70	                        introspection.get("top_family_contributions", [])
    71	                    ),
    72	                },
    73	            )
    74	        )
    75	
    76	    if "refine_typed_ir_or_decompiler_slots" in focus:
    77	        hints.append(
    78	            _hint(
    79	                sample_id,
    80	                action="refine_typed_ir_or_decompiler_slots",
    81	                target_component="modal.ir_decompiler",
    82	                rationale="Embedding residuals point to information not well represented by the typed IR/decompiler.",
    83	                priority=float(introspection.get("reconstruction_loss") or 0.0),
    84	                evidence={
    85	                    "cosine_similarity": introspection.get("cosine_similarity"),
    86	                    "reconstruction_loss": introspection.get("reconstruction_loss"),
    87	                    "top_embedding_features": _feature_names(
    88	                        introspection.get("top_embedding_contributions", [])
    89	                    ),
    90	                },
    91	            )
    92	        )
    93	
    94	    if "audit_frame_logic_terms" in focus:
    95	        frame_features = _frame_features(introspection)
    96	        hints.append(
    97	            _hint(
    98	                sample_id,
    99	                action="audit_frame_logic_terms",
   100	                target_component="modal.frame_logic",
   101	                rationale="Frame-linked features influenced reconstruction or family scoring and should be audited as ontology terms.",
   102	                priority=max(0.05, float(introspection.get("reconstruction_loss") or 0.0)),
   103	                evidence={
   104	                    "frame_features": frame_features,
   105	                    "top_family_features": _feature_names(
   106	                        introspection.get("top_family_contributions", [])
   107	                    ),
   108	                },
   109	            )
   110	        )
   111	
   112	    if _family_margin(introspection) < 0.15:
   113	        hints.append(
   114	            _hint(
   115	                sample_id,
   116	                action="add_or_review_modal_ambiguity_policy",
   117	                target_component="modal.compiler.ambiguity",
   118	                rationale="The adaptive family margin is small, so the compiler should expose an explicit ambiguity.",
   119	                priority=0.15 - _family_margin(introspection),
   120	                evidence={
   121	                    "family_margin": introspection.get("family_margin"),
   122	                    "predicted_family": introspection.get("predicted_family"),
   123	                    "target_family": introspection.get("target_family"),
   124	                },
   125	            )
   126	        )
   127	
   128	    return sorted(hints, key=lambda hint: (-hint.priority, hint.hint_id))
   129	
   130	
   131	def synthesis_hints_from_autoencoder_introspections(
   132	    introspections: Iterable[Mapping[str, Any]],
   133	) -> List[ModalProgramSynthesisHint]:
   134	    """Convert multiple introspection records into deterministic hints."""
   135	    hints: Dict[str, ModalProgramSynthesisHint] = {}
   136	    for introspection in introspections:
   137	        for hint in synthesis_hints_from_autoencoder_introspection(introspection):
   138	            hints[hint.hint_id] = hint
   139	    return sorted(hints.values(), key=lambda hint: (-hint.priority, hint.hint_id))
   140	
   141	
   142	def _hint(
   143	    sample_id: str,
   144	    *,
   145	    action: str,
   146	    target_component: str,
   147	    rationale: str,
   148	    priority: float,
   149	    evidence: Mapping[str, Any],
   150	) -> ModalProgramSynthesisHint:
   151	    evidence_dict = dict(evidence)
   152	    evidence_dict.setdefault("sample_id", sample_id)
   153	    payload = {
   154	        "action": action,
   155	        "evidence": evidence_dict,
   156	        "sample_id": sample_id,
   157	        "target_component": target_component,
   158	    }
   159	    digest = hashlib.sha256(
   160	        json.dumps(payload, ensure_ascii=True, sort_keys=True).encode("utf-8")
   161	    ).hexdigest()[:16]
   162	    return ModalProgramSynthesisHint(
   163	        hint_id=f"modal-synthesis-{digest}",
   164	        action=action,
   165	        target_component=target_component,
   166	        rationale=rationale,
   167	        priority=round(max(0.0, float(priority)), 12),
   168	        evidence=evidence_dict,
   169	    )
   170	
   171	
   172	def _feature_names(contributions: Any) -> List[str]:
   173	    if not isinstance(contributions, Sequence) or isinstance(contributions, (str, bytes)):
   174	        return []
   175	    names: List[str] = []
   176	    for contribution in contributions:
   177	        if not isinstance(contribution, Mapping):
   178	            continue
   179	        feature = str(contribution.get("feature") or "").strip()
   180	        if feature and feature not in names:
   181	            names.append(feature)
   182	    return names
   183	
   184	
   185	def _frame_features(introspection: Mapping[str, Any]) -> List[str]:
   186	    features: List[str] = []
   187	    for key in ("top_family_contributions", "top_embedding_contributions"):
   188	        for feature in _feature_names(introspection.get(key, [])):
   189	            if (
   190	                feature.startswith("frame:")
   191	                or feature.startswith("frame-candidate:")
   192	                or feature.startswith("flogic:")
   193	            ) and feature not in features:
   194	                features.append(feature)
   195	    return features
   196	
   197	
   198	def _priority_from_probability_gap(introspection: Mapping[str, Any]) -> float:
   199	    target_probability = float(introspection.get("target_probability") or 0.0)
   200	    predicted_probability = float(introspection.get("predicted_probability") or 0.0)
   201	    return max(0.0, predicted_probability - target_probability, 1.0 - target_probability)
   202	
   203	
   204	def _family_margin(introspection: Mapping[str, Any]) -> float:
   205	    try:
   206	        return float(introspection.get("family_margin") or 0.0)
   207	    except (TypeError, ValueError):
   208	        return 0.0
   209	
   210	
   211	__all__ = [
   212	    "ModalProgramSynthesisHint",
   213	    "synthesis_hints_from_autoencoder_introspection",
   214	    "synthesis_hints_from_autoencoder_introspections",
   215	]

