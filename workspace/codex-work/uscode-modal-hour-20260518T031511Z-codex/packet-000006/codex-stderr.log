    95	    root_logger = logging.getLogger()
    96	    handlers = list(root_logger.handlers)
    97	    if not handlers:
    98	        return
    99	
   100	    unique_handlers = []
   101	    seen = set()
   102	
   103	    for handler in handlers:
   104	        stream = getattr(handler, "stream", None)
   105	        filename = getattr(handler, "baseFilename", None)
   106	        key = (type(handler), id(stream), filename)
   107	        if key in seen:
   108	            continue
   109	        seen.add(key)
   110	        unique_handlers.append(handler)
   111	
   112	    if unique_handlers != handlers:
   113	        root_logger.handlers = unique_handlers
