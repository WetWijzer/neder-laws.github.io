        bool(token_terms & _TEMPORAL_SCOPE_TOKENS)
        or bool(temporal_scope_phrase)
        or calendar_date_scope
    )
    deontic_scope = (
        bool(token_terms & _DEONTIC_SCOPE_TOKENS)
