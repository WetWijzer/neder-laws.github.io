   147	            "graph_import_report": dict(self.graph_import_report),
   148	            "llm_called": self.llm_called,
   149	            "llm_patch": self.llm_patch,
   150	            "llm_patch_validation": self.llm_patch_validation.to_dict()
   151	            if self.llm_patch_validation
   152	            else None,
   153	            "llm_response": self.llm_response,
