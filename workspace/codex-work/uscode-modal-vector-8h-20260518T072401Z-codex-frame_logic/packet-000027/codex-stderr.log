_ONTOLOGY_TERM_TOKEN_RE = re.compile(r"[A-Za-z0-9]+")
_FRAME_ONTOLOGY_PREDICATE_TOKEN_RE = re.compile(r"[^a-z0-9]+")
_FRAME_ONTOLOGY_POSITIONED_VALUE_RE = re.compile(
    r"^\s*\d+\s*:\s*(?P<value>.+?)\s*$"
)
_FRAME_ONTOLOGY_STOPWORDS = frozenset(
    {
        "a",
