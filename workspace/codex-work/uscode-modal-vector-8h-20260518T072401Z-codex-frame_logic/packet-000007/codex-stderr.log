   255	    program_synthesis_seeded_count: int = 0
   256	    validation_before: Optional[AutoencoderEvaluation] = None
   257	    validation_after: Optional[AutoencoderEvaluation] = None
   258	    created_at: str = field(default_factory=_utc_now)
   259	
   260	    @property
   261	    def cross_entropy_delta(self) -> float:
   262	        return self.before.cross_entropy_loss - self.after.cross_entropy_loss
   263	
   264	    @property
   265	    def cosine_similarity_delta(self) -> float:
   266	        return self.after.embedding_cosine_similarity - self.before.embedding_cosine_similarity
   267	
   268	    @property
   269	    def validation_cross_entropy_delta(self) -> Optional[float]:
   270	        if self.validation_before is None or self.validation_after is None:
   271	            return None
   272	        return self.validation_before.cross_entropy_loss - self.validation_after.cross_entropy_loss
   273	
   274	    @property
   275	    def validation_cosine_similarity_delta(self) -> Optional[float]:
   276	        if self.validation_before is None or self.validation_after is None:
   277	            return None
   278	        return (
   279	            self.validation_after.embedding_cosine_similarity
   280	            - self.validation_before.embedding_cosine_similarity
   281	        )
   282	
   283	    @property
   284	    def improved(self) -> bool:
   285	        if self.validation_before is not None and self.validation_after is not None:
   286	            return bool(
   287	                (self.validation_cross_entropy_delta or 0.0) > 0.0
   288	                or (self.validation_cosine_similarity_delta or 0.0) > 0.0
   289	            )
   290	        return self.cross_entropy_delta > 0.0 or self.cosine_similarity_delta > 0.0
   291	
   292	    def to_dict(self) -> Dict[str, Any]:
   293	        data = {
   294	            "after": self.after.to_dict(),
   295	            "applied_count": self.applied_count,
   296	            "applied_updates": list(self.applied_updates),
   297	            "autoencoder_claimed_count": self.autoencoder_claimed_count,
   298	            "before": self.before.to_dict(),
   299	            "claimed_count": self.claimed_count,
   300	            "claimed_open_count": self.claimed_open_count,
   301	            "completed_count": self.completed_count,
   302	            "completed_todo_ids": list(self.completed_todo_ids),
   303	            "cosine_similarity_delta": self.cosine_similarity_delta,
   304	            "created_at": self.created_at,
   305	            "cross_entropy_delta": self.cross_entropy_delta,
   306	            "failed_validation_count": self.failed_validation_count,
   307	            "failed_validation_todo_ids": list(self.failed_validation_todo_ids),
   308	            "improved": self.improved,
   309	            "iteration": self.iteration,
   310	            "loss_seeded_count": self.loss_seeded_count,
   311	            "pending_count": self.pending_count,
   312	            "program_synthesis_pending_count": self.program_synthesis_pending_count,
   313	            "program_synthesis_seeded_count": self.program_synthesis_seeded_count,
   314	            "seeded_count": self.seeded_count,
   315	            "worker_id": self.worker_id,
   316	        }
   317	        if self.validation_before is not None and self.validation_after is not None:
   318	            data.update(
   319	                {
   320	                    "validation_after": self.validation_after.to_dict(),
   321	                    "validation_before": self.validation_before.to_dict(),
   322	                    "validation_cosine_similarity_delta": self.validation_cosine_similarity_delta,
   323	                    "validation_cross_entropy_delta": self.validation_cross_entropy_delta,
   324	                }
   325	            )
   326	        return data
