        if len(body_tokens) < 2:
            return False
        if body_tokens[0] in _USCODE_HEADING_ONLY_ARTICLE_BANNED_SECOND_TOKENS:
            return False
        token_set = set(body_tokens)
        return bool(token_set & _USCODE_HEADING_ONLY_ARTICLE_NOUN_HINTS)

