   876	    def _decoded_for(self, sample: LegalSample, *, use_sample_memory: bool = True) -> List[float]:
   877	        stored = self.state.decoded_embeddings.get(sample.sample_id) if use_sample_memory else None
   878	        if stored is not None and len(stored) == len(sample.embedding_vector):
   879	            return list(stored)
   880	        base = self._base_decoded_for(sample)
   881	        adjustment = self._feature_embedding_adjustment(sample, dimensions=len(base))
   882	        return [
   883	            base_value + adjustment_value
   884	            for base_value, adjustment_value in zip(base, adjustment)
   885	        ]
   886	
   887	    def _base_decoded_for(self, sample: LegalSample) -> List[float]:
   888	        if self.feature_codec is not None and hasattr(
   889	            self.feature_codec,
   890	            "decode_sample_embedding",
   891	        ):
   892	            decoded = self.feature_codec.decode_sample_embedding(
   893	                sample,
   894	                dimensions=len(sample.embedding_vector),
   895	            )
   896	            if len(decoded) == len(sample.embedding_vector):
   897	                return [float(value) for value in decoded]
   898	        return [self.initial_embedding_scale * float(value) for value in sample.embedding_vector]
