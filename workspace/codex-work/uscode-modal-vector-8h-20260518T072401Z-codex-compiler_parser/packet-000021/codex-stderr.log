import hashlib
import pyarrow.parquet as pq
from pathlib import Path
import re

p=Path('/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet')
t=pq.read_table(p, columns=['title_number','section_number','citation_text','normalized_citation','text'])
rows=t.to_pylist()

def norm(s):
    return re.sub(r'\\s+',' ',(s or '')).strip()

def sid(title, section, text):
    n=norm(text)
    d=hashlib.sha256(f\"{title}:{section}:{n}\".encode('utf-8')).hexdigest()[:16]
    return f\"us-code-{title}-{section}-{d}\"

