+            "DEONTIC": 0.90,
+            "TEMPORAL": 0.10,
+        },
+    )
+
+    assert any(
+        ambiguity.ambiguity_type == "adaptive_family_margin_low"
+        and ambiguity.metadata["adaptive_predicted_family_source"]
