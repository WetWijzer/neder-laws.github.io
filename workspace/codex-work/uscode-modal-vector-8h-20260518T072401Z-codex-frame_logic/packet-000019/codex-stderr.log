   611	def decode_modal_ir_text(modal_ir: ModalIRDocument) -> str:
   612	    """Render a compact deterministic modal formula string for diagnostics."""
   613	    rendered = [modal_formula_to_text(formula) for formula in modal_ir.formulas]
   614	    return "; ".join(rendered)
   615	
   616	
   617	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   618	    """Render one modal IR formula into a stable formula-like string."""
   619	    arguments = ", ".join(formula.predicate.arguments)
   620	    predicate = formula.predicate.name
   621	    if arguments:
   622	        predicate = f"{predicate}({arguments})"
   623	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
