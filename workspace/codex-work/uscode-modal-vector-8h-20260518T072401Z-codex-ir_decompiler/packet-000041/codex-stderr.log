            rf"(?={_USCODE_SECTION_REF_SUFFIX_RE})",
            re.IGNORECASE,
        )
        best_segment: Optional[LegalSegment] = None
        best_score: Optional[tuple[int, int, int]] = None

        for match in reference_pattern.finditer(normalized_text):
            start = match.start()
