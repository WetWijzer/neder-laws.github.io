state=Path('/home/barberb/portland-laws.github.io/workspace/todo-queues/modal-policy-hour-20260509T205855Z.state.json')
obj=json.loads(state.read_text())
# recursively find dicts with hint_id values in target set
hint_ids={
'modal-synthesis-08264af15150e5e1','modal-synthesis-534badd5563e640e','modal-synthesis-99d952eb343ab153','modal-synthesis-fe20c836c79fe037','modal-synthesis-255695f382fc6002','modal-synthesis-500532cf6bf6a9ff','modal-synthesis-892f21f6f36a39f7','modal-synthesis-d77b41c1a42e343e','modal-synthesis-30f49597a7c372f1','modal-synthesis-3ee6336cd1af7a4c','modal-synthesis-6aa1ec02876847e8','modal-synthesis-e48c608edc56a764'}
found=[]

def walk(x,path='root'):
    if isinstance(x,dict):
        hid=x.get('hint_id')
        if isinstance(hid,str) and hid in hint_ids:
            found.append((path,x))
        # sometimes key itself is hint id
        for k,v in x.items():
            if isinstance(k,str) and k in hint_ids:
                found.append((path+f'.{k}',v if isinstance(v,dict) else {'value':v}))
            walk(v,path+f'.{k}')
    elif isinstance(x,list):
        for i,v in enumerate(x):
            walk(v,path+f'[{i}]')

walk(obj)
