diff --git a/tests/unit/optimizers/logic_theorem_optimizer/test_frame_bm25_selector.py b/tests/unit/optimizers/logic_theorem_optimizer/test_frame_bm25_selector.py
index 6f61f8e663a7029f37d5d8dfedb0261fa00f5979..234f70c70699573d76126e99d3661eb3b955d1fb
--- a/tests/unit/optimizers/logic_theorem_optimizer/test_frame_bm25_selector.py
