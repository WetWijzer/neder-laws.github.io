    assert compiler_required_adaptive_ambiguity_targets("frame") == (
        "conditional_normative",
        "deontic",
        "alethic",
        "epistemic",
        "temporal",
        "frame",
    )
    assert compiler_required_adaptive_ambiguity_targets("temporal") == (
        "deontic",
        "conditional_normative",
