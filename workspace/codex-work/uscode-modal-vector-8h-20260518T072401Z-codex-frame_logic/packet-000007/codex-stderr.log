+        if len(token) > 1 and token.lower() not in _FRAME_TERM_STOPWORDS
+    ]
+
+
+def _unique_preserve_order(values: Sequence[str]) -> List[str]:
+    seen: set[str] = set()
+    result: List[str] = []
+    for value in values:
+        if not value or value in seen:
+            continue
+        seen.add(value)
+        result.append(value)
+    return result
