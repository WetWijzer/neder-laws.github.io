+def test_modal_compiler_replays_packet_todo_heading_samples_with_leading_stopwords_for_13_303_12_326_and_16_467b() -> None:
+    cases = [
+        (
+            "us-code-13-303-bcfda0ce2292fef5",
+            "13 U.S.C. 303",
+            _USCODE_LEADING_STOPWORD_HEADING_TODO_TEXT,
+        ),
+        (
+            "us-code-12-326-cdc87a23656b98e3",
+            "12 U.S.C. 326",
+            _USCODE_LEADING_STOPWORD_HEADING_TODO_TEXT,
+        ),
+        (
+            "us-code-16-467b-4168eef88d7e96d0",
+            "16 U.S.C. 467b",
+            _USCODE_LEADING_STOPWORD_HEADING_TODO_TEXT,
+        ),
+    ]
+    for backend in ("regex", "spacy"):
+        compiler = DeterministicModalCompiler(
+            ModalCompilerConfig(
+                parser_backend=backend,
+                spacy_model_name="definitely_missing_legal_model",
+            )
+        )
+        for document_id, citation, text in cases:
+            compiled = compiler.compile(
+                text,
+                document_id=document_id,
+                citation=citation,
+                source="us_code",
+            )
+
+            assert compiled.modal_ir.formulas
+            assert all(
+                ambiguity.ambiguity_type != "missing_modal_formula"
+                for ambiguity in compiled.ambiguities
+            )
+            fallback = compiled.modal_ir.formulas[-1]
+            assert fallback.operator.family == "frame"
+            assert fallback.metadata["cue"] == "__uscode_section_heading_fallback__"
+            assert fallback.metadata["fallback_rule"] == "uscode_heading_with_leading_stopword_v1"
+            assert fallback.provenance.citation == citation
+
+
