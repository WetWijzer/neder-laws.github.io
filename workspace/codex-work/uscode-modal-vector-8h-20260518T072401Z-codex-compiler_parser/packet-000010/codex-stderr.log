parser=LegalModalParser()

for title,section in [('22','2688'),('7','7311'),('15','2402')]:
    text=next(r['text'] for r in rows if str(r['title_number']).strip()==title and str(r['section_number']).strip()==section)
    normalized=parser.normalize_text(text)
