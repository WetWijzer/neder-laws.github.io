   722	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   723	    """Render one modal IR formula into a stable formula-like string."""
   724	    arguments = ", ".join(formula.predicate.arguments)
   725	    predicate = formula.predicate.name
   726	    if arguments:
   727	        predicate = f"{predicate}({arguments})"
   728	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
