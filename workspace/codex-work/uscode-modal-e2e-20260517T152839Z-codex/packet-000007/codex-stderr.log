    def _cue_feature(
        self,
        profile: ModalParseProfile,
        operator: ModalOperatorSpec,
        cue: str,
        start_char: int,
        end_char: int,
        token_indices: Sequence[int],
    ) -> SpaCyModalCueFeature:
