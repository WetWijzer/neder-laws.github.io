   618	def _bounded_ontology_values(
   619	    entries: Iterable[tuple[str, int]],
   620	    *,
   621	    max_items: int,
   622	) -> List[str]:
   623	    """Return deterministic bounded values with overflow priority handling."""
   624	    if max_items <= 0:
   625	        return []
   626	    deduplicated = _deduplicated_ontology_entries(entries)
   627	    if len(deduplicated) <= max_items:
   628	        return [value for value, _priority in deduplicated]
   629	
   630	    selected: List[str] = []
   631	    seen: set[str] = set()
   632	    for priority in (
   633	        _FRAME_ONTOLOGY_TERM_PRIORITY_DIRECT,
   634	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL,
   635	        _FRAME_ONTOLOGY_TERM_PRIORITY_CONTEXTUAL_STRUCTURAL,
   636	        _FRAME_ONTOLOGY_TERM_PRIORITY_NONE,
   637	    ):
   638	        for value, entry_priority in deduplicated:
   639	            if entry_priority != priority or value in seen:
   640	                continue
   641	            selected.append(value)
   642	            seen.add(value)
   643	            if len(selected) >= max_items:
   644	                return selected
   645	    return selected
