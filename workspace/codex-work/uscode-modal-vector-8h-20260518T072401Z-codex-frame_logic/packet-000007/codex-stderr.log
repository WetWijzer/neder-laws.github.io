   670	def _grounding_context(modal_ir: ModalIRDocument) -> Dict[str, Any]:
   671	    subjects = {modal_ir.document_id}
   672	    values = {modal_ir.document_id, modal_ir.source, modal_ir.version}
   673	    modal_payloads: list[Any] = [modal_ir.to_dict()]
