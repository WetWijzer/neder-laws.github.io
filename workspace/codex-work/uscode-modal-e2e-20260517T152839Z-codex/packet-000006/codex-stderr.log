   472	            (
   473	                ModalLogicFamily.CONDITIONAL_NORMATIVE.value,
   474	                bool(signals.get("has_condition_or_exception_scope")),
   475	                "temporal_conditional_normative_family_outvoted",
   476	                (
   477	                    "Conditional or exception scope markers are present, but temporal cues "
   478	                    "outvote conditional-normative family evidence."
   479	                ),
   480	            ),
   481	            (
   482	                ModalLogicFamily.FRAME.value,
   483	                bool(signals.get("has_frame_context") or signals.get("has_frame_cue")),
   484	                "temporal_frame_family_outvoted",
   485	                (
