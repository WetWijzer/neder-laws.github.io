   118	    """
   119	    Result returned by :meth:`FLogicSemanticOptimizer.evaluate`.
   120	
   121	    Attributes:
   122	        similarity_score: Cosine similarity ∈ [-1, 1] between source and
   123	            decoded embeddings.
   124	        passed: ``True`` when similarity ≥ threshold and no blocking violations.
   125	        ontology_consistent: ``True`` when no F-logic constraints were violated.
   126	        violations: List of constraint violations (empty when consistent).
   127	        refinement_rounds: Number of refinement passes that were applied.
   128	        metadata: Additional diagnostic information.
   129	    """
   130	
   131	    similarity_score: float
   132	    passed: bool
   133	    ontology_consistent: bool
   134	    violations: List[OntologyViolation] = field(default_factory=list)
   135	    refinement_rounds: int = 0
   136	    metadata: Dict[str, Any] = field(default_factory=dict)
   137	
   138	
   139	# ---------------------------------------------------------------------------
   140	# Optimizer
   141	# ---------------------------------------------------------------------------
   142	
   143	
   144	class FLogicSemanticOptimizer:
   145	    """
   146	    Optimizer that uses F-logic to preserve semantic meaning across the
   147	    NL → Encoder(KG + formal logic) → Decoder(NL) pipeline.
   148	
   149	    The optimizer:
   150	
   151	    1. Computes the cosine similarity between source and decoded embeddings.
   152	    2. Optionally validates the knowledge-graph triples against an F-logic
   153	       ontology using :class:`~ipfs_datasets_py.logic.flogic.ErgoAIWrapper`.
   154	    3. Returns a :class:`FLogicOptimizerResult` describing whether semantic
   155	       preservation passed and listing any ontology violations.
   156	
   157	    The F-logic check is performed in *simulation mode* when the ErgoAI binary
   158	    is not installed, which means no external dependencies are required.
   159	
   160	    Args:
   161	        config: Optimizer configuration.  Defaults to :class:`FLogicOptimizerConfig`.
   162	    """
   163	
   164	    def __init__(self, config: Optional[FLogicOptimizerConfig] = None) -> None:
   165	        self.config = config or FLogicOptimizerConfig()
   166	        self._ergo: Any = None  # lazy-loaded ErgoAIWrapper
   167	
   168	    # ------------------------------------------------------------------
   169	    # Public API
   170	    # ------------------------------------------------------------------
   171	
   172	    def evaluate(
   173	        self,
   174	        source_text: str,
   175	        decoded_text: str,
   176	        source_embedding: Sequence[float],
   177	        decoded_embedding: Sequence[float],
   178	        kg_triples: Optional[List[Dict[str, str]]] = None,
   179	    ) -> FLogicOptimizerResult:
   180	        """
   181	        Evaluate semantic preservation between *source_text* and *decoded_text*.
   182	
   183	        Args:
   184	            source_text: Original natural language input.
   185	            decoded_text: Reconstructed text after KG encoding and decoding.
   186	            source_embedding: Dense vector embedding of *source_text*.
   187	            decoded_embedding: Dense vector embedding of *decoded_text*.
   188	            kg_triples: Optional list of ``{"subject": …, "predicate": …,
   189	                "object": …}`` dicts representing the encoded knowledge-graph
   190	                triples.  Used for F-logic consistency checking.
   191	
   192	        Returns:
   193	            :class:`FLogicOptimizerResult` with similarity score, pass/fail
   194	            status, and any ontology violations.
   195	        """
   196	        similarity = _cosine_similarity(
   197	            list(source_embedding), list(decoded_embedding)
   198	        )
   199	        violations: List[OntologyViolation] = []
   200	        ontology_consistent = True
   201	        frame_logic_terms: List[str] = []
   202	
   203	        if self.config.check_ontology_consistency and kg_triples:
   204	            violations = self._check_flogic_consistency(kg_triples)
   205	            ontology_consistent = len(violations) == 0
   206	        if kg_triples:
   207	            frame_logic_terms = _audit_frame_logic_terms(kg_triples)
   208	
   209	        metadata: Dict[str, Any] = {
   210	            "source_text": source_text,
   211	            "decoded_text": decoded_text,
   212	            "kg_triple_count": len(kg_triples or []),
   213	            "threshold": self.config.similarity_threshold,
   214	        }
   215	        if frame_logic_terms:
   216	            metadata["frame_logic_terms"] = frame_logic_terms
   217	
   218	        passed = (
   219	            similarity >= self.config.similarity_threshold and ontology_consistent
   220	        )
   221	
   222	        return FLogicOptimizerResult(
   223	            similarity_score=similarity,
   224	            passed=passed,
   225	            ontology_consistent=ontology_consistent,
   226	            violations=violations,
   227	            metadata=metadata,
   228	        )
