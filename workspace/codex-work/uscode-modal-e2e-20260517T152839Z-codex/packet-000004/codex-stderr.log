   250	            family=profile.family.value,
   251	            system=profile.system.value,
   252	            symbol=operator.symbol,
   253	            label=operator.aliases[0] if operator.aliases else operator.symbol,
   254	            cue=cue,
   255	            start_char=start_char,
   256	            end_char=end_char,
   257	            token_indices=list(token_indices),
   258	        )
   259	
   260	    def _load_nlp(self, model_name: str):
   261	        try:
   262	            import spacy
   263	        except ImportError as exc:  # pragma: no cover - dependency is present in supported envs
   264	            raise RuntimeError("spaCy is required for SpaCyLegalEncoder") from exc
   265	        try:
   266	            nlp = spacy.load(model_name)
   267	            used_fallback = False
   268	        except OSError:
   269	            nlp = spacy.blank("en")
   270	            used_fallback = True
   271	        if "sentencizer" not in nlp.pipe_names:
   272	            nlp.add_pipe("sentencizer")
   273	        return nlp, used_fallback
   274	
   275	
   276	class SpaCyModalIRCompiler:
   277	    """Compile spaCy legal encodings into canonical modal IR documents."""
   278	
   279	    def compile(self, encoding: SpaCyLegalEncoding) -> ModalIRDocument:
   280	        formulas: List[ModalIRFormula] = []
   281	        for index, cue in enumerate(encoding.cues, start=1):
   282	            sentence = _sentence_for_cue(encoding.sentences, cue)
   283	            tokens = _tokens_for_span(encoding.tokens, sentence.start_char, sentence.end_char)
   284	            predicate = _predicate_from_tokens(tokens, cue)
   285	            conditions, exceptions = _conditions_and_exceptions_from_sentence(
   286	                sentence.text
   287	            )
   288	            formulas.append(
   289	                ModalIRFormula(
   290	                    formula_id=f"{encoding.document_id}:spacy:f{index:04d}",
   291	                    operator=ModalIROperator(
   292	                        family=cue.family,
   293	                        system=cue.system,
   294	                        symbol=cue.symbol,
   295	                        label=cue.label,
   296	                    ),
   297	                    predicate=predicate,
   298	                    provenance=ModalIRProvenance(
   299	                        source_id=encoding.document_id,
   300	                        start_char=sentence.start_char,
   301	                        end_char=sentence.end_char,
   302	                        citation=encoding.citation,
   303	                    ),
   304	                    conditions=conditions,
   305	                    exceptions=exceptions,
   306	                    metadata={
   307	                        "cue": cue.cue,
   308	                        "cue_start_char": cue.start_char,
   309	                        "cue_end_char": cue.end_char,
   310	                        "encoder": "spacy_modal_codec_v1",
   311	                    },
   312	                )
   313	            )
   314	        return ModalIRDocument(
   315	            document_id=encoding.document_id,
   316	            source=encoding.source,
   317	            normalized_text=encoding.normalized_text,
   318	            formulas=formulas,
   319	            metadata={
   320	                "citation": encoding.citation,
   321	                "deterministic_parser": "spacy_modal_codec_v1",
   322	                "llm_call_count": 0,
   323	                "model_name": encoding.model_name,
   324	                "sentence_count": len(encoding.sentences),
   325	                "token_count": len(encoding.tokens),
   326	                "used_fallback_model": encoding.used_fallback_model,
   327	            },
   328	        )
   329	
   330	
   331	class SpaCyModalDecoder:
   332	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   333	
   334	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   335	        if dimensions < 1:
   336	            raise ValueError("dimensions must be >= 1")
   337	        vector = [0.0 for _ in range(dimensions)]
   338	        for feature in self._feature_stream(encoding):
   339	            slot, value = _feature_hash(feature, dimensions)
   340	            vector[slot] += value
   341	        norm = math.sqrt(sum(value * value for value in vector))
   342	        if norm == 0.0:
   343	            return vector
   344	        return [round(value / norm, 6) for value in vector]
   345	
   346	    def family_logits(
   347	        self,
   348	        encoding: SpaCyLegalEncoding,
   349	        *,
   350	        modal_families: Sequence[str],
   351	    ) -> Dict[str, float]:
   352	        logits = {family: -0.25 for family in modal_families}
   353	        counts = encoding.modal_family_counts()
   354	        for family, count in counts.items():
   355	            if family in logits:
   356	                logits[family] = 2.0 + float(count)
   357	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   358	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   359	        return logits
   360	
   361	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   362	        yield f"doclen:{len(encoding.tokens)}"
   363	        for token in encoding.tokens:
   364	            if token.is_alpha and not token.is_stop:
   365	                yield f"lemma:{token.normalized()}"
   366	            if token.pos:
   367	                yield f"pos:{token.pos}"
   368	            if token.dep:
   369	                yield f"dep:{token.dep}"
   370	        for cue in encoding.cues:
   371	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   372	        for family, count in encoding.modal_family_counts().items():
   373	            yield f"family:{family}:{count}"
   374	
   375	
   376	class SpaCyModalCodec:
   377	    """Convenience facade for encoder -> IR -> vector workflows."""
   378	
   379	    def __init__(
   380	        self,
   381	        *,
   382	        encoder: Optional[SpaCyLegalEncoder] = None,
   383	        compiler: Optional[SpaCyModalIRCompiler] = None,
   384	        decoder: Optional[SpaCyModalDecoder] = None,
   385	    ) -> None:
   386	        self.encoder = encoder or SpaCyLegalEncoder()
   387	        self.compiler = compiler or SpaCyModalIRCompiler()
   388	        self.decoder = decoder or SpaCyModalDecoder()
   389	
   390	    def encode_sample(self, sample: LegalSample) -> SpaCyLegalEncoding:
   391	        return self.encoder.encode(
   392	            sample.text,
   393	            document_id=sample.sample_id,
   394	            citation=sample.citation,
   395	            source=sample.source,
   396	        )
   397	
   398	    def compile_sample_ir(self, sample: LegalSample) -> ModalIRDocument:
   399	        return self.compiler.compile(self.encode_sample(sample))
   400	
   401	    def decode_sample_embedding(self, sample: LegalSample, *, dimensions: int) -> List[float]:
   402	        return self.decoder.decode_embedding(self.encode_sample(sample), dimensions=dimensions)
   403	
   404	    def family_logits_for_sample(
   405	        self,
   406	        sample: LegalSample,
   407	        *,
   408	        modal_families: Sequence[str],
   409	    ) -> Dict[str, float]:
   410	        return self.decoder.family_logits(
   411	            self.encode_sample(sample),
   412	            modal_families=modal_families,
   413	        )
   414	
   415	    def feature_keys_for_sample(self, sample: LegalSample) -> List[str]:
   416	        """Return text-derived features that can receive generalizable SGD updates."""
   417	        encoding = self.encode_sample(sample)
   418	        return _unique_preserve_order(self.decoder._feature_stream(encoding))
