+    def _prefixed_clause_phrases(
+        self,
+        segment_text: str,
+        prefixes: Iterable[str],
+    ) -> List[str]:
+        normalized = self.normalize_text(segment_text)
+        phrases: List[str] = []
+        for prefix in sorted(prefixes, key=lambda value: (-len(value), value)):
