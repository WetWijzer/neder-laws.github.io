+                end_char=candidate_segment.end_char,
+                citation=citation,
+            ),
+            conditions=conditions,
+            exceptions=exceptions,
+            metadata={
+                "cue": "__uscode_declarative_statement_fallback__",
+                "fallback_rule": "uscode_declarative_statement_v1",
+                "statement_hint": statement_hint,
+            },
