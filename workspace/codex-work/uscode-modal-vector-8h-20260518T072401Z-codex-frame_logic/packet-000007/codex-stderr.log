   684	        values.add(formula.operator.family)
   685	        values.add(formula.operator.system)
   686	        values.add(formula.operator.symbol)
   687	        values.add(formula.operator.label)
   688	        values.add(formula.predicate.name)
   689	        values.update(formula.predicate.arguments)
   690	        values.update(formula.conditions)
   691	        values.update(formula.exceptions)
   692	        if formula.predicate.role:
   693	            values.add(formula.predicate.role)
   694	        if formula.provenance.citation:
   695	            values.add(formula.provenance.citation)
   696	    return {
   697	        "modal_text": json.dumps(modal_payloads, ensure_ascii=True, sort_keys=True),
