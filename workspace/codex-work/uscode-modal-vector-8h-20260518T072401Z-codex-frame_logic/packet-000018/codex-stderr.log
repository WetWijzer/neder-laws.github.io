from collections import Counter
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.frame_bm25_selector import is_frame_ontology_feature_key

samples=[
('42','300d','No grant may be made under this section unless the applicant provides assurances under subsection (b).'),
('10','8477','The Secretary may waive this requirement under subsection (c) if the defense procurement is urgent.'),
('42','2000e','It shall be an unlawful employment practice for an employer to fail or refuse to hire any individual.'),
('36','154304','The Secretary may provide grants to the Foundation under this chapter for restoration projects.'),
('28','2674','The United States shall be liable in the same manner and to the same extent as a private individual under like circumstances.'),
('16','460l-12','The Secretary shall administer the fund in accordance with this subsection and subsection (c).'),
('34','20990','The Attorney General may make grants to carry out this section.'),
('7','2270c','The Secretary shall carry out this section in coordination with State agencies.'),
('42','12314','The Secretary shall provide assistance under this section to eligible entities.'),
('46','2118','A vessel may not operate unless the owner has complied with this section.'),
('15','3602','The term means any person engaged in the business of selling or leasing lots.'),
('25','2706','The Commission shall approve a tribal ordinance if the ordinance complies with this section.'),
]
codec=DeterministicModalLogicCodec()
pred_counter=Counter(); pred_examples={}
for t,s,text in samples:
    sample=build_us_code_sample(title=t,section=s,text=text)
    features=codec.feature_keys_for_sample(sample)
    for feature in features:
        if not feature.startswith('flogic:'):
            continue
        if is_frame_ontology_feature_key(feature):
            continue
        # parse predicate
        _,_,tail=feature.partition(':')
        predicate,sep,value=tail.partition(':')
        if not sep:
            predicate='(no-predicate)'
            value=tail
        pred_counter[predicate]+=1
        pred_examples.setdefault(predicate, value)
print('Unrecognized flogic predicates:')
for pred,count in pred_counter.most_common():
    print(f'{pred:35s} {count:4d}  ex={pred_examples[pred][:60]}')
