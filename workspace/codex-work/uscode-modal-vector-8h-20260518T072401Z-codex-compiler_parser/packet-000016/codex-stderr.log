   139	class BM25FrameSelector:
   140	    """Deterministic BM25 ranker for ontology frame candidates."""
   141	
   142	    def __init__(
   143	        self,
   144	        frames: Iterable[FrameCandidate],
   145	        *,
   146	        k1: float = 1.5,
   147	        b: float = 0.75,
   148	    ) -> None:
   149	        self.frames = tuple(frames)
   150	        self.k1 = k1
   151	        self.b = b
   152	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
   153	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
   154	        self._doc_freq = self._build_doc_freq(self._documents)
   155	
   156	    def rank(
   157	        self,
   158	        text: str,
   159	        *,
   160	        top_k: int = 3,
   161	        domain: str | None = None,
   162	    ) -> List[FrameSelection]:
   163	        """Rank frame candidates for text."""
   164	        query_tokens = self._tokenize(text)
   165	        query_terms = sorted(set(query_tokens))
   166	        results: List[FrameSelection] = []
   167	        for frame, document in zip(self.frames, self._documents):
   168	            if domain is not None and frame.domain != domain:
   169	                continue
   170	            matched_terms = sorted(set(query_terms) & set(document))
   171	            score = self._score(query_terms, document)
   172	            if matched_terms:
   173	                score += 0.05 * len(matched_terms)
   174	            results.append(
   175	                FrameSelection(
   176	                    frame=frame,
   177	                    score=round(score, 6),
   178	                    matched_terms=matched_terms,
   179	                    explanation=self._explain(frame, matched_terms, score),
   180	                )
   181	            )
   182	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   183	        return results[:max(top_k, 0)]
