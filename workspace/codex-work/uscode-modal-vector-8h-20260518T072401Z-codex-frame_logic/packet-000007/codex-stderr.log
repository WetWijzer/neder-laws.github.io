   653	def _unique_preserve_order(values: Iterable[str]) -> List[str]:
   654	    seen: set[str] = set()
   655	    result: List[str] = []
   656	    for value in values:
   657	        if not value or value in seen:
   658	            continue
   659	        seen.add(value)
   660	        result.append(value)
   661	    return result
