   152	    embeddings: Dict[str, List[float]] = {}
   153	    if embeddings_parquet is not None:
   154	        embeddings = load_uscode_embeddings_from_parquet(
   155	            embeddings_parquet,
   156	            cids=[record.ipfs_cid for record in records if record.ipfs_cid],
   157	        )
   158	    return [
   159	        record.to_sample(embedding_vector=embeddings.get(record.ipfs_cid))
   160	        for record in records
   161	    ]
