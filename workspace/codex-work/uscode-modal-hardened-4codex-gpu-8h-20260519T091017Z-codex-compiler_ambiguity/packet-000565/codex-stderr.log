+                "share_raw": 0.95,
+                "share": 0.95,
+            },
+            {
+                "family": "DEONTIC",
+                "count": 1,
+                "share_raw": 0.90,
+                "share": 0.90,
+            },
+            {
+                "family": "TEMPORAL",
+                "count": 1,
+                "share_raw": 0.10,
+                "share": 0.10,
+            },
+        ],
+        family_shares={
