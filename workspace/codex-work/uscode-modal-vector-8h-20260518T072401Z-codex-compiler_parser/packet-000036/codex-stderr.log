SELECT title_number, section_number, law_name, text
FROM read_parquet(?)
WHERE title_number='42' AND lower(section_number) IN ('1395w.','1395ww.')
ORDER BY section_number
\"\"\",[p]).fetchall()
parser=LegalModalParser()
for title,section,law_name,text in rows:
    normalized=parser.normalize_text(text or '')
    sid=f\"us-code-{title}-{section}-{hashlib.sha256(f'{title}:{section}:{normalized}'.encode()).hexdigest()[:16]}\"
    doc=parser.parse(text or '', document_id=sid, citation=f\"{title} U.S.C. {section}\", source='us_code')
    print('sid',sid,'law_name',law_name,'len',len(text or ''),'formulas',len(doc.formulas))
    if doc.formulas:
        print(' first',doc.formulas[0].operator.family,doc.formulas[0].metadata.get('cue'),doc.formulas[0].metadata.get('fallback_rule'))
        print(' last',doc.formulas[-1].operator.family,doc.formulas[-1].metadata.get('cue'),doc.formulas[-1].metadata.get('fallback_rule'))
    print('head', (text or '')[:220].replace('\\n',' '))
    print('---')
