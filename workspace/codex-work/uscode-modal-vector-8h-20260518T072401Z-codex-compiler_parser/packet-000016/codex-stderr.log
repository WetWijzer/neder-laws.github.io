   274	    def _classify_segment_role(self, text: str) -> str:
   275	        lowered = text.lower()
   276	        if lowered.startswith(("if ", "unless ", "except ", "provided that ", "subject to ")):
   277	            return "condition"
   278	        if " means " in lowered or lowered.startswith("the term "):
   279	            return "definition"
   280	        if any(term in lowered for term in ("penalty", "fine", "sanction", "remedy")):
   281	            return "remedy"
   282	        return "clause"
