@dataclass
class FLogicOptimizerResult:
    """
    Result returned by :meth:`FLogicSemanticOptimizer.evaluate`.

    Attributes:
        similarity_score: Cosine similarity ∈ [-1, 1] between source and
            decoded embeddings.
