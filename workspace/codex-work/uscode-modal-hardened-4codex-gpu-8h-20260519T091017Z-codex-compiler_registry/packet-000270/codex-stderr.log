+    """Raise non-frame scope floors for dense generic-frame competition."""
+    frame_family = ModalLogicFamily.FRAME.value
+    frame_count = float(counts.get(frame_family, 0.0))
+    if frame_count <= 0.0:
+        return
+
+    base_floor = _scaled_competing_scope_backfill(
+        source_count=frame_count,
+        ratio=_GENERIC_FRAME_COMPETING_SCOPE_RATIO,
+        minimum=_COMPETING_SCOPE_BACKFILL_WEIGHT,
+        maximum=_GENERIC_FRAME_COMPETING_SCOPE_MAX,
+    )
+    strong_floor = _scaled_competing_scope_backfill(
+        source_count=frame_count,
+        ratio=_GENERIC_FRAME_STRONG_COMPETING_SCOPE_RATIO,
+        minimum=_FRAME_MODERATE_COMPETING_SCOPE_BACKFILL_WEIGHT,
+        maximum=_GENERIC_FRAME_STRONG_COMPETING_SCOPE_MAX,
+    )
+
+    has_explicit_conditional_scope = _has_explicit_conditional_scope(signals)
