ipfs_datasets_py/mcp_server/tools/legal_dataset_tools/diagnostic_results/CT_diagnostic.json:17:      "html_content": "<!DOCTYPE html>\n<html lang=\"en-US\">\n<head><script type=\"text/javascript\" src=\"https://web-static.archive.org/_static/js/bundle-playback.js?v=FC38Hc5A\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\" src=\"https://web-static.archive.org/_static/js/wombat.js?v=txqj7nKC\" charset=\"utf-8\"></script>\n<script>window.RufflePlayer=window.RufflePlayer||{};window.RufflePlayer.config={\"autoplay\":\"on\",\"unmuteOverlay\":\"hidden\",\"showSwfDownload\":true};</script>\n<script type=\"text/javascript\" src=\"https://web-static.archive.org/_static/js/ruffle/ruffle.js\"></script>\n<script type=\"text/javascript\">\n    __wm.init(\"http://web.archive.org/web\");\n  __wm.wombat(\"https://www.cga.ct.gov/current/pub/titles.htm\",\"20250901045344\",\"http://web.archive.org/\",\"web\",\"https://web-static.archive.org/_static/\",\n\t      \"1756702424\");\n</script>\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://web-static.archive.org/_static/css/banner-styles.css?v=p7PEIJWi\" />\n<link rel=\"stylesheet\" type=\"text/css\" href=\"https://web-static.archive.org/_static/css/iconochive.css?v=3PDvdIFv\" />\n<!-- End Wayback Rewrite JS Include -->\n\n<meta charset=\"utf-8\"/>\n<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/>\n<meta name=\"Description\" content=\"General Statutes of Connecticut - Titles\"/>\n<title>General Statutes of Connecticut - Titles</title>\n<style type=\"text/css\" media=\"screen\"><!--\n/* High-level style defs for page */\nhtml {\nbackground-color: #ffffff;\ncolor: #000000;\n}\nbody {\npadding: 0em 0.5em;\nfont-family : \"Times New Roman\", Times, serif;\nfont-size: medium;\n}\n/* HEADINGS */\nh1, h2, h3, h4, h5, h6 {\ncolor : #000000;\nfont-style : normal;\nfont-variant : normal;\nfont-weight : normal;\nline-height : 1.1;\nmargin : 0em 0em;\ntext-align : center;\ntext-decoration : none;\ntext-indent : 0em;\n}\nh1, h2, h3 {\nfont-weight : bold;\n}\nh5, h6 {\nmargin-top: 2em;\n}\nh1.title-no, h1.title-name {\ncolor: #800000;\n}\nh2.chap-no, h2.chap-name {\n/* nothing special */\n}\nh3.part-name {\nmargin-top: 0.5em;\n}\nh3.part-no {\nmargin-top: 2em;\n}\nh4.chap_toc_hd {\nfont-weight: bold;\nmargin: 1.5em 0em 1em 0em;\ntext-align: left;\n}\nh4.subpart-name {\nfont-weight: bold;\nmargin-top: 0.5em;\n}\nh4.subpart-no {\nfont-weight: bold;\nmargin-top: 2em;\n}\n/* HORIZONTAL RULES */\nhr.titles_pg_bar {\nbackground-color: #a0a0a0;\nborder-width: 0;\ncolor: #a0a0a0;\nheight: .5em;\nmargin: 1em 0em;\nwidth: 100%;\n}\nhr.chaps_pg_bar {\nbackground-color: #8b0000;\nborder-width: 0;\ncolor: #8b0000;\nheight: .8em;\nmargin: .5em 0em;\nwidth: 100%;\n}\nhr.titles_toc_spcr {\nbackground-color: #ffcc00;\nborder-width: 0;\ncolor: #ffcc00;\nheight: 1em;\nmargin: 0.1em .5em;\ntext-align: left;\nvertical-align: top;\nwidth: 150px;\n}\n/* IMAGES */\nimg.center {\ndisplay: block;\nmargin-left: auto;\nmargin-right: auto;\n}\n/* PARAGRAPHS */\np {\nfont-size : 1em;\nfont-style : normal;\nfont-variant : normal;\nfont-weight : normal;\nline-height : 1.2;\nmargin : 1em 0em 0em 0em;\ntext-align : justify;\ntext-justify:distribute;\ntext-decoration : none;\ntext-indent: 1em;\n}\np.annotation, p.annotation-first {\ncolor: #ff3333;\n}\np.cross-ref, p.cross-ref-first {\ncolor: #009900;\n}\np.front-note, p.front-note-first {\ncolor : #ff6600;\n}\np.history, p.history-first {\ncolor : #9900FF;\n}\np.source, p.source-first {\ncolor : #996600;\n}\np.Form-center, p.Text-center, p.Form-head, p.lesser-head {\ntext-align : center;\ntext-indent: 0em;\n}\np.Form-head, p.lesser-head {\nmargin-top: 2em;\n}\np.Form-left, p.Text-left {\ntext-align : justify;\ntext-indent: 0em;\n}\np.Text-left1 {\ntext-align : justify;\ntext-indent: 0em;\nmargin-top: 0em;\n}\np.Form-right {\ntext-align : right;\ntext-indent: 0em;\n}\np.tb, p.tb-left, p.tb-left1, p.tb-left2, p.tb-center, p.tb-right {\ntext-align : justify;\ntext-indent : 0em;\nmargin : 0.5em 0em 0em 0em;\n}\np.tb, p.tb-left1 {\nmargin-left: 1em;\n}\np.tb-left2 {\nmargin-left: 2em;\n}\np.tb-center {\ntext-align : center;\n}\np.tb-right {\ntext-align : right;\n}\np.nolead {\nmargin-top: 0em;\n}\np.flush {\ntext-align : left;\ntext-indent : 0em;\n}\n/* TABLES */\ntable {\n/* consider border-collapse : collapse; */\nborder-style: none;\nfont-size: 1em;\ntext-align: left;\nvertical-align: top;\nmargin: 1em 0em 1em 0em;\n}\ntbody, thead, tfoot, tr, td, th {\ntext-indent: 0em;\nvertical-align: top;\n}\ntable.center {\nmargin-left: auto;\nmargin-right: auto;\n}\ntable.nav_tbl {\nborder: 0;\nwidth: 50%;\npadding: 2px;\nborder-spacing: 2px;\ntext-align: center;\nmargin: 1em 0em 2em 0em;\n}\ntable.ttl_toc_vol_hd {\nborder: 0;\npadding: 0px;\nborder-right: 15px;\nvertical-align: middle;\nmargin-top: 2em;\n}\ntd.bottom {\nvertical-align: bottom;\n}\ntd.left_25pct {\nwidth: 25%;\n}\ntd.left_38pct {\nwidth: 38%;\n}\ntd.left_40pct {\nwidth: 40%;\n}\n/* SPANS */\nspan.inline_hd {\nfont-weight : bold;\n}\nspan.catchln {\ncolor: #8b0000;\nfont-weight : bold;\n}\nspan.toc_vol_no {\nfont-size: 1.2em;\nfont-style : normal;\nfont-weight : bold;\n}\nspan.toc_ttl_desig, span.toc_ttl_name {\nfont-size: 1.1em;\nfont-weight: bold;\ncolor: #003399;\n}\nspan.toc_rng_chaps {\nfont-size: 1.1em;\nfont-weight: bold;\ncolor: #cc0033;\n}\n/* etc. */\n.titles_main_hd {\ncolor: #ff0000;\n}\n.toc_rng_secs {\ncolor: #cc0033;\nfont-weight: bold;\n}\n.toc_catchln {\ncolor: #8b0000;\nmargin : .1em 0em 0em 2em;\nmax-width: 90%;\ntext-indent: -2em;\n}\n.toc_catchln * {\ncolor: #8b0000;\n}\n.toc_ch_link {\ndisplay: inline-block;\ncolor: #0000ff;\nfont-size: 1.1em;\nfont-weight: normal;\n}\n.nav_link {\ncolor: #0000ff;\n}\n.full-width {\nwidth: 100%;\n}\n.half-width {\nwidth: 50%;\n}\n.third-width {\nwidth: 33%;\n}\n--></style>\n</head>\n<body>\n<div id=\"titles.htm\" lang=\"en-US\">\n<h1>GENERAL STATUTES<br/>OF<br/>CONNECTICUT</h1>\n<h2><i>Revised to January 1, 2025</i></h2>\n<br/>\n<img class=\"center\" alt=\"CT Armorial Bearing\" src=\"/web/20250901045344im_/https://www.cga.ct.gov/current/pub/newstateseal.jpg\" height=\"130\" width=\"150\"/><br/>\n<h4>(Prepared under the direction of the Legislative Commissioners&#x2019; Office)</h4>\n<hr class=\"titles_pg_bar\"/>\n<h1 class=\"titles_main_hd\">T I T L E S</h1>\n<br/>\n<h4><i>(The volume numbers appearing below correspond to the volumes of the printed General Statutes)</i></h4>\n<table class=\"ttl_toc_vol_hd\">\n<tr>\n<td><span class=\"toc_vol_no\">V O L U M E&#160;&#160;&#160;&#160;1</span></td>\n<td>\n<hr class=\"titles_toc_spcr\"/>\n</td>\n</tr>\n</table>\n<table style=\"width:80%\">\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_01.htm\"><span class=\"toc_ttl_desig\">Title 1</span></a> <span class=\"toc_rng_chaps\">Chapters 1 to 15e<br/>(Secs. 1-1 to 1-500)</span></td>\n<td><a href=\"title_01.htm\"><span class=\"toc_ttl_name\">Provisions of General Application</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_02.htm\"><span class=\"toc_ttl_desig\">Title 2</span></a> <span class=\"toc_rng_chaps\">Chapters 16 to 23<i>l</i><br/>(Secs. 2-1 to 2-139)</span></td>\n<td><a href=\"title_02.htm\"><span class=\"toc_ttl_name\">General Assembly and Legislative Agencies</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><span class=\"toc_ttl_desig\">Title 2a</span> <span class=\"toc_rng_chaps\">Chapters 24 to 25</span></td>\n<td><span class=\"toc_ttl_name\">Reserved for future use</span></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><span class=\"toc_ttl_desig\">Title 2b</span> <span class=\"toc_rng_chaps\">Chapters 26 to 27</span></td>\n<td><span class=\"toc_ttl_name\">Reserved for future use</span></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_02c.htm\"><span class=\"toc_ttl_desig\">Title 2c</span></a> <span class=\"toc_rng_chaps\">Chapters 28 to 28a<br/>(Secs. 2c-1 to 2c-21)</span></td>\n<td><a href=\"title_02c.htm\"><span class=\"toc_ttl_name\">Review and Termination of Governmental Entities and Programs</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_03.htm\"><span class=\"toc_ttl_desig\">Title 3</span></a> <span class=\"toc_rng_chaps\">Chapters 31 to 35<br/>(Secs. 3-1 to 3-131)</span></td>\n<td><a href=\"title_03.htm\"><span class=\"toc_ttl_name\">State Elective Officers</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_04.htm\"><span class=\"toc_ttl_desig\">Title 4</span></a> <span class=\"toc_rng_chaps\">Chapters 46 to 55e<br/>(Secs. 4-1 to 4-289)</span></td>\n<td><a href=\"title_04.htm\"><span class=\"toc_ttl_name\">Management of State Agencies</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_04a.htm\"><span class=\"toc_ttl_desig\">Title 4a</span></a> <span class=\"toc_rng_chaps\">Chapters 57 to 58a<br/>(Secs. 4a-1 to 4a-101)</span></td>\n<td><a href=\"title_04a.htm\"><span class=\"toc_ttl_name\">Administrative Services</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_04b.htm\"><span class=\"toc_ttl_desig\">Title 4b</span></a> <span class=\"toc_rng_chaps\">Chapters 59 to 60a<br/>(Secs. 4b-1 to 4b-136)</span></td>\n<td><a href=\"title_04b.htm\"><span class=\"toc_ttl_name\">State Real Property</span></a></td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_04c.htm\"><span class=\"toc_ttl_desig\">Title 4c</span></a> <span class=\"toc_rng_chaps\">Repealed</span></td>\n<td><a href=\"title_04c.htm\"><span class=\"toc_ttl_name\">Business Regulation. Department of Business Regulation</span></a> (<i>All sections repealed or obsolete</i>)</td>\n</tr>\n<tr style=\"vertical-align:top\">\n<td class=\"left_38pct\"><a href=\"title_04d.htm\