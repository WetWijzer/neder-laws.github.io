import json
from dataclasses import dataclass, field
from typing import Any, Dict, List, Mapping, Optional


def _stable_json(data: Mapping[str, Any]) -> str:
    return json.dumps(data, ensure_ascii=True, separators=(",", ":"), sort_keys=True)


