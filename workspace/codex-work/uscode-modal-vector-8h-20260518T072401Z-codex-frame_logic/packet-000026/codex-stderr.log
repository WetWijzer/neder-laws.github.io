def _unique_preserve_order(values: Sequence[str]) -> List[str]:
    seen: set[str] = set()
    result: List[str] = []
    for value in values:
        if not value or value in seen:
            continue
        seen.add(value)
        result.append(value)
    return result


def _sorted_unique_terms(values: Sequence[str]) -> List[str]:
    return sorted(_unique_preserve_order(values))


__all__ = [
    "FLogicSemanticOptimizer",
    "FLogicOptimizerConfig",
    "FLogicOptimizerResult",
    "OntologyViolation",
]

