  2042	def _citation_section_component_profile(
  2043	    *,
  2044	    component_count: int,
  2045	    suffix_component_count: int,
  2046	    is_range: bool,
  2047	) -> str:
  2048	    if component_count <= 0:
  2049	        return ""
  2050	    if is_range:
  2051	        return "range"
  2052	    if component_count == 1:
  2053	        return "single_alphanumeric" if suffix_component_count else "single_numeric"
  2054	    if suffix_component_count == 0:
  2055	        return "compound_numeric"
  2056	    if suffix_component_count == component_count:
  2057	        return "compound_alphanumeric"
  2058	    return "compound_mixed"
