   191	    def _attach_metadata(
   192	        self,
   193	        modal_ir: ModalIRDocument,
   194	        frame_selections: Sequence[FrameSelection],
   195	        *,
   196	        parser_name: str,
   197	        selected_frame: Optional[str],
   198	        ambiguity_count: int,
   199	        encoding: SpaCyLegalEncoding,
   200	    ) -> ModalIRDocument:
   201	        frame_candidates = [
   202	            ModalIRFrame(
   203	                frame_id=selection.frame.frame_id,
   204	                score=selection.score,
   205	                matched_terms=list(selection.matched_terms),
   206	                explanation=selection.explanation,
   207	            )
   208	            for selection in frame_selections
   209	        ]
   210	        metadata = {
   211	            **modal_ir.metadata,
   212	            "ambiguity_count": ambiguity_count,
   213	            "deterministic_compiler": "modal_compiler_v1",
   214	            "deterministic_parser": parser_name,
   215	            "frame_selector": "bm25_v1",
   216	            "llm_call_count": 0,
   217	            "modal_family_counts": encoding.modal_family_counts(),
   218	            "selected_frame": selected_frame,
   219	        }
   220	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
