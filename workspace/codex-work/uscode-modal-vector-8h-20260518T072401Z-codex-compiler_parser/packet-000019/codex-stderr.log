import pyarrow.parquet as pq
import pyarrow.compute as pc
from pathlib import Path
path = Path('/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet')
t = pq.read_table(path, columns=['title_number','section_number','text'])
for title, section in [('16','6410'),('16','47a'),('7','614')]:
    mask = pc.and_(pc.equal(t['title_number'], title), pc.equal(pc.utf8_lower(t['section_number']), section.lower()))
    txt = t.filter(mask)['text'][0].as_py()
    print(f\"_USCODE_{title}_{section.upper().replace('.', '_').replace('-', '_')}_TEXT = (\")
    # wrap at 88 chars roughly using simple chunks
    s = txt
    words=s.split(' ')
    line='    \"'
    for w in words:
        add = ('' if line.endswith('\"') else ' ') + w
        if len(line) + len(add) + 1 > 96:
            print(line + ' \"')
