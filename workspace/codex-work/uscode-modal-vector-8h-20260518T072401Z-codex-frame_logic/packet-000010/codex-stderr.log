   246	def frame_ontology_terms_from_feature_keys(
   247	    feature_keys: Iterable[str],
   248	    *,
   249	    max_terms: int = 64,
   250	) -> List[str]:
   251	    """Extract canonical frame ontology terms from frame-linked feature keys."""
   252	    terms: List[str] = []
   253	    for feature_key in feature_keys:
   254	        feature = str(feature_key or "").strip()
   255	        if not feature:
   256	            continue
   257	
   258	        raw_value = ""
   259	        for prefix in _FRAME_LINKED_FEATURE_PREFIXES:
   260	            if feature.startswith(prefix):
   261	                raw_value = feature[len(prefix) :].strip()
   262	                break
   263	        if not raw_value and feature.startswith("flogic:"):
   264	            parts = feature.split(":", 2)
   265	            if len(parts) == 3 and parts[1] in _FRAME_ONTOLOGY_AUDIT_PREDICATES:
   266	                raw_value = parts[2].strip()
   267	        if not raw_value:
   268	            continue
   269	
   270	        normalized = normalize_frame_ontology_term(raw_value)
   271	        if not normalized:
   272	            continue
   273	        if normalized in terms:
   274	            continue
   275	        terms.append(normalized)
   276	        if len(terms) >= max_terms:
   277	            break
   278	    return terms
