    58	def test_parser_document_id_is_deterministic_from_normalized_text() -> None:
    59	    parser = LegalModalParser()
    60	
    61	    first = parser.parse("The applicant may appeal.")
    62	    second = parser.parse(" The   applicant may appeal. ")
    63	
    64	    assert first.document_id == second.document_id
    65	    assert first.to_json() == second.to_json()
