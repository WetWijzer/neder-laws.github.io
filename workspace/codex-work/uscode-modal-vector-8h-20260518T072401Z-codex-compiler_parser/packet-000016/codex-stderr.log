   290	    def _predicate_from_segment(self, segment_text: str, cue: str) -> str:
   291	        after_cue = segment_text.lower().split(cue.lower(), 1)[-1]
   292	        tokens = _TOKEN_RE.findall(after_cue)
   293	        if not tokens:
   294	            tokens = _TOKEN_RE.findall(segment_text.lower())
   295	        return "_".join(tokens[:6]) or "unnamed_predicate"
