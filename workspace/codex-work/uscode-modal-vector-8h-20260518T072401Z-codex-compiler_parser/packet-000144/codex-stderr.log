def _sample_id(title: str, section: str, normalized_text: str) -> str:
    digest = hashlib.sha256(f"{title}:{section}:{normalized_text}".encode("utf-8")).hexdigest()[:16]
    return f"us-code-{title}-{section}-{digest}"


