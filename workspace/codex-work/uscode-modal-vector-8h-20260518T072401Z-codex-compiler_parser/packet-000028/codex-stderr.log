   444	        for relationship in engine._relationship_cache.values()
   445	        if hasattr(relationship, "type")
   446	    )
   447	    assert modal_formula_to_text(result.modal_ir.formulas[0])
   448	    assert result.metadata["deterministic_decompiler"] == "modal_decompiler_v2"
   449	    assert result.decoded_text == result.normalized_text
   450	    assert result.decoded_modal_text.reconstruction_similarity == 1.0
   451	    assert result.decoded_modal_text.modal_span_coverage == 1.0
   452	    assert _token_overlap_ratio(result.normalized_text, result.decoded_text) == 1.0
   453	    assert "[" not in result.decoded_text
   454	    assert "actor:" not in result.decoded_text
   455	    slot_texts = decoded_modal_phrase_slot_text_map(result.decoded_modal_text)
   456	    assert "obligatory" in slot_texts["operator"]
   457	    assert any("provide notice" in text for text in slot_texts["predicate"])
