+        (f"{slot_prefix}_vowel_count", str(vowel_count)),
+        (f"{slot_prefix}_consonant_count", str(consonant_count)),
+        (
+            f"{slot_prefix}_has_vowel",
+            "true" if vowel_count > 0 else "false",
