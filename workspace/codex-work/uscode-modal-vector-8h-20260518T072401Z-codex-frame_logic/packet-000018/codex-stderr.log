for idx,s in enumerate(samples,1):
    todo1 = type('Todo',(),{'action':'improve_modal_family_classifier','loss_name':'cross_entropy_loss','sample_ids':[s.sample_id],'todo_id':f'ce-{idx}'})()
    todo2 = type('Todo',(),{'action':'improve_encoder_decoder_reconstruction','loss_name':'cosine_loss','sample_ids':[s.sample_id],'todo_id':f'cos-{idx}'})()
    auto.apply_todos([todo1,todo2], {s.sample_id:s}, learning_rate=0.5)

for s in samples:
