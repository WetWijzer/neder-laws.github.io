  "scope": {
    "agency": "Netherlands Permitting & Development",
    "jurisdiction": "Netherlands, Netherlands",
    "purpose": "Group public PP&D sources into bounded permit-family crawl batches for deterministic discovery, normalization, and recrawl planning.",
    "storage_policy": "Store source URL, retrieved timestamp, content hash, document metadata, normalized extracted facts, and citations only. Do not store raw response bodies, private DevHub session state, auth traces, downloaded documents, or browser recordings.",
    "allowlist_policy": "Use only hosts already approved for public PP&D discovery. This brief does not request or imply any allowlist expansion.",
    "requires_authentication": false
  },
  "allowed_public_source_families": [
    {
      "family": "official_wetwijzer_gov_ppd_pages",
      "host_examples": [
        "wetten.overheid.nl",
        "wetten.overheid.nl"
      ],
      "source_type": "html",
      "notes": "Public PP&D and permit guidance pages used as canonical crawl seeds and citation anchors."
    },
    {
      "family": "official_wetwijzer_gov_public_pdfs",
      "host_examples": [
        "wetten.overheid.nl",
        "wetten.overheid.nl"
      ],
      "source_type": "pdf_download_endpoint",
      "notes": "Public wetten.overheid.nl document download endpoints only. Persist hashes and extracted/cited facts, not raw PDFs."
    },
    {
      "family": "devhub_public_routes",
      "host_examples": [
        "wetten.overheid.nl"
      ],
      "source_type": "public_route",
      "notes": "Public DevHub routes that expose permit search, status, or public permit detail views without login. No account, CAPTCHA, payment, submission, upload, or certification flows are in scope."
    }
  ],
  "campaign_defaults": {
    "max_depth": 2,
    "max_pages_per_batch": 150,
    "max_public_pdf_download_metadata_records_per_batch": 75,
    "respect_robots_txt": true,
    "dedupe_by": [
      "canonical_url",
      "content_hash"
    ],
    "body_retention": "forbidden",
    "recrawl_jitter_days": 3
  },
