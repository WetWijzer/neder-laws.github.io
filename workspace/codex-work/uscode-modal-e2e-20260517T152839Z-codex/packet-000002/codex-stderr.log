   326	            for candidate in ranking
   327	            if float(candidate["share"]) >= self.config.modal_family_secondary_share_floor
   328	        ]
   329	        contender_families = {
   330	            str(candidate["family"]) for candidate in strong_contenders
   331	        }
   332	        has_temporal = ModalLogicFamily.TEMPORAL.value in contender_families
   333	        has_normative = any(
   334	            is_normative_modal_family(str(candidate["family"]))
