                                "family_ranking": ranking,
                                "primary_family": primary_family,
                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
                                "primary_share": round(primary_share, 6),
                            },
                        )
                    )
        ambiguities.extend(
            self._temporal_target_family_ambiguities(
