+def test_parser_replays_symbolic_validity_todo_samples_with_uscode_citation_context_fallback() -> None:
+    parser = LegalModalParser()
+    cases = [
+        (
+            "us-code-42-300u-4e3697e3e30dfaab",
+            "42 U.S.C. 300u",
+        ),
+        (
+            "us-code-5-6384-8b50e16be95927f5",
+            "5 U.S.C. 6384",
+        ),
+        (
+            "us-code-33-1265-058d44e9ce9b3d2d",
+            "33 U.S.C. 1265",
+        ),
+    ]
+
+    for document_id, citation in cases:
+        document = parser.parse(
+            _USCODE_CITATION_CONTEXT_ONLY_TEXT,
+            document_id=document_id,
+            source="us_code",
+            citation=citation,
+        )
+
+        assert document.document_id == document_id
+        assert document.formulas
+        fallback = document.formulas[-1]
+        assert fallback.operator.family == "frame"
+        assert fallback.metadata["cue"] == "__uscode_citation_context_fallback__"
+        assert fallback.metadata["fallback_rule"] == "uscode_citation_context_v1"
+        assert fallback.provenance.citation == citation
+
