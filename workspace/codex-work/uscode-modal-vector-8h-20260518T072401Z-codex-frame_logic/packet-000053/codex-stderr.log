   321	class BM25FrameSelector:
   322	    """Deterministic BM25 ranker for ontology frame candidates."""
   323	
   324	    def __init__(
   325	        self,
   326	        frames: Iterable[FrameCandidate],
   327	        *,
   328	        k1: float = 1.5,
   329	        b: float = 0.75,
   330	    ) -> None:
   331	        self.frames = tuple(frames)
   332	        self.k1 = k1
   333	        self.b = b
   334	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
   335	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
   336	        self._doc_freq = self._build_doc_freq(self._documents)
   337	
   338	    def rank(
   339	        self,
   340	        text: str,
   341	        *,
   342	        top_k: int = 3,
   343	        domain: str | None = None,
   344	    ) -> List[FrameSelection]:
   345	        """Rank frame candidates for text."""
   346	        query_tokens = self._tokenize(text)
   347	        query_terms = sorted(set(query_tokens))
   348	        results: List[FrameSelection] = []
   349	        for frame, document in zip(self.frames, self._documents):
   350	            if domain is not None and frame.domain != domain:
   351	                continue
   352	            matched_terms = sorted(set(query_terms) & set(document))
   353	            score = self._score(query_terms, document)
   354	            if matched_terms:
   355	                score += 0.05 * len(matched_terms)
   356	            results.append(
   357	                FrameSelection(
   358	                    frame=frame,
   359	                    score=round(score, 6),
   360	                    matched_terms=matched_terms,
   361	                    explanation=self._explain(frame, matched_terms, score),
   362	                )
   363	            )
   364	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   365	        return results[:max(top_k, 0)]
   366	
   367	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   368	        if not query_terms or not document or not self.frames:
   369	            return 0.0
   370	        doc_len = len(document)
   371	        term_counts = {term: document.count(term) for term in set(document)}
   372	        total = 0.0
   373	        for term in query_terms:
   374	            freq = term_counts.get(term, 0)
   375	            if freq == 0:
   376	                continue
   377	            doc_freq = self._doc_freq.get(term, 0)
   378	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   379	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   380	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   381	        return total
