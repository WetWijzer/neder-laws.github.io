    source: str = "legal_text"
    model_name: str = ""
    used_fallback_model: bool = False

    def modal_family_counts(self) -> Dict[str, int]:
        counts: Dict[str, int] = {}
        for cue in self.cues:
            counts[cue.family] = counts.get(cue.family, 0) + 1
