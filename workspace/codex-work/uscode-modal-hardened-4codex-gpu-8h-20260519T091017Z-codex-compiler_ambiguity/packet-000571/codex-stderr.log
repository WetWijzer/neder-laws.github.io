        ("epistemic", "conditional_normative"),
        ("frame", "conditional_normative"),
        ("frame", "deontic"),
        ("frame", "alethic"),
        ("frame", "epistemic"),
        ("frame", "dynamic"),
        ("frame", "temporal"),
        ("hybrid", "frame"),
        ("temporal", "deontic"),
        ("temporal", "conditional_normative"),
        ("temporal", "temporal"),
    }
