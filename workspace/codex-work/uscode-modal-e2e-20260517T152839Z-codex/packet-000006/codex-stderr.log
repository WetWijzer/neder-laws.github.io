   346	class SpaCyModalDecoder:
   347	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   348	
   349	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   350	        if dimensions < 1:
   351	            raise ValueError("dimensions must be >= 1")
   352	        vector = [0.0 for _ in range(dimensions)]
   353	        for feature in self._feature_stream(encoding):
   354	            slot, value = _feature_hash(feature, dimensions)
   355	            vector[slot] += value
   356	        norm = math.sqrt(sum(value * value for value in vector))
   357	        if norm == 0.0:
   358	            return vector
   359	        return [round(value / norm, 6) for value in vector]
   360	
   361	    def family_logits(
   362	        self,
   363	        encoding: SpaCyLegalEncoding,
   364	        *,
   365	        modal_families: Sequence[str],
   366	    ) -> Dict[str, float]:
   367	        logits = {family: -0.25 for family in modal_families}
   368	        counts = encoding.modal_family_counts()
   369	        for family, count in counts.items():
   370	            if family in logits:
   371	                logits[family] = 2.0 + float(count)
   372	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   373	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   374	        return logits
   375	
   376	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   377	        yield f"doclen:{len(encoding.tokens)}"
   378	        for token in encoding.tokens:
   379	            if token.is_alpha and not token.is_stop:
   380	                yield f"lemma:{token.normalized()}"
   381	            if token.pos:
   382	                yield f"pos:{token.pos}"
   383	            if token.dep:
   384	                yield f"dep:{token.dep}"
   385	        for cue in encoding.cues:
   386	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   387	        for family, count in encoding.modal_family_counts().items():
   388	            yield f"family:{family}:{count}"
   389	
