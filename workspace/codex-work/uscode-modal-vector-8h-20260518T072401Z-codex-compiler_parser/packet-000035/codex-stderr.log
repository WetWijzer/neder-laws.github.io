            return None
        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(heading_prefix):
            return None

        if not (
            self._contains_citation_section_reference(heading_prefix, citation_section)
            or self._starts_with_citation_section_reference(
                heading_prefix,
                citation_section,
            )
        ):
