   872	def supports_signal_free_adaptive_ambiguity_pair(
   873	    predicted_family: ModalLogicFamily | str,
   874	    target_family: ModalLogicFamily | str,
   875	) -> bool:
   876	    """Return whether an adaptive pair should emit ambiguity without target cues."""
   877	    resolved_target_family = _resolve_modal_family_name(target_family)
   878	    return (
   879	        resolved_target_family in compiler_ambiguity_policy_targets(predicted_family)
   880	        or resolved_target_family in signal_free_adaptive_ambiguity_targets(
   881	            predicted_family
   882	        )
   883	        or resolved_target_family in compiler_required_adaptive_ambiguity_targets(
   884	            predicted_family
   885	        )
   886	    )
   887	
