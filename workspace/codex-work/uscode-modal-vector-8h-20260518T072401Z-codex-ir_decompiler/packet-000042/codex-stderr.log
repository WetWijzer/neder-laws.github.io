def slot(citation, source_id):
    f=ModalIRFormula(formula_id='f',operator=ModalIROperator(family='deontic',system='kd',symbol='O',label='obligatory'),predicate=ModalIRPredicate(name='x'),provenance=ModalIRProvenance(source_id=source_id,start_char=0,end_char=len(citation),citation=citation))
