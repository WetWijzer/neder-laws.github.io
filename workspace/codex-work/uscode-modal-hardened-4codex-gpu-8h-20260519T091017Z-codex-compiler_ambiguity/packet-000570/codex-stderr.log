 14929	def _token_overlap_ratio(left: str, right: str) -> float:
 14930	    left_tokens = {
 14931	        token.lower()
 14932	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
 14933	    }
 14934	    right_tokens = {
 14935	        token.lower()
 14936	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
 14937	    }
 14938	    if not left_tokens:
 14939	        return 1.0 if not right_tokens else 0.0
 14940	    return len(left_tokens & right_tokens) / len(left_tokens)

