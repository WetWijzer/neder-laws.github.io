  1377	    for cue in encoding.cues:
  1378	        start = int(cue.start_char)
  1379	        end = int(cue.end_char)
  1380	        if start < 0 or end <= start:
  1381	            continue
  1382	        spans_by_family.setdefault(cue.family, []).append((start, end))
  1383	
  1384	    counts: Dict[str, float] = {}
  1385	    for family, spans in spans_by_family.items():
  1386	        if not spans:
  1387	            continue
  1388	        unique_spans = sorted(set(spans))
  1389	        effective_spans: List[tuple[int, int]] = []
  1390	        for start, end in unique_spans:
  1391	            span_len = end - start
  1392	            covered_by_larger_span = False
  1393	            for other_start, other_end in unique_spans:
  1394	                if other_start == start and other_end == end:
  1395	                    continue
  1396	                other_len = other_end - other_start
  1397	                if (
  1398	                    other_start <= start
  1399	                    and other_end >= end
  1400	                    and other_len > span_len
  1401	                ):
  1402	                    covered_by_larger_span = True
  1403	                    break
  1404	            if not covered_by_larger_span:
  1405	                effective_spans.append((start, end))
  1406	        counts[family] = float(len(effective_spans))
  1407	    return counts
