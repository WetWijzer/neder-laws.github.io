   204	    def _tokenize(self, text: str) -> List[str]:
   205	        return [token.lower() for token in _TOKEN_RE.findall(text)]
   206	
   207	    def _build_doc_freq(self, documents: Sequence[Sequence[str]]) -> Dict[str, int]:
   208	        frequencies: Dict[str, int] = {}
   209	        for document in documents:
   210	            for term in set(document):
   211	                frequencies[term] = frequencies.get(term, 0) + 1
   212	        return frequencies
