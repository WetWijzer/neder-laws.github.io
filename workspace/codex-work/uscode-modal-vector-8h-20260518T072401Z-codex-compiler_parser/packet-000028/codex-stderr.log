   399	def test_modal_codec_encodes_all_modal_families_with_frame_logic() -> None:
   400	    codec = DeterministicModalLogicCodec(
   401	        ModalLogicCodecConfig(parser_backend="spacy", embedding_dimensions=8)
   402	    )
   403	
   404	    result = codec.encode(
   405	        "The agency must provide notice within 30 days after application.",
   406	        document_id="sample-doc",
   407	        citation="5 U.S.C. 552",
   408	        source="us_code",
   409	    )
   410	
   411	    families = {formula.operator.family for formula in result.modal_ir.formulas}
   412	    assert {"deontic", "temporal"}.issubset(families)
   413	    assert result.modal_ir.metadata["llm_call_count"] == 0
   414	    assert result.selected_frame == "administrative_notice_hearing"
   415	    assert result.modal_ir.frame_candidates
   416	    assert len(result.decoded_embedding) == 8
   417	    assert result.losses["cross_entropy_loss"] >= 0.0
   418	    assert "flogic_similarity_loss" in result.losses
   419	    assert result.losses["text_reconstruction_loss"] == 0.0
   420	    assert result.losses["modal_span_coverage_loss"] == 0.0
   421	    assert -1.0 <= result.losses["cosine_similarity"] <= 1.0
   422	    assert result.flogic_result is not None
   423	    assert result.flogic_result.ontology_consistent is True
   424	    assert result.kg_triples
   425	    assert all(triple["predicate"] for triple in result.kg_triples)
   426	    assert result.modal_ir.frame_logic.triples
   427	    assert result.modal_ir.frame_logic.to_triples() == result.kg_triples
   428	    assert result.modal_ir.frame_logic.selected_frame == result.selected_frame
   429	    assert result.modal_ir.frame_logic.graph_id == "sample-doc:flogic"
   430	    assert "LegalModalDocument" in result.modal_ir.frame_logic.neo4j_node_labels
   431	    assert result.modal_ir.metadata["flogic_triple_count"] == len(result.kg_triples)
   432	    assert result.modal_ir.metadata["flogic_triples"] == result.kg_triples
   433	    assert result.flogic_ontology.frames
   434	    assert result.neo4j_graph_data.metadata["neo4j_compatible"] is True
   435	    assert result.neo4j_graph_data.node_count > 0
   436	    assert result.neo4j_graph_data.relationship_count == len(result.kg_triples)
   437	    assert "LegalModalDocument" in result.neo4j_graph_data.schema.node_labels
   438	    engine, import_report = import_graph_data_to_graph_engine(result.neo4j_graph_data)
   439	    assert import_report["nodes_imported"] == result.neo4j_graph_data.node_count
   440	    assert import_report["relationships_imported"] == result.neo4j_graph_data.relationship_count
   441	    assert engine.find_nodes(labels=["LegalModalDocument"], properties={"name": "sample-doc"})
   442	    assert any(
