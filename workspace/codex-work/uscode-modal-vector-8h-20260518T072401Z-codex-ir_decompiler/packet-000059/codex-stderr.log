+        mixed_triples,
+        "citation_section_component_signature_positioned",
+    ) == ["1:N3A3", "2:N1"]
+    assert objects(mixed_triples, "citation_section_primary_component_signature") == [
+        "N3A3"
+    ]
+    assert objects(mixed_triples, "citation_section_terminal_component_signature") == [
+        "N1"
+    ]
