    81	def iter_uscode_records_from_parquet(
    82	    laws_parquet: str | Path | BinaryIO,
    83	    *,
    84	    limit: Optional[int] = None,
    85	    offset: int = 0,
    86	    batch_size: int = 128,
    87	) -> Iterator[USCodeParquetRecord]:
    88	    """Yield U.S. Code records from a local or file-like parquet source."""
    89	    if offset < 0:
    90	        raise ValueError("offset must be >= 0")
    91	    if limit is not None and limit <= 0:
    92	        return
    93	    skipped = 0
    94	    for row in _iter_parquet_rows(laws_parquet, columns=_LAW_COLUMNS, batch_size=batch_size):
    95	        if skipped < offset:
    96	            skipped += 1
    97	            continue
    98	        yield USCodeParquetRecord.from_row(row)
    99	        if limit is not None:
   100	            limit -= 1
   101	            if limit <= 0:
   102	                break
