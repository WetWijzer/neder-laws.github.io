  1728	def _token_overlap_ratio(left: str, right: str) -> float:
  1729	    left_tokens = {
  1730	        token.lower()
  1731	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
  1732	    }
  1733	    right_tokens = {
  1734	        token.lower()
  1735	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
  1736	    }
  1737	    if not left_tokens:
  1738	        return 1.0 if not right_tokens else 0.0
  1739	    return len(left_tokens & right_tokens) / len(left_tokens)

