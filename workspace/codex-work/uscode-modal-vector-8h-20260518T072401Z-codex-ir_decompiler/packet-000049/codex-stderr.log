+    assert section_marker_slot_map["citation_section_primary"] == ["190l"]
+    assert section_marker_slot_map["citation_section_component_profile"] == [
+        "single_alphanumeric"
+    ]
+    assert section_marker_slot_map["citation_section_has_delimiter"] == ["false"]
