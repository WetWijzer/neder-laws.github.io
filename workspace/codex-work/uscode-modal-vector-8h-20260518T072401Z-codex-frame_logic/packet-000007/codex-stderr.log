   124	                    ontology_terms=ontology_terms,
   125	                    explanation=self._explain(frame, matched_terms, score),
   126	                )
   127	            )
   128	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   129	        return results[:max(top_k, 0)]
   130	
   131	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   132	        if not query_terms or not document or not self.frames:
   133	            return 0.0
   134	        doc_len = len(document)
   135	        term_counts = {term: document.count(term) for term in set(document)}
   136	        total = 0.0
   137	        for term in query_terms:
   138	            freq = term_counts.get(term, 0)
   139	            if freq == 0:
   140	                continue
   141	            doc_freq = self._doc_freq.get(term, 0)
   142	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   143	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   144	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   145	        return total
