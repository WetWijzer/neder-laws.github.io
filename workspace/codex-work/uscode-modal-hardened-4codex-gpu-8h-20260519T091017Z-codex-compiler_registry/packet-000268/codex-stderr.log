   391	def _ordered_unique_adaptive_ambiguity_family_pairs(
   392	    pairs: Iterable[Tuple[str, str]],
   393	) -> Tuple[Tuple[str, str], ...]:
   394	    """Return a stable pair table with duplicates removed and order preserved."""
   395	    unique_pairs: list[Tuple[str, str]] = []
   396	    seen_pairs: set[Tuple[str, str]] = set()
   397	    for pair in pairs:
   398	        if pair in seen_pairs:
   399	            continue
   400	        seen_pairs.add(pair)
   401	        unique_pairs.append(pair)
   402	    return tuple(unique_pairs)
