                "scope:pursuant_to_subsection_(b)",
                "authority:as_provided_in_paragraph_(1)",
            ],
            role="clause",
        ),
        provenance=ModalIRProvenance(
            source_id="statutory-doc",
            start_char=0,
            end_char=86,
            citation="5 U.S.C. 552",
        ),
        conditions=["under section 552(a)(1)"],
    )
    document = ModalIRDocument(
