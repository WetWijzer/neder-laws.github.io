            check_ontology_consistency=False,
        )
    )

    result = optimizer.evaluate(
        source_text="source",
        decoded_text="decoded",
        source_embedding=[1.0, 0.0],
        decoded_embedding=[1.0, 0.0],
        kg_triples=[],
