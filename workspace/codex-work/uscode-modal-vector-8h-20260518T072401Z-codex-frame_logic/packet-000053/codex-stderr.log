   383	    def _explain(self, frame: FrameCandidate, matched_terms: Sequence[str], score: float) -> str:
   384	        if matched_terms:
   385	            return f"Frame {frame.frame_id} matched {', '.join(matched_terms)} with BM25 score {score:.3f}."
   386	        return f"Frame {frame.frame_id} had no lexical query matches; BM25 score {score:.3f}."
