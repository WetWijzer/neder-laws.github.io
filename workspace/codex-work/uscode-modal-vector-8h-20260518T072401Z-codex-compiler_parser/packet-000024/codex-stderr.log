from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_modal_parser import LegalModalParser
from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler, ModalCompilerConfig
import pyarrow.parquet as pq
path='/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet'
pf=pq.ParquetFile(path)
need={('2','130a'):('us-code-2-130a-a14e984db7a8af87','2 U.S.C. 130a'),('4','123'):('us-code-4-123-d46eff3eecad7d48','4 U.S.C. 123'),('5','5564'):('us-code-5-5564-bdff7b035cd4f4cc','5 U.S.C. 5564')}
rows={}
for batch in pf.iter_batches(columns=['title_number','section_number','text'], batch_size=20000):
    for r in batch.to_pylist():
        key=(str(r.get('title_number')).strip(),str(r.get('section_number')).strip())
        if key in need:
            rows[key]=str(r.get('text') or '')

parser=LegalModalParser()
compiler=DeterministicModalCompiler(ModalCompilerConfig(parser_backend='regex'))
for key,(doc_id,citation) in need.items():
    text=rows[key]
    doc=parser.parse(text,document_id=doc_id,source='us_code',citation=citation)
    print('===',doc_id,citation)
    print('formulas',len(doc.formulas))
    for i,f in enumerate(doc.formulas[:5],1):
        print(i,f.operator.family,f.metadata.get('cue'),f.metadata.get('fallback_rule'),f.predicate.name[:80])
    if len(doc.formulas)>5:
        print('...')
    comp=compiler.compile(text,document_id=doc_id,citation=citation,source='us_code')
    miss=[a for a in comp.ambiguities if a.ambiguity_type=='missing_modal_formula']
    print('compile formulas',len(comp.modal_ir.formulas),'missing ambiguity',bool(miss))
    print('families',sorted({f.operator.family for f in comp.modal_ir.formulas}))
PY" in /home/barberb/portland-laws.github.io/workspace/codex-work/uscode-modal-vector-8h-20260518T072401Z-codex-compiler_parser/worktrees/agent-codex-compiler_parser-packet-000024-20260518_095913
