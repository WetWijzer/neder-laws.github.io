   521	
   522	def _unique_preserve_order(features: Iterable[str]) -> List[str]:
   523	    seen: set[str] = set()
   524	    result: List[str] = []
   525	    for feature in features:
   526	        if feature in seen:
   527	            continue
   528	        seen.add(feature)
   529	        result.append(feature)
   530	    return result
