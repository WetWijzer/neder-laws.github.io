    60	class LegalModalParser:
    61	    """Small deterministic parser that compiles legal text into modal IR."""
    62	
    63	    def __init__(self, registry: ModalRegistry = DEFAULT_MODAL_REGISTRY) -> None:
    64	        self.registry = registry
    65	
    66	    def normalize_text(self, text: str) -> str:
    67	        """Normalize whitespace while preserving legal punctuation."""
    68	        return _WHITESPACE_RE.sub(" ", text).strip()
    69	
    70	    def segment(self, text: str) -> List[LegalSegment]:
    71	        """Split normalized legal text into deterministic legal segments."""
    72	        normalized = self.normalize_text(text)
    73	        segments: List[LegalSegment] = []
    74	        for match in _SEGMENT_RE.finditer(normalized):
    75	            segment_text = match.group(0).strip()
    76	            if not segment_text:
    77	                continue
    78	            segments.append(
    79	                LegalSegment(
    80	                    text=segment_text,
    81	                    start_char=match.start(),
    82	                    end_char=match.end(),
    83	                    role=self._classify_segment_role(segment_text),
    84	                )
    85	            )
    86	        return segments
    87	
    88	    def extract_cues(self, text: str) -> List[ModalCueSpan]:
    89	        """Extract modal cue spans from text using registry cue terms."""
    90	        normalized = self.normalize_text(text)
    91	        found: List[ModalCueSpan] = []
    92	        for profile in self.registry.all_profiles():
    93	            for operator in profile.operators:
    94	                for cue in operator.cue_terms:
    95	                    pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
    96	                    for match in pattern.finditer(normalized):
    97	                        found.append(
    98	                            ModalCueSpan(
    99	                                family=profile.family,
   100	                                profile=profile,
   101	                                operator=operator,
   102	                                cue=cue,
   103	                                start_char=match.start(),
   104	                                end_char=match.end(),
   105	                            )
   106	                        )
   107	        return sorted(found, key=lambda cue: (cue.start_char, cue.end_char, cue.family.value, cue.operator.symbol))
   108	
   109	    def parse(
   110	        self,
   111	        text: str,
   112	        *,
   113	        document_id: Optional[str] = None,
   114	        source: str = "legal_text",
   115	        citation: Optional[str] = None,
   116	    ) -> ModalIRDocument:
   117	        """Parse legal text into canonical modal IR."""
   118	        normalized = self.normalize_text(text)
   119	        resolved_document_id = document_id or self._document_id(normalized)
   120	        segments = self.segment(normalized)
   121	        cues = self.extract_cues(normalized)
   122	        formulas: List[ModalIRFormula] = []
   123	
   124	        for index, cue in enumerate(cues, start=1):
   125	            segment = self._segment_for_cue(segments, cue)
   126	            predicate = self._predicate_from_segment(segment.text, cue.cue)
   127	            conditions, exceptions = self._conditions_and_exceptions_from_segment(
   128	                segment.text
   129	            )
   130	            formulas.append(
   131	                ModalIRFormula(
   132	                    formula_id=f"{resolved_document_id}:f{index:04d}",
   133	                    operator=ModalIROperator(
   134	                        family=cue.family.value,
   135	                        system=cue.profile.system.value,
   136	                        symbol=cue.operator.symbol,
   137	                        label=cue.operator.aliases[0] if cue.operator.aliases else cue.operator.symbol,
   138	                    ),
   139	                    predicate=ModalIRPredicate(
   140	                        name=predicate,
   141	                        arguments=[],
   142	                        role=segment.role,
   143	                    ),
   144	                    provenance=ModalIRProvenance(
   145	                        source_id=resolved_document_id,
   146	                        start_char=segment.start_char,
   147	                        end_char=segment.end_char,
   148	                        citation=citation,
   149	                    ),
   150	                    conditions=conditions,
   151	                    exceptions=exceptions,
   152	                    metadata={
   153	                        "cue": cue.cue,
   154	                        "cue_start_char": cue.start_char,
   155	                        "cue_end_char": cue.end_char,
   156	                    },
   157	                )
   158	            )
   159	
   160	        fallback_formula = self._uscode_codification_fallback_formula(
   161	            resolved_document_id=resolved_document_id,
   162	            normalized_text=normalized,
   163	            citation=citation,
   164	            segments=segments,
   165	            start_index=len(formulas) + 1,
   166	        )
   167	        if fallback_formula is not None:
   168	            formulas.append(fallback_formula)
   169	
   170	        return ModalIRDocument(
   171	            document_id=resolved_document_id,
   172	            source=source,
   173	            normalized_text=normalized,
   174	            formulas=formulas,
   175	            metadata={
   176	                "citation": citation,
   177	                "deterministic_parser": "legal_modal_parser_v1",
   178	                "segment_count": len(segments),
   179	            },
   180	        )
