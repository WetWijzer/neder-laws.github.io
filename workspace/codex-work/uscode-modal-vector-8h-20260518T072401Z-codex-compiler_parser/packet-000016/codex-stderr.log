   284	    def _segment_for_cue(self, segments: Iterable[LegalSegment], cue: ModalCueSpan) -> LegalSegment:
   285	        for segment in segments:
   286	            if segment.start_char <= cue.start_char < segment.end_char:
   287	                return segment
   288	        return LegalSegment(text="", start_char=cue.start_char, end_char=cue.end_char)
