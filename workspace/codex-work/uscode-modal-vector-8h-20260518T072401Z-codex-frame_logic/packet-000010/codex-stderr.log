   174	def frame_ontology_terms(
   175	    frame: FrameCandidate,
   176	    *,
   177	    matched_terms: Sequence[str] = (),
   178	    max_terms: int = 24,
   179	) -> List[str]:
   180	    """Return deterministic ontology terms for one frame candidate.
   181	
   182	    The term list is intentionally stable and explainable: we keep canonical
   183	    phrase forms plus tokenized atoms for frame id/label/domain/terms and the
   184	    lexical matches that affected BM25 scoring.
   185	    """
   186	
   187	    raw_values = [
   188	        (frame.frame_id, False),
   189	        *((value, True) for value in matched_terms),
   190	        (frame.label, True),
   191	        (frame.domain, True),
   192	        *((value, True) for value in frame.terms),
   193	    ]
   194	    terms: List[str] = []
   195	    for raw, include_tokens in raw_values:
   196	        text = str(raw or "").strip()
   197	        if not text:
   198	            continue
   199	        canonical = normalize_frame_ontology_term(text)
   200	        if canonical and canonical not in terms:
   201	            terms.append(canonical)
   202	            if len(terms) >= max_terms:
   203	                break
   204	        if include_tokens:
   205	            for token in _informative_ontology_tokens(text):
   206	                if token not in terms:
   207	                    terms.append(token)
   208	                    if len(terms) >= max_terms:
   209	                        break
   210	        if len(terms) >= max_terms:
   211	            break
   212	    return terms
