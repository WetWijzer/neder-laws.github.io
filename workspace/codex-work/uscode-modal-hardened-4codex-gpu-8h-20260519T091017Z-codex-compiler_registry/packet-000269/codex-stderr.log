    )
    epistemic_scope_phrase = _contains_scope_phrase(
        normalized_text, _EPISTEMIC_SCOPE_PHRASES
    )
    temporal_scope_phrase = _contains_scope_phrase(
        normalized_text, _TEMPORAL_SCOPE_PHRASES
