            )
        )
        frame_ontology_terms_from_kg_triples = _sorted_unique_terms(
            frame_ontology_terms_from_triples(
                kg_triples or [],
                max_terms=_FRAME_ONTOLOGY_AUDIT_MAX_TERMS,
            )
        )
