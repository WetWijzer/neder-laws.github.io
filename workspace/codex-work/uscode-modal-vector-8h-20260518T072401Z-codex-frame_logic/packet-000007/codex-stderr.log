   486	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   487	    """Render one modal IR formula into a stable formula-like string."""
   488	    arguments = ", ".join(formula.predicate.arguments)
   489	    predicate = formula.predicate.name
   490	    if arguments:
   491	        predicate = f"{predicate}({arguments})"
   492	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
