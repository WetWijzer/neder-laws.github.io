    unpicked = [f for f in flogic if f not in frame_keys]
    print(f\"\\n{sample.sample_id}\")
    print('frame_keys', len(frame_keys), 'terms', len(terms))
    print('terms[:12]=', terms[:12])
    if unpicked:
        print('unpicked_flogic[:12]=', unpicked[:12])
