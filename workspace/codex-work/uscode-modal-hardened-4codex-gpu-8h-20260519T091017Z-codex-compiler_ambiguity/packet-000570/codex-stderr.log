   407	def _ordered_unique_adaptive_ambiguity_family_pairs(
   408	    pairs: Iterable[Tuple[str, str]],
   409	) -> Tuple[Tuple[str, str], ...]:
   410	    """Return a stable pair table with duplicates removed and order preserved."""
   411	    unique_pairs: list[Tuple[str, str]] = []
   412	    seen_pairs: set[Tuple[str, str]] = set()
   413	    for pair in pairs:
   414	        if pair in seen_pairs:
   415	            continue
   416	        seen_pairs.add(pair)
   417	        unique_pairs.append(pair)
   418	    return tuple(unique_pairs)
