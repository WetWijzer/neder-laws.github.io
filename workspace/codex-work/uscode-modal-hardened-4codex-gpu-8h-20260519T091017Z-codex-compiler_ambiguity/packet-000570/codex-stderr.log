   828	class ModalRegistry:
   829	    """Lookup table for modal parse profiles."""
   830	
   831	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   832	        self._profiles: Dict[str, ModalParseProfile] = {
   833	            profile.profile_id: profile for profile in profiles
   834	        }
   835	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   836	            profile.family: profile for profile in profiles
   837	        }
   838	
   839	    def get_profile(
   840	        self,
   841	        family: ModalLogicFamily | str,
   842	        system: Optional[ModalSystem | str] = None,
   843	    ) -> ModalParseProfile:
   844	        """Get a profile by family, optionally constrained by system."""
   845	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   846	        if system is None:
   847	            return self._by_family[resolved_family]
   848	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   849	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   850	
   851	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   852	        """Return all profiles in deterministic order."""
   853	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   854	
   855	    def to_dict(self) -> Mapping[str, object]:
   856	        """Return a stable JSON-ready registry mapping."""
   857	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   858	
