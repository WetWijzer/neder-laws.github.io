   402	def frame_ontology_feature_keys(
   403	    feature_keys: Iterable[str],
   404	    *,
   405	    max_keys: int = 256,
   406	) -> List[str]:
   407	    """Return unique frame-linked feature keys in stable encounter order."""
   408	    result: List[str] = []
   409	    for feature_key in feature_keys:
   410	        feature = str(feature_key or "").strip()
   411	        if not feature or feature in result:
   412	            continue
   413	        if not is_frame_ontology_feature_key(feature):
   414	            continue
   415	        result.append(feature)
   416	        if len(result) >= max_keys:
   417	            break
   418	    return result
   419	
   420	
   421	def _informative_ontology_tokens(
   422	    value: str,
   423	    *,
   424	    keep_numeric_tokens: bool = False,
   425	) -> List[str]:
   426	    tokens = _ONTOLOGY_TERM_TOKEN_RE.findall(str(value or "").lower())
   427	    return [
   428	        token
   429	        for token in tokens
   430	        if _is_informative_ontology_token(
   431	            token,
   432	            keep_numeric_tokens=keep_numeric_tokens,
   433	        )
   434	    ]
   435	
   436	
   437	def _is_informative_ontology_token(
   438	    token: str,
   439	    *,
   440	    keep_numeric_tokens: bool = False,
   441	) -> bool:
   442	    if token.isdigit():
   443	        return keep_numeric_tokens
   444	    if len(token) < 2:
   445	        return False
   446	    if token in _FRAME_ONTOLOGY_STOPWORDS:
   447	        return False
   448	    return any(character.isalpha() for character in token)
