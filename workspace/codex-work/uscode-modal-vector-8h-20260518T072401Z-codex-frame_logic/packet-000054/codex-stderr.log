        subject_map: Dict[str, Dict[str, str]] = {}
        for triple in kg_triples:
            subj = triple.get("subject", "")
            pred = triple.get("predicate", "")
            obj = triple.get("object", "")
            if not subj:
                continue
            if subj not in subject_map:
                subject_map[subj] = {}
            subject_map[subj][pred] = obj


