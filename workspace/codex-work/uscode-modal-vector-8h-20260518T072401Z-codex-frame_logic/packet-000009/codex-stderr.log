+        if triple["predicate"] in {
+            "candidate_ontology_term",
+            "selected_ontology_term",
+            "interpreted_in_frame_term",
+        }
+    }
+    assert "and" not in term_objects
+    assert "the" not in term_objects
+    assert "hearing_rights" in term_objects
+
