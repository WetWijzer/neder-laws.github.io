I’m going to run a local parquet scan for files with U.S.C.-style columns (`title_number`, `section_number`, `text`) and extract rows for sections `26/6503`, `45/163`, and `50/403` so we can anchor the rule to real sample text.
exec
/bin/bash -lc "python - <<'PY'
import os
from pathlib import Path

base = Path('/home/barberb/portland-laws.github.io/workspace')
paths = []
for root, dirs, files in os.walk(base):
    # prune huge .git dirs
    dirs[:] = [d for d in dirs if d "'!= '"'.git' and d "'!= '"'__pycache__']
    for f in files:
        if f.endswith('.parquet'):
            paths.append(Path(root)/f)

try:
    import pyarrow.parquet as pq
except Exception as e:
    print('pyarrow unavailable', e)
    raise SystemExit(0)

need = {('26','6503'), ('45','163'), ('50','403')}
found_any = False
checked = 0
for p in paths:
    try:
        pf = pq.ParquetFile(p)
    except Exception:
        continue
    cols = set(pf.schema_arrow.names)
    required = {'title_number','section_number'}
    if not required.issubset(cols):
        continue
    text_col = None
    for candidate in ('text','law_name','normalized_citation','citation_text'):
        if candidate in cols:
            text_col = candidate
            break
    if text_col is None:
        continue
    checked += 1
    selected = ['title_number','section_number',text_col]
    for optional in ('normalized_citation','citation_text','law_name'):
        if optional in cols and optional not in selected:
            selected.append(optional)
    try:
        for batch in pf.iter_batches(batch_size=256, columns=selected):
            for row in batch.to_pylist():
                t = str(row.get('title_number','')).strip()
                s = str(row.get('section_number','')).strip().rstrip('.')
                key = (t, s)
                if key in need:
                    found_any = True
                    print('\\nMATCH', key, 'file=', p)
                    citation = row.get('normalized_citation') or row.get('citation_text') or ''
                    print('citation=', str(citation)[:200])
                    text = row.get(text_col) or ''
                    txt = str(text).replace('\\n',' ')
                    print('text_col=', text_col, 'text=', txt[:600])
    except Exception:
        continue

print('\\nChecked parquet files with title/section schema:', checked)
print('Found matches:', found_any)
