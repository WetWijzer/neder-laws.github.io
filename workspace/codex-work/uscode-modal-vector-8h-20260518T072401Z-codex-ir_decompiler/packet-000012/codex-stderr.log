+            start_char=29,
+            end_char=57,
+            citation="26 U.S.C. 6050K",
+        ),
+        metadata={"fallback_rule": "uscode_section_heading_v1"},
+    )
+    document = ModalIRDocument(
+        document_id="citation-shape-doc",
+        source="us_code",
+        normalized_text="Sec. 31a-2b. Example heading. Sec. 6050K. Another heading.",
