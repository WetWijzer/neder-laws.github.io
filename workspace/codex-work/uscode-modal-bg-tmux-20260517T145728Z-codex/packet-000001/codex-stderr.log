    14	def test_parser_normalizes_and_segments_legal_text() -> None:
    15	    parser = LegalModalParser()
    16	    text = "  The agency   must provide notice. Unless waived, the applicant may appeal. "
    17	
    18	    segments = parser.segment(text)
    19	
    20	    assert [segment.text for segment in segments] == [
    21	        "The agency must provide notice.",
    22	        "Unless waived, the applicant may appeal.",
    23	    ]
    24	    assert segments[1].role == "condition"
    25	
    26	
    27	def test_parser_extracts_deontic_and_temporal_cues() -> None:
    28	    parser = LegalModalParser()
    29	
    30	    cues = parser.extract_cues("The agency must respond within 30 days.")
    31	    families = {cue.family.value for cue in cues}
    32	    cue_terms = {cue.cue for cue in cues}
    33	
    34	    assert "deontic" in families
    35	    assert "temporal" in families
    36	    assert {"must", "within"}.issubset(cue_terms)
    37	
