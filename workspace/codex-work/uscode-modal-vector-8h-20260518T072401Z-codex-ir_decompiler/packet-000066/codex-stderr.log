  1407	def _merged_formula_spans(
  1408	    formulas: Sequence[ModalIRFormula],
  1409	    source_length: int,
  1410	) -> List[Tuple[int, int]]:
  1411	    spans: List[Tuple[int, int]] = []
  1412	    for formula in formulas:
  1413	        start = max(0, min(source_length, int(formula.provenance.start_char)))
  1414	        end = max(start, min(source_length, int(formula.provenance.end_char)))
  1415	        if end > start:
  1416	            spans.append((start, end))
  1417	    if not spans:
  1418	        return []
  1419	
  1420	    spans.sort()
  1421	    merged: List[Tuple[int, int]] = []
  1422	    current_start, current_end = spans[0]
  1423	    for start, end in spans[1:]:
  1424	        if start <= current_end:
  1425	            current_end = max(current_end, end)
  1426	            continue
  1427	        merged.append((current_start, current_end))
  1428	        current_start, current_end = start, end
  1429	    merged.append((current_start, current_end))
  1430	    return merged
