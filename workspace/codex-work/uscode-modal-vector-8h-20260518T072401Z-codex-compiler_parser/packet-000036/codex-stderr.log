import duckdb
from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler, ModalCompilerConfig
p='/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet'
con=duckdb.connect()
rows=con.execute(\"\"\"
SELECT title_number, section_number, law_name, text
FROM read_parquet(?)
WHERE (title_number='42' AND lower(section_number)='1395w' AND law_name LIKE '–131.%')
   OR (title_number='5' AND lower(section_number)='3110')
   OR (title_number='16' AND lower(section_number)='2204')
ORDER BY title_number, section_number
\"\"\",[p]).fetchall()
for backend in ('regex','spacy'):
    print('=== backend',backend)
    compiler=DeterministicModalCompiler(ModalCompilerConfig(parser_backend=backend, spacy_model_name='definitely_missing_legal_model'))
    for title,section,law_name,text in rows:
        citation=f\"{title} U.S.C. {section}\"
        sid=f\"us-code-{title}-{section}\"
        compiled=compiler.compile(text,document_id=sid,citation=citation,source='us_code')
        print('---',citation,'law_name=',law_name)
        print('text_len',len(text or ''),'formula_count',len(compiled.modal_ir.formulas),'ambiguities',[a.ambiguity_type for a in compiled.ambiguities])
        if compiled.modal_ir.formulas:
            last=compiled.modal_ir.formulas[-1]
            print(' last_family',last.operator.family,'cue',last.metadata.get('cue'),'fallback',last.metadata.get('fallback_rule'),'role',last.predicate.role)
            fams={f.operator.family for f in compiled.modal_ir.formulas}
            print(' families',sorted(fams))
        print(' text_head', (text or '').replace('\\n',' ')[:260])
