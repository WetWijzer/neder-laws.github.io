+                slot=slot,
+                spans=spans,
+                provenance_only=True,
+            )
+        )
+
+
+def _statutory_scope_slots(text: str) -> List[Tuple[str, str]]:
+    normalized = _clean_text(text).replace("_", " ").lower()
