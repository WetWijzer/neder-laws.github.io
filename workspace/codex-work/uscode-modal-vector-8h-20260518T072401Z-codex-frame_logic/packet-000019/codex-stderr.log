   249	def modal_text_token_similarity(left: str, right: str) -> float:
   250	    """Return deterministic token-set F1 similarity for reconstruction checks."""
   251	    left_tokens = set(_tokenize_for_similarity(left))
   252	    right_tokens = set(_tokenize_for_similarity(right))
   253	    if not left_tokens and not right_tokens:
   254	        return 1.0
   255	    if not left_tokens or not right_tokens:
   256	        return 0.0
   257	    overlap = len(left_tokens & right_tokens)
   258	    if overlap == 0:
   259	        return 0.0
   260	    precision = overlap / len(right_tokens)
   261	    recall = overlap / len(left_tokens)
   262	    return round((2.0 * precision * recall) / (precision + recall), 6)
