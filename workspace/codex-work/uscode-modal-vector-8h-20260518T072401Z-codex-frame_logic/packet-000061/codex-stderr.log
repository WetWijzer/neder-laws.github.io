  4056	                    return
  4057	            _collect_frame_ontology_metadata_values(
  4058	                value,
  4059	                extracted,
  4060	                depth=depth + 1,
  4061	            )
  4062	            if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4063	                return
  4064	        return
  4065	    if isinstance(values, Sequence) and not isinstance(values, (str, bytes)):
  4066	        for value in values:
  4067	            _collect_frame_ontology_metadata_values(
  4068	                value,
  4069	                extracted,
  4070	                depth=depth + 1,
  4071	            )
  4072	            if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4073	                return
  4074	        return
