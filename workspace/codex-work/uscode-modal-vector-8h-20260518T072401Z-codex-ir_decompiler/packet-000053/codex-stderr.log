        _normalized_modal_family_counts(modal_ir.metadata.get("modal_family_counts")),
        start=1,
    ):
        components.extend(
            [
                ("modal_family_count", f"{family}:{count}"),
                ("modal_family_count_ranked", f"{rank}:{family}:{count}"),
