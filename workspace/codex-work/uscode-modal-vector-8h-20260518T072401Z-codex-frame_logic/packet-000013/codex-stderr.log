    45	
    46	def cross_entropy_distribution_loss(
    47	    probabilities: Mapping[str, float],
    48	    target_distribution: Mapping[str, float],
    49	) -> float:
    50	    """Return cross entropy against a target label distribution."""
    51	    total_weight = sum(
    52	        max(0.0, float(weight))
    53	        for weight in target_distribution.values()
    54	    )
    55	    if total_weight <= 0.0:
    56	        return 0.0
    57	    loss = 0.0
    58	    for family, weight in target_distribution.items():
    59	        normalized_weight = max(0.0, float(weight)) / total_weight
    60	        probability = max(float(probabilities.get(str(family), 0.0)), 1e-12)
    61	        loss += normalized_weight * -math.log(probability)
    62	    return loss
