   180	
   181	    def _attach_metadata(
   182	        self,
   183	        modal_ir: ModalIRDocument,
   184	        frame_selections: Sequence[FrameSelection],
   185	        *,
   186	        parser_name: str,
   187	        selected_frame: Optional[str],
   188	        ambiguity_count: int,
   189	        encoding: SpaCyLegalEncoding,
   190	    ) -> ModalIRDocument:
   191	        frame_candidates = [
   192	            ModalIRFrame(
   193	                frame_id=selection.frame.frame_id,
   194	                score=selection.score,
   195	                matched_terms=list(selection.matched_terms),
   196	                explanation=selection.explanation,
   197	            )
   198	            for selection in frame_selections
   199	        ]
   200	        metadata = {
   201	            **modal_ir.metadata,
   202	            "ambiguity_count": ambiguity_count,
   203	            "deterministic_compiler": "modal_compiler_v1",
   204	            "deterministic_parser": parser_name,
   205	            "frame_selector": "bm25_v1",
   206	            "llm_call_count": 0,
   207	            "modal_family_counts": encoding.modal_family_counts(),
   208	            "selected_frame": selected_frame,
   209	        }
   210	        return replace(modal_ir, frame_candidates=frame_candidates, metadata=metadata)
   211	
   212	    def _formula_ambiguities(
   213	        self,
   214	        modal_ir: ModalIRDocument,
   215	    ) -> List[ModalCompilationAmbiguity]:
   216	        by_span: Dict[tuple[int, int], List[str]] = {}
   217	        for formula in modal_ir.formulas:
   218	            span = (formula.provenance.start_char, formula.provenance.end_char)
   219	            candidate = (
   220	                f"{formula.formula_id}:{formula.operator.family}:"
   221	                f"{formula.operator.system}:{formula.operator.symbol}"
   222	            )
   223	            by_span.setdefault(span, []).append(candidate)
   224	
   225	        ambiguities: List[ModalCompilationAmbiguity] = []
   226	        for span, candidates in sorted(by_span.items()):
   227	            families = {candidate.split(":")[1] for candidate in candidates}
   228	            if len(candidates) > 1 and len(families) > 1:
   229	                ambiguities.append(
   230	                    ModalCompilationAmbiguity(
   231	                        ambiguity_type="multi_family_same_span",
   232	                        message="Multiple modal families were compiled from the same text span.",
   233	                        candidate_ids=sorted(candidates),
   234	                        metadata={"span": list(span)},
   235	                    )
   236	                )
   237	        return ambiguities
   238	
   239	    def _frame_ambiguities(
   240	        self,
   241	        frame_selections: Sequence[FrameSelection],
   242	    ) -> List[ModalCompilationAmbiguity]:
   243	        if len(frame_selections) < 2:
   244	            return []
   245	        first, second = frame_selections[0], frame_selections[1]
   246	        margin = float(first.score) - float(second.score)
   247	        if margin > self.config.frame_score_margin:
   248	            return []
   249	        return [
   250	            ModalCompilationAmbiguity(
   251	                ambiguity_type="close_bm25_frame_scores",
   252	                message="Top ontology frame choices are close enough to require review.",
   253	                candidate_ids=[first.frame.frame_id, second.frame.frame_id],
   254	                metadata={
   255	                    "margin": round(margin, 6),
   256	                    "top_score": first.score,
   257	                    "runner_up_score": second.score,
   258	                },
   259	            )
   260	        ]

