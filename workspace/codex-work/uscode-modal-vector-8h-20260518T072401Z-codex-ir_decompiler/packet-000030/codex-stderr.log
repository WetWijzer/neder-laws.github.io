from ipfs_datasets_py.logic.modal.decompiler import decode_modal_ir_document,decoded_modal_phrase_slot_text_map
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_ir import ModalIRDocument,ModalIRFormula,ModalIROperator,ModalIRPredicate,ModalIRProvenance

def slots(citation,source_id):
    formula=ModalIRFormula(
        formula_id='f',
        operator=ModalIROperator(family='deontic',system='kd',symbol='O',label='obligatory'),
        predicate=ModalIRPredicate(name='x'),
        provenance=ModalIRProvenance(source_id=source_id,start_char=0,end_char=10,citation=citation),
    )
    doc=ModalIRDocument(document_id=source_id,source='us_code',normalized_text='x text',formulas=[formula])
    m=decoded_modal_phrase_slot_text_map(decode_modal_ir_document(doc))
    keys=[k for k in sorted(m) if k.startswith('citation_') or k.startswith('source_id_')]
    print('\\n==',citation,'==')
    for k in keys:
        print(k,':',m[k])

for title,sec in [('42','300gg'),('50','494.'),('43','641.'),('18','982'),('7','1441a')]:
    citation=f'{title} U.S.C. {sec}'
    source_id=f'us-code-{title}-{sec}-0123456789abcdef'
    slots(citation,source_id)
