   629	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
   630	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
   631	    slot = int.from_bytes(digest[:4], "big") % dimensions
   632	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
   633	    magnitude = 0.5 + (digest[5] / 255.0)
   634	    return slot, sign * magnitude
