def _slot_feature_value(value: str, *, max_tokens: int = 8) -> str:
    tokens = _SLOT_FEATURE_TOKEN_RE.findall(_clean_non_empty_string(value).lower())
    if not tokens:
        return ""
    return "_".join(tokens[:max_tokens])


