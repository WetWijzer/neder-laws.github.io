    ]
    assert slot_texts["statutory_scope_unit"] == [
        "section",
        "subsection",
        "paragraph",
    ]
    assert slot_texts["statutory_scope_target"] == ["this", "(b)", "(1)", "552(a)(1)"]
    assert any(
        triple["predicate"] == "statutory_scope_reference"
        and triple["object"] == "under this section"
        for triple in triples
