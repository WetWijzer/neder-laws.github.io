    20	def stable_mock_embedding(text: str, *, dimensions: int = 8) -> List[float]:
    21	    """Create a deterministic mock embedding for tests and fixtures."""
    22	    seed = int(hashlib.sha256(text.encode("utf-8")).hexdigest()[:16], 16)
    23	    rng = random.Random(seed)
    24	    return [round(rng.uniform(-1.0, 1.0), 6) for _ in range(dimensions)]
