    96	class BM25FrameSelector:
    97	    """Deterministic BM25 ranker for ontology frame candidates."""
    98	
    99	    def __init__(
   100	        self,
   101	        frames: Iterable[FrameCandidate],
   102	        *,
   103	        k1: float = 1.5,
   104	        b: float = 0.75,
   105	    ) -> None:
   106	        self.frames = tuple(frames)
   107	        self.k1 = k1
   108	        self.b = b
   109	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
   110	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
   111	        self._doc_freq = self._build_doc_freq(self._documents)
   112	
   113	    def rank(
   114	        self,
   115	        text: str,
   116	        *,
   117	        top_k: int = 3,
   118	        domain: str | None = None,
   119	    ) -> List[FrameSelection]:
   120	        """Rank frame candidates for text."""
   121	        query_tokens = self._tokenize(text)
   122	        query_terms = sorted(set(query_tokens))
   123	        results: List[FrameSelection] = []
   124	        for frame, document in zip(self.frames, self._documents):
   125	            if domain is not None and frame.domain != domain:
   126	                continue
   127	            matched_terms = sorted(set(query_terms) & set(document))
   128	            score = self._score(query_terms, document)
   129	            if matched_terms:
   130	                score += 0.05 * len(matched_terms)
   131	            results.append(
   132	                FrameSelection(
   133	                    frame=frame,
   134	                    score=round(score, 6),
   135	                    matched_terms=matched_terms,
   136	                    explanation=self._explain(frame, matched_terms, score),
   137	                )
   138	            )
   139	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   140	        return results[:max(top_k, 0)]
   141	
   142	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   143	        if not query_terms or not document or not self.frames:
   144	            return 0.0
   145	        doc_len = len(document)
   146	        term_counts = {term: document.count(term) for term in set(document)}
   147	        total = 0.0
   148	        for term in query_terms:
   149	            freq = term_counts.get(term, 0)
   150	            if freq == 0:
   151	                continue
   152	            doc_freq = self._doc_freq.get(term, 0)
   153	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   154	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   155	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   156	        return total
   157	
   158	    def _explain(self, frame: FrameCandidate, matched_terms: Sequence[str], score: float) -> str:
   159	        if matched_terms:
   160	            return f"Frame {frame.frame_id} matched {', '.join(matched_terms)} with BM25 score {score:.3f}."
   161	        return f"Frame {frame.frame_id} had no lexical query matches; BM25 score {score:.3f}."
   162	
   163	    def _tokenize(self, text: str) -> List[str]:
   164	        return [token.lower() for token in _TOKEN_RE.findall(text)]
   165	
   166	    def _build_doc_freq(self, documents: Sequence[Sequence[str]]) -> Dict[str, int]:
   167	        frequencies: Dict[str, int] = {}
   168	        for document in documents:
   169	            for term in set(document):
   170	                frequencies[term] = frequencies.get(term, 0) + 1
   171	        return frequencies
