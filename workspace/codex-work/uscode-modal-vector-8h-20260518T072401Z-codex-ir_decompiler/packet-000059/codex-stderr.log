  2061	def _primary_terminal_number_relation(
  2062	    *,
  2063	    primary_number: str,
  2064	    terminal_number: str,
  2065	) -> tuple[str, str] | None:
  2066	    primary_text = _clean_non_empty_string(primary_number)
  2067	    terminal_text = _clean_non_empty_string(terminal_number)
  2068	    if not primary_text or not terminal_text:
  2069	        return None
  2070	    try:
  2071	        primary_value = int(primary_text)
  2072	        terminal_value = int(terminal_text)
  2073	    except (TypeError, ValueError):
  2074	        return None
  2075	    if primary_value == terminal_value:
  2076	        return ("equal", "0")
  2077	    if primary_value < terminal_value:
  2078	        return ("ascending", str(terminal_value - primary_value))
  2079	    return ("descending", str(primary_value - terminal_value))
