   511	    if lowered.startswith(_FRAME_ONTOLOGY_CUE_FEATURE_PREFIX):
   512	        cue_tail = feature[len(_FRAME_ONTOLOGY_CUE_FEATURE_PREFIX) :].strip()
   513	        if not cue_tail:
