    50	class BM25FrameSelector:
    51	    """Deterministic BM25 ranker for ontology frame candidates."""
    52	
    53	    def __init__(
    54	        self,
    55	        frames: Iterable[FrameCandidate],
    56	        *,
    57	        k1: float = 1.5,
    58	        b: float = 0.75,
    59	    ) -> None:
    60	        self.frames = tuple(frames)
    61	        self.k1 = k1
    62	        self.b = b
    63	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
    64	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
    65	        self._doc_freq = self._build_doc_freq(self._documents)
    66	
    67	    def rank(
    68	        self,
    69	        text: str,
    70	        *,
    71	        top_k: int = 3,
    72	        domain: str | None = None,
    73	    ) -> List[FrameSelection]:
    74	        """Rank frame candidates for text."""
    75	        query_tokens = self._tokenize(text)
    76	        query_terms = sorted(set(query_tokens))
    77	        results: List[FrameSelection] = []
    78	        for frame, document in zip(self.frames, self._documents):
    79	            if domain is not None and frame.domain != domain:
    80	                continue
    81	            matched_terms = sorted(set(query_terms) & set(document))
    82	            score = self._score(query_terms, document)
    83	            if matched_terms:
    84	                score += 0.05 * len(matched_terms)
    85	            results.append(
    86	                FrameSelection(
    87	                    frame=frame,
    88	                    score=round(score, 6),
    89	                    matched_terms=matched_terms,
    90	                    explanation=self._explain(frame, matched_terms, score),
    91	                )
    92	            )
    93	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
    94	        return results[:max(top_k, 0)]
    95	
    96	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
    97	        if not query_terms or not document or not self.frames:
    98	            return 0.0
    99	        doc_len = len(document)
   100	        term_counts = {term: document.count(term) for term in set(document)}
   101	        total = 0.0
   102	        for term in query_terms:
   103	            freq = term_counts.get(term, 0)
   104	            if freq == 0:
   105	                continue
   106	            doc_freq = self._doc_freq.get(term, 0)
   107	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   108	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   109	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   110	        return total
