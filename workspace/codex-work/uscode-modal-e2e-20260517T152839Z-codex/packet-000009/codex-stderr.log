)
compiled = compiler.compile(\"Within 30 days after review, the agency shall submit an annual report.\")
a = find(compiled.ambiguities, 'deontic_scope_family_outvoted')
assert a.candidate_ids == ['temporal', 'deontic']
assert a.metadata['predicted_family'] == 'temporal'
assert a.metadata['target_family'] == 'deontic'
assert a.metadata['family_margin'] < 0.0
