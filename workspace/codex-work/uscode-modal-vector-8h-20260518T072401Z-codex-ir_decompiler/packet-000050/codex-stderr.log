    document = ModalIRDocument(
        document_id=sample.document_id,
        source=sample.source,
        normalized_text=sample.normalized_text,
        formulas=list(sample.formulas),
        metadata={
            "modal_family_counts": {
                "deontic": 2,
                "temporal": 1,
            }
        },
