        frame_logic=ModalIRFrameLogic(selected_frame=selected_frame),
        metadata={
            **result.modal_ir.metadata,
            "frame_ontology_terms": {
                selected_frame: [
                    {"term": "hearing rights", "weight": 1.0},
                    {"text": "final order", "confidence": 0.9},
                ],
                alternate_frame: {
                    "terms": [
                        {"label": "housing voucher benefits"},
                        {"value": "and"},
