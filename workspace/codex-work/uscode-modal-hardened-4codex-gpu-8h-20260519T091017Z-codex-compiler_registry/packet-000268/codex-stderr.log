   105	def load_uscode_embeddings_from_parquet(
   106	    embeddings_parquet: str | Path | BinaryIO,
   107	    *,
   108	    cids: Optional[Iterable[str]] = None,
   109	    max_rows: Optional[int] = None,
   110	    batch_size: int = 512,
   111	) -> Dict[str, List[float]]:
   112	    """Load first embedding vector per CID from `laws_embeddings.parquet`."""
   113	    wanted = {str(cid) for cid in cids} if cids is not None else None
   114	    embeddings: Dict[str, List[float]] = {}
   115	    rows_seen = 0
   116	    for row in _iter_parquet_rows(embeddings_parquet, columns=_EMBEDDING_COLUMNS, batch_size=batch_size):
   117	        rows_seen += 1
   118	        cid = _clean(row.get("cid"))
   119	        if not cid or cid in embeddings:
   120	            continue
   121	        if wanted is not None and cid not in wanted:
   122	            if max_rows is not None and rows_seen >= max_rows:
   123	                break
   124	            continue
   125	        vector = row.get("embedding")
   126	        if isinstance(vector, list) and vector:
   127	            embeddings[cid] = [float(value) for value in vector]
   128	        if wanted is not None and wanted.issubset(embeddings):
   129	            break
   130	        if max_rows is not None and rows_seen >= max_rows:
   131	            break
   132	    return embeddings
   133	
