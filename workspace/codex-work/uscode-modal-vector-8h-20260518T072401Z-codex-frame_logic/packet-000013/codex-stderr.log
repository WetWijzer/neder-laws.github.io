    17	def cosine_similarity(left: Sequence[float], right: Sequence[float]) -> float:
    18	    """Return cosine similarity for two vectors."""
    19	    _check_same_length(left, right)
    20	    left_norm = math.sqrt(sum(value * value for value in left))
    21	    right_norm = math.sqrt(sum(value * value for value in right))
    22	    if left_norm == 0.0 or right_norm == 0.0:
    23	        return 0.0
    24	    return sum(a * b for a, b in zip(left, right)) / (left_norm * right_norm)
