   297	def test_modal_compiler_surfaces_adaptive_family_margin_ambiguity_for_temporal_conflicts() -> None:
   298	    compiler = DeterministicModalCompiler(
   299	        ModalCompilerConfig(
   300	            parser_backend="regex",
   301	            frame_score_margin=0.0,
   302	            modal_adaptive_family_margin=0.15,
   303	        )
   304	    )
   305	
   306	    compiled = compiler.compile(
   307	        "Notwithstanding subsection (b), within 30 days after review, the secretary shall submit the report."
   308	    )
   309	
   310	    adaptive_ambiguities = [
   311	        ambiguity
   312	        for ambiguity in compiled.ambiguities
   313	        if ambiguity.ambiguity_type == "adaptive_family_margin_low"
   314	    ]
   315	    pairs = {tuple(ambiguity.candidate_ids) for ambiguity in adaptive_ambiguities}
   316	    explicit_types = {
   317	        tuple(ambiguity.candidate_ids): str(ambiguity.metadata["explicit_ambiguity_type"])
   318	        for ambiguity in adaptive_ambiguities
   319	    }
   320	    explicit_adaptive_ambiguities = {
   321	        ambiguity.ambiguity_type: ambiguity
   322	        for ambiguity in compiled.ambiguities
   323	        if ambiguity.ambiguity_type.startswith("adaptive_")
   324	        and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   325	    }
   326	
   327	    assert ("temporal", "conditional_normative") in pairs
   328	    assert ("temporal", "deontic") in pairs
   329	    assert ("temporal", "frame") in pairs
   330	    assert (
   331	        explicit_types[("temporal", "conditional_normative")]
   332	        == "adaptive_temporal_conditional_normative_outvoted_margin_low"
   333	    )
   334	    assert (
   335	        explicit_types[("temporal", "deontic")]
   336	        == "adaptive_temporal_deontic_outvoted_margin_low"
   337	    )
   338	    assert (
   339	        explicit_types[("temporal", "frame")]
   340	        == "adaptive_temporal_frame_outvoted_margin_low"
   341	    )
   342	    assert "adaptive_temporal_conditional_normative_outvoted_margin_low" in explicit_adaptive_ambiguities
   343	    assert "adaptive_temporal_deontic_outvoted_margin_low" in explicit_adaptive_ambiguities
   344	    assert "adaptive_temporal_frame_outvoted_margin_low" in explicit_adaptive_ambiguities
   345	    assert all(
   346	        ambiguity.metadata["adaptive_base_ambiguity_type"] == "adaptive_family_margin_low"
   347	        for ambiguity in explicit_adaptive_ambiguities.values()
   348	    )
   349	    assert all(
   350	        ambiguity.metadata["adaptive_family_margin_threshold"] == 0.15
   351	        for ambiguity in adaptive_ambiguities
   352	    )
   353	    assert all(
   354	        ambiguity.metadata["adaptive_margin_direction"] == "outvoted"
   355	        for ambiguity in adaptive_ambiguities
   356	    )
   357	    assert all(ambiguity.metadata["family_margin"] < 0.0 for ambiguity in adaptive_ambiguities)
