   900	    def _family_distribution(
   901	        self,
   902	        sample: LegalSample,
   903	        *,
   904	        use_sample_memory: bool = True,
   905	    ) -> Dict[str, float]:
   906	        return _softmax(self._logits_for(sample, use_sample_memory=use_sample_memory))
   907	
   908	    def _logits_for(
   909	        self,
   910	        sample: LegalSample,
   911	        *,
   912	        use_sample_memory: bool = True,
   913	    ) -> Dict[str, float]:
   914	        if self.feature_codec is not None and hasattr(
   915	            self.feature_codec,
   916	            "family_logits_for_sample",
   917	        ):
   918	            logits = self.feature_codec.family_logits_for_sample(
   919	                sample,
   920	                modal_families=self.modal_families,
   921	            )
   922	            logits = {str(family): float(value) for family, value in logits.items()}
   923	        else:
   924	            logits = {family: 0.0 for family in self.modal_families}
   925	        for family in self.modal_families:
   926	            logits.setdefault(family, 0.0)
   927	        for feature in self._feature_keys_for(sample):
   928	            for family, value in self.state.feature_family_logits.get(feature, {}).items():
   929	                if family in logits:
   930	                    logits[family] += float(value) * self.feature_family_logit_scale
   931	        if use_sample_memory:
   932	            for family, value in self.state.family_logits.get(sample.sample_id, {}).items():
   933	                if family in logits:
   934	                    logits[family] += float(value)
   935	        return logits
   936	
   937	    def _nudge_decoded_embedding(self, sample: LegalSample, *, learning_rate: float) -> None:
   938	        step = _clamp_learning_rate(learning_rate)
   939	        current = self._decoded_for(sample)
   940	        if len(current) != len(sample.embedding_vector):
   941	            current = [0.0 for _ in sample.embedding_vector]
   942	        error = [
   943	            float(target_value) - current_value
   944	            for current_value, target_value in zip(current, sample.embedding_vector)
   945	        ]
   946	        self.state.decoded_embeddings[sample.sample_id] = [
   947	            current_value + step * (float(target_value) - current_value)
   948	            for current_value, target_value in zip(current, sample.embedding_vector)
   949	        ]
   950	        feature_keys = self._feature_keys_for(sample)
   951	        if not feature_keys:
   952	            return
   953	        feature_step = step / len(feature_keys)
   954	        for feature in feature_keys:
   955	            weights = self.state.feature_embedding_weights.setdefault(
   956	                feature,
   957	                [0.0 for _ in sample.embedding_vector],
   958	            )
   959	            if len(weights) != len(sample.embedding_vector):
   960	                weights[:] = [0.0 for _ in sample.embedding_vector]
   961	            for index, value in enumerate(error):
   962	                weights[index] += feature_step * value
   963	
   964	    def _nudge_family_logits(self, sample: LegalSample, *, learning_rate: float) -> None:
   965	        step = _clamp_learning_rate(learning_rate)
   966	        target = _target_family(sample)
   967	        logits = self.state.family_logits.setdefault(sample.sample_id, {})
   968	        logits[target] = logits.get(target, 0.0) + (2.0 * step)
   969	        for family in self.modal_families:
   970	            if family != target:
   971	                logits[family] = logits.get(family, 0.0) - (
   972	                    step / max(len(self.modal_families) - 1, 1)
   973	                )
   974	        feature_keys = self._feature_keys_for(sample)
   975	        if not feature_keys:
   976	            return
   977	        feature_step = step / len(feature_keys)
   978	        for feature in feature_keys:
   979	            feature_logits = self.state.feature_family_logits.setdefault(feature, {})
   980	            feature_logits[target] = feature_logits.get(target, 0.0) + (2.0 * feature_step)
   981	            for family in self.modal_families:
   982	                if family != target:
   983	                    feature_logits[family] = feature_logits.get(family, 0.0) - (
   984	                        feature_step / max(len(self.modal_families) - 1, 1)
   985	                    )
   986	
   987	    def _feature_embedding_adjustment(self, sample: LegalSample, *, dimensions: int) -> List[float]:
   988	        adjustment = [0.0 for _ in range(dimensions)]
   989	        for feature in self._feature_keys_for(sample):
   990	            weights = self.state.feature_embedding_weights.get(feature)
   991	            if weights is None or len(weights) != dimensions:
   992	                continue
   993	            for index, value in enumerate(weights):
   994	                adjustment[index] += float(value) * self.feature_embedding_weight_scale
   995	        return adjustment
