/bin/bash -lc "python3 - <<'PY'
from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec, ModalLogicCodecConfig, _slot_features, _frame_decoder_audit_features, _frame_ontology_audit_feature_keys
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample

sample=build_us_code_sample(title='54', section='102701.', text='Sec. 102701. Administrative provisions.')
codec=DeterministicModalLogicCodec(ModalLogicCodecConfig(parser_backend='spacy', embedding_dimensions=8))
result=codec.encode(sample.text, document_id=sample.sample_id, citation=sample.citation, source=sample.source, source_embedding=sample.embedding_vector)
enc=result.encoding
slot_keys=_slot_features(result.decoded_modal_text)
dec_keys=list(codec.decoder._feature_stream(enc))
frame_dec=_frame_decoder_audit_features(enc, codec.decoder)
audit=_frame_ontology_audit_feature_keys(modal_ir=result.modal_ir, selected_frame=result.selected_frame, kg_triples=result.kg_triples, extra_feature_keys=slot_keys+frame_dec)

print('slot total',len(slot_keys))
print('slot keys',slot_keys)
print('decoder total',len(dec_keys))
print('decoder frame keys',frame_dec)
print('audit total',len(audit))
# show slot keys not in audit and mention containing frame/source/citation/modal
missing=[k for k in slot_keys if k not in audit]
print('missing slot',missing)
print('contains frame-like missing', [k for k in missing if any(w in k for w in ['frame','source','citation','modal','condition','exception'])])
