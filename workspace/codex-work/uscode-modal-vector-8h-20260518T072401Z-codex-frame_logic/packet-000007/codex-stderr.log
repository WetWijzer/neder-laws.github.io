   105	        domain: str | None = None,
   106	    ) -> List[FrameSelection]:
   107	        """Rank frame candidates for text."""
   108	        query_tokens = self._tokenize(text)
   109	        query_terms = sorted(set(query_tokens))
   110	        results: List[FrameSelection] = []
   111	        for frame, document in zip(self.frames, self._documents):
   112	            if domain is not None and frame.domain != domain:
   113	                continue
   114	            matched_terms = sorted(set(query_terms) & set(document))
