        components.append(
            (
                "citation_section_has_roman_suffix",
                "true" if roman_suffix_component_count > 0 else "false",
            )
        )
    if primary_has_suffix is not None:
        components.append(
            (
                "citation_section_primary_has_suffix",
                "true" if primary_has_suffix else "false",
