   222	def frame_ontology_terms_from_triples(
   223	    triples: Iterable[Mapping[str, object]],
   224	    *,
   225	    max_terms: int = 64,
   226	) -> List[str]:
   227	    """Extract canonical frame ontology terms from frame-linked triples."""
   228	    terms: List[str] = []
   229	    for triple in triples:
   230	        predicate = str(triple.get("predicate", "")).strip()
   231	        if predicate not in _FRAME_ONTOLOGY_AUDIT_PREDICATES:
   232	            continue
   233	        normalized = normalize_frame_ontology_term(
   234	            str(triple.get("object", "")).strip()
   235	        )
   236	        if not normalized:
   237	            continue
   238	        if normalized in terms:
   239	            continue
   240	        terms.append(normalized)
   241	        if len(terms) >= max_terms:
   242	            break
   243	    return terms
   244	
