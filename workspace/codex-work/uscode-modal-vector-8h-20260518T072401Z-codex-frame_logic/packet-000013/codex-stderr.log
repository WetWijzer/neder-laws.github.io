   137	class BM25FrameSelector:
   138	    """Deterministic BM25 ranker for ontology frame candidates."""
   139	
   140	    def __init__(
   141	        self,
   142	        frames: Iterable[FrameCandidate],
   143	        *,
   144	        k1: float = 1.5,
   145	        b: float = 0.75,
   146	    ) -> None:
   147	        self.frames = tuple(frames)
   148	        self.k1 = k1
   149	        self.b = b
   150	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
   151	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
   152	        self._doc_freq = self._build_doc_freq(self._documents)
   153	
   154	    def rank(
   155	        self,
   156	        text: str,
   157	        *,
   158	        top_k: int = 3,
   159	        domain: str | None = None,
   160	    ) -> List[FrameSelection]:
   161	        """Rank frame candidates for text."""
   162	        query_tokens = self._tokenize(text)
   163	        query_terms = sorted(set(query_tokens))
   164	        results: List[FrameSelection] = []
   165	        for frame, document in zip(self.frames, self._documents):
   166	            if domain is not None and frame.domain != domain:
   167	                continue
   168	            matched_terms = sorted(set(query_terms) & set(document))
   169	            score = self._score(query_terms, document)
   170	            if matched_terms:
   171	                score += 0.05 * len(matched_terms)
   172	            results.append(
   173	                FrameSelection(
   174	                    frame=frame,
   175	                    score=round(score, 6),
   176	                    matched_terms=matched_terms,
   177	                    explanation=self._explain(frame, matched_terms, score),
   178	                )
   179	            )
   180	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   181	        return results[:max(top_k, 0)]
   182	
   183	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   184	        if not query_terms or not document or not self.frames:
   185	            return 0.0
   186	        doc_len = len(document)
   187	        term_counts = {term: document.count(term) for term in set(document)}
   188	        total = 0.0
   189	        for term in query_terms:
   190	            freq = term_counts.get(term, 0)
   191	            if freq == 0:
   192	                continue
   193	            doc_freq = self._doc_freq.get(term, 0)
   194	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   195	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   196	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   197	        return total
