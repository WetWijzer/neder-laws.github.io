   633	def decode_modal_ir_text(modal_ir: ModalIRDocument) -> str:
   634	    """Render a compact deterministic modal formula string for diagnostics."""
   635	    rendered = [modal_formula_to_text(formula) for formula in modal_ir.formulas]
   636	    return "; ".join(rendered)
   637	
   638	
   639	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   640	    """Render one modal IR formula into a stable formula-like string."""
   641	    arguments = ", ".join(formula.predicate.arguments)
   642	    predicate = formula.predicate.name
   643	    if arguments:
   644	        predicate = f"{predicate}({arguments})"
   645	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
   646	
   647	
   648	def target_family_for_modal_ir(modal_ir: ModalIRDocument) -> str:
   649	    """Return the training target family used for cross-entropy diagnostics."""
   650	    if not modal_ir.formulas:
   651	        return ModalLogicFamily.HYBRID.value
   652	    return modal_ir.formulas[0].operator.family
   653	
   654	
   655	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   656	    """Return observed modal-family frequencies for multi-family legal clauses."""
   657	    families = [formula.operator.family for formula in modal_ir.formulas]
   658	    if not families:
   659	        return {ModalLogicFamily.HYBRID.value: 1.0}
   660	    counts: Dict[str, int] = {}
   661	    for family in families:
   662	        counts[family] = counts.get(family, 0) + 1
   663	    total = float(sum(counts.values()))
   664	    return {
   665	        family: count / total
   666	        for family, count in sorted(counts.items())
   667	    }
