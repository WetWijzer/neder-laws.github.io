   836	    def _looks_like_heading_without_section_reference(self, segment_text: str) -> bool:
   837	        normalized = self.normalize_text(segment_text)
   838	        if not normalized:
   839	            return False
   840	        lowered = normalized.lower()
   841	        tokens = _TOKEN_RE.findall(lowered)
   842	        if len(tokens) < 2 or len(tokens) > _USCODE_HEADING_ONLY_MAX_TOKENS:
   843	            return False
   844	        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(lowered):
   845	            return False
   846	        if (
   847	            _USCODE_CODIFICATION_HINT_RE.search(lowered)
   848	            or _USCODE_EDITORIAL_STATUS_HINT_RE.search(lowered)
   849	            or _USCODE_DECLARATIVE_STATEMENT_HINT_RE.search(lowered)
   850	        ):
   851	            return False
   852	        if any(punctuation in normalized for punctuation in ",:;()[]{}"):
   853	            return False
   854	        if tokens[0] in _USCODE_HEADING_ONLY_LEADING_STOPWORDS:
   855	            return False
   856	        return True
