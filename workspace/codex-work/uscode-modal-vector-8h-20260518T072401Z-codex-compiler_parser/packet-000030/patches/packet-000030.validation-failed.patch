+    def _is_bare_section_reference_segment(
+        self,
+        segment_text: str,
+        *,
+        citation_section: str,
+    ) -> bool:
+        """Return true for minimal ``§1234.``-style lead segments with no heading tokens."""
+        if not self._starts_with_citation_section_reference(segment_text, citation_section):
+            return False
+
+        normalized = self.normalize_text(segment_text)
+        section_pattern = re.escape(citation_section)
+        suffix_match = _USCODE_SECTION_REF_SUFFIX_RE
+        remainder = re.sub(
+            rf"^{_USCODE_OPTIONAL_SECTION_REF_PREFIX_RE}{section_pattern}(?={suffix_match})",
+            "",
+            normalized,
+            count=1,
+            flags=re.IGNORECASE,
+        )
+        remainder = re.sub(r"^[\s\-.;,:\u2012\u2013\u2014()]+", "", remainder).strip()
+        if not remainder:
+            return True
+        return len(_TOKEN_RE.findall(remainder.lower())) == 0
+
+    def _merge_bare_section_reference_with_heading_segment(
+        self,
+        *,
+        index: int,
+        segments: Sequence[LegalSegment],
+        citation_section: str,
+    ) -> Optional[LegalSegment]:
+        """Attach heading text that follows a bare ``§1234.`` lead segment."""
+        if index + 1 >= len(segments):
+            return None
+
+        next_segment = segments[index + 1]
+        next_text = self.normalize_text(next_segment.text)
+        if not next_text:
+            return None
+        if self._starts_with_citation_section_reference(next_text, citation_section):
+            return None
+
+        next_token_count = len(_TOKEN_RE.findall(next_text.lower()))
+        if (
+            next_token_count < _USCODE_HEADING_ONLY_MIN_TOKENS
+            or next_token_count > _USCODE_SECTION_HEADING_EXTENDED_MAX_TOKENS
+        ):
+            return None
+        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(next_text):
+            return None
+
+        prefix_text = self.normalize_text(segments[index].text)
+        combined_text = self.normalize_text(f"{prefix_text} {next_text}")
+        combined_token_count = len(_TOKEN_RE.findall(combined_text.lower()))
+        if (
+            combined_token_count < _USCODE_HEADING_ONLY_MIN_TOKENS
+            or combined_token_count > _USCODE_SECTION_HEADING_EXTENDED_MAX_TOKENS
+        ):
+            return None
+
+        return LegalSegment(
+            text=combined_text,
+            start_char=segments[index].start_char,
+            end_char=next_segment.end_char,
+            role="clause",
+        )
+
