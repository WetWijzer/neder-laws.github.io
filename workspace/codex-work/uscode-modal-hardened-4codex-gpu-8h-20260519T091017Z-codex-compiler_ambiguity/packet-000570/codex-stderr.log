    53	def test_conditional_profile_includes_terms_and_conditions_cues() -> None:
    54	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.CONDITIONAL_NORMATIVE)
    55	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    56	
    57	    assert "under such terms and conditions" in cue_terms
