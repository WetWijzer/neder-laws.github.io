assert slot_texts['statement_hint'] == ['sense_of_congress'], slot_texts.get('statement_hint')
assert any(
    triple['predicate'] == 'statement_hint' and triple['object'] == 'sense_of_congress'
    for triple in triples
)
print('ok')
