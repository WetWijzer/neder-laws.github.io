   713	    if heading_tail:
   714	        return heading_tail
   715	    source_text = str(document.normalized_text or "")
   716	    if not source_text:
   717	        return ""
   718	    start = max(0, min(len(source_text), int(formula.provenance.start_char)))
   719	    end = max(start, min(len(source_text), int(formula.provenance.end_char)))
   720	    span_text = _clean_text(source_text[start:end])
