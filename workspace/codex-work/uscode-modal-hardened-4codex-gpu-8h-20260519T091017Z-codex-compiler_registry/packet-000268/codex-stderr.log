   405	    )
   406	    sample = build_us_code_sample(
   407	        title="42",
   408	        section="247b",
   409	        text=(
   410	            "Authority under this section and jurisdiction under this chapter "
   411	            "shall apply."
   412	        ),
   413	    )
   414	
   415	    ranking = ranked_modal_families(codec.encode_sample(sample))
   416	
   417	    assert ranking[0]["family"] == "deontic"
   418	    assert any(item["family"] == "frame" and item["count"] >= 1 for item in ranking)
   419	    deontic_share = next(
   420	        float(item["share"])
   421	        for item in ranking
   422	        if item["family"] == "deontic"
   423	    )
   424	    frame_share = next(
   425	        float(item["share"])
   426	        for item in ranking
   427	        if item["family"] == "frame"
   428	    )
   429	    assert deontic_share > frame_share
