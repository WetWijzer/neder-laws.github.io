   536	class AdaptiveModalAutoencoder:
   537	    """Small trainable modal encoder/decoder used by the TODO supervisor.
   538	
   539	    This is an adaptive diagnostic/advisor, not the canonical legal
   540	    representation.  The expert-auditable path is the deterministic modal
   541	    compiler/decompiler in ``ipfs_datasets_py.logic.modal``; this class keeps
   542	    feature-level nudges only to identify where vague text, frame choice, or
   543	    reconstruction may need compiler-rule improvements.
   544	    """
   545	
   546	    def __init__(
   547	        self,
   548	        *,
   549	        state: Optional[ModalAutoencoderTrainingState] = None,
   550	        initial_embedding_scale: float = 0.0,
   551	        modal_families: Optional[Sequence[str]] = None,
   552	        feature_codec: Optional[Any] = None,
   553	        feature_embedding_weight_scale: float = 0.5,
   554	        feature_family_logit_scale: float = 0.0,
   555	    ) -> None:
   556	        self.state = state or ModalAutoencoderTrainingState()
   557	        self.initial_embedding_scale = float(initial_embedding_scale)
   558	        self.modal_families = tuple(modal_families or _all_modal_families())
   559	        self.feature_codec = feature_codec
   560	        self.feature_embedding_weight_scale = max(
   561	            0.0,
   562	            float(feature_embedding_weight_scale),
   563	        )
   564	        self.feature_family_logit_scale = max(0.0, float(feature_family_logit_scale))
   565	
   566	    def evaluate(
   567	        self,
   568	        samples: Iterable[LegalSample],
   569	        *,
   570	        use_sample_memory: bool = True,
   571	    ) -> AutoencoderEvaluation:
   572	        """Evaluate current encoder/decoder state against legal samples."""
   573	        sample_list = list(samples)
   574	        if not sample_list:
   575	            return AutoencoderEvaluation(
   576	                sample_count=0,
   577	                embedding_cosine_similarity=0.0,
   578	                cosine_loss=0.0,
   579	                reconstruction_loss=0.0,
   580	                cross_entropy_loss=0.0,
   581	                frame_ranking_loss=0.0,
   582	                symbolic_validity_penalty=0.0,
   583	                decoded_embeddings={},
   584	            )
   585	
   586	        cosine_scores: List[float] = []
   587	        cosine_losses: List[float] = []
   588	        reconstruction_losses: List[float] = []
   589	        ce_losses: List[float] = []
   590	        frame_losses: List[float] = []
   591	        symbolic_penalties: List[float] = []
   592	        decoded_embeddings: Dict[str, List[float]] = {}
   593	
   594	        for sample in sample_list:
   595	            decoded = self.decode(self.encode(sample, use_sample_memory=use_sample_memory))
   596	            decoded_embeddings[sample.sample_id] = decoded
   597	            cosine_scores.append(cosine_similarity(sample.embedding_vector, decoded))
   598	            cosine_losses.append(cosine_loss(sample.embedding_vector, decoded))
   599	            reconstruction_losses.append(mse_loss(sample.embedding_vector, decoded))
