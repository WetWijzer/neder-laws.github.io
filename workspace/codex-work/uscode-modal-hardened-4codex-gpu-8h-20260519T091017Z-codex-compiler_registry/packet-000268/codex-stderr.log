    57	        )
    58	        text = _clean(row.get("text")) or _clean(row.get("law_name")) or citation
    59	        return cls(
    60	            ipfs_cid=_clean(row.get("ipfs_cid")) or _clean(row.get("cid")),
    61	            title_number=title,
    62	            section_number=section,
    63	            text=text,
