   989	def _resolve_modal_family_name(family: ModalLogicFamily | str) -> str:
   990	    if isinstance(family, ModalLogicFamily):
   991	        return family.value
   992	    try:
   993	        return ModalLogicFamily(str(family)).value
   994	    except ValueError:
   995	        return str(family).strip().lower()
