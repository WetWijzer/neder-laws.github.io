   670	def _fallback_section_heading_tail_text(
   671	    *,
   672	    document: ModalIRDocument,
   673	    formula: ModalIRFormula,
   674	    max_tokens: int = 18,
   675	) -> str:
   676	    fallback_rule = _clean_text(formula.metadata.get("fallback_rule") or "")
   677	    if fallback_rule not in _USCODE_SECTION_HEADING_TAIL_RULES:
   678	        return ""
   679	    source_text = str(document.normalized_text or "")
   680	    if not source_text:
   681	        return ""
   682	    start = max(0, min(len(source_text), int(formula.provenance.start_char)))
   683	    end = max(start, min(len(source_text), int(formula.provenance.end_char)))
   684	    trailing = source_text[end:]
   685	    if not trailing:
   686	        return ""
   687	    trailing = trailing.lstrip(" \t\r\n-–—:;,.")
   688	    if not trailing:
   689	        return ""
   690	    candidate = _SECTION_HEADING_TAIL_SPLIT_RE.split(trailing, maxsplit=1)[0]
   691	    heading_tail = _clean_text(candidate)
   692	    if not heading_tail:
   693	        return ""
   694	    if len(_tokenize_for_similarity(heading_tail)) > max_tokens:
   695	        return ""
   696	    return heading_tail
