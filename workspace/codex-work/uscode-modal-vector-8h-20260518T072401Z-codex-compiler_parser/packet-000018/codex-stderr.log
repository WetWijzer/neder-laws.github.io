+        normalized_text: str,
+        citation_section: str,
+    ) -> Optional[LegalSegment]:
+        """Extract leading heading text before a long ``(a)``-style subsection body."""
+        marker = _USCODE_SUBSECTION_MARKER_RE.search(normalized_text)
+        if marker is None:
+            return None
