    assert is_compiler_ambiguity_policy_pair(
        "epistemic",
        "conditional_normative",
    ) is True
    assert is_compiler_ambiguity_policy_pair("frame", "conditional_normative") is True
    assert is_compiler_ambiguity_policy_pair("frame", "deontic") is True

