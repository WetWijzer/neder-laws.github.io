   750	    def _looks_like_transferred_section_heading(
   751	        self,
   752	        segment_text: str,
   753	        *,
   754	        citation_section: str,
   755	    ) -> bool:
   756	        normalized = self.normalize_text(segment_text).lower()
   757	        if "transferred" not in normalized:
   758	            return False
   759	        if normalized.startswith("transferred"):
   760	            return True
   761	        return self._contains_citation_section_reference(
   762	            normalized,
   763	            citation_section,
   764	        ) or self._starts_with_citation_section_reference(
   765	            normalized,
   766	            citation_section,
   767	        )
