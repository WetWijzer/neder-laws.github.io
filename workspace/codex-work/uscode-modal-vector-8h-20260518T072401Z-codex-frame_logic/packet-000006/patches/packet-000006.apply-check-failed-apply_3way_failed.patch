@@ -0,0 +1,145 @@
+"""Tests for deterministic frame-logic term auditing and projection."""
+
+from ipfs_datasets_py.logic.modal.codec import modal_ir_to_flogic_triples
+from ipfs_datasets_py.optimizers.logic.flogic_optimizer import (
+    FLogicOptimizerConfig,
+    FLogicSemanticOptimizer,
+)
+from ipfs_datasets_py.optimizers.logic_theorem_optimizer.frame_bm25_selector import (
+    BM25FrameSelector,
+    FrameCandidate,
+)
+from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_ir import (
+    ModalIRDocument,
+    ModalIRFrame,
+)
+
+
+class _FakeErgo:
+    def __init__(self) -> None:
+        self.frames = []
+
+    def add_frame(self, frame) -> None:
+        self.frames.append(frame)
+
+
+def test_bm25_selector_exposes_ontology_term_matches() -> None:
+    selector = BM25FrameSelector(
+        [
+            FrameCandidate(
+                frame_id="administrative_notice_hearing",
+                label="Administrative notice and hearing",
+                description="Agency notice, finding, hearing rights, final order.",
+                terms=("notice", "hearing"),
+                domain="administrative",
+            )
+        ]
+    )
+
+    selection = selector.rank("Agency rights include notice", top_k=1)[0]
+
+    assert selection.matched_terms == ["notice"]
+    assert "agency" in selection.lexical_matches
+    assert set(selection.ontology_terms) == {"notice", "hearing"}
+
+
+def test_modal_ir_to_flogic_triples_emits_ontology_terms() -> None:
+    modal_ir = ModalIRDocument(
+        document_id="doc-1",
+        source="us_code",
+        normalized_text="agency must provide notice and hearing",
+        frame_candidates=[
+            ModalIRFrame(
+                frame_id="administrative_notice_hearing",
+                score=1.0,
+                matched_terms=["notice", "hearing", "notice"],
+            )
+        ],
+    )
+
+    triples = modal_ir_to_flogic_triples(
+        modal_ir,
+        selected_frame="administrative_notice_hearing",
+    )
+
+    assert {
+        "subject": "administrative_notice_hearing",
+        "predicate": "ontology_term",
+        "object": "notice",
+    } in triples
+    assert {
+        "subject": "administrative_notice_hearing",
+        "predicate": "ontology_term",
+        "object": "hearing",
+    } in triples
+    assert {
+        "subject": "doc-1",
+        "predicate": "selected_ontology_term",
+        "object": "notice",
+    } in triples
+    assert sum(
+        1
+        for triple in triples
+        if triple["subject"] == "doc-1"
+        and triple["predicate"] == "selected_ontology_term"
+        and triple["object"] == "notice"
+    ) == 1
+
+
+def test_flogic_consistency_keeps_repeated_predicates_as_set_methods() -> None:
+    optimizer = FLogicSemanticOptimizer(
+        FLogicOptimizerConfig(check_ontology_consistency=True)
+    )
+    fake_ergo = _FakeErgo()
+    optimizer._get_ergo = lambda: fake_ergo  # type: ignore[method-assign]
+
+    violations = optimizer._check_flogic_consistency(
+        [
+            {
+                "subject": "doc-1",
+                "predicate": "type",
+                "object": "legal_modal_document",
+            },
+            {
+                "subject": "doc-1",
+                "predicate": "candidate_ontology_frame",
+                "object": "frame_a",
+            },
+            {
+                "subject": "doc-1",
+                "predicate": "candidate_ontology_frame",
+                "object": "frame_b",
+            },
+            {
+                "subject": "doc-1",
+                "predicate": "candidate_ontology_frame",
+                "object": "frame_a",
+            },
+        ]
+    )
+
+    assert violations == []
+    assert len(fake_ergo.frames) == 1
+    frame = fake_ergo.frames[0]
+    assert frame.isa == "legal_modal_document"
+    assert frame.set_methods["candidate_ontology_frame"] == ["frame_a", "frame_b"]
+
+
+def test_flogic_consistency_reports_empty_predicate_and_object() -> None:
+    optimizer = FLogicSemanticOptimizer(
+        FLogicOptimizerConfig(check_ontology_consistency=True)
+    )
+    fake_ergo = _FakeErgo()
+    optimizer._get_ergo = lambda: fake_ergo  # type: ignore[method-assign]
+
+    violations = optimizer._check_flogic_consistency(
+        [
+            {"subject": "doc-1", "predicate": "", "object": "x"},
+            {"subject": "doc-1", "predicate": "p", "object": ""},
+        ]
+    )
+
+    assert {violation.constraint for violation in violations} == {
+        "non_empty_object",
+        "non_empty_predicate",
+    }
