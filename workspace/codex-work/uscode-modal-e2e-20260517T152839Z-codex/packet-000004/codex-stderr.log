   410	def _token_overlap_ratio(left: str, right: str) -> float:
   411	    left_tokens = {
   412	        token.lower()
   413	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", left)
   414	    }
   415	    right_tokens = {
   416	        token.lower()
   417	        for token in re.findall(r"[A-Za-z0-9][A-Za-z0-9_'-]*", right)
   418	    }
   419	    if not left_tokens:
   420	        return 1.0 if not right_tokens else 0.0
   421	    return len(left_tokens & right_tokens) / len(left_tokens)

