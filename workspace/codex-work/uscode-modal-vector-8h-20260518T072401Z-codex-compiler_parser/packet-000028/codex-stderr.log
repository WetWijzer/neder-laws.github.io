  1012	            return False
  1013	        return True
  1014	
  1015	    def _looks_like_relaxed_heading_without_section_reference(
  1016	        self,
  1017	        segment_text: str,
  1018	    ) -> bool:
  1019	        """Allow compact heading-like phrases that start with stopwords."""
  1020	        normalized = self.normalize_text(segment_text)
  1021	        if not normalized:
  1022	            return False
  1023	        lowered = normalized.lower()
  1024	        tokens = _TOKEN_RE.findall(lowered)
  1025	        if (
  1026	            len(tokens) < _USCODE_HEADING_ONLY_MIN_TOKENS
  1027	            or len(tokens) > _USCODE_HEADING_ONLY_MAX_TOKENS
  1028	        ):
  1029	            return False
  1030	        if _USCODE_HEADING_ONLY_VERB_HINT_RE.search(lowered):
  1031	            return False
  1032	        if (
  1033	            _USCODE_CODIFICATION_HINT_RE.search(lowered)
  1034	            or _USCODE_EDITORIAL_STATUS_HINT_RE.search(lowered)
  1035	            or _USCODE_DECLARATIVE_STATEMENT_HINT_RE.search(lowered)
  1036	        ):
  1037	            return False
  1038	        if any(punctuation in normalized for punctuation in ":[]{}"):
  1039	            return False
  1040	        # Prevent degenerate headings like just "the" or "this".
  1041	        if len(tokens) == 1 and tokens[0] in _USCODE_HEADING_ONLY_LEADING_STOPWORDS:
  1042	            return False
  1043	        return True
  1044	
  1045	    def _coarse_citation_heading_segment(
  1046	        self,
  1047	        *,
  1048	        normalized_text: str,
  1049	        citation_section: str,
  1050	    ) -> Optional[LegalSegment]:
  1051	        """Recover a compact heading around a citation reference in noisy long lines."""
  1052	        if not citation_section:
  1053	            return None
  1054	
  1055	        section_pattern = re.escape(citation_section)
  1056	        reference_pattern = re.compile(
  1057	            rf"(?<!\w){_USCODE_OPTIONAL_SECTION_REF_PREFIX_RE}{section_pattern}"
  1058	            rf"(?={_USCODE_SECTION_REF_SUFFIX_RE})",
  1059	            re.IGNORECASE,
  1060	        )
  1061	        match = reference_pattern.search(normalized_text)
  1062	        if match is None:
  1063	            return None
  1064	
  1065	        start = match.start()

