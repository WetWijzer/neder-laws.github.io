def test_modal_ir_to_flogic_triples_emits_numeric_section_range_relation_slots() -> None:
    triples = modal_ir_to_flogic_triples(_numeric_range_sample_document())

    def objects(predicate: str) -> list[str]:
        return [
            triple["object"]
