   637	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
   638	    """Rank modal families by deterministic cue count and normalized share."""
   639	    counts = encoding.modal_family_counts()
   640	    total = sum(counts.values())
   641	    if total <= 0:
   642	        return []
   643	    ranking: List[Dict[str, float]] = []
   644	    for family, count in sorted(counts.items(), key=lambda item: (-item[1], item[0])):
   645	        ranking.append(
   646	            {
   647	                "family": family,
   648	                "count": int(count),
   649	                "share": round(float(count) / float(total), 6),
   650	            }
   651	        )
   652	    return ranking
