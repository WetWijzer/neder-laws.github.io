   495	def test_logic_extractor_uses_deterministic_modal_parser_without_llm() -> None:
   496	    class FailingBackend:
   497	        def generate(self, request):  # pragma: no cover - should never be called
   498	            raise AssertionError("LLM backend should not be called for deterministic modal parsing")
   499	
   500	    extractor = LogicExtractor(
   501	        backend=FailingBackend(),
   502	        use_ipfs_accelerate=False,
   503	        enable_formula_translation=False,
   504	        enable_kg_integration=False,
   505	        enable_rag_integration=False,
   506	    )
   507	    context = LogicExtractionContext(
   508	        data="The agency must provide notice within 30 days.",
   509	        data_type=DataType.TEXT,
   510	        domain="legal",
   511	        config={"extraction_mode": "modal", "modal_profile": "deontic:D"},
   512	        hints=["5 U.S.C. 552"],
   513	    )
   514	
   515	    result = extractor.extract(context)
   516	
   517	    assert result.success is True
   518	    assert result.statements
   519	    assert result.metrics["llm_call_count"] == 0
   520	    assert result.metrics["deterministic_coverage_ratio"] == 1.0
   521	    assert result.metrics["modal_profile"] == "deontic:D"
   522	    assert result.metrics["modal_families"] == ["deontic", "temporal"]
   523	    assert all(statement.formalism == "modal" for statement in result.statements)
   524	    assert all(statement.metadata["deterministic_parser"] == "legal_modal_parser_v1" for statement in result.statements)
   525	    assert {statement.metadata["modal_family"] for statement in result.statements} >= {"deontic", "temporal"}
