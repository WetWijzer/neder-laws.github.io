            triples.append(
                {
                    "subject": modal_ir.document_id,
                    "predicate": predicate,
                    "object": value,
                }
            )
    if selected_frame:
        triples.append(
            {
                "subject": modal_ir.document_id,
                "predicate": "selected_ontology_frame",
                "object": selected_frame,
            }

