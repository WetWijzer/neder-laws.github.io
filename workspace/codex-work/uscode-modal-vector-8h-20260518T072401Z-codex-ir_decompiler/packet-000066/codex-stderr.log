   281	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   282	    """Render a stable formula-like string from one modal IR formula."""
   283	    arguments = ", ".join(formula.predicate.arguments)
   284	    predicate = formula.predicate.name
   285	    if arguments:
   286	        predicate = f"{predicate}({arguments})"
   287	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
