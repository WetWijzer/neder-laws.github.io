    95	
    96	def _slot_and_triple_values_for_predicate(
    97	    sample_section: str,
    98	    *,
    99	    title: str,
   100	    predicate: str,
   101	) -> tuple[list[str], list[str]]:
   102	    sample = build_us_code_sample(
   103	        title=title,
   104	        section=sample_section,
   105	        citation=f"{title} U.S.C. {sample_section}",
   106	        text=f"Sec. {sample_section} - Administrative provisions.",
   107	    )
   108	    decoded = decode_modal_ir_document(sample.modal_ir)
   109	    slot_map = decoded_modal_phrase_slot_text_map(decoded)
   110	    triple_values: list[str] = []
   111	    for triple in modal_ir_to_flogic_triples(sample.modal_ir):
   112	        if str(triple.get("predicate", "")).strip() != predicate:
   113	            continue
   114	        value = str(triple.get("object", "")).strip()
   115	        if value and value not in triple_values:
   116	            triple_values.append(value)
   117	    return slot_map.get(predicate, []), triple_values
