  1137	    counts: Dict[str, int] = {}
  1138	    for family in families:
  1139	        counts[family] = counts.get(family, 0) + 1
  1140	    total = float(sum(counts.values()))
  1141	    return {family: count / total for family, count in sorted(counts.items())}
