   140	class SpaCyLegalEncoder:
   141	    """Encode legal text using spaCy tokens plus deterministic modal cues."""
   142	
   143	    def __init__(
   144	        self,
   145	        *,
   146	        model_name: str = "en_core_web_sm",
   147	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   148	    ) -> None:
   149	        self.model_name = model_name
   150	        self.registry = registry
   151	        self.nlp, self.used_fallback_model = self._load_nlp(model_name)
   152	
   153	    def encode(
   154	        self,
   155	        text: str,
   156	        *,
   157	        document_id: Optional[str] = None,
   158	        citation: Optional[str] = None,
   159	        source: str = "legal_text",
   160	    ) -> SpaCyLegalEncoding:
   161	        normalized = _normalize(text)
   162	        resolved_document_id = document_id or _document_id(normalized)
   163	        doc = self.nlp(normalized)
   164	        tokens = [
   165	            SpaCyTokenFeature(
   166	                text=token.text,
   167	                lemma=(token.lemma_ or token.lower_).lower(),
   168	                lower=token.lower_,
   169	                pos=token.pos_,
   170	                dep=token.dep_,
   171	                start_char=token.idx,
   172	                end_char=token.idx + len(token.text),
   173	                is_stop=bool(token.is_stop),
   174	                is_alpha=bool(token.is_alpha),
   175	            )
   176	            for token in doc
   177	        ]
   178	        sentences = [
   179	            SpaCySentenceFeature(
   180	                text=sent.text,
   181	                start_char=sent.start_char,
   182	                end_char=sent.end_char,
   183	            )
   184	            for sent in doc.sents
   185	        ]
   186	        if not sentences and normalized:
   187	            sentences = [SpaCySentenceFeature(text=normalized, start_char=0, end_char=len(normalized))]
   188	        return SpaCyLegalEncoding(
   189	            document_id=resolved_document_id,
   190	            text=text,
   191	            normalized_text=normalized,
   192	            tokens=tokens,
   193	            sentences=sentences,
   194	            cues=self._extract_cues(normalized, tokens),
   195	            citation=citation,
   196	            source=source,
   197	            model_name=self.model_name,
   198	            used_fallback_model=self.used_fallback_model,
   199	        )
   200	
   201	    def _extract_cues(
   202	        self,
   203	        normalized: str,
   204	        tokens: Sequence[SpaCyTokenFeature],
   205	    ) -> List[SpaCyModalCueFeature]:
   206	        found: Dict[tuple[int, int, str, str], SpaCyModalCueFeature] = {}
   207	        token_spans = [(index, token.start_char, token.end_char) for index, token in enumerate(tokens)]
   208	        for profile in self.registry.all_profiles():
   209	            for operator in profile.operators:
   210	                for cue in sorted(operator.cue_terms, key=lambda value: (-len(value), value)):
   211	                    pattern = re.compile(rf"(?<!\w){re.escape(cue)}(?!\w)", re.IGNORECASE)
   212	                    for match in pattern.finditer(normalized):
   213	                        token_indices = [
   214	                            index
   215	                            for index, start, end in token_spans
   216	                            if start < match.end() and end > match.start()
   217	                        ]
   218	                        key = (match.start(), match.end(), profile.family.value, operator.symbol)
   219	                        found[key] = self._cue_feature(
   220	                            profile,
   221	                            operator,
   222	                            cue,
   223	                            match.start(),
   224	                            match.end(),
   225	                            token_indices,
   226	                        )
   227	        return sorted(
   228	            found.values(),
   229	            key=lambda cue: (cue.start_char, cue.end_char, cue.family, cue.symbol, cue.cue),
   230	        )
