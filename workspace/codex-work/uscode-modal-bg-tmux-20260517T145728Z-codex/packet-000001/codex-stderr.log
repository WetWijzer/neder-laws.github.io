    68	def test_logic_extractor_uses_deterministic_modal_parser_without_llm() -> None:
    69	    class FailingBackend:
    70	        def generate(self, request):  # pragma: no cover - should never be called
    71	            raise AssertionError("LLM backend should not be called for deterministic modal parsing")
    72	
    73	    extractor = LogicExtractor(
    74	        backend=FailingBackend(),
    75	        use_ipfs_accelerate=False,
    76	        enable_formula_translation=False,
    77	        enable_kg_integration=False,
    78	        enable_rag_integration=False,
    79	    )
    80	    context = LogicExtractionContext(
    81	        data="The agency must provide notice within 30 days.",
    82	        data_type=DataType.TEXT,
    83	        domain="legal",
    84	        config={"extraction_mode": "modal", "modal_profile": "deontic:D"},
    85	        hints=["5 U.S.C. 552"],
    86	    )
    87	
    88	    result = extractor.extract(context)
    89	
    90	    assert result.success is True
    91	    assert result.statements
    92	    assert result.metrics["llm_call_count"] == 0
    93	    assert result.metrics["deterministic_coverage_ratio"] == 1.0
    94	    assert result.metrics["modal_profile"] == "deontic:D"
    95	    assert result.metrics["modal_families"] == ["deontic", "temporal"]
    96	    assert all(statement.formalism == "modal" for statement in result.statements)
    97	    assert all(statement.metadata["deterministic_parser"] == "legal_modal_parser_v1" for statement in result.statements)
    98	    assert {statement.metadata["modal_family"] for statement in result.statements} >= {"deontic", "temporal"}
