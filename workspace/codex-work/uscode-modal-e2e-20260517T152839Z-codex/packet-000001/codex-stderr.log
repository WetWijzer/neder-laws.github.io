   150	def modal_text_token_similarity(left: str, right: str) -> float:
   151	    """Return deterministic token-set F1 similarity for reconstruction checks."""
   152	    left_tokens = set(_tokenize_for_similarity(left))
   153	    right_tokens = set(_tokenize_for_similarity(right))
   154	    if not left_tokens and not right_tokens:
   155	        return 1.0
   156	    if not left_tokens or not right_tokens:
   157	        return 0.0
   158	    overlap = len(left_tokens & right_tokens)
   159	    if overlap == 0:
   160	        return 0.0
   161	    precision = overlap / len(right_tokens)
   162	    recall = overlap / len(left_tokens)
   163	    return round((2.0 * precision * recall) / (precision + recall), 6)
