   399	def frame_ontology_terms(
   400	    frame: FrameCandidate,
   401	    *,
   402	    matched_terms: Sequence[str] = (),
   403	    max_terms: int = 24,
   404	) -> List[str]:
   405	    """Return deterministic ontology terms for one frame candidate.
   406	
   407	    The term list is intentionally stable and explainable: we keep canonical
   408	    phrase forms plus tokenized atoms for frame id/label/domain/terms and the
   409	    lexical matches that affected BM25 scoring.
