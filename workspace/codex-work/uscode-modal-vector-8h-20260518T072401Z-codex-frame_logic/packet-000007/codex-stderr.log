   687	    raw_key, raw_value = argument.split(":", 1)
   688	    key = "".join(
   689	        character.lower() if character.isalnum() else "_"
   690	        for character in raw_key.strip()
   691	    ).strip("_")
   692	    value = raw_value.strip()
   693	    if not key or not value:
   694	        return None
   695	    return key, value
