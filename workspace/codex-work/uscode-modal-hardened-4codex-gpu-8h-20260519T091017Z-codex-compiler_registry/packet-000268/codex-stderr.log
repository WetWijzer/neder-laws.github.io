   808	class ModalRegistry:
   809	    """Lookup table for modal parse profiles."""
   810	
   811	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   812	        self._profiles: Dict[str, ModalParseProfile] = {
   813	            profile.profile_id: profile for profile in profiles
   814	        }
   815	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   816	            profile.family: profile for profile in profiles
   817	        }
   818	
   819	    def get_profile(
   820	        self,
   821	        family: ModalLogicFamily | str,
   822	        system: Optional[ModalSystem | str] = None,
   823	    ) -> ModalParseProfile:
   824	        """Get a profile by family, optionally constrained by system."""
   825	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   826	        if system is None:
   827	            return self._by_family[resolved_family]
   828	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   829	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   830	
   831	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   832	        """Return all profiles in deterministic order."""
   833	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   834	
   835	    def to_dict(self) -> Mapping[str, object]:
   836	        """Return a stable JSON-ready registry mapping."""
   837	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   838	
   839	
   840	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   841	    """Return whether a modal family encodes normative legal force."""
   842	    if isinstance(family, ModalLogicFamily):
   843	        resolved = family
   844	    else:
   845	        try:
   846	            resolved = ModalLogicFamily(str(family))
   847	        except ValueError:
   848	            return False
