   533	def _sentence_for_cue(
   534	    sentences: Sequence[SpaCySentenceFeature],
   535	    cue: SpaCyModalCueFeature,
   536	) -> SpaCySentenceFeature:
   537	    for sentence in sentences:
   538	        if sentence.start_char <= cue.start_char < sentence.end_char:
   539	            return sentence
   540	    return SpaCySentenceFeature(text="", start_char=cue.start_char, end_char=cue.end_char)

