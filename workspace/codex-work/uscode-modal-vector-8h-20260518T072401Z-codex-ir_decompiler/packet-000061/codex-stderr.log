                    candidate_segment = segment
                    break
                if (
                    embedded_heading_segment is None
                    and token_count <= _USCODE_SECTION_HEADING_EXTENDED_MAX_TOKENS
                ):
                    embedded_heading_segment = segment
            if candidate_segment is None:
