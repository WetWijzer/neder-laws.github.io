def _canonical_statutory_scope_unit(unit: str) -> str:
    normalized = _clean_non_empty_string(unit).lower()
    if normalized.endswith("s"):
        singular = normalized[:-1]
        if singular in _STATUTORY_SCOPE_UNITS:
            return singular
    return normalized


