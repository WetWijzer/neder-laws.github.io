+        unit = _clean_non_empty_string(match.group("unit")).lower()
+        target = _clean_non_empty_string(match.group("target")).lower()
+        if _clean_non_empty_string(match.group("this")):
+            target = f"this {target}".strip()
+        values: List[tuple[str, str]] = [
+            ("statutory_scope_reference", _clean_non_empty_string(match.group(0)).lower()),
+            ("statutory_scope_connector", connector),
+            ("statutory_scope_unit", unit),
+        ]
+        if target:
+            values.append(("statutory_scope_target", target))
+        for entry in values:
+            if entry in seen:
+                continue
+            seen.add(entry)
+            entries.append(entry)
+    return entries
