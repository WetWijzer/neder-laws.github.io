   583	    @staticmethod
   584	    def _adaptive_explicit_ambiguity_key(
   585	        ambiguity: ModalCompilationAmbiguity,
   586	    ) -> tuple[str, tuple[str, ...], str, str]:
   587	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   588	        return (
   589	            str(ambiguity.ambiguity_type),
   590	            tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   591	            str(metadata.get("adaptive_policy_pair") or ""),
   592	            str(metadata.get("adaptive_predicted_family_source") or ""),
   593	        )
   594	
   595	    def _ensure_explicit_adaptive_ambiguities(
   596	        self,
   597	        ambiguities: Sequence[ModalCompilationAmbiguity],
   598	    ) -> List[ModalCompilationAmbiguity]:
   599	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   600	        resolved_ambiguities = list(ambiguities)
   601	        existing_explicit_keys = {
   602	            self._adaptive_explicit_ambiguity_key(ambiguity)
   603	            for ambiguity in resolved_ambiguities
   604	            if ambiguity.ambiguity_type.startswith("adaptive_")
   605	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   606	        }
   607	        for ambiguity in list(resolved_ambiguities):
   608	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   609	                continue
   610	            metadata = (
   611	                ambiguity.metadata
   612	                if isinstance(ambiguity.metadata, dict)
   613	                else {}
   614	            )
   615	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   616	            if not explicit_type:
   617	                continue
   618	            explicit_key = (
   619	                explicit_type,
   620	                tuple(str(candidate_id) for candidate_id in ambiguity.candidate_ids),
   621	                str(metadata.get("adaptive_policy_pair") or ""),
   622	                str(metadata.get("adaptive_predicted_family_source") or ""),
   623	            )
   624	            if explicit_key in existing_explicit_keys:
   625	                continue
   626	            explicit_message = (
   627	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   628	                "family against close competing families."
   629	                if bool(metadata.get("is_self_pair"))
   630	                else (
   631	                    "Explicit adaptive modal-family conflict between the predicted "
   632	                    "family and a competing legal family."
   633	                )
   634	            )
   635	            resolved_ambiguities.append(
   636	                ModalCompilationAmbiguity(
   637	                    ambiguity_type=explicit_type,
   638	                    message=explicit_message,
   639	                    candidate_ids=list(ambiguity.candidate_ids),
   640	                    severity=ambiguity.severity,
   641	                    metadata={
   642	                        **metadata,
   643	                        "adaptive_base_ambiguity_type": "adaptive_family_margin_low",
   644	                    },
   645	                )
   646	            )
   647	            existing_explicit_keys.add(explicit_key)
   648	        return resolved_ambiguities
   649	
   650	    def _derive_explicit_adaptive_ambiguity_type(
   651	        self,
   652	        ambiguity: ModalCompilationAmbiguity,
   653	    ) -> Optional[str]:
   654	        """Resolve explicit adaptive ambiguity type from base metadata."""
   655	        metadata = ambiguity.metadata if isinstance(ambiguity.metadata, dict) else {}
   656	        explicit_type = str(metadata.get("explicit_ambiguity_type") or "").strip()
   657	        if explicit_type and explicit_type != "adaptive_family_margin_low":
   658	            return explicit_type
   659	
   660	        predicted_family = str(metadata.get("predicted_family") or "").strip()
   661	        target_family = str(metadata.get("target_family") or "").strip()
   662	        if not predicted_family and ambiguity.candidate_ids:
   663	            predicted_family = str(ambiguity.candidate_ids[0]).strip()
   664	        if not target_family and len(ambiguity.candidate_ids) > 1:
   665	            target_family = str(ambiguity.candidate_ids[1]).strip()
   666	
   667	        policy_pair = str(metadata.get("adaptive_policy_pair") or "").strip()
   668	        if "->" in policy_pair:
   669	            policy_predicted, policy_target = policy_pair.split("->", maxsplit=1)
   670	            if not predicted_family:
   671	                predicted_family = policy_predicted.strip()
   672	            if not target_family:
   673	                target_family = policy_target.strip()
   674	
   675	        is_self_pair = bool(metadata.get("is_self_pair")) or (
   676	            len(ambiguity.candidate_ids) == 1
   677	        )
   678	        if is_self_pair and predicted_family and not target_family:
   679	            target_family = predicted_family
   680	        if not predicted_family or not target_family:
   681	            return None
   682	
   683	        margin_direction = str(metadata.get("adaptive_margin_direction") or "").strip().lower()
   684	        if margin_direction not in {"contested", "outvoted"}:
   685	            family_margin = metadata.get("family_margin_raw", metadata.get("family_margin"))
   686	            try:
   687	                margin_direction = "outvoted" if float(family_margin) <= 0.0 else "contested"
   688	            except (TypeError, ValueError):
   689	                margin_direction = "outvoted"
   690	        return self._adaptive_margin_explicit_type(
   691	            predicted_family,
   692	            target_family,
   693	            margin_direction,
   694	        )
   695	
   696	    def _adaptive_family_ranking_from_logits(
   697	        self,
   698	        encoding: SpaCyLegalEncoding,
   699	    ) -> List[Dict[str, float]]:
   700	        """Build fallback family ranking from deterministic decoder logits."""
   701	        modal_families = [family.value for family in ModalLogicFamily]
   702	        logits = self.decoder.family_logits(
   703	            encoding,
   704	            modal_families=modal_families,
   705	        )
   706	        if not logits:
   707	            return []
   708	        max_logit = max(float(value) for value in logits.values())
   709	        exp_by_family = {
   710	            family: math.exp(float(logit) - max_logit)
   711	            for family, logit in logits.items()
   712	        }
   713	        total = sum(exp_by_family.values())
   714	        if total <= 0.0:
   715	            return []
   716	        ranking: List[Dict[str, float]] = []
   717	        for family in sorted(
   718	            exp_by_family,
   719	            key=lambda key: (-exp_by_family[key], key),
   720	        ):
   721	            share_raw = exp_by_family[family] / total
   722	            ranking.append(
   723	                {
   724	                    "family": family,
   725	                    "count": 0,
   726	                    "logit": round(float(logits[family]), 6),
   727	                    "share_raw": share_raw,
   728	                    "share": round(share_raw, 6),
   729	                    "source": "logit_softmax_fallback",
   730	                }
   731	            )
   732	        return ranking
   733	
   734	    def _adaptive_family_margin_ambiguities(
   735	        self,
   736	        encoding: SpaCyLegalEncoding,
   737	        *,
   738	        modal_ir: ModalIRDocument,
   739	        ranking: Sequence[Dict[str, Any]],
   740	        family_shares: Dict[str, float],
   741	        frame_selections: Sequence[FrameSelection] = (),
   742	        predicted_family_source: str = "ranked_modal_families",
   743	    ) -> List[ModalCompilationAmbiguity]:
   744	        """Surface explicit ambiguities when strong legal families compete."""
   745	        if not ranking:
   746	            return []
   747	        predicted_family = str(ranking[0]["family"])
   748	        predicted_share = self._ranking_share(ranking[0])
   749	        runner_up_family: Optional[str] = None
   750	        runner_up_share = 0.0
   751	        predicted_margin_to_runner_up: Optional[float] = None
   752	        if len(ranking) > 1:
   753	            runner_up_family = str(ranking[1]["family"])
   754	            runner_up_share = self._ranking_share(ranking[1])
   755	            predicted_margin_to_runner_up = predicted_share - runner_up_share
   756	        signals = modal_ambiguity_signals(encoding)
   757	        threshold = float(self.config.modal_adaptive_family_margin)
   758	        has_frame_bm25_support = self._has_frame_bm25_support(frame_selections)
   759	        compiled_modal_families = {
   760	            str(formula.operator.family) for formula in modal_ir.formulas
   761	        }
   762	        compiled_primary_family = (
   763	            str(modal_ir.formulas[0].operator.family)
   764	            if modal_ir.formulas
   765	            else None
   766	        )
   767	        has_frame_scope = bool(
   768	            signals.get("has_frame_context")
   769	            or signals.get("has_frame_cue")
   770	            or signals.get("has_statutory_scope_reference")
   771	            or has_frame_bm25_support
   772	        )
   773	        target_signal_by_family = self._adaptive_target_signal_by_family(
   774	            predicted_family,
   775	            signals=signals,
   776	            has_frame_scope=has_frame_scope,
   777	        )
   778	        for policy_target_family in self._ordered_policy_target_families(
   779	            predicted_family
   780	        ):
   781	            target_signal_by_family.setdefault(policy_target_family, False)
   782	        ordered_target_families: List[str] = []
   783	        if target_signal_by_family:
   784	            ordered_target_families = self._ordered_adaptive_target_families(
   785	                predicted_family=predicted_family,
   786	                target_signal_by_family=target_signal_by_family,
   787	            )
   788	        ambiguities: List[ModalCompilationAmbiguity] = []
   789	        for target_family in ordered_target_families:
   790	            has_signal = bool(target_signal_by_family.get(target_family, False))
   791	            is_self_pair = target_family == predicted_family
   792	            runner_up_is_priority_policy_pair = bool(
   793	                is_self_pair
   794	                and runner_up_family is not None
   795	                and is_priority_signal_free_adaptive_ambiguity_pair(
   796	                    predicted_family,
   797	                    runner_up_family,
   798	                )
   799	            )
   800	            runner_up_is_compiler_required_policy_pair = bool(
   801	                is_self_pair
   802	                and runner_up_family is not None
   803	                and is_compiler_required_adaptive_ambiguity_pair(
   804	                    predicted_family,
   805	                    runner_up_family,
   806	                )
   807	            )
   808	            if is_self_pair and (
   809	                predicted_margin_to_runner_up is None
   810	                or not self._adaptive_margin_within_threshold(
   811	                    family_margin=predicted_margin_to_runner_up,
   812	                    threshold=threshold,
   813	                )
   814	            ):
   815	                continue
   816	            target_share = float(family_shares.get(target_family, 0.0))
   817	            has_compiled_target_family_formula = target_family in compiled_modal_families
   818	            has_target_signal_evidence = bool(
   819	                has_signal
   820	                or target_share > 0.0
   821	                or has_compiled_target_family_formula
   822	            )
   823	            supports_signal_free_pair_policy = self._supports_signal_free_adaptive_pair(
   824	                predicted_family,
   825	                target_family,
   826	            )
   827	            is_priority_policy_pair = is_priority_signal_free_adaptive_ambiguity_pair(
   828	                predicted_family,
   829	                target_family,
   830	            ) or runner_up_is_priority_policy_pair
   831	            is_compiler_required_policy_pair = (
   832	                is_compiler_required_adaptive_ambiguity_pair(
   833	                    predicted_family,
   834	                    target_family,
   835	                )
   836	                or runner_up_is_compiler_required_policy_pair
   837	            )
   838	            if (
   839	                not has_target_signal_evidence
   840	                and not supports_signal_free_pair_policy
   841	            ):
   842	                continue
   843	            family_margin = (
   844	                predicted_margin_to_runner_up
   845	                if is_self_pair and predicted_margin_to_runner_up is not None
   846	                else target_share - predicted_share
   847	            )
   848	            if not self._adaptive_margin_within_threshold(
   849	                family_margin=family_margin,
   850	                threshold=threshold,
   851	            ):
   852	                continue
   853	            margin_direction = self._adaptive_margin_direction(
   854	                family_margin=family_margin,
   855	                predicted_family=predicted_family,
   856	                target_family=target_family,
   857	                is_priority_policy_pair=is_priority_policy_pair,
   858	                is_compiler_required_policy_pair=is_compiler_required_policy_pair,
   859	            )
   860	            requires_rule = margin_direction == "outvoted"
   861	            explicit_type = self._adaptive_margin_explicit_type(
   862	                predicted_family,
   863	                target_family,
   864	                margin_direction,
   865	            )
   866	            predicted_share_display = round(predicted_share, 6)
   867	            target_share_display = round(target_share, 6)
   868	            family_margin_display = (
   869	                round(family_margin, 6)
   870	                if is_self_pair
   871	                else round(
   872	                    target_share_display - predicted_share_display,
   873	                    6,
   874	                )
   875	            )
   876	            candidate_ids = (
   877	                [predicted_family]
   878	                if is_self_pair
   879	                else [predicted_family, target_family]
   880	            )
   881	            is_compiler_ambiguity_bundle_pair = is_compiler_ambiguity_policy_pair(
   882	                predicted_family,
   883	                target_family,
   884	            )
   885	            adaptive_priority = self._adaptive_margin_priority(
   886	                family_margin=family_margin,
   887	                threshold=threshold,
   888	            )
   889	            base_metadata = {
   890	                "adaptive_family_margin_threshold": threshold,
   891	                "adaptive_margin_direction": margin_direction,
   892	                "adaptive_margin_abs": abs(family_margin),
   893	                "adaptive_priority": adaptive_priority,
   894	                "priority": adaptive_priority,
   895	                "adaptive_predicted_family_source": predicted_family_source,
   896	                "adaptive_policy_pair": f"{predicted_family}->{target_family}",
   897	                "explicit_ambiguity_type": explicit_type,
   898	                "family_margin_raw": family_margin,
   899	                "family_margin": family_margin_display,
   900	                "family_ranking": list(ranking),
   901	                "compiled_modal_families": sorted(compiled_modal_families),
   902	                "has_target_signal_evidence": has_target_signal_evidence,
   903	                "signal_free_pair_policy_applied": (
   904	                    not has_target_signal_evidence
   905	                    and supports_signal_free_pair_policy
   906	                ),
   907	                "has_compiled_target_family_formula": has_compiled_target_family_formula,
   908	                "has_frame_bm25_support": has_frame_bm25_support,
   909	                "lexical_signals": dict(sorted(signals.items())),
   910	                "is_compiler_required_policy_pair": is_compiler_required_policy_pair,
   911	                "runner_up_is_compiler_required_policy_pair": (
   912	                    runner_up_is_compiler_required_policy_pair
   913	                ),
   914	                "is_priority_policy_pair": is_priority_policy_pair,
   915	                "runner_up_is_priority_policy_pair": runner_up_is_priority_policy_pair,
   916	                "is_compiler_ambiguity_bundle_pair": is_compiler_ambiguity_bundle_pair,
