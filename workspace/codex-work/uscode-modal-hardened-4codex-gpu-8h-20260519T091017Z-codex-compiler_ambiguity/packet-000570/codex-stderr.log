    33	def test_deontic_profile_has_expected_operators_and_serial_semantics() -> None:
    34	    profile = DEFAULT_MODAL_REGISTRY.get_profile(ModalLogicFamily.DEONTIC)
    35	    symbols = {operator.symbol for operator in profile.operators}
    36	    cue_terms = {cue for operator in profile.operators for cue in operator.cue_terms}
    37	
    38	    assert profile.system == ModalSystem.D
    39	    assert profile.semantics.serial is True
    40	    assert {"O", "P", "F"}.issubset(symbols)
    41	    assert {"shall", "must", "may", "prohibited"}.issubset(cue_terms)
    42	    assert {"has a duty to", "under an obligation to"}.issubset(cue_terms)
    43	
