+def _audit_frame_logic_terms(kg_triples: Sequence[Dict[str, str]]) -> List[str]:
+    terms: List[str] = []
+    for triple in kg_triples:
+        predicate = str(triple.get("predicate", "")).strip()
+        obj = str(triple.get("object", "")).strip()
+        if not obj or predicate not in _FRAME_TERM_PREDICATES:
+            continue
+        terms.extend(_tokenize_frame_term(obj))
+    return _unique_preserve_order(terms)
+
+
+def _tokenize_frame_term(value: str) -> List[str]:
+    text = str(value or "").replace("_", " ").replace("-", " ")
+    return [
+        token.lower()
+        for token in _FRAME_TERM_RE.findall(text)
+        if len(token) > 1
+    ]
+
+
+def _unique_preserve_order(values: Sequence[str]) -> List[str]:
+    seen: set[str] = set()
+    result: List[str] = []
+    for value in values:
+        if not value or value in seen:
+            continue
+        seen.add(value)
+        result.append(value)
+    return result
+
