   135	def load_uscode_samples_from_parquet(
   136	    laws_parquet: str | Path | BinaryIO,
   137	    *,
   138	    embeddings_parquet: str | Path | BinaryIO | None = None,
   139	    limit: int = 25,
   140	    offset: int = 0,
   141	    batch_size: int = 128,
   142	) -> List[LegalSample]:
   143	    """Load deterministic `LegalSample`s from U.S. Code parquet rows."""
   144	    records = list(
   145	        iter_uscode_records_from_parquet(
   146	            laws_parquet,
