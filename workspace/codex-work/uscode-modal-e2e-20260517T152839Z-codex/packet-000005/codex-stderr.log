   531	def _predicate_from_tokens(
   532	    tokens: Sequence[SpaCyTokenFeature],
   533	    cue: SpaCyModalCueFeature,
   534	) -> ModalIRPredicate:
   535	    after_cue = [
   536	        token.normalized()
   537	        for token in tokens
   538	        if token.start_char >= cue.end_char and token.is_alpha and not token.is_stop
   539	    ]
   540	    before_cue = [
   541	        token.normalized()
   542	        for token in tokens
   543	        if token.end_char <= cue.start_char and token.is_alpha and not token.is_stop
   544	    ]
   545	    predicate_terms = after_cue[:6] or before_cue[-6:] or [cue.label]
   546	    arguments = []
   547	    if before_cue:
   548	        arguments.append(f"actor:{'_'.join(before_cue[-4:])}")
   549	    if after_cue:
   550	        arguments.append(f"scope:{'_'.join(after_cue[:4])}")
   551	    return ModalIRPredicate(
   552	        name="_".join(predicate_terms),
   553	        arguments=arguments,
   554	        role=_role_for_cue(cue),
   555	    )
   556	
   557	
   558	def _role_for_cue(cue: SpaCyModalCueFeature) -> str:
   559	    if cue.family == ModalLogicFamily.CONDITIONAL_NORMATIVE.value:
   560	        return "condition"
   561	    if cue.family == ModalLogicFamily.TEMPORAL.value:
   562	        return "temporal_scope"
   563	    if cue.family == ModalLogicFamily.FRAME.value:
   564	        return "frame"
   565	    return "clause"
