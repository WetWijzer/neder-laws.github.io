from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_samples import build_us_code_sample
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_modal_parser import LegalModalParser
path='/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet'
table=pq.read_table(path, columns=['title_number','section_number','text','source_url','law_name'])
rows=table.to_pylist()
targets=[('36','110105','us-code-36-110105-c16a1da4a57f02ec'),('25','450','us-code-25-450-c265a65e885d4655'),('25','5396','us-code-25-5396-17291bf2fa3ae3f6')]
for title,section,expected in targets:
    matches=[r for r in rows if str(r['title_number'])==title and str(r['section_number']).strip()==section]
    print('\\n===',title,section,'matches',len(matches))
    for i,r in enumerate(matches[:3]):
        text=r['text'] or ''
        parser=LegalModalParser()
        sample=build_us_code_sample(title=title,section=section,text=text,citation=f'{title} U.S.C. {section}',parser=parser)
        print('idx',i,'sample_id',sample.sample_id,'expected?',sample.sample_id==expected,'len',len(text),'law',r['law_name'])
        print('source',r['source_url'])
        print('text_snip',text[:500].replace('\\n',' ')[:500])
        print('formula_count',len(sample.modal_ir.formulas))
        if sample.modal_ir.formulas:
            print('last_fallback',sample.modal_ir.formulas[-1].metadata.get('fallback_rule'), sample.modal_ir.formulas[-1].metadata.get('cue'))
