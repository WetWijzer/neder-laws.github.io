+def test_modal_compiler_replays_sparse_heading_segments_for_42_1395w_5_3110_and_16_2204() -> None:
+    cases = [
+        (
+            "us-code-42-1395w-heading-segment",
+            "42 U.S.C. 1395w",
+            _USCODE_42_1395W_SPARSE_HEADING_TEXT,
+            "application",
+        ),
+        (
+            "us-code-5-3110-heading-segment",
+            "5 U.S.C. 3110",
+            _USCODE_5_3110_SPARSE_HEADING_TEXT,
+            "employment",
+        ),
+        (
+            "us-code-16-2204-heading-segment",
+            "16 U.S.C. 2204",
+            _USCODE_16_2204_SPARSE_HEADING_TEXT,
+            "funding",
+        ),
+    ]
+    for backend in ("regex", "spacy"):
+        compiler = DeterministicModalCompiler(
+            ModalCompilerConfig(
+                parser_backend=backend,
+                spacy_model_name="definitely_missing_legal_model",
+            )
+        )
+        for document_id, citation, text, expected_token in cases:
+            compiled = compiler.compile(
+                text,
+                document_id=document_id,
+                citation=citation,
+                source="us_code",
+            )
+
+            assert compiled.modal_ir.formulas
+            assert all(
+                ambiguity.ambiguity_type != "missing_modal_formula"
+                for ambiguity in compiled.ambiguities
+            )
+            fallback = compiled.modal_ir.formulas[-1]
+            assert fallback.operator.family == "frame"
+            assert fallback.metadata["cue"] == "__uscode_section_heading_fallback__"
+            assert fallback.metadata["fallback_rule"] == "uscode_section_heading_v1"
+            assert fallback.predicate.name != "unnamed_predicate"
+            assert expected_token in fallback.predicate.name
+            assert fallback.provenance.citation == citation
+
