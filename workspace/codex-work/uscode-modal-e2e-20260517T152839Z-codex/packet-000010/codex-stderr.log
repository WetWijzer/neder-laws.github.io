from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler, ModalCompilerConfig

compiler = DeterministicModalCompiler(
    ModalCompilerConfig(
        parser_backend='regex',
        frame_score_margin=0.0,
        modal_temporal_target_family_outvote_margin=0.0,
    )
)

text_conditional = (
    'In the case of a reviewed year adjustment, interest shall be computed after '
    'the due date and by the adjustment year return.'
)
compiled_conditional = compiler.compile(text_conditional)
amb1 = next(
    a for a in compiled_conditional.ambiguities
    if a.ambiguity_type == 'temporal_conditional_normative_family_outvoted'
)
assert amb1.metadata['predicted_family'] == 'temporal'
assert amb1.metadata['target_family'] == 'conditional_normative'
assert amb1.metadata['target_share'] == 0.0
assert amb1.metadata['lexical_signals']['has_conditional_scope_phrase'] is True
assert amb1.metadata['lexical_signals']['has_condition_or_exception_scope'] is True

text_temporal = (
    'The agency shall provide notice for the period beginning on January 1, 2030 '
    'and ending on December 31, 2030.'
)
compiled_temporal = compiler.compile(text_temporal)
amb2 = next(
    a for a in compiled_temporal.ambiguities
    if a.ambiguity_type == 'temporal_scope_family_outvoted'
)
assert amb2.metadata['predicted_family'] == 'deontic'
assert amb2.metadata['target_family'] == 'temporal'
assert amb2.metadata['target_share'] == 0.0
assert amb2.metadata['lexical_signals']['has_temporal_scope_phrase'] is True
assert amb2.metadata['lexical_signals']['has_calendar_date_scope'] is True
print('ok')
