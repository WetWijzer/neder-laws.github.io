def _zero_digit_signature_sample_document() -> ModalIRDocument:
    source_id = "us-code-43-1470.-845d9dceb9d264ab"
    formula = ModalIRFormula(
        formula_id="f-zero-digit-signature",
        operator=ModalIROperator(
            family="deontic",
