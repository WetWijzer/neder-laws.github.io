+def test_parser_replays_symbolic_validity_todo_samples_for_19_2372a_42_665_and_42_16988() -> None:
+    parser = LegalModalParser()
+    cases = [
+        (
+            "us-code-19-2372a-db684d3dbf8260c1",
+            "19 U.S.C. 2372a",
+            _USCODE_19_2372A_TODO_TEXT,
+        ),
+        (
+            "us-code-42-665.-09a84f3d930035b6",
+            "42 U.S.C. 665.",
+            _USCODE_42_665_TODO_TEXT,
+        ),
+        (
+            "us-code-42-16988.-04cba655455e764a",
+            "42 U.S.C. 16988.",
+            _USCODE_42_16988_TODO_TEXT,
+        ),
+    ]
+
+    for document_id, citation, text in cases:
+        document = parser.parse(
+            text,
+            document_id=document_id,
+            source="us_code",
+            citation=citation,
+        )
+
+        assert document.document_id == document_id
+        assert document.formulas
+        fallback = document.formulas[-1]
+        assert fallback.operator.family == "frame"
+        assert fallback.metadata["cue"] == "__uscode_section_heading_fallback__"
+        assert fallback.metadata["fallback_rule"] == "uscode_section_heading_v1"
+        assert fallback.predicate.name != "unnamed_predicate"
+        assert fallback.provenance.citation == citation
+
+
