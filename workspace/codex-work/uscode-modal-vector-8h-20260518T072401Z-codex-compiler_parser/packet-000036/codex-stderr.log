import duckdb, hashlib, re
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_modal_parser import LegalModalParser
p='/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet'
con=duckdb.connect()
rows=con.execute(\"\"\"
SELECT title_number, section_number, law_name, text
FROM read_parquet(?)
WHERE (title_number='42' AND lower(section_number)='1395w')
   OR (title_number='5' AND lower(section_number)='3110')
   OR (title_number='16' AND lower(section_number)='2204')
\"\"\",[p]).fetchall()
parser=LegalModalParser()
targets={
'us-code-42-1395w-31cd2a0825aafea6',
'us-code-5-3110-48ce897fc0a629fc',
'us-code-16-2204-98b9e979ee82fc81',
}
print('rows',len(rows))
for title,section,law_name,text in rows:
    normalized=parser.normalize_text(text or '')
    digest=hashlib.sha256(f\"{title}:{section}:{normalized}\".encode('utf-8')).hexdigest()[:16]
    sid=f\"us-code-{title}-{section}-{digest}\"
    if sid in targets:
        print('MATCH',sid,'law_name=',law_name,'len',len(text or ''))
print('done')
