    sample: LegalSample,
    *,
    prover_adapter: Optional[Any] = None,
    timeout: Optional[float] = None,
) -> ProverCompilationSignal:
    """Compile modal IR formulas through the local prover adapter."""
    formulas = list(sample.modal_ir.formulas)

