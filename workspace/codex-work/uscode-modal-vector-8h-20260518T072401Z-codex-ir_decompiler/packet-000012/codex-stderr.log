   936	def _softmax(logits: Mapping[str, float]) -> Dict[str, float]:
   937	    if not logits:
   938	        return {}
   939	    max_logit = max(float(value) for value in logits.values())
   940	    exponentials = {
   941	        name: math.exp(float(value) - max_logit)
   942	        for name, value in logits.items()
   943	    }
   944	    total = sum(exponentials.values())
   945	    if total == 0.0:
   946	        uniform = 1.0 / len(exponentials)
   947	        return {name: uniform for name in sorted(exponentials)}
   948	    return {name: exponentials[name] / total for name in sorted(exponentials)}
