   536	        return "", False
   537	    predicate, separator, value = tail.partition(":")
   538	    if not separator:
   539	        return "", False
   540	    canonical_predicate = _canonical_frame_ontology_predicate(predicate)
   541	    if canonical_predicate:
   542	        return (
   543	            _normalized_frame_ontology_value(canonical_predicate, value),
   544	            _predicate_allows_numeric_ontology_tokens(canonical_predicate),
   545	        )
   546	    if (
   547	        namespace in _FRAME_ONTOLOGY_CONTEXTUAL_NAMESPACED_FEATURE_PREFIXES
   548	        and _is_contextual_frame_ontology_predicate(predicate)
   549	    ):
   550	        return (
   551	            _normalized_frame_ontology_value(predicate, value),
   552	            _predicate_allows_numeric_ontology_tokens(predicate),
   553	        )
   554	    return "", False
   555	
   556	
   557	def _predicate_allows_numeric_ontology_tokens(predicate: str) -> bool:
   558	    normalized = _FRAME_ONTOLOGY_PREDICATE_TOKEN_RE.sub(
   559	        "_",
   560	        str(predicate or "").strip().lower(),
   561	    ).strip("_")
   562	    if not normalized or normalized.endswith("_count"):
   563	        return False
   564	    canonical = _FRAME_ONTOLOGY_PREDICATE_ALIASES.get(normalized, normalized)
   565	    return any(
   566	        canonical.startswith(prefix)
   567	        for prefix in _FRAME_ONTOLOGY_NUMERIC_VALUE_PREDICATE_PREFIXES
   568	    )
