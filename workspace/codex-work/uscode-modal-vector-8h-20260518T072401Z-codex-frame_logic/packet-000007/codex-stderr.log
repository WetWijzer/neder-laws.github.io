  1071	    def _embedding_contributions_for(
  1072	        self,
  1073	        feature_keys: Sequence[str],
  1074	        residual: Sequence[float],
  1075	        *,
  1076	        dimensions: int,
  1077	    ) -> List[AutoencoderFeatureContribution]:
  1078	        contributions: List[AutoencoderFeatureContribution] = []
  1079	        residual_norm = _vector_norm(residual)
  1080	        for feature in feature_keys:
  1081	            weights = self.state.feature_embedding_weights.get(feature)
  1082	            if weights is None or len(weights) != dimensions:
  1083	                continue
  1084	            scaled_weights = [
  1085	                float(value) * self.feature_embedding_weight_scale
  1086	                for value in weights
  1087	            ]
  1088	            alignment = sum(float(left) * float(right) for left, right in zip(residual, scaled_weights))
  1089	            weight_norm = _vector_norm(scaled_weights)
  1090	            normalized_alignment = alignment / (residual_norm * weight_norm) if residual_norm and weight_norm else 0.0
  1091	            contributions.append(
  1092	                AutoencoderFeatureContribution(
  1093	                    feature=feature,
  1094	                    contribution_type="feature_embedding_weight",
  1095	                    value=round(alignment, 12),
  1096	                    magnitude=round(weight_norm, 12),
  1097	                    metadata={
  1098	                        "alignment_with_residual": round(normalized_alignment, 12),
  1099	                        "feature_embedding_weight_scale": self.feature_embedding_weight_scale,
  1100	                    },
  1101	                )
  1102	            )
  1103	        return sorted(
  1104	            contributions,
  1105	            key=lambda contribution: (
  1106	                -abs(float(contribution.metadata.get("alignment_with_residual", 0.0))),
  1107	                -contribution.magnitude,
  1108	                contribution.feature,
  1109	            ),
  1110	        )
