   182	def test_modal_codec_encodes_all_modal_families_with_frame_logic() -> None:
   183	    codec = DeterministicModalLogicCodec(
   184	        ModalLogicCodecConfig(parser_backend="spacy", embedding_dimensions=8)
   185	    )
   186	
   187	    result = codec.encode(
   188	        "The agency must provide notice within 30 days after application.",
   189	        document_id="sample-doc",
   190	        citation="5 U.S.C. 552",
   191	        source="us_code",
   192	    )
   193	
   194	    families = {formula.operator.family for formula in result.modal_ir.formulas}
   195	    assert {"deontic", "temporal"}.issubset(families)
   196	    assert result.modal_ir.metadata["llm_call_count"] == 0
   197	    assert result.selected_frame == "administrative_notice_hearing"
   198	    assert result.modal_ir.frame_candidates
   199	    assert len(result.decoded_embedding) == 8
   200	    assert result.losses["cross_entropy_loss"] >= 0.0
   201	    assert "flogic_similarity_loss" in result.losses
   202	    assert result.losses["text_reconstruction_loss"] == 0.0
   203	    assert result.losses["modal_span_coverage_loss"] == 0.0
   204	    assert -1.0 <= result.losses["cosine_similarity"] <= 1.0
   205	    assert result.flogic_result is not None
