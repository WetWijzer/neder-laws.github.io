   504	def _frame_ontology_value_from_feature(feature: str) -> tuple[str, bool]:
   505	    lowered = feature.lower()
   506	
   507	    for prefix in _FRAME_FAMILY_FEATURE_PREFIXES:
   508	        if lowered == prefix or lowered.startswith(f"{prefix}:"):
