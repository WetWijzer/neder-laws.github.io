   299	def test_modal_codec_encodes_all_modal_families_with_frame_logic() -> None:
   300	    codec = DeterministicModalLogicCodec(
   301	        ModalLogicCodecConfig(parser_backend="spacy", embedding_dimensions=8)
   302	    )
   303	
   304	    result = codec.encode(
   305	        "The agency must provide notice within 30 days after application.",
   306	        document_id="sample-doc",
   307	        citation="5 U.S.C. 552",
   308	        source="us_code",
   309	    )
   310	
   311	    families = {formula.operator.family for formula in result.modal_ir.formulas}
   312	    assert {"deontic", "temporal"}.issubset(families)
   313	    assert result.modal_ir.metadata["llm_call_count"] == 0
   314	    assert result.selected_frame == "administrative_notice_hearing"
   315	    assert result.modal_ir.frame_candidates
   316	    assert len(result.decoded_embedding) == 8
   317	    assert result.losses["cross_entropy_loss"] >= 0.0
   318	    assert "flogic_similarity_loss" in result.losses
   319	    assert result.losses["text_reconstruction_loss"] == 0.0
   320	    assert result.losses["modal_span_coverage_loss"] == 0.0
   321	    assert -1.0 <= result.losses["cosine_similarity"] <= 1.0
   322	    assert result.flogic_result is not None
   323	    assert result.flogic_result.ontology_consistent is True
   324	    assert result.kg_triples
   325	    assert all(triple["predicate"] for triple in result.kg_triples)
   326	    assert result.modal_ir.frame_logic.triples
   327	    assert result.modal_ir.frame_logic.to_triples() == result.kg_triples
   328	    assert result.modal_ir.frame_logic.selected_frame == result.selected_frame
   329	    assert result.modal_ir.frame_logic.graph_id == "sample-doc:flogic"
   330	    assert "LegalModalDocument" in result.modal_ir.frame_logic.neo4j_node_labels
   331	    assert result.modal_ir.metadata["flogic_triple_count"] == len(result.kg_triples)
   332	    assert result.modal_ir.metadata["flogic_triples"] == result.kg_triples
   333	    assert result.flogic_ontology.frames
   334	    assert result.neo4j_graph_data.metadata["neo4j_compatible"] is True
   335	    assert result.neo4j_graph_data.node_count > 0
   336	    assert result.neo4j_graph_data.relationship_count == len(result.kg_triples)
   337	    assert "LegalModalDocument" in result.neo4j_graph_data.schema.node_labels
   338	    engine, import_report = import_graph_data_to_graph_engine(result.neo4j_graph_data)
   339	    assert import_report["nodes_imported"] == result.neo4j_graph_data.node_count
   340	    assert import_report["relationships_imported"] == result.neo4j_graph_data.relationship_count

