   318	class SpaCyModalDecoder:
   319	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   320	
   321	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   322	        if dimensions < 1:
   323	            raise ValueError("dimensions must be >= 1")
   324	        vector = [0.0 for _ in range(dimensions)]
   325	        for feature in self._feature_stream(encoding):
   326	            slot, value = _feature_hash(feature, dimensions)
   327	            vector[slot] += value
   328	        norm = math.sqrt(sum(value * value for value in vector))
   329	        if norm == 0.0:
   330	            return vector
   331	        return [round(value / norm, 6) for value in vector]
   332	
   333	    def family_logits(
   334	        self,
   335	        encoding: SpaCyLegalEncoding,
   336	        *,
   337	        modal_families: Sequence[str],
   338	    ) -> Dict[str, float]:
   339	        logits = {family: -0.25 for family in modal_families}
   340	        counts = encoding.modal_family_counts()
   341	        for family, count in counts.items():
   342	            if family in logits:
   343	                logits[family] = 2.0 + float(count)
   344	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   345	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   346	        return logits
   347	
   348	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   349	        yield f"doclen:{len(encoding.tokens)}"
   350	        for token in encoding.tokens:
   351	            if token.is_alpha and not token.is_stop:
   352	                yield f"lemma:{token.normalized()}"
   353	            if token.pos:
   354	                yield f"pos:{token.pos}"
   355	            if token.dep:
   356	                yield f"dep:{token.dep}"
   357	        for cue in encoding.cues:
   358	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   359	        for family, count in encoding.modal_family_counts().items():
   360	            yield f"family:{family}:{count}"
