   595	    def _ensure_explicit_adaptive_ambiguities(
   596	        self,
   597	        ambiguities: Sequence[ModalCompilationAmbiguity],
   598	    ) -> List[ModalCompilationAmbiguity]:
   599	        """Backfill explicit adaptive ambiguity variants from base low-margin records."""
   600	        resolved_ambiguities = list(ambiguities)
   601	        existing_explicit_keys = {
   602	            self._adaptive_explicit_ambiguity_key(ambiguity)
   603	            for ambiguity in resolved_ambiguities
   604	            if ambiguity.ambiguity_type.startswith("adaptive_")
   605	            and ambiguity.ambiguity_type != "adaptive_family_margin_low"
   606	        }
   607	        for ambiguity in list(resolved_ambiguities):
   608	            if ambiguity.ambiguity_type != "adaptive_family_margin_low":
   609	                continue
   610	            metadata = (
   611	                ambiguity.metadata
   612	                if isinstance(ambiguity.metadata, dict)
   613	                else {}
   614	            )
   615	            explicit_type = self._derive_explicit_adaptive_ambiguity_type(ambiguity)
   616	            if not explicit_type:
   617	                continue
   618	            predicted_family, target_family, is_self_pair = (
   619	                self._adaptive_policy_families(ambiguity)
   620	            )
   621	            explicit_candidate_ids = list(ambiguity.candidate_ids)
   622	            if predicted_family and target_family:
   623	                explicit_candidate_ids = (
   624	                    [predicted_family]
   625	                    if is_self_pair or predicted_family == target_family
   626	                    else [predicted_family, target_family]
   627	                )
   628	            explicit_key = (
   629	                explicit_type,
   630	                tuple(str(candidate_id) for candidate_id in explicit_candidate_ids),
   631	                str(metadata.get("adaptive_policy_pair") or ""),
   632	                str(metadata.get("adaptive_predicted_family_source") or ""),
   633	            )
   634	            if explicit_key in existing_explicit_keys:
   635	                continue
   636	            explicit_message = (
   637	                "Explicit adaptive low-margin ambiguity for the predicted modal "
   638	                "family against close competing families."
   639	                if bool(metadata.get("is_self_pair"))
   640	                else (
   641	                    "Explicit adaptive modal-family conflict between the predicted "
   642	                    "family and a competing legal family."
   643	                )
   644	            )
   645	            resolved_ambiguities.append(
   646	                ModalCompilationAmbiguity(
   647	                    ambiguity_type=explicit_type,
   648	                    message=explicit_message,
   649	                    candidate_ids=explicit_candidate_ids,
