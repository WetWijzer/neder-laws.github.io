   154	@dataclass(frozen=True)
   155	class FrameCandidate:
   156	    """Candidate ontology frame for legal interpretation."""
   157	
   158	    frame_id: str
   159	    label: str
   160	    description: str = ""
   161	    terms: Sequence[str] = field(default_factory=tuple)
   162	    domain: str = "general"
   163	    metadata: Mapping[str, object] = field(default_factory=dict)
   164	
   165	    def document_text(self) -> str:
   166	        """Return lexical text indexed by BM25."""
   167	        return " ".join([self.label, self.description, *self.terms, self.domain])
   168	
   169	
   170	@dataclass(frozen=True)
   171	class FrameSelection:
   172	    """BM25 selection result with deterministic explanation fields."""
   173	
   174	    frame: FrameCandidate
   175	    score: float
   176	    matched_terms: List[str]
   177	    explanation: str
   178	
   179	    def to_dict(self) -> Dict[str, object]:
   180	        return {
   181	            "domain": self.frame.domain,
   182	            "explanation": self.explanation,
   183	            "frame_id": self.frame.frame_id,
   184	            "label": self.frame.label,
   185	            "matched_terms": list(self.matched_terms),
   186	            "score": self.score,
   187	        }
   188	
   189	
   190	class BM25FrameSelector:
   191	    """Deterministic BM25 ranker for ontology frame candidates."""
   192	
   193	    def __init__(
   194	        self,
   195	        frames: Iterable[FrameCandidate],
   196	        *,
   197	        k1: float = 1.5,
   198	        b: float = 0.75,
   199	    ) -> None:
   200	        self.frames = tuple(frames)
   201	        self.k1 = k1
   202	        self.b = b
   203	        self._documents = [self._tokenize(frame.document_text()) for frame in self.frames]
   204	        self._avgdl = sum(len(document) for document in self._documents) / len(self._documents) if self._documents else 0.0
   205	        self._doc_freq = self._build_doc_freq(self._documents)
   206	
   207	    def rank(
   208	        self,
   209	        text: str,
   210	        *,
   211	        top_k: int = 3,
   212	        domain: str | None = None,
   213	    ) -> List[FrameSelection]:
   214	        """Rank frame candidates for text."""
   215	        query_tokens = self._tokenize(text)
   216	        query_terms = sorted(set(query_tokens))
   217	        results: List[FrameSelection] = []
   218	        for frame, document in zip(self.frames, self._documents):
   219	            if domain is not None and frame.domain != domain:
   220	                continue
   221	            matched_terms = sorted(set(query_terms) & set(document))
   222	            score = self._score(query_terms, document)
   223	            if matched_terms:
   224	                score += 0.05 * len(matched_terms)
   225	            results.append(
   226	                FrameSelection(
   227	                    frame=frame,
   228	                    score=round(score, 6),
   229	                    matched_terms=matched_terms,
   230	                    explanation=self._explain(frame, matched_terms, score),
   231	                )
   232	            )
   233	        results.sort(key=lambda result: (-result.score, result.frame.frame_id))
   234	        return results[:max(top_k, 0)]
   235	
   236	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   237	        if not query_terms or not document or not self.frames:
   238	            return 0.0
   239	        doc_len = len(document)
   240	        term_counts = {term: document.count(term) for term in set(document)}
   241	        total = 0.0
   242	        for term in query_terms:
   243	            freq = term_counts.get(term, 0)
   244	            if freq == 0:
   245	                continue
   246	            doc_freq = self._doc_freq.get(term, 0)
   247	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   248	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   249	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   250	        return total
   251	
   252	    def _explain(self, frame: FrameCandidate, matched_terms: Sequence[str], score: float) -> str:
   253	        if matched_terms:
   254	            return f"Frame {frame.frame_id} matched {', '.join(matched_terms)} with BM25 score {score:.3f}."
   255	        return f"Frame {frame.frame_id} had no lexical query matches; BM25 score {score:.3f}."
   256	
   257	    def _tokenize(self, text: str) -> List[str]:
   258	        return [token.lower() for token in _TOKEN_RE.findall(text)]
   259	
   260	    def _build_doc_freq(self, documents: Sequence[Sequence[str]]) -> Dict[str, int]:
   261	        frequencies: Dict[str, int] = {}
   262	        for document in documents:
   263	            for term in set(document):
   264	                frequencies[term] = frequencies.get(term, 0) + 1
   265	        return frequencies
   266	
   267	
   268	def frame_ontology_terms(
   269	    frame: FrameCandidate,
   270	    *,
   271	    matched_terms: Sequence[str] = (),
   272	    max_terms: int = 24,
   273	) -> List[str]:
   274	    """Return deterministic ontology terms for one frame candidate.
   275	
   276	    The term list is intentionally stable and explainable: we keep canonical
   277	    phrase forms plus tokenized atoms for frame id/label/domain/terms and the
   278	    lexical matches that affected BM25 scoring.
   279	    """
   280	
   281	    raw_values = [
   282	        (frame.frame_id, False),
   283	        *((value, True) for value in matched_terms),
   284	        (frame.label, True),
   285	        (frame.domain, True),
   286	        *((value, True) for value in frame.terms),
   287	    ]
   288	    terms: List[str] = []
   289	    for raw, include_tokens in raw_values:
   290	        text = str(raw or "").strip()
   291	        if not text:
   292	            continue
   293	        canonical = normalize_frame_ontology_term(text)
   294	        if canonical and canonical not in terms:
   295	            terms.append(canonical)
