from ipfs_datasets_py.logic.modal.codec import DeterministicModalLogicCodec, ModalLogicCodecConfig
import ipfs_datasets_py.optimizers.logic_theorem_optimizer.frame_bm25_selector as fs

codec=DeterministicModalLogicCodec(ModalLogicCodecConfig(parser_backend='spacy', embedding_dimensions=8))
texts=[
('5 U.S.C. 552','The agency must provide notice and hearing before issuing a final order.'),
('48 U.S.C. 1572.','Administrative notice and hearing.'),
('2 U.S.C. 74b','Transferred.'),
('7 U.S.C. 2611','The Secretary may make grants under subsection (b).'),
]
for i,(cit,text) in enumerate(texts,1):
    r=codec.encode(text,document_id=f'doc{i}',citation=cit,source='us_code')
    ignored=[]
    ctx=[]
    aud=[]
    for t in r.kg_triples:
        p=t['predicate']
        can=fs._canonical_frame_ontology_predicate(p)
        cxt=fs._is_contextual_frame_ontology_predicate(p)
        if can: aud.append(p)
        elif cxt: ctx.append(p)
        else: ignored.append(p)
    def top(vals):
        seen=[]
        for v in vals:
            if v not in seen:
                seen.append(v)
        return seen
    print('\\n===',cit)
    print('aud',top(aud)[:30])
    print('ctx',top(ctx)[:40])
    print('ignored',top(ignored)[:40])
