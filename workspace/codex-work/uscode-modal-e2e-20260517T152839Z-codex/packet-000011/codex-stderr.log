        codex_model="gpt-5.5",
        codex_apply_mode="patch_only",
        codex_commit_mode="none",
        codex_sandbox="workspace-write",
        codex_timeout_seconds=45.0,
        warm_start_run_id=[],
        warm_start_state=[],
