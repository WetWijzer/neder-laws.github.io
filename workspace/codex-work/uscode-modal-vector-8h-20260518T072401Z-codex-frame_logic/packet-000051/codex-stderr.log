def frame_ontology_high_signal_terms(
    terms: Iterable[str],
    *,
    max_terms: int = 256,
    min_numeric_length: int = _FRAME_ONTOLOGY_AUDIT_MIN_NUMERIC_TERM_LENGTH,
) -> List[str]:
