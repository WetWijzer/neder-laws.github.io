            "deterministic_compiler": "modal_compiler_v1",
            "deterministic_parser": parser_name,
            "frame_selector": "bm25_v1",
            "llm_call_count": 0,
            "modal_family_counts": encoding.modal_family_counts(),
            "selected_frame": selected_frame,
        }
