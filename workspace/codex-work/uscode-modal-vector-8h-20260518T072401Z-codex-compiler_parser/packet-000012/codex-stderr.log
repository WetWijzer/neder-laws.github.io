import hashlib,itertools,re

samples=[
    ('2','123b','a41bd4aaf77abbf3'),
    ('25','478','ebbb6cefef299fc2'),
    ('15','1693l','62b207bc138a3216'),
]

statuses=[
    'Transferred', 'Omitted', 'Repealed', 'Reserved', 'Vacant', 'Renumbered', 'Terminated',
    'Transferred.', 'Omitted.', 'Repealed.', 'Reserved.', 'Vacant.', 'Renumbered.', 'Terminated.'
]
# patterns for heading text
patterns=[
    '§{sec}. {status}',
    '§ {sec}. {status}',
    '{sec}. {status}',
    '§{sec} {status}',
    '§ {sec} {status}',
    '{sec} {status}',
    '§{sec}.—{status}',
    '§ {sec}.—{status}',
    '{sec}.—{status}',
]
# optional trailing notes and punctuation variants
trailers=['', ' Editorial Notes', ' Editorial notes', ' Editor\\'s note', ' [Transferred]']

# normalization function in parser
norm=lambda s: re.sub(r'\\s+',' ',s).strip()

for title,sec,target in samples:
    found=[]
    for pat,status,tr in itertools.product(patterns,statuses,trailers):
        t=pat.format(sec=sec,status=status)+tr
        n=norm(t)
        dig=hashlib.sha256(f\"{title}:{sec}:{n}\".encode()).hexdigest()[:16]
        if dig==target:
