   408	def _normalize(text: str) -> str:
   409	    return _WHITESPACE_RE.sub(" ", text).strip()
   410	
   411	
   412	def _document_id(normalized: str) -> str:
   413	    digest = hashlib.sha256(normalized.encode("utf-8")).hexdigest()[:16]
   414	    return f"spacy-legal-text-{digest}"
   415	
   416	
   417	def _feature_hash(feature: str, dimensions: int) -> tuple[int, float]:
   418	    digest = hashlib.sha256(feature.encode("utf-8")).digest()
   419	    slot = int.from_bytes(digest[:4], "big") % dimensions
   420	    sign = 1.0 if digest[4] % 2 == 0 else -1.0
   421	    magnitude = 0.5 + (digest[5] / 255.0)
   422	    return slot, sign * magnitude
   423	
   424	
   425	def _unique_preserve_order(features: Iterable[str]) -> List[str]:
   426	    seen: set[str] = set()
   427	    result: List[str] = []
   428	    for feature in features:
   429	        if feature in seen:
   430	            continue
   431	        seen.add(feature)
   432	        result.append(feature)
   433	    return result
   434	
   435	
   436	def _sentence_for_cue(
   437	    sentences: Sequence[SpaCySentenceFeature],
   438	    cue: SpaCyModalCueFeature,
   439	) -> SpaCySentenceFeature:
   440	    for sentence in sentences:
   441	        if sentence.start_char <= cue.start_char < sentence.end_char:
   442	            return sentence
   443	    return SpaCySentenceFeature(text="", start_char=cue.start_char, end_char=cue.end_char)
   444	
   445	
   446	def _tokens_for_span(
   447	    tokens: Sequence[SpaCyTokenFeature],
   448	    start_char: int,
   449	    end_char: int,
   450	) -> List[SpaCyTokenFeature]:
   451	    return [
   452	        token
   453	        for token in tokens
   454	        if token.start_char < end_char and token.end_char > start_char
   455	    ]
   456	
   457	
   458	def _predicate_from_tokens(
   459	    tokens: Sequence[SpaCyTokenFeature],
   460	    cue: SpaCyModalCueFeature,
   461	) -> ModalIRPredicate:
   462	    after_cue = [
   463	        token.normalized()
   464	        for token in tokens
   465	        if token.start_char >= cue.end_char and token.is_alpha and not token.is_stop
   466	    ]
   467	    before_cue = [
   468	        token.normalized()
   469	        for token in tokens
   470	        if token.end_char <= cue.start_char and token.is_alpha and not token.is_stop
   471	    ]
   472	    predicate_terms = after_cue[:6] or before_cue[-6:] or [cue.label]
   473	    arguments = []
   474	    if before_cue:
   475	        arguments.append(f"actor:{'_'.join(before_cue[-4:])}")
   476	    if after_cue:
   477	        arguments.append(f"scope:{'_'.join(after_cue[:4])}")
   478	    return ModalIRPredicate(
   479	        name="_".join(predicate_terms),
   480	        arguments=arguments,
   481	        role=_role_for_cue(cue),
   482	    )
   483	
   484	
   485	def _role_for_cue(cue: SpaCyModalCueFeature) -> str:
   486	    if cue.family == ModalLogicFamily.CONDITIONAL_NORMATIVE.value:
   487	        return "condition"
   488	    if cue.family == ModalLogicFamily.TEMPORAL.value:
   489	        return "temporal_scope"
   490	    if cue.family == ModalLogicFamily.FRAME.value:
   491	        return "frame"
   492	    return "clause"
   493	
