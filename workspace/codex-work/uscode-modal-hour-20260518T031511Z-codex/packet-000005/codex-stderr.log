                                "against competing cue evidence."
                            ),
                            candidate_ids=[primary_family, best_other_family],
                            metadata={
                                "best_other_family": best_other_family,
                                "best_other_share": round(best_other_share, 6),
                                "family_margin": round(family_margin, 6),
