diff --git a/tests/unit/optimizers/logic_theorem_optimizer/test_legal_modal_parser.py b/tests/unit/optimizers/logic_theorem_optimizer/test_legal_modal_parser.py
index 22714f811673e47a47beb5cac119d63b10a2743d..89fe2e9f544f402514833bfa1ef8bde28f3ceb3e
--- a/tests/unit/optimizers/logic_theorem_optimizer/test_legal_modal_parser.py
+++ b/tests/unit/optimizers/logic_theorem_optimizer/test_legal_modal_parser.py
@@ -194,6 +194,47 @@
     assert fallback.provenance.citation == "18 U.S.C. 3008"
 
 
+def test_parser_replays_short_editorial_status_zero_formula_cases() -> None:
+    parser = LegalModalParser()
+    cases = [
+        (
+            "us-code-15-8563-3b998304c368f8a4",
+            "15 U.S.C. 8563",
+            "\u00a78563. Renumbered.",
+            "renumbered",
+        ),
+        (
+            "us-code-2-74b-55df9e8ab40ae3a5",
+            "2 U.S.C. 74b",
+            "\u00a774b. Terminated.",
+            "terminated",
+        ),
+        (
+            "us-code-42-11924.-096a2b2493c6c5cf",
+            "42 U.S.C. 11924.",
+            "\u00a711924. Vacant.",
+            "vacant",
+        ),
+    ]
+
+    for document_id, citation, text, status_keyword in cases:
+        document = parser.parse(
+            text,
+            document_id=document_id,
+            source="us_code",
+            citation=citation,
+        )
+
+        assert document.document_id == document_id
+        assert document.formulas
+        fallback = document.formulas[-1]
+        assert fallback.operator.family == "frame"
+        assert fallback.metadata["cue"] == "__uscode_editorial_status_fallback__"
+        assert fallback.metadata["fallback_rule"] == "uscode_editorial_status_heading_v1"
+        assert fallback.metadata["status_keyword"] == status_keyword
+        assert fallback.provenance.citation == citation
+
+
