   252	    def _load_nlp(self, model_name: str):
   253	        try:
   254	            import spacy
   255	        except ImportError as exc:  # pragma: no cover - dependency is present in supported envs
   256	            raise RuntimeError("spaCy is required for SpaCyLegalEncoder") from exc
   257	        try:
   258	            nlp = spacy.load(model_name)
   259	            used_fallback = False
   260	        except OSError:
   261	            nlp = spacy.blank("en")
   262	            used_fallback = True
   263	        if "sentencizer" not in nlp.pipe_names:
   264	            nlp.add_pipe("sentencizer")
   265	        return nlp, used_fallback
