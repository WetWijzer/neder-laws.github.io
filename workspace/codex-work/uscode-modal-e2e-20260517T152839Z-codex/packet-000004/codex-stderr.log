    17	def cosine_similarity(left: Sequence[float], right: Sequence[float]) -> float:
    18	    """Return cosine similarity for two vectors."""
    19	    _check_same_length(left, right)
    20	    left_norm = math.sqrt(sum(value * value for value in left))
    21	    right_norm = math.sqrt(sum(value * value for value in right))
    22	    if left_norm == 0.0 or right_norm == 0.0:
    23	        return 0.0
    24	    return sum(a * b for a, b in zip(left, right)) / (left_norm * right_norm)
    25	
    26	
    27	def cosine_loss(left: Sequence[float], right: Sequence[float]) -> float:
    28	    """Return ``1 - cosine_similarity``."""
    29	    return 1.0 - cosine_similarity(left, right)
    30	
    31	
    32	def mse_loss(left: Sequence[float], right: Sequence[float]) -> float:
    33	    """Return mean squared reconstruction error."""
    34	    _check_same_length(left, right)
    35	    if not left:
    36	        return 0.0
    37	    return sum((a - b) ** 2 for a, b in zip(left, right)) / len(left)
    38	
    39	
    40	def cross_entropy_loss(probabilities: Mapping[str, float], target: str) -> float:
    41	    """Return categorical cross entropy for a target label."""
    42	    probability = max(float(probabilities.get(target, 0.0)), 1e-12)
    43	    return -math.log(probability)
    44	
    45	
    46	def cross_entropy_distribution_loss(
    47	    probabilities: Mapping[str, float],
    48	    target_distribution: Mapping[str, float],
    49	) -> float:
    50	    """Return cross entropy against a target label distribution."""
    51	    total_weight = sum(
    52	        max(0.0, float(weight))
    53	        for weight in target_distribution.values()
    54	    )
    55	    if total_weight <= 0.0:
    56	        return 0.0
    57	    loss = 0.0
    58	    for family, weight in target_distribution.items():
    59	        normalized_weight = max(0.0, float(weight)) / total_weight
    60	        probability = max(float(probabilities.get(str(family), 0.0)), 1e-12)
    61	        loss += normalized_weight * -math.log(probability)
    62	    return loss
