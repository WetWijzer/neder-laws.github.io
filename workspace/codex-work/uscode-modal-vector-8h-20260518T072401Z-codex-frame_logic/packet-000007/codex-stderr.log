  1521	    their AST/write lanes.
  1522	    """
  1523	    if max_items < 1:
  1524	        return []
  1525	    candidates = [
  1526	        todo
  1527	        for todo in sorted(todos, key=_todo_priority_key)
  1528	        if _coerce_vector(vectors_by_todo_id.get(todo.todo_id))
  1529	    ]
  1530	    if not candidates:
  1531	        return []
  1532	
  1533	    anchor = candidates[0]
  1534	    anchor_vector = _coerce_vector(vectors_by_todo_id.get(anchor.todo_id))
  1535	    if not anchor_vector:
  1536	        return []
  1537	
  1538	    selected: List[Dict[str, Any]] = [
  1539	        {"similarity": 1.0, "todo": anchor},
  1540	    ]
  1541	    scored: List[tuple[float, tuple[float, str, str], ModalTodo]] = []
  1542	    for todo in candidates[1:]:
  1543	        if not _program_todo_vector_bundle_compatible(anchor, todo):
  1544	            continue
  1545	        vector = _coerce_vector(vectors_by_todo_id.get(todo.todo_id))
  1546	        if not vector:
  1547	            continue
  1548	        similarity = _cosine_similarity(anchor_vector, vector)
  1549	        if similarity < float(min_similarity):
  1550	            continue
  1551	        scored.append((similarity, _todo_priority_key(todo), todo))
  1552	
  1553	    for similarity, _, todo in sorted(scored, key=lambda item: (-item[0], item[1])):
  1554	        if len(selected) >= max_items:
  1555	            break
  1556	        selected.append({"similarity": similarity, "todo": todo})
  1557	    return selected
  1558	
  1559	
  1560	def _program_todo_scope(todo: ModalTodo) -> str:
  1561	    scope = str(todo.metadata.get("program_synthesis_scope") or "").strip()
  1562	    if scope:
  1563	        return scope
  1564	    return _program_synthesis_scope(
  1565	        action=todo.action,
  1566	        target_component=_todo_target_component(todo),
  1567	    )
  1568	
  1569	
  1570	def _program_todo_vector_bundle_compatible(anchor: ModalTodo, candidate: ModalTodo) -> bool:
  1571	    if _program_todo_scope(anchor) != _program_todo_scope(candidate):
  1572	        return False
  1573	    return _todo_optimizer_role(anchor) == _todo_optimizer_role(candidate)
  1574	
  1575	
  1576	def _coerce_vector(value: Optional[Sequence[float]]) -> List[float]:
  1577	    if value is None:
  1578	        return []
  1579	    try:
  1580	        vector = [float(item) for item in value]
  1581	    except (TypeError, ValueError):
  1582	        return []
  1583	    return vector if vector else []
  1584	
  1585	
  1586	def _cosine_similarity(left: Sequence[float], right: Sequence[float]) -> float:
  1587	    size = min(len(left), len(right))
  1588	    if size == 0:
  1589	        return 0.0
  1590	    dot = sum(float(left[index]) * float(right[index]) for index in range(size))
  1591	    left_norm = sum(float(left[index]) ** 2 for index in range(size)) ** 0.5
  1592	    right_norm = sum(float(right[index]) ** 2 for index in range(size)) ** 0.5
  1593	    if left_norm == 0.0 or right_norm == 0.0:
  1594	        return 0.0
  1595	    return dot / (left_norm * right_norm)
  1596	
  1597	
  1598	def _program_todo_family_pairs_from_evidence(value: Any) -> List[str]:
  1599	    if not isinstance(value, list):
  1600	        return []
  1601	    pairs: List[str] = []
  1602	    for item in value:
  1603	        if not isinstance(item, Mapping):
  1604	            continue
  1605	        predicted = str(item.get("predicted_family") or "").strip()
  1606	        target = str(item.get("target_family") or "").strip()
  1607	        if predicted and target:
  1608	            pairs.append(f"{predicted}->{target}")
  1609	    return sorted(set(pairs))
  1610	
  1611	
  1612	def _program_todos_near_duplicate(
  1613	    existing: ModalTodo,
  1614	    candidate: ModalTodo,
  1615	    *,
  1616	    jaccard_threshold: float,
  1617	) -> bool:
  1618	    if existing.action != candidate.action:
  1619	        return False
  1620	    if _todo_target_component(existing) != _todo_target_component(candidate):
  1621	        return False
  1622	    existing_signature = str(existing.metadata.get("dedupe_signature") or "")
  1623	    candidate_signature = str(candidate.metadata.get("dedupe_signature") or "")
  1624	    if existing_signature and candidate_signature and existing_signature == candidate_signature:
  1625	        return True
  1626	    existing_samples = set(existing.sample_ids)
  1627	    candidate_samples = set(candidate.sample_ids)
  1628	    if not existing_samples or not candidate_samples:
  1629	        return False
  1630	    intersection = len(existing_samples & candidate_samples)
  1631	    union = len(existing_samples | candidate_samples)
  1632	    if union == 0:
  1633	        return False
  1634	    return (intersection / union) >= float(jaccard_threshold)
  1635	
  1636	
  1637	def _todo_target_component(todo: ModalTodo) -> str:
  1638	    return str(
  1639	        todo.metadata.get("target_component")
  1640	        or PROGRAM_SYNTHESIS_ACTION_TARGETS.get(todo.action)
  1641	        or ""
  1642	    )
  1643	
  1644	
  1645	def _program_synthesis_scope(*, action: str, target_component: str) -> str:
  1646	    target = target_component or PROGRAM_SYNTHESIS_ACTION_TARGETS.get(action, "")
  1647	    if target.startswith("modal.frame_logic"):
  1648	        return "frame_logic"
  1649	    if target.startswith("modal.ir_decompiler"):
  1650	        return "ir_decompiler"
  1651	    if target.startswith("modal.compiler.ambiguity"):
  1652	        return "compiler_ambiguity"
  1653	    if target.startswith("modal.compiler.registry"):
  1654	        return "compiler_registry"
  1655	    if target.startswith("modal.compiler"):
  1656	        return "compiler_parser"
  1657	    return action.replace("-", "_").replace(".", "_")
  1658	
  1659	
  1660	def _sample_id_from_hint(hint: ModalProgramSynthesisHint) -> str:
  1661	    return str(hint.evidence.get("sample_id") or "").strip()
  1662	
  1663	
  1664	def _compact_hint_evidence(hint: ModalProgramSynthesisHint) -> Dict[str, Any]:
  1665	    """Keep the autoencoder evidence needed for later deterministic repair."""
  1666	    evidence = dict(hint.evidence)
  1667	    summary: Dict[str, Any] = {
  1668	        "hint_id": hint.hint_id,
  1669	        "priority": hint.priority,
  1670	    }
  1671	    for key in (
  1672	        "cosine_similarity",
  1673	        "family_margin",
  1674	        "frame_features",
  1675	        "predicted_family",
  1676	        "reconstruction_loss",
  1677	        "sample_id",
  1678	        "target_family",
  1679	        "target_probability",
  1680	        "top_embedding_features",
  1681	        "top_family_features",
  1682	    ):
  1683	        value = evidence.get(key)
  1684	        if value not in (None, "", []):
  1685	            summary[key] = value
  1686	    return summary
  1687	
  1688	
  1689	def _todo_optimizer_role(todo: ModalTodo) -> str:
  1690	    role = str(todo.metadata.get("optimizer_role") or "").strip()
  1691	    if role:
  1692	        return role
  1693	    return ModalOptimizerPolicy().role_for(
  1694	        action=str(todo.action),
  1695	        loss_name=str(todo.loss_name),
  1696	    )
  1697	
  1698	
  1699	def _todo_matches(
  1700	    todo: ModalTodo,
  1701	    *,
  1702	    status: str,
  1703	    optimizer_role: Optional[str] = None,
  1704	    metadata_filter: Optional[Mapping[str, str]] = None,
  1705	) -> bool:
  1706	    if todo.status != status:
  1707	        return False
  1708	    if optimizer_role is not None and _todo_optimizer_role(todo) != optimizer_role:
  1709	        return False
  1710	    if metadata_filter:
  1711	        for key, value in metadata_filter.items():
  1712	            if str(todo.metadata.get(key) or "") != str(value):
  1713	                return False
  1714	    return True
