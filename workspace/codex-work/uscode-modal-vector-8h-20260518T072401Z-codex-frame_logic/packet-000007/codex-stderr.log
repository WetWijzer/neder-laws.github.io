   675	        subjects.add(str(triple.get("subject", "")))
   676	        values.update(str(triple.get(key, "")) for key in ("subject", "predicate", "object"))
   677	    for frame in modal_ir.frame_candidates:
   678	        subjects.add(frame.frame_id)
   679	        values.add(frame.frame_id)
   680	        values.update(frame.matched_terms)
   681	    for formula in modal_ir.formulas:
