  4041	                _collect_frame_ontology_metadata_values(
  4042	                    value,
  4043	                    extracted,
  4044	                    depth=depth + 1,
  4045	                )
  4046	                if len(extracted) >= _FRAME_ONTOLOGY_METADATA_MAX_VALUES:
  4047	                    return
