   172	    """Load samples directly from the Hugging Face Hub filesystem.
   173	
   174	    This function performs network I/O and is intended for opt-in integration
   175	    tests or manual smoke checks, not default unit tests.
   176	    """
   177	    from huggingface_hub import HfFileSystem
   178	
   179	    fs = HfFileSystem()
   180	    laws_hf_path = f"datasets/{repo_id}/{laws_path}"
   181	    if embeddings_path is None:
   182	        with fs.open(laws_hf_path, "rb") as laws_file:
   183	            return load_uscode_samples_from_parquet(laws_file, limit=limit, offset=offset)
   184	
   185	    embeddings_hf_path = f"datasets/{repo_id}/{embeddings_path}"
   186	    with fs.open(laws_hf_path, "rb") as laws_file:
   187	        records = list(iter_uscode_records_from_parquet(laws_file, limit=limit, offset=offset))
   188	    with fs.open(embeddings_hf_path, "rb") as embeddings_file:
