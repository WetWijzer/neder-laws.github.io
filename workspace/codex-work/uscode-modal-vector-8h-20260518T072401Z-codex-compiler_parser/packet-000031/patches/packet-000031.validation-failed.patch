+def test_parser_replays_symbolic_validity_todo_samples_for_14_1155_7_2110_and_7_2611() -> None:
+    parser = LegalModalParser()
+    cases = [
+        (
+            "us-code-14-1155-e938dff6f2f5890b",
+            "14 U.S.C. 1155",
+            _USCODE_14_1155_TODO_TEXT,
+        ),
+        (
+            "us-code-7-2110-14b22fe93d7e45d7",
+            "7 U.S.C. 2110",
+            _USCODE_7_2110_TODO_TEXT,
+        ),
+        (
+            "us-code-7-2611-3091131587c51778",
+            "7 U.S.C. 2611",
+            _USCODE_7_2611_TODO_TEXT,
+        ),
+    ]
+
+    for document_id, citation, text in cases:
+        document = parser.parse(
+            text,
+            document_id=document_id,
+            source="us_code",
+            citation=citation,
+        )
+
+        assert document.document_id == document_id
+        assert document.formulas
+        fallback = document.formulas[-1]
+        assert fallback.operator.family == "frame"
+        assert fallback.metadata["cue"] == "__uscode_no_cue_citation_fallback__"
+        assert fallback.metadata["fallback_rule"] == "uscode_no_cue_citation_v1"
+        assert fallback.provenance.citation == citation
+
