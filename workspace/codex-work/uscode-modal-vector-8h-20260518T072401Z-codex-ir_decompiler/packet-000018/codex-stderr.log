        self,
        sample: LegalSample,
        *,
        modal_families: Sequence[str],
    ) -> Dict[str, float]:
        """Return deterministic modal-family logits for a ``LegalSample``."""
        return self.decoder.family_logits(
            self.encode_sample(sample),
            modal_families=modal_families,
