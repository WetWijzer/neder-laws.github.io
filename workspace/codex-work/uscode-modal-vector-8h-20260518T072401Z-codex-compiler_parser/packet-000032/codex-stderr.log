+def test_parser_replays_packet_todo_samples_for_36_110105_and_25_450() -> None:
+    parser = LegalModalParser()
+    cases = [
+        (
+            "us-code-36-110105-c16a1da4a57f02ec",
+            "36 U.S.C. 110105",
+            _USCODE_36_110105_TODO_TEXT,
