   490	    if normalized_predicate.endswith("_positioned"):
   491	        match = _FRAME_ONTOLOGY_POSITIONED_VALUE_RE.match(raw_value)
   492	        if match:
   493	            positioned_value = str(match.group("value") or "").strip()
   494	            if positioned_value:
