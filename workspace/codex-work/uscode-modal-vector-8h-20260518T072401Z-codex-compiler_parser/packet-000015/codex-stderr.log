import pyarrow.parquet as pq
from pathlib import Path
from collections import Counter
from ipfs_datasets_py.logic.modal.compiler import DeterministicModalCompiler, ModalCompilerConfig
p=Path('/home/barberb/.ipfs_datasets/uscode/uscode_parquet/uscode.parquet')
rows=pq.read_table(p, columns=['title_number','section_number','text']).to_pylist()
targets=[('25','478-1','25 U.S.C. 478-1'),('42','6930.','42 U.S.C. 6930.'),('46','60101.','46 U.S.C. 60101.')]
for backend in ('regex','spacy'):
    print('\\nbackend',backend)
    compiler=DeterministicModalCompiler(ModalCompilerConfig(parser_backend=backend, spacy_model_name='definitely_missing_legal_model'))
    for title,section,citation in targets:
        row=next(item for item in rows if str(item['title_number'])==title and str(item['section_number'])==section)
        text=' '.join(str(row['text']).split())
        docid=f'us-code-{title}-{section}'
        result=compiler.compile(text, document_id=docid, citation=citation, source='us_code')
        fams=[f.operator.family for f in result.modal_ir.formulas]
        cues=[str(f.metadata.get('cue','')) for f in result.modal_ir.formulas]
        fallback=[f.metadata.get('fallback_rule') for f in result.modal_ir.formulas if f.metadata.get('fallback_rule')]
        print(citation,'n=',len(fams),'families',dict(Counter(fams)),'first',fams[0] if fams else None,'last',fams[-1] if fams else None)
        print('  has_missing',any(a.ambiguity_type=='missing_modal_formula' for a in result.ambiguities),'fallbacks',fallback[:2],'cues_first5',cues[:5])
