        f"flogic:citation_section_component:{1000 + index}"
        for index in range(12)
    ]
    terms = frame_ontology_terms_from_feature_keys(
        contextual_features
        + ["selected-frame-term:final order"],
        max_terms=4,
    )

    assert terms == [
        "final_order",
        "1000",
        "1001",
        "1002",
    ]


