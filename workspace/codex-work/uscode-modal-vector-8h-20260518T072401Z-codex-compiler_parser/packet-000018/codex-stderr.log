   808	    def _segment_or_neighbor_has_citation_section_reference(
   809	        self,
   810	        *,
   811	        index: int,
   812	        segments: Sequence[LegalSegment],
   813	        citation_section: str,
   814	    ) -> bool:
   815	        for offset in (-2, -1, 0, 1, 2):
   816	            position = index + offset
   817	            if position < 0 or position >= len(segments):
   818	                continue
   819	            segment_text = segments[position].text
   820	            if self._contains_citation_section_reference(segment_text, citation_section):
   821	                return True
   822	            if self._starts_with_citation_section_reference(segment_text, citation_section):
   823	                return True
   824	        return False
