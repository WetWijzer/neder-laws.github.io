   410	    def _citation_section_token(self, citation: Optional[str]) -> str:
   411	        if not citation:
   412	            return ""
   413	        match = _USCODE_CITATION_SECTION_RE.search(citation)
   414	        if not match:
   415	            return ""
   416	        token = match.group(1).strip().lower()
   417	        return _USCODE_TRAILING_SECTION_PUNCT_RE.sub("", token)
   418	
   419	    def _contains_citation_section_reference(self, text: str, citation_section: str) -> bool:
   420	        if not citation_section:
   421	            return False
   422	        normalized = self.normalize_text(text).lower()
   423	        section_pattern = re.escape(citation_section)
   424	        if re.search(
   425	            rf"§\s*{section_pattern}(?={_USCODE_SECTION_REF_SUFFIX_RE})",
   426	            normalized,
   427	        ):
   428	            return True
   429	        if re.search(
   430	            rf"\bsection\s+{section_pattern}(?={_USCODE_SECTION_REF_SUFFIX_RE})",
   431	            normalized,
   432	        ):
   433	            return True
   434	        if re.search(
   435	            rf"\bsec\.?\s*{section_pattern}(?={_USCODE_SECTION_REF_SUFFIX_RE})",
   436	            normalized,
   437	        ):
   438	            return True
   439	        return False
   440	
   441	    def _starts_with_citation_section_reference(self, text: str, citation_section: str) -> bool:
   442	        if not citation_section:
   443	            return False
   444	        normalized = self.normalize_text(text).lower()
   445	        section_pattern = re.escape(citation_section)
   446	        return bool(
   447	            re.match(
   448	                rf"^(?:§\s*|sec\.?\s*|section\s+)?{section_pattern}"
   449	                rf"(?={_USCODE_SECTION_REF_SUFFIX_RE})",
   450	                normalized,
   451	            )
   452	        )
