  1356	            _append_source_phrase(
  1357	                phrases,
  1358	                source_text,
  1359	                cursor,
  1360	                start,
  1361	                slot="source_context_span",
  1362	            )
  1363	        _append_source_phrase(
  1364	            phrases,
  1365	            source_text,
  1366	            start,
  1367	            end,
  1368	            slot="modal_source_span",
  1369	        )
  1370	        covered_chars += max(0, end - start)
  1371	        cursor = max(cursor, end)
  1372	    if cursor < len(source_text):
  1373	        _append_source_phrase(
  1374	            phrases,
  1375	            source_text,
  1376	            cursor,
  1377	            len(source_text),
  1378	            slot="source_context_span",
  1379	        )
  1380	
  1381	    coverage = covered_chars / len(source_text) if source_text else 0.0
  1382	    return phrases, round(min(1.0, max(0.0, coverage)), 6)
