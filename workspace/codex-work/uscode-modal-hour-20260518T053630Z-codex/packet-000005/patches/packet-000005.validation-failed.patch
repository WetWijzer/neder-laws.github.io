+def test_spacy_codec_treats_extension_of_time_as_temporal_family_cue() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="26",
+        section="6164",
+        text=(
+            "The Secretary may grant an extension of time for payment, and the amount "
+            "is due not later than 12 months after notice."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    temporal_entry = next((entry for entry in ranking if entry["family"] == "temporal"), None)
+
+    assert temporal_entry is not None
+    assert temporal_entry["count"] >= 2
+
+
+def test_spacy_codec_treats_penalty_language_as_deontic_family_cue() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="42",
+        section="1397a",
+        text=(
+            "A person who violates this section shall be fined under this title and "
+            "subject to a criminal penalty."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    assert ranking
+    assert ranking[0]["family"] == "deontic"
+
+
+def test_spacy_codec_treats_extent_feasibility_as_conditional_normative_cue() -> None:
+    codec = SpaCyModalCodec(
+        encoder=SpaCyLegalEncoder(model_name="definitely_missing_legal_model"),
+        decoder=SpaCyModalDecoder(),
+    )
+    sample = build_us_code_sample(
+        title="42",
+        section="12144",
+        text=(
+            "Public entities shall provide access to the maximum extent feasible "
+            "when alterations are made."
+        ),
+    )
+
+    ranking = ranked_modal_families(codec.encode_sample(sample))
+    conditional_entry = next(
+        (entry for entry in ranking if entry["family"] == "conditional_normative"),
+        None,
+    )
+
+    assert conditional_entry is not None
+    assert conditional_entry["count"] >= 1
+
