   346	def _unique_preserve_order(values: Sequence[str]) -> List[str]:
   347	    seen: set[str] = set()
   348	    result: List[str] = []
   349	    for value in values:
   350	        if not value or value in seen:
   351	            continue
   352	        seen.add(value)
   353	        result.append(value)
   354	    return result
