    48	    @classmethod
    49	    def from_row(cls, row: Mapping[str, Any]) -> "USCodeParquetRecord":
    50	        title = _clean(row.get("title_number")) or "unknown"
    51	        section = _clean(row.get("section_number")) or "unknown"
    52	        citation = (
