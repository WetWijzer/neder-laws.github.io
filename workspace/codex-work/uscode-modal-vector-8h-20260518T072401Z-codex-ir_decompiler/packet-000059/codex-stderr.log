  2029	def _citation_section_delimiter_kind(delimiter: str) -> str:
  2030	    cleaned = _clean_non_empty_string(delimiter)
  2031	    if not cleaned:
  2032	        return ""
  2033	    if all(character == "." for character in cleaned):
  2034	        return "dot"
  2035	    if all(character == "-" for character in cleaned):
