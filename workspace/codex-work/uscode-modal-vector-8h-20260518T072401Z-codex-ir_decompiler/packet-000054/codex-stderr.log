    (\"us-code-30-49d-450397eabc2ed637\", \"30 U.S.C. 49d\"),
    (\"us-code-16-192b-10-0422f4fd5bfc290b\", \"16 U.S.C. 192b-10\"),
    (\"us-code-42-3796gg-8fa27f093a17bc0c\", \"42 U.S.C. 3796gg\"),
    (\"us-code-10-8033-d6f331db0fe8d7bd\", \"10 U.S.C. 8033\"),
]

for source_id, citation in samples:
