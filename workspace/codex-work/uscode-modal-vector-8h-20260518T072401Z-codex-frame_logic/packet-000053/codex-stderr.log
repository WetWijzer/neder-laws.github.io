   738	def target_family_distribution_for_modal_ir(modal_ir: ModalIRDocument) -> Dict[str, float]:
   739	    """Return observed modal-family frequencies for multi-family legal clauses."""
   740	    families = [formula.operator.family for formula in modal_ir.formulas]
   741	    if not families:
   742	        return {ModalLogicFamily.HYBRID.value: 1.0}
   743	    counts: Dict[str, int] = {}
   744	    for family in families:
   745	        counts[family] = counts.get(family, 0) + 1
   746	    total = float(sum(counts.values()))
   747	    return {
   748	        family: count / total
   749	        for family, count in sorted(counts.items())
   750	    }
