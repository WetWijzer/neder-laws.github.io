@dataclass(frozen=True)
class SpaCyTokenFeature:
    """Stable token-level features extracted from a spaCy `Doc`."""

    text: str
    lemma: str
    lower: str
    pos: str
    dep: str
    start_char: int
    end_char: int
    is_stop: bool = False
    is_alpha: bool = False

    def normalized(self) -> str:
