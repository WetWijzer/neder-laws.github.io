  1954	def _statutory_scope_entries(text: str) -> List[tuple[str, str]]:
  1955	    normalized = _clean_non_empty_string(text).replace("_", " ").lower()
  1956	    if not normalized:
  1957	        return []
  1958	    entries: List[tuple[str, str]] = []
  1959	    seen: set[tuple[str, str]] = set()
  1960	    for match in _STATUTORY_SCOPE_REFERENCE_RE.finditer(normalized):
  1961	        connector = _clean_non_empty_string(match.group("connector")).lower()
  1962	        unit_surface = _clean_non_empty_string(match.group("unit")).lower()
  1963	        unit = _canonical_statutory_scope_unit(unit_surface)
  1964	        determiner = _clean_non_empty_string(match.group("determiner")).lower()
  1965	        has_determiner = bool(determiner)
  1966	        target = _clean_non_empty_string(match.group("target")).lower()
  1967	        if (
  1968	            has_determiner
  1969	            and target
  1970	            and not target.startswith("(")
  1971	            and not any(character.isdigit() for character in target)
  1972	            and _ROMAN_NUMERAL_RE.fullmatch(target) is None
  1973	        ):
  1974	            target = ""
  1975	        reference_parts = (
  1976	            [connector, determiner, unit_surface]
  1977	            if has_determiner
  1978	            else [connector, unit_surface]
  1979	        )
  1980	        if target:
  1981	            reference_parts.append(target)
  1982	        reference = " ".join(reference_parts)
  1983	        resolved_target = (
  1984	            f"{determiner} {target}".strip() if has_determiner else target
  1985	        )
  1986	        if has_determiner and not target:
  1987	            resolved_target = determiner
  1988	        values: List[tuple[str, str]] = [
  1989	            ("statutory_scope_reference", reference),
  1990	            ("statutory_scope_connector", connector),
  1991	            ("statutory_scope_unit", unit),
  1992	        ]
  1993	        if resolved_target:
  1994	            values.append(("statutory_scope_target", resolved_target))
  1995	        for entry in values:
  1996	            if entry in seen:
  1997	                continue
  1998	            seen.add(entry)
  1999	            entries.append(entry)
  2000	    return entries
