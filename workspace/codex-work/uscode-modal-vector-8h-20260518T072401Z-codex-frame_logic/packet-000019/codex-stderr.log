   217	def modal_formula_to_text(formula: ModalIRFormula) -> str:
   218	    """Render a stable formula-like string from one modal IR formula."""
   219	    arguments = ", ".join(formula.predicate.arguments)
   220	    predicate = formula.predicate.name
   221	    if arguments:
   222	        predicate = f"{predicate}({arguments})"
   223	    return f"{formula.operator.symbol}[{formula.operator.family}:{formula.operator.system}]({predicate})"
