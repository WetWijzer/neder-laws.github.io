+def test_modal_compiler_regex_replays_short_editorial_status_zero_formula_samples() -> None:
+    compiler = DeterministicModalCompiler(ModalCompilerConfig(parser_backend="regex"))
+    cases = [
+        (
+            "us-code-15-8563-3b998304c368f8a4",
