   219	    def _formula_ambiguities(
   220	        self,
   221	        modal_ir: ModalIRDocument,
   222	    ) -> List[ModalCompilationAmbiguity]:
   223	        by_span: Dict[tuple[int, int], List[str]] = {}
   224	        for formula in modal_ir.formulas:
   225	            span = (formula.provenance.start_char, formula.provenance.end_char)
   226	            candidate = (
   227	                f"{formula.formula_id}:{formula.operator.family}:"
   228	                f"{formula.operator.system}:{formula.operator.symbol}"
   229	            )
   230	            by_span.setdefault(span, []).append(candidate)
   231	
   232	        ambiguities: List[ModalCompilationAmbiguity] = []
   233	        for span, candidates in sorted(by_span.items()):
   234	            families = {candidate.split(":")[1] for candidate in candidates}
   235	            if len(candidates) > 1 and len(families) > 1:
   236	                ambiguities.append(
   237	                    ModalCompilationAmbiguity(
   238	                        ambiguity_type="multi_family_same_span",
   239	                        message="Multiple modal families were compiled from the same text span.",
   240	                        candidate_ids=sorted(candidates),
   241	                        metadata={"span": list(span)},
   242	                    )
   243	                )
   244	        return ambiguities
   245	
   246	    def _family_ambiguities(
   247	        self,
   248	        encoding: SpaCyLegalEncoding,
   249	        *,
   250	        modal_ir: ModalIRDocument,
   251	    ) -> List[ModalCompilationAmbiguity]:
   252	        ranking = ranked_modal_families(encoding)
   253	        if not ranking:
   254	            return []
   255	
   256	        ambiguities: List[ModalCompilationAmbiguity] = []
   257	        if modal_ir.formulas:
   258	            primary_family = str(modal_ir.formulas[0].operator.family)
   259	            primary_share = next(
   260	                (
   261	                    float(candidate["share"])
   262	                    for candidate in ranking
   263	                    if str(candidate["family"]) == primary_family
   264	                ),
   265	                0.0,
   266	            )
   267	            best_other = max(
   268	                (
   269	                    candidate
   270	                    for candidate in ranking
   271	                    if str(candidate["family"]) != primary_family
   272	                ),
   273	                key=lambda candidate: (
   274	                    float(candidate["share"]),
   275	                    str(candidate["family"]),
   276	                ),
   277	                default=None,
   278	            )
   279	            if best_other is not None:
   280	                best_other_family = str(best_other["family"])
   281	                best_other_share = float(best_other["share"])
   282	                family_margin = primary_share - best_other_share
   283	                if family_margin <= self.config.modal_primary_family_margin:
   284	                    ambiguities.append(
   285	                        ModalCompilationAmbiguity(
   286	                            ambiguity_type="low_primary_modal_family_margin",
   287	                            message=(
   288	                                "The primary compiled modal family has a low margin "
   289	                                "against competing cue evidence."
   290	                            ),
   291	                            candidate_ids=[primary_family, best_other_family],
   292	                            metadata={
   293	                                "best_other_family": best_other_family,
   294	                                "best_other_share": round(best_other_share, 6),
   295	                                "family_margin": round(family_margin, 6),
   296	                                "family_ranking": ranking,
   297	                                "primary_family": primary_family,
   298	                                "primary_family_margin_threshold": self.config.modal_primary_family_margin,
   299	                                "primary_share": round(primary_share, 6),
   300	                            },
   301	                        )
   302	                    )
   303	        if len(ranking) < 2:
   304	            return ambiguities
   305	
   306	        top, runner_up = ranking[0], ranking[1]
   307	        share_margin = float(top["share"]) - float(runner_up["share"])
   308	        if share_margin <= self.config.modal_family_share_margin:
   309	            ambiguities.append(
   310	                ModalCompilationAmbiguity(
   311	                    ambiguity_type="close_modal_family_shares",
   312	                    message="Top modal families are close enough that legal family selection is ambiguous.",
   313	                    candidate_ids=[str(top["family"]), str(runner_up["family"])],
   314	                    metadata={
   315	                        "family_margin": round(share_margin, 6),
   316	                        "family_ranking": ranking,
   317	                        "share_margin": round(share_margin, 6),
   318	                        "top_family": str(top["family"]),
   319	                        "runner_up_family": str(runner_up["family"]),
   320	                    },
   321	                )
   322	            )
   323	
   324	        strong_contenders = [
