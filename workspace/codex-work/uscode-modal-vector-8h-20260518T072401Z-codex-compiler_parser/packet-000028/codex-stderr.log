+        if any(punctuation in normalized for punctuation in ":[]{}"):
+            return False
+        # Prevent degenerate headings like just "the" or "this".
+        if len(tokens) == 1 and tokens[0] in _USCODE_HEADING_ONLY_LEADING_STOPWORDS:
+            return False
+        return True
