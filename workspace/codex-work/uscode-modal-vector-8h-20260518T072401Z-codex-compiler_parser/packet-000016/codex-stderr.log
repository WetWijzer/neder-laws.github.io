   125	        *,
   126	        document_id: Optional[str] = None,
   127	        citation: Optional[str] = None,
   128	        source: str = "legal_text",
   129	    ) -> ModalCompilationResult:
   130	        """Compile text into modal IR using deterministic rules only."""
   131	        normalized_text = self.parser.normalize_text(text)
   132	        backend = self.config.parser_backend.lower().strip()
   133	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   134	            text,
   135	            document_id=document_id,
   136	            citation=citation,
   137	            source=source,
   138	        )
   139	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   140	            modal_ir = self.parser.parse(
   141	                text,
   142	                document_id=document_id or encoding.document_id,
   143	                citation=citation,
   144	                source=source,
   145	            )
   146	            parser_name = "legal_modal_parser_v1"
   147	        else:
   148	            modal_ir = self.ir_compiler.compile(encoding)
   149	            parser_name = "spacy_modal_codec_v1"
   150	
   151	        frame_selections = self.frame_selector.rank(
   152	            normalized_text,
   153	            top_k=self.config.top_k_frames,
   154	            domain=self.config.frame_domain,
   155	        )
   156	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   157	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
