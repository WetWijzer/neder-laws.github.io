    96	class DeterministicModalCompiler:
    97	    """Compile legal text into modal IR with explainable frame selection."""
    98	
    99	    def __init__(
   100	        self,
   101	        config: Optional[ModalCompilerConfig] = None,
   102	        *,
   103	        registry: ModalRegistry = DEFAULT_MODAL_REGISTRY,
   104	        frame_selector: Optional[BM25FrameSelector] = None,
   105	    ) -> None:
   106	        self.config = config or ModalCompilerConfig()
   107	        self.registry = registry
   108	        self.parser = LegalModalParser(registry=registry)
   109	        self.encoder = SpaCyLegalEncoder(
   110	            model_name=self.config.spacy_model_name,
   111	            registry=registry,
   112	        )
   113	        self.ir_compiler = SpaCyModalIRCompiler()
   114	        self.frame_selector = frame_selector or BM25FrameSelector(DEFAULT_LEGAL_FRAME_FIXTURE)
   115	
   116	    def compile(
   117	        self,
   118	        text: str,
   119	        *,
   120	        document_id: Optional[str] = None,
   121	        citation: Optional[str] = None,
   122	        source: str = "legal_text",
   123	    ) -> ModalCompilationResult:
   124	        """Compile text into modal IR using deterministic rules only."""
   125	        normalized_text = self.parser.normalize_text(text)
   126	        backend = self.config.parser_backend.lower().strip()
   127	        encoding: Optional[SpaCyLegalEncoding] = self.encoder.encode(
   128	            text,
   129	            document_id=document_id,
   130	            citation=citation,
   131	            source=source,
   132	        )
   133	        if backend in {"regex", "legal", "legal_modal_parser", "deontic", "deontic:d"}:
   134	            modal_ir = self.parser.parse(
   135	                text,
   136	                document_id=document_id or encoding.document_id,
   137	                citation=citation,
   138	                source=source,
   139	            )
   140	            parser_name = "legal_modal_parser_v1"
   141	        else:
   142	            modal_ir = self.ir_compiler.compile(encoding)
   143	            parser_name = "spacy_modal_codec_v1"
   144	
   145	        frame_selections = self.frame_selector.rank(
   146	            normalized_text,
   147	            top_k=self.config.top_k_frames,
   148	            domain=self.config.frame_domain,
   149	        )
   150	        frame_candidates = [selection.to_dict() for selection in frame_selections]
   151	        selected_frame = str(frame_candidates[0]["frame_id"]) if frame_candidates else None
   152	        ambiguities = [
   153	            *self._formula_ambiguities(modal_ir),
   154	            *self._family_ambiguities(encoding, modal_ir=modal_ir),
