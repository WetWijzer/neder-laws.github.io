  2757	def _unique_preserve_order(features: Iterable[str]) -> List[str]:
  2758	    seen: set[str] = set()
  2759	    result: List[str] = []
  2760	    for feature in features:
  2761	        if feature in seen:
  2762	            continue
  2763	        seen.add(feature)
  2764	        result.append(feature)
  2765	    return result

