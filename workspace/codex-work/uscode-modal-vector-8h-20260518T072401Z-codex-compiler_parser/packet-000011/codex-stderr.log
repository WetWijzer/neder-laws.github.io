import hashlib,itertools,re
samples=[('15','8563','3b998304c368f8a4'),('2','74b','55df9e8ab40ae3a5'),('42','11924.','096a2b2493c6c5cf')]
status_words=['Transferred','Omitted','Repealed','Reserved','Vacant','Renumbered','Terminated']
prefixes=['§','§ ','Sec. ','Section ','']
seps=['','.',' .']
trailings=['','.',':',';']
joiners=[' ','  ','\\n','']
extras=['',' Transferred.',' (Transferred.)',' [Transferred.]']
# generate candidate normalized texts by composing heading + status in one or two clauses
cands=[]
for title,section,digest in samples:
    found=[]
    sec_base=section.rstrip('.')
    sec_forms=[section,sec_base,sec_base+'.']
    sec_forms=sorted(set(sec_forms), key=lambda x:(len(x),x))
    for pref,sec,sep,join,word,trailing in itertools.product(prefixes,sec_forms,seps,joiners,status_words,trailings):
        # heading maybe with punctuation sep after section
        heading=f\"{pref}{sec}{sep}\"
        text=f\"{heading}{join}{word}{trailing}\"
        # normalize like parser
        norm=' '.join(text.split()).strip()
        if not norm:
            continue
        h=hashlib.sha256(f\"{title}:{section}:{norm}\".encode()).hexdigest()[:16]
        if h==digest:
            found.append(norm)
    # additional templates with sentence words
    templates=[
        \"{pref}{sec}. {word}.\",
        \"{pref}{sec} {word}.\",
        \"{pref}{sec}. {word}\",
        \"{pref}{sec}.- {word}.\",
        \"{pref}{sec}. {word}.\",
        \"{pref}{sec}. {word}. (Pub. L. 0, 0 Stat. 0.)\",
        \"{pref}{sec}. {word}. See section 1 of this title.\",
        \"{word}.\",
    ]
    for tpl, pref, sec, word in itertools.product(templates,prefixes,sec_forms,status_words):
        text=tpl.format(pref=pref,sec=sec,word=word)
        norm=' '.join(text.split()).strip()
        h=hashlib.sha256(f\"{title}:{section}:{norm}\".encode()).hexdigest()[:16]
        if h==digest and norm not in found:
            found.append(norm)
    print('\\n',title,section,digest,'matches',len(found))
    for m in found[:20]:
        print(' ',m)
