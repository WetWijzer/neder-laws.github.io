   606	            frame_losses.append(frame_ranking_loss(sample))
   607	            symbolic_penalties.append(symbolic_validity_penalty(sample))
   608	
   609	        return AutoencoderEvaluation(
   610	            sample_count=len(sample_list),
   611	            embedding_cosine_similarity=_mean(cosine_scores),
   612	            cosine_loss=_mean(cosine_losses),
   613	            reconstruction_loss=_mean(reconstruction_losses),
   614	            cross_entropy_loss=_mean(ce_losses),
