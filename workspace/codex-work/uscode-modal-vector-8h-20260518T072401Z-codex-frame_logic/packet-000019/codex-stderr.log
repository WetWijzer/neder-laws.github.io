   223	    def _score(self, query_terms: Sequence[str], document: Sequence[str]) -> float:
   224	        if not query_terms or not document or not self.frames:
   225	            return 0.0
   226	        doc_len = len(document)
   227	        term_counts = {term: document.count(term) for term in set(document)}
   228	        total = 0.0
   229	        for term in query_terms:
   230	            freq = term_counts.get(term, 0)
   231	            if freq == 0:
   232	                continue
   233	            doc_freq = self._doc_freq.get(term, 0)
   234	            idf = math.log(1 + (len(self.frames) - doc_freq + 0.5) / (doc_freq + 0.5))
   235	            denominator = freq + self.k1 * (1 - self.b + self.b * (doc_len / (self._avgdl or 1.0)))
   236	            total += idf * ((freq * (self.k1 + 1)) / denominator)
   237	        return total
