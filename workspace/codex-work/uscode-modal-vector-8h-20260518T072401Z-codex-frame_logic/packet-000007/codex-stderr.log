   150	        return f"Frame {frame.frame_id} had no lexical query matches; BM25 score {score:.3f}."
   151	
   152	    def _tokenize(self, text: str) -> List[str]:
   153	        return _tokenize_text(text)
   154	
   155	    def _build_doc_freq(self, documents: Sequence[Sequence[str]]) -> Dict[str, int]:
   156	        frequencies: Dict[str, int] = {}
