   291	class SpaCyModalIRCompiler:
   292	    """Compile spaCy legal encodings into canonical modal IR documents."""
   293	
   294	    def compile(self, encoding: SpaCyLegalEncoding) -> ModalIRDocument:
   295	        formulas: List[ModalIRFormula] = []
   296	        for index, cue in enumerate(encoding.cues, start=1):
   297	            sentence = _sentence_for_cue(encoding.sentences, cue)
   298	            tokens = _tokens_for_span(encoding.tokens, sentence.start_char, sentence.end_char)
   299	            predicate = _predicate_from_tokens(tokens, cue)
   300	            conditions, exceptions = _conditions_and_exceptions_from_sentence(
   301	                sentence.text
   302	            )
   303	            formulas.append(
   304	                ModalIRFormula(
   305	                    formula_id=f"{encoding.document_id}:spacy:f{index:04d}",
   306	                    operator=ModalIROperator(
   307	                        family=cue.family,
   308	                        system=cue.system,
   309	                        symbol=cue.symbol,
   310	                        label=cue.label,
   311	                    ),
   312	                    predicate=predicate,
   313	                    provenance=ModalIRProvenance(
   314	                        source_id=encoding.document_id,
   315	                        start_char=sentence.start_char,
   316	                        end_char=sentence.end_char,
   317	                        citation=encoding.citation,
   318	                    ),
   319	                    conditions=conditions,
   320	                    exceptions=exceptions,
   321	                    metadata={
   322	                        "cue": cue.cue,
   323	                        "cue_start_char": cue.start_char,
   324	                        "cue_end_char": cue.end_char,
   325	                        "encoder": "spacy_modal_codec_v1",
   326	                    },
   327	                )
   328	            )
   329	        return ModalIRDocument(
   330	            document_id=encoding.document_id,
   331	            source=encoding.source,
   332	            normalized_text=encoding.normalized_text,
   333	            formulas=formulas,
   334	            metadata={
   335	                "citation": encoding.citation,
   336	                "deterministic_parser": "spacy_modal_codec_v1",
   337	                "llm_call_count": 0,
   338	                "model_name": encoding.model_name,
   339	                "sentence_count": len(encoding.sentences),
   340	                "token_count": len(encoding.tokens),
   341	                "used_fallback_model": encoding.used_fallback_model,
   342	            },
   343	        )
