   453	def ranked_modal_families(encoding: SpaCyLegalEncoding) -> List[Dict[str, float]]:
   454	    """Rank modal families by deterministic cue count and normalized share."""
   455	    counts = encoding.modal_family_counts()
   456	    total = sum(counts.values())
