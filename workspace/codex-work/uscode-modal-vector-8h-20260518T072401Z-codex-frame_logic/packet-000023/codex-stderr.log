   566	class SpaCyModalDecoder:
   567	    """Decode spaCy/IR features into deterministic embedding-like vectors."""
   568	
   569	    def decode_embedding(self, encoding: SpaCyLegalEncoding, *, dimensions: int = 8) -> List[float]:
   570	        if dimensions < 1:
   571	            raise ValueError("dimensions must be >= 1")
   572	        vector = [0.0 for _ in range(dimensions)]
   573	        for feature in self._feature_stream(encoding):
   574	            slot, value = _feature_hash(feature, dimensions)
   575	            vector[slot] += value
   576	        norm = math.sqrt(sum(value * value for value in vector))
   577	        if norm == 0.0:
   578	            return vector
   579	        return [round(value / norm, 6) for value in vector]
   580	
   581	    def family_logits(
   582	        self,
   583	        encoding: SpaCyLegalEncoding,
   584	        *,
   585	        modal_families: Sequence[str],
   586	    ) -> Dict[str, float]:
   587	        logits = {family: -0.25 for family in modal_families}
   588	        counts = encoding.modal_family_counts()
   589	        for family, count in counts.items():
   590	            if family in logits:
   591	                logits[family] = 2.0 + float(count)
   592	        if not counts and ModalLogicFamily.HYBRID.value in logits:
   593	            logits[ModalLogicFamily.HYBRID.value] = 1.0
   594	        return logits
   595	
   596	    def _feature_stream(self, encoding: SpaCyLegalEncoding) -> Iterable[str]:
   597	        yield f"doclen:{len(encoding.tokens)}"
   598	        for token in encoding.tokens:
   599	            if token.is_alpha and not token.is_stop:
   600	                yield f"lemma:{token.normalized()}"
   601	            if token.pos:
   602	                yield f"pos:{token.pos}"
   603	            if token.dep:
   604	                yield f"dep:{token.dep}"
   605	        for cue in encoding.cues:
   606	            yield f"cue:{cue.family}:{cue.symbol}:{cue.cue.lower()}"
   607	        for family, count in encoding.modal_family_counts().items():
   608	            yield f"family:{family}:{count}"
