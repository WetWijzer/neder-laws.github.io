+"""Regression tests for source-id section slot normalization."""
+
+from __future__ import annotations
+
+from ipfs_datasets_py.logic.modal.codec import modal_ir_to_flogic_triples
+from ipfs_datasets_py.logic.modal.decompiler import (
+    decode_modal_ir_document,
+    decoded_modal_phrase_slot_text_map,
+)
+from ipfs_datasets_py.optimizers.logic_theorem_optimizer.modal_ir import (
+    ModalIRDocument,
+    ModalIRFormula,
+    ModalIROperator,
+    ModalIRPredicate,
+    ModalIRProvenance,
+)
+
+
+def _document_for_source_id(source_id: str) -> ModalIRDocument:
+    return ModalIRDocument(
+        document_id=source_id,
+        source="us_code",
+        normalized_text="Section heading text.",
+        formulas=[
+            ModalIRFormula(
+                formula_id=f"{source_id}:f0001",
+                operator=ModalIROperator(
+                    family="frame",
+                    system="Frame",
+                    symbol="Frame",
+                    label="framed as",
+                ),
+                predicate=ModalIRPredicate(
+                    name="section_heading_text",
+                    arguments=[],
+                    role="frame",
+                ),
+                provenance=ModalIRProvenance(
+                    source_id=source_id,
+                    start_char=0,
+                    end_char=21,
+                    citation="50 U.S.C. 171a.",
+                ),
+                metadata={"cue": "__uscode_section_heading_fallback__"},
+            )
+        ],
+    )
+
+
+def test_source_id_section_slots_keep_normalized_and_raw_values() -> None:
+    source_id = "us-code-50-171a.-b44deffd2b6380cc"
+    document = _document_for_source_id(source_id)
+
+    decoded = decode_modal_ir_document(document)
+    slot_map = decoded_modal_phrase_slot_text_map(decoded)
+
+    assert slot_map["source_id_section"] == ["171a"]
+    assert slot_map["source_id_section_raw"] == ["171a."]
+    assert slot_map["source_id_section_normalized"] == ["171a"]
+    assert slot_map["source_id_section_trailing_punct"] == ["."]
+
+    triples = modal_ir_to_flogic_triples(document)
+    source_id_section_triples = {
+        (str(item["predicate"]), str(item["object"]))
+        for item in triples
+        if str(item.get("predicate", "")).startswith("source_id_section")
+    }
+    assert ("source_id_section", "171a") in source_id_section_triples
+    assert ("source_id_section_raw", "171a.") in source_id_section_triples
+    assert ("source_id_section_normalized", "171a") in source_id_section_triples

