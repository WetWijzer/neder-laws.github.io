   363	class SpaCyModalCodec:
   364	    """Convenience facade for encoder -> IR -> vector workflows."""
   365	
   366	    def __init__(
   367	        self,
   368	        *,
   369	        encoder: Optional[SpaCyLegalEncoder] = None,
   370	        compiler: Optional[SpaCyModalIRCompiler] = None,
   371	        decoder: Optional[SpaCyModalDecoder] = None,
   372	    ) -> None:
   373	        self.encoder = encoder or SpaCyLegalEncoder()
   374	        self.compiler = compiler or SpaCyModalIRCompiler()
   375	        self.decoder = decoder or SpaCyModalDecoder()
   376	
   377	    def encode_sample(self, sample: LegalSample) -> SpaCyLegalEncoding:
   378	        return self.encoder.encode(
   379	            sample.text,
   380	            document_id=sample.sample_id,
   381	            citation=sample.citation,
   382	            source=sample.source,
   383	        )
   384	
   385	    def compile_sample_ir(self, sample: LegalSample) -> ModalIRDocument:
   386	        return self.compiler.compile(self.encode_sample(sample))
   387	
   388	    def decode_sample_embedding(self, sample: LegalSample, *, dimensions: int) -> List[float]:
   389	        return self.decoder.decode_embedding(self.encode_sample(sample), dimensions=dimensions)
   390	
   391	    def family_logits_for_sample(
   392	        self,
   393	        sample: LegalSample,
   394	        *,
   395	        modal_families: Sequence[str],
   396	    ) -> Dict[str, float]:
   397	        return self.decoder.family_logits(
   398	            self.encode_sample(sample),
   399	            modal_families=modal_families,
   400	        )
   401	
   402	    def feature_keys_for_sample(self, sample: LegalSample) -> List[str]:
   403	        """Return text-derived features that can receive generalizable SGD updates."""
   404	        encoding = self.encode_sample(sample)
   405	        return _unique_preserve_order(self.decoder._feature_stream(encoding))
