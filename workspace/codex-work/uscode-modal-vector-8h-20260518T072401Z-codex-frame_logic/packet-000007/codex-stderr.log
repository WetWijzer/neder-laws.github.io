    32	        decoded_text="A canine sprinted through the green space.",
    33	        source_embedding=[0.1, 0.2, ...],
    34	        decoded_embedding=[0.11, 0.19, ...],
    35	    )
    36	    print(result.similarity_score)       # 0.97
    37	    print(result.ontology_consistent)    # True
    38	    print(result.passed)                 # True
