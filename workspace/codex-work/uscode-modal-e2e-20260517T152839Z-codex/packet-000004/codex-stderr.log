    27	@dataclass(frozen=True)
    28	class LegalSample:
    29	    """One U.S. Code-style sample with parser and training metadata."""
    30	
    31	    sample_id: str
    32	    source: str
    33	    title: str
    34	    section: str
    35	    citation: str
    36	    text: str
    37	    normalized_text: str
    38	    embedding_model: str
    39	    embedding_vector: List[float]
    40	    modal_ir: ModalIRDocument
    41	    frame_candidates: List[Dict[str, Any]] = field(default_factory=list)
    42	    selected_frame: Optional[str] = None
    43	    parser_trace: Dict[str, Any] = field(default_factory=dict)
    44	    losses: Dict[str, float] = field(default_factory=dict)
    45	
    46	    def validate(self) -> None:
    47	        """Validate required fields and cross-field invariants."""
    48	        if self.source != "us_code":
    49	            raise LegalSampleValidationError("LegalSample.source must be 'us_code'")
    50	        for field_name in ("sample_id", "title", "section", "citation", "text", "normalized_text"):
    51	            if not getattr(self, field_name):
    52	                raise LegalSampleValidationError(f"LegalSample.{field_name} must not be empty")
    53	        if not self.embedding_vector:
    54	            raise LegalSampleValidationError("LegalSample.embedding_vector must not be empty")
    55	        if not all(isinstance(value, (float, int)) for value in self.embedding_vector):
    56	            raise LegalSampleValidationError("LegalSample.embedding_vector must contain only numbers")
    57	        if self.modal_ir.normalized_text != self.normalized_text:
    58	            raise LegalSampleValidationError("LegalSample.modal_ir.normalized_text must match normalized_text")
    59	        if self.selected_frame and self.selected_frame not in {
    60	            str(candidate.get("frame_id")) for candidate in self.frame_candidates
    61	        }:
    62	            raise LegalSampleValidationError("LegalSample.selected_frame must be one of frame_candidates")
    63	
    64	    def to_dict(self) -> Dict[str, Any]:
    65	        """Return stable JSON-ready sample data."""
    66	        return {
    67	            "citation": self.citation,
    68	            "embedding_model": self.embedding_model,
    69	            "embedding_vector": list(self.embedding_vector),
    70	            "frame_candidates": list(self.frame_candidates),
    71	            "losses": dict(sorted(self.losses.items())),
    72	            "modal_ir": self.modal_ir.to_dict(),
    73	            "normalized_text": self.normalized_text,
    74	            "parser_trace": dict(sorted(self.parser_trace.items())),
    75	            "sample_id": self.sample_id,
    76	            "section": self.section,
    77	            "selected_frame": self.selected_frame,
    78	            "source": self.source,
    79	            "text": self.text,
    80	            "title": self.title,
    81	        }
    82	
    83	    def to_json(self) -> str:
    84	        """Return stable compact JSON."""
    85	        return json.dumps(self.to_dict(), ensure_ascii=True, separators=(",", ":"), sort_keys=True)
