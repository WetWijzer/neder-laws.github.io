from pathlib import Path
import pyarrow.parquet as pq
from ipfs_datasets_py.optimizers.logic_theorem_optimizer.legal_modal_parser import LegalModalParser

path=Path('/home/barberb/.cache/huggingface/hub/datasets--justicedao--ipfs_uscode/snapshots/4bb664f4b7fd34158d3b6a1e59f2a71f0fa59c58/uscode_parquet/laws.parquet')
