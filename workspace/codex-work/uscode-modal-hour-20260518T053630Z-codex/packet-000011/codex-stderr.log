   228	class ModalRegistry:
   229	    """Lookup table for modal parse profiles."""
   230	
   231	    def __init__(self, profiles: Iterable[ModalParseProfile] = DEFAULT_MODAL_PROFILES) -> None:
   232	        self._profiles: Dict[str, ModalParseProfile] = {
   233	            profile.profile_id: profile for profile in profiles
   234	        }
   235	        self._by_family: Dict[ModalLogicFamily, ModalParseProfile] = {
   236	            profile.family: profile for profile in profiles
   237	        }
   238	
   239	    def get_profile(
   240	        self,
   241	        family: ModalLogicFamily | str,
   242	        system: Optional[ModalSystem | str] = None,
   243	    ) -> ModalParseProfile:
   244	        """Get a profile by family, optionally constrained by system."""
   245	        resolved_family = family if isinstance(family, ModalLogicFamily) else ModalLogicFamily(str(family))
   246	        if system is None:
   247	            return self._by_family[resolved_family]
   248	        resolved_system = system if isinstance(system, ModalSystem) else ModalSystem(str(system))
   249	        return self._profiles[f"{resolved_family.value}:{resolved_system.value}"]
   250	
   251	    def all_profiles(self) -> Tuple[ModalParseProfile, ...]:
   252	        """Return all profiles in deterministic order."""
   253	        return tuple(sorted(self._profiles.values(), key=lambda profile: profile.profile_id))
   254	
   255	    def to_dict(self) -> Mapping[str, object]:
   256	        """Return a stable JSON-ready registry mapping."""
   257	        return {profile.profile_id: profile.to_dict() for profile in self.all_profiles()}
   258	
   259	
   260	def is_normative_modal_family(family: ModalLogicFamily | str) -> bool:
   261	    """Return whether a modal family encodes normative legal force."""
   262	    if isinstance(family, ModalLogicFamily):
   263	        resolved = family
   264	    else:
   265	        try:
   266	            resolved = ModalLogicFamily(str(family))
   267	        except ValueError:
   268	            return False
   269	    return resolved in NORMATIVE_MODAL_FAMILIES
   270	
   271	
   272	DEFAULT_MODAL_REGISTRY = ModalRegistry()
   273	
   274	
